;;; linalg/mat_test -- tests for linalg/mat module

(defmodule linalg/mat_test
  (import linalg/mat :refer [mat mat-new mat-new-zeroed mat-identity mat-from-list
                              mat-copy mat-free mat-rows mat-cols mat-shape
                              mat-get mat-set! mat-row mat-col mat-submat mat-diag]
           :rename {mat-new mat--new
                    mat-new-zeroed mat--new-zeroed
                    mat-identity mat--identity
                    mat-from-list mat--from-list
                    mat-copy mat--copy
                    mat-free mat--free
                    mat-rows mat--rows
                    mat-cols mat--cols
                    mat-shape mat--shape
                    mat-get mat--get
                    mat-set! mat--set!
                    mat-row mat--row
                    mat-col mat--col
                    mat-submat mat--submat
                    mat-diag mat--diag})
  (import test/assert :refer [assert-eq assert-true assert-false]))

;;; Test mat-new and basic properties
(deftest "test-mat-new" []
  (let [m (mat--new 3 4)]
    (assert-true (mat m))
    (assert-eq (mat--rows m) 3)
    (assert-eq (mat--cols m) 4)
    (mat--free m)
    true))

;;; Test mat-new-zeroed
(deftest "test-mat-new-zeroed" []
  (let [m (mat--new-zeroed 2 3)]
    (assert-eq (mat--rows m) 2)
    (assert-eq (mat--cols m) 3)
    ;; Check all elements are zero
    (dotimes [r 2]
      (dotimes [c 3]
        (assert-eq (mat--get m r c) 0.0)))
    (mat--free m)
    true))

;;; Test mat-identity
(deftest "test-mat-identity" []
  (let [m (mat--identity 3)]
    (assert-eq (mat--rows m) 3)
    (assert-eq (mat--cols m) 3)
    ;; Check diagonal elements are 1
    (dotimes [i 3]
      (assert-eq (mat--get m i i) 1.0))
    ;; Check off-diagonal elements are 0
    (dotimes [r 3]
      (dotimes [c 3]
        (when (not= r c)
          (assert-eq (mat--get m r c) 0.0))))
    (mat--free m)
    true))

;;; Test mat-from-list
(deftest "test-mat-from-list" []
  (let [data (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0))))
        m (mat--from-list 2 2 data)]
    (assert-eq (mat--rows m) 2)
    (assert-eq (mat--cols m) 2)
    (assert-eq (mat--get m 0 0) 1.0)
    (assert-eq (mat--get m 0 1) 2.0)
    (assert-eq (mat--get m 1 0) 3.0)
    (assert-eq (mat--get m 1 1) 4.0)
    (mat--free m)
    true))

;;; Test mat-copy
(deftest "test-mat-copy" []
  (let [m (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        c (mat--copy m)]
    (assert-eq (mat--get c 0 0) 1.0)
    (assert-eq (mat--get c 1 1) 4.0)
    ;; Modify original, ensure copy is independent
    (mat--set! m 0 0 99.0)
    (assert-eq (mat--get m 0 0) 99.0)
    (assert-eq (mat--get c 0 0) 1.0)
    (mat--free m)
    (mat--free c)
    true))

;;; Test mat-shape
(deftest "test-mat-shape" []
  (let [m (mat--new 3 4)]
    (let [shape (mat--shape m)]
      (assert-eq (car shape) 3)
      (assert-eq (cdr shape) 4))
    (mat--free m)
    true))

;;; Test mat-get and mat-set!
(deftest "test-mat-access" []
  (let [m (mat--new-zeroed 2 2)]
    (mat--set! m 0 0 5.0)
    (mat--set! m 1 1 7.0)
    (assert-eq (mat--get m 0 0) 5.0)
    (assert-eq (mat--get m 1 1) 7.0)
    (mat--free m)
    true))

;;; Test mat-row
(deftest "test-mat-row" []
  (let [m (mat--from-list 2 3 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 0)))))))]
    (let [row0 (mat--row m 0)]
      (assert-eq (vec-len row0) 3)
      (assert-eq (vec-get row0 0) 1.0)
      (assert-eq (vec-get row0 1) 2.0)
      (assert-eq (vec-get row0 2) 3.0)
      (vec-free row0))
    (mat--free m)
    true))

;;; Test mat-col
(deftest "test-mat-col" []
  (let [m (mat--from-list 3 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 0)))))))]
    (let [col1 (mat--col m 1)]
      (assert-eq (vec-len col1) 3)
      (assert-eq (vec-get col1 0) 2.0)
      (assert-eq (vec-get col1 1) 4.0)
      (assert-eq (vec-get col1 2) 6.0)
      (vec-free col1))
    (mat--free m)
    true))

;;; Test mat-submat
(deftest "test-mat-submat" []
  (let [m (mat--from-list 3 3
                (cons 1.0 (cons 2.0 (cons 3.0
                       (cons 4.0 (cons 5.0 (cons 6.0
                              (cons 7.0 (cons 8.0 (cons 9.0 0)))))))))]
    (let [sub (mat--submat m 1 1 3 3)]
      (assert-eq (mat--rows sub) 2)
      (assert-eq (mat--cols sub) 2)
      (assert-eq (mat--get sub 0 0) 5.0)
      (assert-eq (mat--get sub 0 1) 6.0)
      (assert-eq (mat--get sub 1 0) 8.0)
      (assert-eq (mat--get sub 1 1) 9.0)
      (mat--free sub))
    (mat--free m)
    true))

;;; Test mat-diag
(deftest "test-mat-diag" []
  (let [v (vec-from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        m (mat--diag v)]
    (assert-eq (mat--rows m) 3)
    (assert-eq (mat--cols m) 3)
    (assert-eq (mat--get m 0 0) 1.0)
    (assert-eq (mat--get m 1 1) 2.0)
    (assert-eq (mat--get m 2 2) 3.0)
    (assert-eq (mat--get m 0 1) 0.0)
    (mat--free m)
    (vec-free v)
    true))

;;; LA1 arithmetic tests

;;; Test mat-add
(deftest "test-mat-add" []
  (let [a (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        b (mat--from-list 2 2 (cons 5.0 (cons 6.0 (cons 7.0 (cons 8.0 0)))))
        c (mat-add a b)]
    (assert-eq (mat--get c 0 0) 6.0)
    (assert-eq (mat--get c 0 1) 8.0)
    (assert-eq (mat--get c 1 0) 10.0)
    (assert-eq (mat--get c 1 1) 12.0)
    (mat--free a)
    (mat--free b)
    (mat--free c)
    true))

;;; Test mat-sub
(deftest "test-mat-sub" []
  (let [a (mat--from-list 2 2 (cons 10.0 (cons 20.0 (cons 30.0 (cons 40.0 0)))))
        b (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        c (mat-sub a b)]
    (assert-eq (mat--get c 0 0) 9.0)
    (assert-eq (mat--get c 0 1) 18.0)
    (assert-eq (mat--get c 1 0) 27.0)
    (assert-eq (mat--get c 1 1) 36.0)
    (mat--free a)
    (mat--free b)
    (mat--free c)
    true))

;;; Test mat-scale
(deftest "test-mat-scale" []
  (let [m (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        c (mat-scale m 2.0)]
    (assert-eq (mat--get c 0 0) 2.0)
    (assert-eq (mat--get c 0 1) 4.0)
    (assert-eq (mat--get c 1 0) 6.0)
    (assert-eq (mat--get c 1 1) 8.0)
    (mat--free m)
    (mat--free c)
    true))

;;; Test mat-mul
(deftest "test-mat-mul" []
  (let [a (mat--from-list 2 3 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 0)))))))
        b (mat--from-list 3 2 (cons 7.0 (cons 8.0 (cons 9.0 (cons 10.0 (cons 11.0 (cons 12.0 0)))))))
        c (mat-mul a b)]
    (assert-eq (mat--rows c) 2)
    (assert-eq (mat--cols c) 2)
    ;; c[0,0] = 1*7 + 2*9 + 3*11 = 7 + 18 + 33 = 58
    ;; c[0,1] = 1*8 + 2*10 + 3*12 = 8 + 20 + 36 = 64
    ;; c[1,0] = 4*7 + 5*9 + 6*11 = 28 + 45 + 66 = 139
    ;; c[1,1] = 4*8 + 5*10 + 6*12 = 32 + 50 + 72 = 154
    (assert-eq (mat--get c 0 0) 58.0)
    (assert-eq (mat--get c 0 1) 64.0)
    (assert-eq (mat--get c 1 0) 139.0)
    (assert-eq (mat--get c 1 1) 154.0)
    (mat--free a)
    (mat--free b)
    (mat--free c)
    true))

;;; Test mat-mul-vec
(deftest "test-mat-mul-vec" []
  (let [m (mat--from-list 2 3 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 0)))))))
        v (vec-from-list (cons 7.0 (cons 8.0 (cons 9.0 0))))
        r (mat-mul-vec m v)]
    (assert-eq (vec-len r) 2)
    ;; r[0] = 1*7 + 2*8 + 3*9 = 7 + 16 + 27 = 50
    ;; r[1] = 4*7 + 5*8 + 6*9 = 28 + 40 + 54 = 122
    (assert-eq (vec-get r 0) 50.0)
    (assert-eq (vec-get r 1) 122.0)
    (mat--free m)
    (vec-free v)
    (vec-free r)
    true))

;;; Test mat-transpose
(deftest "test-mat-transpose" []
  (let [m (mat--from-list 2 3 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 0)))))))
        t (mat-transpose m)]
    (assert-eq (mat--rows t) 3)
    (assert-eq (mat--cols t) 2)
    (assert-eq (mat--get t 0 0) 1.0)
    (assert-eq (mat--get t 0 1) 4.0)
    (assert-eq (mat--get t 1 0) 2.0)
    (assert-eq (mat--get t 1 1) 5.0)
    (assert-eq (mat--get t 2 0) 3.0)
    (assert-eq (mat--get t 2 1) 6.0)
    (mat--free m)
    (mat--free t)
    true))

;;; Test mat-trace
(deftest "test-mat-trace" []
  (let [m (mat--from-list 3 3 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 (cons 7.0 (cons 8.0 (cons 9.0 0)))))))))]
    (assert-eq (mat-trace m) 15.0) ; 1 + 5 + 9 = 15
    (mat--free m)
    true))

;;; Test mat-norm-fro
(deftest "test-mat-norm-fro" []
  (let [m (mat--from-list 2 2 (cons 3.0 (cons 4.0 (cons 0.0 (cons 0.0 0)))))]
    (assert-eq (mat-norm-fro m) 5.0) ; sqrt(9 + 16) = 5
    (mat--free m)
    true))

;;; Test mat-norm-max
(deftest "test-mat-norm-max" []
  (let [m (mat--from-list 2 2 (cons -1.0 (cons 2.0 (cons -3.0 (cons 4.0 0)))))]
    (assert-eq (mat-norm-max m) 4.0)
    (mat--free m)
    true))

;;; Test mat-square?
(deftest "test-mat-square?" []
  (let [sq (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        rect (mat--from-list 2 3 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 (cons 5.0 (cons 6.0 0)))))))]
    (assert-eq (mat-square? sq) 1)
    (assert-eq (mat-square? rect) 0)
    (mat--free sq)
    (mat--free rect)
    true))

;;; Test mat-approx-eq?
(deftest "test-mat-approx-eq?" []
  (let [a (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        b (mat--from-list 2 2 (cons 1.0001 (cons 2.0001 (cons 3.0001 (cons 4.0001 0)))))]
    (assert-eq (mat-approx-eq? a b 0.001) 1)
    (assert-eq (mat-approx-eq? a b 0.00001) 0)
    (mat--free a)
    (mat--free b)
    true))

) ;; end defmodule linalg/mat_test
