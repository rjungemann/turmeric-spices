;;; linalg/vec_test -- tests for linalg/vec module

(defmodule linalg/vec_test
  (import linalg/vec :refer [vec vec-new vec-new-zeroed vec-from-list
                              vec-copy vec-free vec-get vec-set! vec-len]
           :rename {vec-new vec--new
                    vec-new-zeroed vec--new-zeroed
                    vec-from-list vec--from-list
                    vec-copy vec--copy
                    vec-free vec--free
                    vec-get vec--get
                    vec-set! vec--set!
                    vec-len vec--len})
  (import test/assert :refer [assert-eq assert-true assert-false]))

;;; Test vec-new and basic properties
(deftest "test-vec-new" []
  (let [v (vec--new 5)]
    (assert-true (vec v))
    (assert-eq (vec--len v) 5)
    (vec--free v)
    true))

;;; Test vec-new-zeroed
(deftest "test-vec-new-zeroed" []
  (let [v (vec--new-zeroed 4)]
    (assert-eq (vec--len v) 4)
    ;; Check all elements are zero
    (dotimes [i 4]
      (assert-eq (vec--get v i) 0.0))
    (vec--free v)
    true))

;;; Test vec-from-list
(deftest "test-vec-from-list" []
  (let [data (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0))))
        v (vec--from-list data)]
    (assert-eq (vec--len v) 4)
    (assert-eq (vec--get v 0) 1.0)
    (assert-eq (vec--get v 1) 2.0)
    (assert-eq (vec--get v 2) 3.0)
    (assert-eq (vec--get v 3) 4.0)
    (vec--free v)
    true))

;;; Test vec-copy
(deftest "test-vec-copy" []
  (let [v (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        c (vec--copy v)]
    (assert-eq (vec--len c) 3)
    (assert-eq (vec--get c 0) 1.0)
    (assert-eq (vec--get c 1) 2.0)
    (assert-eq (vec--get c 2) 3.0)
    ;; Modify original, ensure copy is independent
    (vec--set! v 0 99.0)
    (assert-eq (vec--get v 0) 99.0)
    (assert-eq (vec--get c 0) 1.0)
    (vec--free v)
    (vec--free c)
    true))

;;; Test vec-get and vec-set!
(deftest "test-vec-access" []
  (let [v (vec--new-zeroed 3)]
    (vec--set! v 0 5.0)
    (vec--set! v 1 7.0)
    (vec--set! v 2 9.0)
    (assert-eq (vec--get v 0) 5.0)
    (assert-eq (vec--get v 1) 7.0)
    (assert-eq (vec--get v 2) 9.0)
    (vec--free v)
    true))

;;; Test vec-len
(deftest "test-vec-len" []
  (let [v (vec--new 10)]
    (assert-eq (vec--len v) 10)
    (vec--free v)
    true))

;;; LA1 arithmetic tests

;;; Test vec-add
(deftest "test-vec-add" []
  (let [a (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        b (vec--from-list (cons 4.0 (cons 5.0 (cons 6.0 0))))
        c (vec-add a b)]
    (assert-eq (vec--len c) 3)
    (assert-eq (vec--get c 0) 5.0)
    (assert-eq (vec--get c 1) 7.0)
    (assert-eq (vec--get c 2) 9.0)
    (vec--free a)
    (vec--free b)
    (vec--free c)
    true))

;;; Test vec-sub
(deftest "test-vec-sub" []
  (let [a (vec--from-list (cons 10.0 (cons 20.0 (cons 30.0 0))))
        b (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        c (vec-sub a b)]
    (assert-eq (vec--get c 0) 9.0)
    (assert-eq (vec--get c 1) 18.0)
    (assert-eq (vec--get c 2) 27.0)
    (vec--free a)
    (vec--free b)
    (vec--free c)
    true))

;;; Test vec-scale
(deftest "test-vec-scale" []
  (let [v (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        c (vec-scale v 2.0)]
    (assert-eq (vec--get c 0) 2.0)
    (assert-eq (vec--get c 1) 4.0)
    (assert-eq (vec--get c 2) 6.0)
    (vec--free v)
    (vec--free c)
    true))

;;; Test vec-dot
(deftest "test-vec-dot" []
  (let [a (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        b (vec--from-list (cons 4.0 (cons 5.0 (cons 6.0 0)))]
    (assert-eq (vec-dot a b) 32.0) ; 1*4 + 2*5 + 3*6 = 4 + 10 + 18 = 32
    (vec--free a)
    (vec--free b)
    true))

;;; Test vec-outer
(deftest "test-vec-outer" []
  (let [a (vec--from-list (cons 1.0 (cons 2.0 0)))
        b (vec--from-list (cons 3.0 (cons 4.0 0)))
        m (vec-outer a b)]
    (assert-eq (mat-rows m) 2)
    (assert-eq (mat-cols m) 2)
    (assert-eq (mat-get m 0 0) 3.0) ; 1 * 3
    (assert-eq (mat-get m 0 1) 4.0) ; 1 * 4
    (assert-eq (mat-get m 1 0) 6.0) ; 2 * 3
    (assert-eq (mat-get m 1 1) 8.0) ; 2 * 4
    (vec--free a)
    (vec--free b)
    (mat-free m)
    true))

;;; Test vec-norm
(deftest "test-vec-norm" []
  (let [v (vec--from-list (cons 3.0 (cons 4.0 0)))]
    (assert-eq (vec-norm v) 5.0) ; sqrt(9 + 16) = 5
    (vec--free v)
    true))

;;; Test vec-norm-1
(deftest "test-vec-norm-1" []
  (let [v (vec--from-list (cons -1.0 (cons 2.0 (cons -3.0 0)))]
    (assert-eq (vec-norm-1 v) 6.0) ; abs(-1) + abs(2) + abs(-3) = 1 + 2 + 3 = 6
    (vec--free v)
    true))

;;; Test vec-norm-inf
(deftest "test-vec-norm-inf" []
  (let [v (vec--from-list (cons -1.0 (cons 2.0 (cons -3.0 0)))]
    (assert-eq (vec-norm-inf v) 3.0) ; max(abs(-1), abs(2), abs(-3)) = 3
    (vec--free v)
    true))

;;; Test vec-normalize
(deftest "test-vec-normalize" []
  (let [v (vec--from-list (cons 3.0 (cons 4.0 0)))
        u (vec-normalize v)]
    (assert-eq (vec--len u) 2)
    (assert-eq (vec--get u 0) 0.6) ; 3/5 = 0.6
    (assert-eq (vec--get u 1) 0.8) ; 4/5 = 0.8
    (vec--free v)
    (vec--free u)
    true))

;;; Test vec-approx-eq?
(deftest "test-vec-approx-eq?" []
  (let [a (vec--from-list (cons 1.0 (cons 2.0 0)))
        b (vec--from-list (cons 1.0001 (cons 2.0001 0)))]
    (assert-eq (vec-approx-eq? a b 0.001) 1)
    (assert-eq (vec-approx-eq? a b 0.00001) 0)
    (vec--free a)
    (vec--free b)
    true))

) ;; end defmodule linalg/vec_test
