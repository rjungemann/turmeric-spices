;;; linalg/fmt_test -- tests for linalg/fmt module

(defmodule linalg/fmt_test
  (import test/suite :refer [describe it])
  (import test/assert :refer [assert-eq assert-true assert-false])
  (import linalg/mat :refer [mat-new mat-from-list mat-free mat-rows mat-cols])
  (import linalg/vec :refer [vec-new vec-from-list vec-free vec-len])
  (import linalg/fmt :refer [mat-print vec-print mat->str vec->str
                               mat-print-prec vec-print-prec mat->str-prec vec->str-prec])
  (rename {mat-new mat--new
          mat-from-list mat--from-list
          mat-free mat--free
          mat-rows mat--rows
          mat-cols mat--cols
          vec-new vec--new
          vec-from-list vec--from-list
          vec-free vec--free
          vec-len vec--len
          mat-print mat--print
          vec-print vec--print
          mat->str mat-->str
          vec->str vec-->str
          mat-print-prec mat--print-prec
          vec-print-prec vec--print-prec
          mat->str-prec mat-->str-prec
          vec->str-prec vec-->str-prec}))

;;; Test mat-print (just check it doesn't crash)
(deftest "test-mat-print" []
  (let [m (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))]
    (mat--print m)
    (mat--free m)
    true))

;;; Test vec-print (just check it doesn't crash)
(deftest "test-vec-print" []
  (let [v (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))]
    (vec--print v)
    (vec--free v)
    true))

;;; Test mat->str
(deftest "test-mat->str" []
  (let [m (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        s (mat-->str m)]
    (assert-true (string? s))
    (free s)
    (mat--free m)
    true))

;;; Test vec->str
(deftest "test-vec->str" []
  (let [v (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        s (vec-->str v)]
    (assert-true (string? s))
    (free s)
    (vec--free v)
    true))

;;; Test mat->str-prec
(deftest "test-mat->str-prec" []
  (let [m (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))
        s (mat-->str-prec m 2)]
    (assert-true (string? s))
    (free s)
    (mat--free m)
    true))

;;; Test vec->str-prec
(deftest "test-vec->str-prec" []
  (let [v (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))
        s (vec-->str-prec v 2)]
    (assert-true (string? s))
    (free s)
    (vec--free v)
    true))

;;; Test mat-print-prec (just check it doesn't crash)
(deftest "test-mat-print-prec" []
  (let [m (mat--from-list 2 2 (cons 1.0 (cons 2.0 (cons 3.0 (cons 4.0 0)))))]
    (mat--print-prec m 2)
    (mat--free m)
    true))

;;; Test vec-print-prec (just check it doesn't crash)
(deftest "test-vec-print-prec" []
  (let [v (vec--from-list (cons 1.0 (cons 2.0 (cons 3.0 0))))]
    (vec--print-prec v 2)
    (vec--free v)
    true))

) ;; end defmodule linalg/fmt_test
