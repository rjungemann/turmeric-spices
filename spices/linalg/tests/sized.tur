;;; sized.tur -- tests for linalg/sized statically-sized float vectors (U4).
;;;
;;; Positive coverage: same-length ops compute the right values. The negative
;;; case -- mixing a (LaVecN (Static 2)) with a (LaVecN (Static 3)) -- is a
;;; compile error (TUR-E0260) and so lives in tests/errors/, not here.
;;;
;;; Mirrors linalg.tur's TAP harness (inline-C fail counter; `finish` returns
;;; non-zero if any check failed).

(load "stdlib/sized.tur")

(defmodule linalg/sized-test
  (import linalg/sized :refer [LaVecN lavecn-zeros lavecn-free lavecn-len
                               lavecn-get lavecn-set! lavecn-add lavecn-sub
                               lavecn-scale lavecn-dot lavecn-norm
                               LaMatN lamat-zeros lamat-free lamat-rows
                               lamat-cols lamat-get lamat-set! lamat-add
                               lamat-sub lamat-scale lamat-mul lamat-transpose])

  ;; --- TAP harness (inline-C fail counter) ---
  (defn check [idx : int  name : cstr  ok : bool] : void
    ```c
    /* __tur_include__: static int g_sz_fails = 0; */
    if (!ok) g_sz_fails++;
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn finish [count : int] : int
    ```c
    printf("1..%lld\n", (long long)count);
    if (g_sz_fails == 0) {
      fprintf(stderr, "# All %lld linalg/sized tests passed.\n", (long long)count);
      return 0;
    }
    fprintf(stderr, "# %d/%lld linalg/sized tests failed.\n", g_sz_fails, (long long)count);
    return 1;
    ```)

  (defn fa [x : float] : float ```c return x < 0.0 ? -x : x; ```)
  (defn approx [a : float  b : float] : bool (< (fa (- a b)) 1e-9))

  ;; A length-2 vector [a b].
  (defn v2 [a : float  b : float] : (LaVecN (Static 2))
    (let [v (lavecn-zeros 2)]
      (lavecn-set! v 0 a)
      (lavecn-set! v 1 b)
      v))

  (defn t-len [] : int
    (let [v (v2 3.0 4.0)] (let [n (lavecn-len v)] (lavecn-free v) n)))
  (defn t-dot [] : float
    (let [a (v2 3.0 4.0) b (v2 3.0 4.0)]
      (let [d (lavecn-dot a b)] (lavecn-free a) (lavecn-free b) d)))   ;; 25
  (defn t-norm [] : float
    (let [v (v2 3.0 4.0)] (let [d (lavecn-norm v)] (lavecn-free v) d)))  ;; 5
  (defn t-add [] : float
    (let [a (v2 3.0 4.0) b (v2 1.0 2.0) c (lavecn-add a b)]
      (let [x (lavecn-get c 1)] (lavecn-free a) (lavecn-free b) (lavecn-free c) x)))  ;; 6
  (defn t-sub [] : float
    (let [a (v2 3.0 4.0) b (v2 1.0 2.0) c (lavecn-sub a b)]
      (let [x (lavecn-get c 0)] (lavecn-free a) (lavecn-free b) (lavecn-free c) x)))  ;; 2
  (defn t-scale [] : float
    (let [a (v2 3.0 4.0) c (lavecn-scale a 2.0)]
      (let [x (lavecn-get c 1)] (lavecn-free a) (lavecn-free c) x)))  ;; 8

  ;; --- matrices ---
  ;; A 2x2 matrix [[a b][c d]].
  (defn m22 [a : float  b : float  c : float  d : float] : (LaMatN (Static 2) (Static 2))
    (let [m (lamat-zeros 2 2)]
      (lamat-set! m 0 0 a) (lamat-set! m 0 1 b)
      (lamat-set! m 1 0 c) (lamat-set! m 1 1 d)
      m))

  (defn t-mat-shape [] : bool
    (let [m (m22 1.0 2.0 3.0 4.0)]
      (let [r (and (= (lamat-rows m) 2) (= (lamat-cols m) 2))] (lamat-free m) r)))
  (defn t-mat-add [] : float
    (let [a (m22 1.0 2.0 3.0 4.0) b (m22 5.0 6.0 7.0 8.0) c (lamat-add a b)]
      (let [x (lamat-get c 1 1)] (lamat-free a) (lamat-free b) (lamat-free c) x)))  ;; 12
  (defn t-mat-sub [] : float
    (let [a (m22 5.0 6.0 7.0 8.0) b (m22 1.0 2.0 3.0 4.0) c (lamat-sub a b)]
      (let [x (lamat-get c 0 0)] (lamat-free a) (lamat-free b) (lamat-free c) x)))  ;; 4
  (defn t-mat-scale [] : float
    (let [a (m22 1.0 2.0 3.0 4.0) c (lamat-scale a 3.0)]
      (let [x (lamat-get c 1 0)] (lamat-free a) (lamat-free c) x)))  ;; 9
  (defn t-mat-mul [] : float
    ;; [[1 2][3 4]] * [[5 6][7 8]] = [[19 22][43 50]]
    (let [a (m22 1.0 2.0 3.0 4.0) b (m22 5.0 6.0 7.0 8.0) c (lamat-mul a b)]
      (let [x (lamat-get c 1 1)] (lamat-free a) (lamat-free b) (lamat-free c) x)))  ;; 50
  (defn t-mat-transpose [] : float
    (let [a (m22 1.0 2.0 3.0 4.0) t (lamat-transpose a)]
      (let [x (lamat-get t 0 1)] (lamat-free a) (lamat-free t) x)))  ;; 3 (was a[1][0])
  ;; rectangular: (2x3) * (3x2) -> (2x2), result[1][0] = 4*7+5*9+6*11 = 139
  (defn t-mat-mul-rect [] : float
    (let [a (lamat-zeros 2 3) b (lamat-zeros 3 2)]
      (lamat-set! a 0 0 1.0) (lamat-set! a 0 1 2.0) (lamat-set! a 0 2 3.0)
      (lamat-set! a 1 0 4.0) (lamat-set! a 1 1 5.0) (lamat-set! a 1 2 6.0)
      (lamat-set! b 0 0 7.0) (lamat-set! b 0 1 8.0)
      (lamat-set! b 1 0 9.0) (lamat-set! b 1 1 10.0)
      (lamat-set! b 2 0 11.0) (lamat-set! b 2 1 12.0)
      (let [c (lamat-mul (:: a (LaMatN (Static 2) (Static 3)))
                         (:: b (LaMatN (Static 3) (Static 2))))]
        (let [x (lamat-get c 1 0)]
          (lamat-free a) (lamat-free b) (lamat-free c) x))))  ;; 139

  (defn main [] : int
    (check 1 "lavecn-len"   (= (t-len) 2))
    (check 2 "lavecn-dot"   (approx (t-dot) 25.0))
    (check 3 "lavecn-norm"  (approx (t-norm) 5.0))
    (check 4 "lavecn-add"   (approx (t-add) 6.0))
    (check 5 "lavecn-sub"   (approx (t-sub) 2.0))
    (check 6 "lavecn-scale" (approx (t-scale) 8.0))
    (check 7  "lamat-shape"     (t-mat-shape))
    (check 8  "lamat-add"       (approx (t-mat-add) 12.0))
    (check 9  "lamat-sub"       (approx (t-mat-sub) 4.0))
    (check 10 "lamat-scale"     (approx (t-mat-scale) 9.0))
    (check 11 "lamat-mul"       (approx (t-mat-mul) 50.0))
    (check 12 "lamat-transpose" (approx (t-mat-transpose) 3.0))
    (check 13 "lamat-mul-rect"  (approx (t-mat-mul-rect) 139.0))
    (finish 13)))
