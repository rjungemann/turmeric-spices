;;; small.tur -- test runner for the linalg/small fixed-size graphics API.
;;;
;;; Mirrors linalg.tur's TAP harness (inline-C fail counter; `finish` returns
;;; non-zero if any check failed). Focuses on mat4-inv -- validated by
;;; multiplying the inverse back against the input with the module's own
;;; mat4-mul and checking the product is identity -- plus a convention-free
;;; diagonal check and light smoke coverage of the surrounding mat4 ops, which
;;; previously had no tests at all.

(defmodule linalg/small-test
  (import linalg/small :refer [vec3 vec3-of mat4 mat4-identity mat4-mul
                               mat4-inv mat4-transpose mat4-translate mat4-scale
                               mat4-rotate-z])

;; --- TAP harness (inline-C fail counter) ---
(defn check [idx : int  name : cstr  ok : bool] : void
  ```c
  /* __tur_include__: static int g_sm_fails = 0; */
  if (!ok) g_sm_fails++;
  printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
  ```)

(defn finish [count : int] : int
  ```c
  printf("1..%lld\n", (long long)count);
  if (g_sm_fails == 0) {
    fprintf(stderr, "# All %lld linalg/small tests passed.\n", (long long)count);
    return 0;
  }
  fprintf(stderr, "# %d/%lld linalg/small tests failed.\n", g_sm_fails, (long long)count);
  return 1;
  ```)

(defn fa [x : float] : float ```c return x < 0.0 ? -x : x; ```)
(defn fmax [a : float  b : float] : float (if (> a b) a b))
(defn approx [a : float  b : float] : bool (< (fa (- a b)) 1e-9))

;; Max absolute deviation of p from the 4x4 identity, across all 16 entries.
(defn mat4-id-dev [p : mat4] : float
  (let [^mut d 0.0]
    (set! d (fmax d (fa (- (.m00 p) 1.0)))) (set! d (fmax d (fa (.m01 p))))
    (set! d (fmax d (fa (.m02 p))))         (set! d (fmax d (fa (.m03 p))))
    (set! d (fmax d (fa (.m10 p))))         (set! d (fmax d (fa (- (.m11 p) 1.0))))
    (set! d (fmax d (fa (.m12 p))))         (set! d (fmax d (fa (.m13 p))))
    (set! d (fmax d (fa (.m20 p))))         (set! d (fmax d (fa (.m21 p))))
    (set! d (fmax d (fa (- (.m22 p) 1.0)))) (set! d (fmax d (fa (.m23 p))))
    (set! d (fmax d (fa (.m30 p))))         (set! d (fmax d (fa (.m31 p))))
    (set! d (fmax d (fa (.m32 p))))         (set! d (fmax d (fa (- (.m33 p) 1.0))))
    d))

;; A general invertible matrix: translate * rotate-z * (non-uniform) scale.
(defn general-m [] : mat4
  (mat4-mul (mat4-mul (mat4-translate (vec3-of 1.0 2.0 3.0))
                      (mat4-rotate-z 0.7))
            (mat4-scale (vec3-of 2.0 0.5 3.0))))

;; --- mat4 smoke (these ops had no coverage before) ---
(defn t-identity [] : bool
  (let [m (mat4-identity)] (and (approx (.m00 m) 1.0) (approx (.m01 m) 0.0))))
(defn t-mul-identity [] : float
  ;; I * I = I
  (mat4-id-dev (mat4-mul (mat4-identity) (mat4-identity))))
(defn t-transpose [] : bool
  ;; transpose swaps m{i}{j} with m{j}{i}
  (let [m (general-m) t (mat4-transpose m)]
    (and (approx (.m01 t) (.m10 m)) (approx (.m32 t) (.m23 m)))))

;; --- mat4-inv ---
(defn t-inv-identity [] : float
  (mat4-id-dev (mat4-inv (mat4-identity))))
(defn t-inv-scale-diag [] : bool
  ;; inverse of a diagonal (scale) matrix is the reciprocal diagonal --
  ;; convention-independent, so a concrete numeric check.
  (let [s (mat4-inv (mat4-scale (vec3-of 2.0 4.0 8.0)))]
    (and (approx (.m00 s) 0.5)
         (and (approx (.m11 s) 0.25)
              (and (approx (.m22 s) 0.125) (approx (.m33 s) 1.0))))))
(defn t-inv-roundtrip-left [] : float
  ;; inv(M) * M = I
  (let [m (general-m)] (mat4-id-dev (mat4-mul (mat4-inv m) m))))
(defn t-inv-roundtrip-right [] : float
  ;; M * inv(M) = I
  (let [m (general-m)] (mat4-id-dev (mat4-mul m (mat4-inv m)))))

(defn main [] : int
  (check 1 "mat4-identity"        (t-identity))
  (check 2 "mat4-mul I*I=I"       (< (t-mul-identity) 1e-9))
  (check 3 "mat4-transpose"       (t-transpose))
  (check 4 "mat4-inv identity"    (< (t-inv-identity) 1e-9))
  (check 5 "mat4-inv scale diag"  (t-inv-scale-diag))
  (check 6 "mat4-inv inv(M)*M=I"  (< (t-inv-roundtrip-left) 1e-9))
  (check 7 "mat4-inv M*inv(M)=I"  (< (t-inv-roundtrip-right) 1e-9))
  (finish 7))

) ;; end defmodule linalg/small-test
