;;; linalg.tur -- test runner for linalg spice

(defmodule linalg/test
  (import test/suite :refer [describe it])
  (import test/runner :refer [run-all])

  ;; Import test modules
  (import linalg/mat_test)
  (import linalg/vec_test)

  (describe "linalg tests"
    (it "mat module loads" true)
    (it "vec module loads" true))

  (defn main [] : int
    (run-all)
    0)
)
