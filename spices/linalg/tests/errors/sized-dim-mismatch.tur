;; U4 negative: linalg/sized vectors carry their length in the type, so an op
;; that shares a size variable across both operands rejects mismatched lengths
;; at compile time -- no runtime length check, no silent wrong answer.
;;
;;   tur check tests/errors/sized-dim-mismatch.tur
;;   => error [TUR-E0260]: sized type mismatch: function 'lavecn-dot' shares
;;      size variable 'n' across parameters, but argument 1 has size 2 while
;;      argument 2 has size 3
;;
;; The check is always on (it does not need -Xsized-types). Like the opengl U1
;; error fixtures, this lives outside the flat `tur test tests` run, so it does
;; not break CI; it is checked by hand / a future negative-fixture harness.

(load "stdlib/sized.tur")

(defmodule sized_dim_mismatch_test
  (import linalg/sized :refer [LaVecN lavecn-zeros lavecn-dot]))

(defn mk2 [] : (LaVecN (Static 2)) (lavecn-zeros 2))
(defn mk3 [] : (LaVecN (Static 3)) (lavecn-zeros 3))

(defn bad-dot [] : float
  (lavecn-dot (mk2) (mk3)))   ;; ERROR TUR-E0260: size 2 vs size 3
