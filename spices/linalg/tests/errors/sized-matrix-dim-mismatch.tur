;; U4 negative: linalg/sized matrices carry their shape (m, n) in the type, so
;; matrix ops that share a size variable reject mismatched shapes at compile
;; time -- no runtime shape check, no silent wrong answer. Unblocked by
;; turmeric main #476 (multi-index opaque cross-parameter unification).
;;
;;   tur check tests/errors/sized-matrix-dim-mismatch.tur
;;   => error [TUR-E0260]: sized type mismatch: function 'lamat-mul' shares
;;      size variable 'k' across parameters, but argument 1 has size 3 while
;;      argument 2 has size 5
;;
;; Like the opengl U1 / sized-vector error fixtures this lives outside the flat
;; `tur test tests` run, so it documents the guarantee without breaking CI.

(load "stdlib/sized.tur")

(defmodule sized_matrix_dim_mismatch_test
  (import linalg/sized :refer [LaMatN lamat-zeros lamat-mul lamat-add]))

(defn mk23 [] : (LaMatN (Static 2) (Static 3)) (lamat-zeros 2 3))
(defn mk54 [] : (LaMatN (Static 5) (Static 4)) (lamat-zeros 5 4))
(defn mk24 [] : (LaMatN (Static 2) (Static 4)) (lamat-zeros 2 4))

;; (2x3) * (5x4): inner dimension 3 != 5 -- the shared `k` cannot unify.
(defn bad-mul [] : (LaMatN (Static 2) (Static 4))
  (lamat-mul (mk23) (mk54)))   ;; ERROR TUR-E0260: k := 3 vs k := 5

;; add of (2x3) and (2x4): the shared column count n cannot unify (3 vs 4).
(defn bad-add [] : (LaMatN (Static 2) (Static 3))
  (lamat-add (mk23) (mk24)))   ;; ERROR TUR-E0260: n := 3 vs n := 4
