;; tests/opengl/buffers_test.tur -- smoke tests for opengl/buffers.
;;
;; Buffer object creation requires a live GL context. Tests open a
;; 1x1 hidden window for initialisation, and skip when no display is found.
(defmodule opengl/tests/buffers
  (import opengl/window  :refer [make-window destroy-window])
  (import opengl/buffers :refer [make-vao make-vbo make-ebo
                                  bind-vao bind-vbo bind-ebo
                                  unbind-vao delete-vao delete-vbo delete-ebo
                                  vertex-attrib])
  (import test/assert    :refer [assert-true])
  (import test/suite     :refer [describe it])
  (import test/runner    :refer [run-all])

  (defn __has-display [] : bool
    ```c
    #include <stdlib.h>
    return (getenv("DISPLAY") != NULL || getenv("WAYLAND_DISPLAY") != NULL);
    ```)

  (describe "make-vao / make-vbo / make-ebo"

    (it "make-vao returns a non-zero handle"
      (if (__has-display)
        (let [w   (make-window 1 1 "test")
              vao (make-vao)
              ok  (not (= (:: vao :int) 0))]
          (delete-vao vao)
          (destroy-window w)
          (assert-true ok))
        (do (println "# SKIP: no display available") true)))

    (it "make-vbo returns a non-zero handle"
      (if (__has-display)
        (let [w   (make-window 1 1 "test")
              vbo (make-vbo)
              ok  (not (= (:: vbo :int) 0))]
          (delete-vbo vbo)
          (destroy-window w)
          (assert-true ok))
        (do (println "# SKIP: no display available") true)))

    (it "make-ebo returns a non-zero handle"
      (if (__has-display)
        (let [w   (make-window 1 1 "test")
              ebo (make-ebo)
              ok  (not (= (:: ebo :int) 0))]
          (delete-ebo ebo)
          (destroy-window w)
          (assert-true ok))
        (do (println "# SKIP: no display available") true))))

  (describe "bind and vertex-attrib"

    (it "bind-vao + bind-vbo + vertex-attrib do not crash"
      (if (__has-display)
        (let [w   (make-window 1 1 "test")
              vao (make-vao)
              vbo (make-vbo)]
          (bind-vao vao)
          (bind-vbo vbo)
          ;; Describe a 3-float position attribute at location 0, stride 12 bytes
          (vertex-attrib 0 3 ":float" false 12 0)
          (unbind-vao)
          (delete-vbo vbo)
          (delete-vao vao)
          (destroy-window w)
          (assert-true true))
        (do (println "# SKIP: no display available") true)))

    (it "bind-ebo does not crash"
      (if (__has-display)
        (let [w   (make-window 1 1 "test")
              vao (make-vao)
              ebo (make-ebo)]
          (bind-vao vao)
          (bind-ebo ebo)
          (unbind-vao)
          (delete-ebo ebo)
          (delete-vao vao)
          (destroy-window w)
          (assert-true true))
        (do (println "# SKIP: no display available") true))))


  (defn main [] : int
    (run-all)
    0))
