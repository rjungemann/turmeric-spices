;; tests/keys_test.tur -- AN2 tests for ansi/keys.
;;
;; Tests both directions of the key-name <-> bytes mapping, plus the
;; modifier-prefix helpers.

(defmodule ansi/tests/keys
  (import ansi/keys :refer [parse-key-bytes key-name->bytes
                            key=? key-ctrl? key-shift? key-alt?])

  ;; Static fail counter avoids threading 69 result vars through a deep
  ;; (+ ...) tree.  tap-record prints one TAP line and bumps the counter
  ;; on failure; tap-finish prints the plan + summary and returns 0/1.

  (defn tap-record [idx : int name : cstr ok : bool] #fx{Unsafe} : void
    ```c
    /* __tur_include__: static int g_keys_fails = 0; */
    if (!ok) g_keys_fails++;
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)name);
    ```)

  (defn tap-finish [count : int] #fx{Unsafe} : int
    ```c
    printf("1..%lld\n", (long long)count);
    if (g_keys_fails == 0) {
      fprintf(stderr, "# All %lld ansi/keys tests passed.\n", (long long)count);
      return 0;
    }
    fprintf(stderr, "# %d/%lld ansi/keys tests failed.\n",
            g_keys_fails, (long long)count);
    return 1;
    ```)

  ;; The decode/encode tests call `parse-key-bytes` / `key-name->bytes`
  ;; through their real Turmeric interface (imported above) rather than by
  ;; reaching into the generated C symbol -- the latter hard-codes the
  ;; compiler's name-mangling and silently breaks when it changes.  The C
  ;; helpers below only supply literal byte fixtures and do the malloc-aware
  ;; comparison; the function-under-test is invoked from Turmeric.

  ;; Literal byte sequence for a decode test-id.  Every fixture is
  ;; NUL-free, so `strlen` recovers the original length the parser needs.
  (defn decode-bytes [test-id : int] #fx{Unsafe} : cstr
    ```c
    switch ((int)test_id) {
      case 1:  return (const char *)"\x1b[A";
      case 2:  return (const char *)"\x1b[B";
      case 3:  return (const char *)"\x1b[C";
      case 4:  return (const char *)"\x1b[D";
      case 5:  return (const char *)"\x1b[H";
      case 6:  return (const char *)"\x1b[F";
      case 7:  return (const char *)"\x1b[Z";
      case 8:  return (const char *)"\x1bOP";
      case 9:  return (const char *)"\x1bOQ";
      case 10: return (const char *)"\x1bOR";
      case 11: return (const char *)"\x1bOS";
      case 12: return (const char *)"\x1b[15~";
      case 13: return (const char *)"\x1b[17~";
      case 14: return (const char *)"\x1b[18~";
      case 15: return (const char *)"\x1b[19~";
      case 16: return (const char *)"\x1b[20~";
      case 17: return (const char *)"\x1b[21~";
      case 18: return (const char *)"\x1b[23~";
      case 19: return (const char *)"\x1b[24~";
      case 20: return (const char *)"\x1b[2~";
      case 21: return (const char *)"\x1b[3~";
      case 22: return (const char *)"\x1b[5~";
      case 23: return (const char *)"\x1b[6~";
      case 24: return (const char *)"\x01";
      case 25: return (const char *)"\x1a";
      case 26: return (const char *)"\r";
      case 27: return (const char *)"\n";
      case 28: return (const char *)"\t";
      case 29: return (const char *)"\x7f";
      case 30: return (const char *)"\x1b";
      case 31: return (const char *)"a";
      case 32: return (const char *)" ";
      case 33: return (const char *)"\x1b" "a";
      case 34: return (const char *)"\x1b[1;5A";
      case 35: return (const char *)"\x1b[1;2A";
      case 36: return (const char *)"\x1b[1;3A";
      case 37: return (const char *)"\x1b[1;7A";
      case 38: return (const char *)"\x1b[1;8A";
      case 39: return (const char *)"\x1b[3;5~";
      case 40: return (const char *)"\x1b[1;2P";
      default: return (const char *)"";
    }
    ```)

  ;; Expected encoded byte sequence for an encode test-id.  Also NUL-free,
  ;; so a plain strcmp against the encoder output is exact.
  (defn encode-expected [test-id : int] #fx{Unsafe} : cstr
    ```c
    switch ((int)test_id) {
      case 1:  return (const char *)"\x1b[A";
      case 2:  return (const char *)"\x1b[B";
      case 3:  return (const char *)"\x1b[C";
      case 4:  return (const char *)"\x1b[D";
      case 5:  return (const char *)"\x1b[Z";
      case 6:  return (const char *)"\x1bOP";
      case 7:  return (const char *)"\x1bOS";
      case 8:  return (const char *)"\x1b[15~";
      case 9:  return (const char *)"\x1b[24~";
      case 10: return (const char *)"\x1b[3~";
      case 11: return (const char *)"\x1b[5~";
      case 12: return (const char *)"\x01";
      case 13: return (const char *)"\x1a";
      case 14: return (const char *)"\r";
      case 15: return (const char *)"\t";
      case 16: return (const char *)"\x7f";
      case 17: return (const char *)"\x1b";
      case 18: return (const char *)"a";
      case 19: return (const char *)"\x1b" "a";
      case 20: return (const char *)"\x1b[1;5A";
      case 21: return (const char *)"\x1b[3;5~";
      default: return (const char *)"";
    }
    ```)

  ;; strlen as a Turmeric-callable int (the fixtures carry no embedded NUL).
  (defn cstr-len [s : cstr] #fx{Unsafe} : int ```c return (int64_t)strlen((const char *)s); ```)

  ;; Compare `got` (malloc'd by the function-under-test) against a static
  ;; expected literal, then free `got`.  Returns whether they matched.
  (defn streq-free [got : cstr expected : cstr] #fx{Unsafe} : bool
    ```c
    int ok = strcmp((const char *)got, (const char *)expected) == 0;
    free((void *)got);
    return ok ? 1 : 0;
    ```)

  ;; Decode a literal byte sequence (selected by test-id) via the real
  ;; `parse-key-bytes` and compare the resulting key name against expected.
  (defn decode-test [test-id : int expected : cstr] #fx{Unsafe} : bool
    (let [bytes (decode-bytes test-id)]
      (streq-free (parse-key-bytes bytes (cstr-len bytes)) expected)))

  ;; Encode a key name via the real `key-name->bytes` and compare against
  ;; the expected byte sequence for this test-id.
  (defn encode-test [test-id : int name : cstr] #fx{Unsafe} : bool
    (streq-free (key-name->bytes name) (encode-expected test-id)))

  (defn mod-check [name : cstr ctrl : int shift : int alt : int] #fx{Unsafe} : bool
    (and (= (key-ctrl? name) ctrl)
         (and (= (key-shift? name) shift)
              (= (key-alt? name) alt))))

  (defn run-decode [idx : int label : cstr tid : int expected : cstr] #fx{Unsafe} : void
    (tap-record idx label (decode-test tid expected)))

  (defn run-encode [idx : int label : cstr tid : int name : cstr] #fx{Unsafe} : void
    (tap-record idx label (encode-test tid name)))

  (defn run-mod [idx : int label : cstr name : cstr c : int s : int a : int] #fx{Unsafe} : void
    (tap-record idx label (mod-check name c s a)))

  (defn main [] #fx{Unsafe} : int
    (do
      ;; Decode tests
      (run-decode  1 "decode CSI A -> <Up>"           1 "<Up>")
      (run-decode  2 "decode CSI B -> <Down>"         2 "<Down>")
      (run-decode  3 "decode CSI C -> <Right>"        3 "<Right>")
      (run-decode  4 "decode CSI D -> <Left>"         4 "<Left>")
      (run-decode  5 "decode CSI H -> <Home>"         5 "<Home>")
      (run-decode  6 "decode CSI F -> <End>"          6 "<End>")
      (run-decode  7 "decode CSI Z -> <S-Tab>"        7 "<S-Tab>")
      (run-decode  8 "decode SS3 P -> <F1>"           8 "<F1>")
      (run-decode  9 "decode SS3 Q -> <F2>"           9 "<F2>")
      (run-decode 10 "decode SS3 R -> <F3>"          10 "<F3>")
      (run-decode 11 "decode SS3 S -> <F4>"          11 "<F4>")
      (run-decode 12 "decode CSI 15~ -> <F5>"        12 "<F5>")
      (run-decode 13 "decode CSI 17~ -> <F6>"        13 "<F6>")
      (run-decode 14 "decode CSI 18~ -> <F7>"        14 "<F7>")
      (run-decode 15 "decode CSI 19~ -> <F8>"        15 "<F8>")
      (run-decode 16 "decode CSI 20~ -> <F9>"        16 "<F9>")
      (run-decode 17 "decode CSI 21~ -> <F10>"       17 "<F10>")
      (run-decode 18 "decode CSI 23~ -> <F11>"       18 "<F11>")
      (run-decode 19 "decode CSI 24~ -> <F12>"       19 "<F12>")
      (run-decode 20 "decode CSI 2~ -> <Insert>"     20 "<Insert>")
      (run-decode 21 "decode CSI 3~ -> <Delete>"     21 "<Delete>")
      (run-decode 22 "decode CSI 5~ -> <PageUp>"     22 "<PageUp>")
      (run-decode 23 "decode CSI 6~ -> <PageDown>"   23 "<PageDown>")
      (run-decode 24 "decode 0x01 -> <C-a>"          24 "<C-a>")
      (run-decode 25 "decode 0x1a -> <C-z>"          25 "<C-z>")
      (run-decode 26 "decode CR -> <Enter>"          26 "<Enter>")
      (run-decode 27 "decode LF -> <Enter>"          27 "<Enter>")
      (run-decode 28 "decode TAB -> <Tab>"           28 "<Tab>")
      (run-decode 29 "decode 0x7f -> <Backspace>"    29 "<Backspace>")
      (run-decode 30 "decode ESC alone -> <Escape>"  30 "<Escape>")
      (run-decode 31 "decode 'a' -> a"               31 "a")
      (run-decode 32 "decode space -> ' '"           32 " ")
      (run-decode 33 "decode ESC a -> <M-a>"         33 "<M-a>")
      (run-decode 34 "decode CSI 1;5A -> <C-Up>"     34 "<C-Up>")
      (run-decode 35 "decode CSI 1;2A -> <S-Up>"     35 "<S-Up>")
      (run-decode 36 "decode CSI 1;3A -> <M-Up>"     36 "<M-Up>")
      (run-decode 37 "decode CSI 1;7A -> <C-M-Up>"   37 "<C-M-Up>")
      (run-decode 38 "decode CSI 1;8A -> <C-M-S-Up>" 38 "<C-M-S-Up>")
      (run-decode 39 "decode CSI 3;5~ -> <C-Delete>" 39 "<C-Delete>")
      (run-decode 40 "decode CSI 1;2P -> <S-F1>"     40 "<S-F1>")
      ;; Encode tests
      (run-encode 41 "encode <Up>"          1  "<Up>")
      (run-encode 42 "encode <Down>"        2  "<Down>")
      (run-encode 43 "encode <Right>"       3  "<Right>")
      (run-encode 44 "encode <Left>"        4  "<Left>")
      (run-encode 45 "encode <S-Tab>"       5  "<S-Tab>")
      (run-encode 46 "encode <F1>"          6  "<F1>")
      (run-encode 47 "encode <F4>"          7  "<F4>")
      (run-encode 48 "encode <F5>"          8  "<F5>")
      (run-encode 49 "encode <F12>"         9  "<F12>")
      (run-encode 50 "encode <Delete>"      10 "<Delete>")
      (run-encode 51 "encode <PageUp>"      11 "<PageUp>")
      (run-encode 52 "encode <C-a>"         12 "<C-a>")
      (run-encode 53 "encode <C-z>"         13 "<C-z>")
      (run-encode 54 "encode <Enter>"       14 "<Enter>")
      (run-encode 55 "encode <Tab>"         15 "<Tab>")
      (run-encode 56 "encode <Backspace>"   16 "<Backspace>")
      (run-encode 57 "encode <Escape>"      17 "<Escape>")
      (run-encode 58 "encode plain 'a'"     18 "a")
      (run-encode 59 "encode <M-a>"         19 "<M-a>")
      (run-encode 60 "encode <C-Up>"        20 "<C-Up>")
      (run-encode 61 "encode <C-Delete>"    21 "<C-Delete>")
      ;; key=? + modifier helpers
      (tap-record 62 "key=? matches identical strings"        (= (key=? "<C-S-Up>" "<C-S-Up>") 1))
      (tap-record 63 "key=? rejects different strings"        (= (key=? "<Up>" "<Down>") 0))
      (run-mod    64 "key-ctrl? finds C- in <C-a>"            "<C-a>"     1 0 0)
      (run-mod    65 "key-shift? finds S- in <S-Tab>"         "<S-Tab>"   0 1 0)
      (run-mod    66 "key-alt? finds M- in <M-x>"             "<M-x>"     0 0 1)
      (run-mod    67 "C- and S- both fire for <C-S-Up>"       "<C-S-Up>"  1 1 0)
      (run-mod    68 "no modifiers on plain <Enter>"          "<Enter>"   0 0 0)
      (run-mod    69 "all three modifiers on <C-M-S-Up>"      "<C-M-S-Up>" 1 1 1)
      (tap-finish 69)))

) ;; end defmodule
