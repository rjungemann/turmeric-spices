;; tests/cursor_test.tur -- AN0 tests for ansi/cursor escape-sequence emission.
;;
;; Each test captures stdout via a pipe + dup2, runs a cursor operation, then
;; compares the captured bytes to the expected ANSI sequence.  Comparisons
;; happen inside inline-C so the ESC literal stays in C source (Turmeric
;; string literals re-emit \033 as \x0033, which collides with following
;; hex/digit bytes -- the C compiler then reads too many digits).

(defmodule ansi/tests/cursor
  (import ansi/cursor :refer [cursor-move-to cursor-up cursor-down
                              cursor-left cursor-right cursor-col
                              cursor-show cursor-hide
                              cursor-save cursor-restore])

  (defn tap-line [idx : int name : cstr ok : bool] #fx{Unsafe} : void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count : int fails : int] #fx{Unsafe} : void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld ansi/cursor tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld ansi/cursor tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok : bool] : int (if ok 0 1))

  (defn run-case [idx : int name : cstr ok : bool] #fx{Unsafe} : int
    (do (tap-line idx name ok) (bool->fail ok)))

  (defn __capture-begin [] #fx{Unsafe} : void
    ```c
    /* __tur_include__: static int g_cap_saved_fd = -1; */
    /* __tur_include__: static int g_cap_pipe_r = -1; */
    /* __tur_include__: static int g_cap_pipe_w = -1; */
    fflush(stdout);
    int fds[2];
    if (pipe(fds) != 0) return;
    int sf = fcntl(fds[0], F_GETFL, 0);
    if (sf >= 0) fcntl(fds[0], F_SETFL, sf | O_NONBLOCK);
    g_cap_pipe_r = fds[0];
    g_cap_pipe_w = fds[1];
    g_cap_saved_fd = dup(STDOUT_FILENO);
    dup2(g_cap_pipe_w, STDOUT_FILENO);
    ```)

  ;; Capture stdout and compare against the expected escape sequence (built
  ;; inside the inline-C body so ESC is a C-literal byte, never a Turmeric
  ;; string).  test-id selects which expected pattern to use.
  (defn __capture-check [test-id : int] #fx{Unsafe} : bool
    ```c
    fflush(stdout);
    if (g_cap_saved_fd < 0) return 0;
    dup2(g_cap_saved_fd, STDOUT_FILENO);
    close(g_cap_saved_fd);
    close(g_cap_pipe_w);
    g_cap_saved_fd = -1;
    g_cap_pipe_w = -1;

    char buf[256];
    size_t len = 0;
    for (;;) {
      if (len >= sizeof(buf) - 1) break;
      ssize_t n = read(g_cap_pipe_r, buf + len, sizeof(buf) - 1 - len);
      if (n <= 0) break;
      len += (size_t)n;
    }
    buf[len] = '\0';
    close(g_cap_pipe_r);
    g_cap_pipe_r = -1;

    const char *expected = "";
    size_t exp_len = 0;
    switch ((int)test_id) {
      case 1: expected = "\033[3;7H";       exp_len = 6;  break;
      case 2: expected = "\033[5A";         exp_len = 4;  break;
      case 3: expected = "\033[2B";         exp_len = 4;  break;
      case 4: expected = "\033[4C";         exp_len = 4;  break;
      case 5: expected = "\033[1D";         exp_len = 4;  break;
      case 6: expected = "\033[10G";        exp_len = 5;  break;
      case 7: expected = "\033[?25l\033[?25h"; exp_len = 12; break;
      case 8: expected = "\0337\0338";      exp_len = 4;  break;
      case 9: expected = "";                exp_len = 0;  break;
      default: return 0;
    }
    if (len != exp_len) return 0;
    return memcmp(buf, expected, exp_len) == 0;
    ```)

  (defn test-move-to [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-move-to 3 7) (__capture-check 1)))

  (defn test-up [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-up 5) (__capture-check 2)))

  (defn test-down [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-down 2) (__capture-check 3)))

  (defn test-right [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-right 4) (__capture-check 4)))

  (defn test-left [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-left 1) (__capture-check 5)))

  (defn test-col [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-col 10) (__capture-check 6)))

  (defn test-show-hide [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-hide) (cursor-show) (__capture-check 7)))

  (defn test-save-restore [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-save) (cursor-restore) (__capture-check 8)))

  ;; Argument <= 0 is a no-op (avoids emitting "\033[0A" which moves -1 row).
  (defn test-noop-on-zero [] #fx{Unsafe} : bool
    (do (__capture-begin) (cursor-up 0) (cursor-down 0) (__capture-check 9)))

  (defn main [] #fx{Unsafe} : int
    (let [f1 (run-case 1 "cursor-move-to emits CSI <r>;<c>H"       (test-move-to))
          f2 (run-case 2 "cursor-up emits CSI <n>A"               (test-up))
          f3 (run-case 3 "cursor-down emits CSI <n>B"             (test-down))
          f4 (run-case 4 "cursor-right emits CSI <n>C"            (test-right))
          f5 (run-case 5 "cursor-left emits CSI <n>D"             (test-left))
          f6 (run-case 6 "cursor-col emits CSI <n>G"              (test-col))
          f7 (run-case 7 "show/hide emit DECTCEM toggles"         (test-show-hide))
          f8 (run-case 8 "save/restore emit ESC 7 / ESC 8"        (test-save-restore))
          f9 (run-case 9 "relative moves are a no-op when n <= 0" (test-noop-on-zero))]
      (do
        (tap-plan 9 (+ f1 (+ f2 (+ f3 (+ f4 (+ f5 (+ f6 (+ f7 (+ f8 f9)))))))))
        (if (= (+ f1 (+ f2 (+ f3 (+ f4 (+ f5 (+ f6 (+ f7 (+ f8 f9)))))))) 0) 0 1))))

) ;; end defmodule
