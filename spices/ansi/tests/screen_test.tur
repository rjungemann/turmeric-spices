;; tests/screen_test.tur -- AN1 byte-exact tests for ansi/screen emission.

(defmodule ansi/tests/screen
  (import ansi/screen :refer [screen-clear screen-clear-to-eol screen-clear-line
                              alt-screen-enter alt-screen-leave
                              scroll-up scroll-down])

  (defn tap-line [idx :int name :cstr ok :bool] #{Unsafe} :void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count :int fails :int] #{Unsafe} :void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld ansi/screen tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld ansi/screen tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok :bool] :int (if ok 0 1))
  (defn run-case [idx :int name :cstr ok :bool] #{Unsafe} :int
    (do (tap-line idx name ok) (bool->fail ok)))

  (defn __capture-begin [] #{Unsafe} :void
    ```c
    /* __tur_include__: static int g_scr_saved_fd = -1; */
    /* __tur_include__: static int g_scr_pipe_r = -1; */
    /* __tur_include__: static int g_scr_pipe_w = -1; */
    fflush(stdout);
    int fds[2];
    if (pipe(fds) != 0) return;
    int sf = fcntl(fds[0], F_GETFL, 0);
    if (sf >= 0) fcntl(fds[0], F_SETFL, sf | O_NONBLOCK);
    g_scr_pipe_r = fds[0];
    g_scr_pipe_w = fds[1];
    g_scr_saved_fd = dup(STDOUT_FILENO);
    dup2(g_scr_pipe_w, STDOUT_FILENO);
    ```)

  (defn __capture-check [test-id :int] #{Unsafe} :bool
    ```c
    fflush(stdout);
    if (g_scr_saved_fd < 0) return 0;
    dup2(g_scr_saved_fd, STDOUT_FILENO);
    close(g_scr_saved_fd);
    close(g_scr_pipe_w);
    g_scr_saved_fd = -1;
    g_scr_pipe_w = -1;
    char buf[64];
    size_t len = 0;
    for (;;) {
      if (len >= sizeof(buf) - 1) break;
      ssize_t n = read(g_scr_pipe_r, buf + len, sizeof(buf) - 1 - len);
      if (n <= 0) break;
      len += (size_t)n;
    }
    buf[len] = '\0';
    close(g_scr_pipe_r);
    g_scr_pipe_r = -1;
    const char *expected = "";
    size_t exp_len = 0;
    switch ((int)test_id) {
      case 1: expected = "\033[2J\033[H";  exp_len = 7;  break;
      case 2: expected = "\033[K";          exp_len = 3;  break;
      case 3: expected = "\033[2K";         exp_len = 4;  break;
      case 4: expected = "\033[?1049h";     exp_len = 8;  break;
      case 5: expected = "\033[?1049l";     exp_len = 8;  break;
      case 6: expected = "\033[3S";         exp_len = 4;  break;
      case 7: expected = "\033[2T";         exp_len = 4;  break;
      case 8: expected = "";                 exp_len = 0;  break; /* scroll-up 0 no-op */
      default: return 0;
    }
    if (len != exp_len) return 0;
    return memcmp(buf, expected, exp_len) == 0;
    ```)

  (defn t-clear        [] #{Unsafe} :bool (do (__capture-begin) (screen-clear)         (__capture-check 1)))
  (defn t-clear-eol    [] #{Unsafe} :bool (do (__capture-begin) (screen-clear-to-eol)  (__capture-check 2)))
  (defn t-clear-line   [] #{Unsafe} :bool (do (__capture-begin) (screen-clear-line)    (__capture-check 3)))
  (defn t-alt-enter    [] #{Unsafe} :bool (do (__capture-begin) (alt-screen-enter)     (__capture-check 4)))
  (defn t-alt-leave    [] #{Unsafe} :bool (do (__capture-begin) (alt-screen-leave)     (__capture-check 5)))
  (defn t-scroll-up    [] #{Unsafe} :bool (do (__capture-begin) (scroll-up 3)          (__capture-check 6)))
  (defn t-scroll-down  [] #{Unsafe} :bool (do (__capture-begin) (scroll-down 2)        (__capture-check 7)))
  (defn t-scroll-noop  [] #{Unsafe} :bool (do (__capture-begin) (scroll-up 0)          (__capture-check 8)))

  (defn main [] #{Unsafe} :int
    (let [r1 (run-case 1 "screen-clear emits 2J then H"             (t-clear))
          r2 (run-case 2 "screen-clear-to-eol emits CSI K"          (t-clear-eol))
          r3 (run-case 3 "screen-clear-line emits CSI 2K"           (t-clear-line))
          r4 (run-case 4 "alt-screen-enter emits CSI ?1049h"        (t-alt-enter))
          r5 (run-case 5 "alt-screen-leave emits CSI ?1049l"        (t-alt-leave))
          r6 (run-case 6 "scroll-up 3 emits CSI 3 S"                (t-scroll-up))
          r7 (run-case 7 "scroll-down 2 emits CSI 2 T"              (t-scroll-down))
          r8 (run-case 8 "scroll-up 0 is a no-op"                   (t-scroll-noop))]
      (do
        (tap-plan 8 (+ r1 (+ r2 (+ r3 (+ r4 (+ r5 (+ r6 (+ r7 r8))))))))
        (if (= (+ r1 (+ r2 (+ r3 (+ r4 (+ r5 (+ r6 (+ r7 r8))))))) 0) 0 1))))

) ;; end defmodule
