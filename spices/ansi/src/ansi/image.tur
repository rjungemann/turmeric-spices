;;; ansi/image -- inline image protocols (Kitty / iTerm2) with placeholder fallback.
;;
;; All terminal escape sequences are emitted to stdout.  Image data is loaded
;; from disk or accepted pre-encoded as base64.  Sixel is deferred to v0.2
;; (see docs/tur-ansi-spice-plan.md "Risks and open questions" #1); calls that
;; request sixel currently fall back to the bracketed placeholder so that
;; callers using (term-image-protocol) need no special-case logic.

(defmodule ansi/image
  (export image-display image-display-base64
          image-display-protocol image-placeholder)

  ;;; image-placeholder -- write a bracketed "[image: path]" string to stdout.
  ;;;
  ;;; Used as the fallback when no inline-image protocol is available, or as
  ;;; an explicit caller-driven sentinel.  Emits no trailing newline.
  ;;;
  ;;; Parameters:
  ;;;   path -- the path string to embed in the placeholder.  May be empty.
  ;;;
  ;;; Since: tur-ansi AN4
  (defn image-placeholder [path :cstr] #{Unsafe} :void
    ```c
    const char *p = (const char *)path;
    if (!p) p = "";
    printf("[image: %s]", p);
    fflush(stdout);
    ```)

  ;;; image-display-base64 -- emit a Kitty inline-image sequence from base64 PNG data.
  ;;;
  ;;; Parameters:
  ;;;   b64 -- ASCII base64-encoded PNG bytes (no whitespace, no '=' stripping)
  ;;;
  ;;; Chunks the payload into 4096-character APC blocks per the Kitty protocol,
  ;;; with m=1 on every chunk except the last (m=0).  Outputs nothing if b64
  ;;; is empty or null.
  ;;;
  ;;; Since: tur-ansi AN4
  (defn image-display-base64 [b64 :cstr] #{Unsafe} :void
    ```c
    const char *s = (const char *)b64;
    if (!s || !s[0]) return;
    size_t n = strlen(s);
    const size_t CHUNK = 4096;
    size_t off = 0;
    while (off < n) {
      size_t left = n - off;
      size_t take = left > CHUNK ? CHUNK : left;
      int more = (off + take < n) ? 1 : 0;
      if (off == 0) {
        printf("\033_Gf=100,a=T,m=%d;", more);
      } else {
        printf("\033_Gm=%d;", more);
      }
      fwrite(s + off, 1, take, stdout);
      fputs("\033\\", stdout);
      off += take;
    }
    fflush(stdout);
    ```)

  ;;
  ;; File-loading + base64 helpers used by the path-based variants below.
  ;;
  ;; __image-read-file returns a malloc'd buffer (via *out and *out_len) on
  ;; success, NULL on failure.  __image-base64 returns a malloc'd ASCII string
  ;; of the encoded bytes, or NULL on allocation failure.  Both are defined as
  ;; static helpers in this file via __tur_include__.
  ;;
  (defn __image-init [] #{Unsafe} :void
    ```c
    /* __tur_include__: #include <stdio.h> */
    /* __tur_include__: #include <stdlib.h> */
    /* __tur_include__: #include <string.h> */
    /* __tur_include__: static char *__image_read_file(const char *path, size_t *out_len) {
         FILE *f = fopen(path, "rb");
