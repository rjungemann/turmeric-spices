;;; ansi/cursor -- terminal cursor positioning and visibility via ANSI CSI.
;;
;; Pure escape-sequence emission to stdout.  No terminal-mode dependency:
;; these functions work in cooked or raw mode and on any VT100-class terminal.

(defmodule ansi/cursor
  (export cursor-move-to cursor-up cursor-down cursor-left cursor-right
          cursor-col cursor-show cursor-hide cursor-save cursor-restore)

  ;;; cursor-move-to -- move the cursor to an absolute 1-based (row col).
  ;;;
  ;;; Parameters:
  ;;;   row -- 1-based row (top is 1)
  ;;;   col -- 1-based column (leftmost is 1)
  ;;;
  ;;; Example:
  ;;;   (cursor-move-to 1 1)  ; home the cursor
  ;;;
  ;;; Since: tur-ansi AN0
  (defn cursor-move-to [row : int col : int] #fx{Unsafe} : void
    ```c
    if (row < 1) row = 1;
    if (col < 1) col = 1;
    printf("\033[%lld;%lldH", (long long)row, (long long)col);
    fflush(stdout);
    ```)

  ;;; cursor-up -- move the cursor up n rows (clamped at top of screen).
  (defn cursor-up [n : int] #fx{Unsafe} : void
    ```c
    if (n < 1) return;
    printf("\033[%lldA", (long long)n);
    fflush(stdout);
    ```)

  ;;; cursor-down -- move the cursor down n rows (clamped at bottom).
  (defn cursor-down [n : int] #fx{Unsafe} : void
    ```c
    if (n < 1) return;
    printf("\033[%lldB", (long long)n);
    fflush(stdout);
    ```)

  ;;; cursor-right -- move the cursor right n columns (clamped at right edge).
  (defn cursor-right [n : int] #fx{Unsafe} : void
    ```c
    if (n < 1) return;
    printf("\033[%lldC", (long long)n);
    fflush(stdout);
    ```)

  ;;; cursor-left -- move the cursor left n columns (clamped at left edge).
  (defn cursor-left [n : int] #fx{Unsafe} : void
    ```c
    if (n < 1) return;
    printf("\033[%lldD", (long long)n);
    fflush(stdout);
    ```)

  ;;; cursor-col -- move to a column on the current row (CSI <n> G).
  (defn cursor-col [col : int] #fx{Unsafe} : void
    ```c
    if (col < 1) col = 1;
    printf("\033[%lldG", (long long)col);
    fflush(stdout);
    ```)

  ;;; cursor-show -- make the cursor visible (DECTCEM h).
  (defn cursor-show [] #fx{Unsafe} : void
    ```c
    fputs("\033[?25h", stdout);
    fflush(stdout);
    ```)

  ;;; cursor-hide -- hide the cursor (DECTCEM l).
  (defn cursor-hide [] #fx{Unsafe} : void
    ```c
    fputs("\033[?25l", stdout);
    fflush(stdout);
    ```)

  ;;; cursor-save -- save current cursor position (DEC SC, ESC 7).
  (defn cursor-save [] #fx{Unsafe} : void
    ```c
    fputs("\0337", stdout);
    fflush(stdout);
    ```)

  ;;; cursor-restore -- restore previously saved cursor position (DEC RC, ESC 8).
  (defn cursor-restore [] #fx{Unsafe} : void
    ```c
    fputs("\0338", stdout);
    fflush(stdout);
    ```)

) ;; end defmodule ansi/cursor
