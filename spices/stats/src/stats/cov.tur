;; stats/cov.tur -- covariance and correlation between tur-frame float64 columns.
;;
;; cov / cor operate on the intersection of non-null rows across both columns.
;; cor-spearman converts each column to ranks first, then applies Pearson cor.
;; Matrix variants iterate over a list of columns and return N-by-N frames.

(defmodule stats/cov
  (export cov cor cor-spearman
          cov-matrix cor-matrix cor-matrix-spearman
          frame-cor frame-cor-spearman)

;; file-scope-c-block: hoist includes, shared struct layouts, and static
;; helpers so they are available at file scope in every generated TU.
```c
#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

#ifndef __STATS_FRAME_COL_DEFINED
#define __STATS_FRAME_COL_DEFINED
struct __frame_col {
  int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
  void *validity; void *values; void *offsets;
};
#endif
#ifndef __STATS_CONS_DEFINED
#define __STATS_CONS_DEFINED
struct __cons { int64_t value; int64_t next; };
#endif
#ifndef __STATS_FRAME_TYPES_DEFINED
#define __STATS_FRAME_TYPES_DEFINED
struct __field { int64_t name_ptr; int64_t type_tag; int64_t nullable; };
struct __schema { int64_t arity; struct __field *fields; };
struct __frame {
  int64_t nrows; int64_t ncols;
  int64_t schema_ptr; int64_t *columns;
};
#endif
#ifndef __STATS_VALID_DEFINED
#define __STATS_VALID_DEFINED
static inline int __valid(void *validity, int64_t i) {
  if (!validity) return 1;
  uint8_t *bm = (uint8_t *)validity;
  return (bm[i >> 3] >> (i & 7)) & 1;
}
#endif
typedef struct { double val; int64_t idx; } __pair_t;
typedef double (*__pairfn_t)(int64_t, int64_t);
static int __cmp_pair(const void *x, const void *y) {
  double a = ((__pair_t *)x)->val, b = ((__pair_t *)y)->val;
  return (a > b) - (a < b);
}
static double __cov_cols(int64_t ah, int64_t bh) {
  struct __frame_col *ca = (struct __frame_col *)(intptr_t)ah;
  struct __frame_col *cb = (struct __frame_col *)(intptr_t)bh;
  double *va = (double *)ca->values, *vb = (double *)cb->values;
  int64_t len = ca->length < cb->length ? ca->length : cb->length;
  double sa=0.0, sb2=0.0; int64_t n=0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)){sa+=va[i];sb2+=vb[i];n++;}
  if(n<2) return 0.0/0.0;
  double ma=sa/(double)n, mb=sb2/(double)n, s=0.0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i))
      s+=(va[i]-ma)*(vb[i]-mb);
  return s/(double)(n-1);
}
static double __cor_cols(int64_t ah, int64_t bh) {
  struct __frame_col *ca=(struct __frame_col *)(intptr_t)ah;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)bh;
  double *va=(double *)ca->values, *vb=(double *)cb->values;
  int64_t len=ca->length<cb->length?ca->length:cb->length;
  double sa=0.0, sb2=0.0; int64_t n=0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)){sa+=va[i];sb2+=vb[i];n++;}
  if(n<2) return 0.0/0.0;
  double ma=sa/(double)n, mb=sb2/(double)n, sab=0.0, ssa=0.0, ssb=0.0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)){
      double da=va[i]-ma, db=vb[i]-mb;
      sab+=da*db; ssa+=da*da; ssb+=db*db;
    }
  double denom=sqrt(ssa*ssb);
  return denom==0.0?0.0/0.0:sab/denom;
}
static double __spear_cols(int64_t ah, int64_t bh) {
  struct __frame_col *ca=(struct __frame_col *)(intptr_t)ah;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)bh;
  double *va=(double *)ca->values, *vb=(double *)cb->values;
  int64_t len=ca->length<cb->length?ca->length:cb->length;
  int64_t n=0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)) n++;
  if(n<2) return 0.0/0.0;
  __pair_t *pa=(__pair_t *)malloc((size_t)n*sizeof(__pair_t));
  __pair_t *pb=(__pair_t *)malloc((size_t)n*sizeof(__pair_t));
  int64_t k=0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)){
      pa[k].val=va[i];pa[k].idx=k;
      pb[k].val=vb[i];pb[k].idx=k;k++;
    }
  qsort(pa,(size_t)n,sizeof(__pair_t),__cmp_pair);
  qsort(pb,(size_t)n,sizeof(__pair_t),__cmp_pair);
  double *ra=(double *)malloc((size_t)n*sizeof(double));
  double *rb=(double *)malloc((size_t)n*sizeof(double));
  for(int64_t i=0;i<n;){
    int64_t j=i;
    while(j<n&&pa[j].val==pa[i].val)j++;
    double avg=(double)(i+j-1)/2.0+1.0;
    for(int64_t kk=i;kk<j;kk++)ra[pa[kk].idx]=avg;
    i=j;
  }
  for(int64_t i=0;i<n;){
    int64_t j=i;
    while(j<n&&pb[j].val==pb[i].val)j++;
    double avg=(double)(i+j-1)/2.0+1.0;
    for(int64_t kk=i;kk<j;kk++)rb[pb[kk].idx]=avg;
    i=j;
  }
  double sa=0.0,sb2=0.0;
  for(int64_t i=0;i<n;i++){sa+=ra[i];sb2+=rb[i];}
  double ma=sa/(double)n,mb=sb2/(double)n,sab=0.0,ssa=0.0,ssb=0.0;
  for(int64_t i=0;i<n;i++){
    double da=ra[i]-ma,db=rb[i]-mb;
    sab+=da*db;ssa+=da*da;ssb+=db*db;
  }
  free(pa);free(pb);free(ra);free(rb);
  double denom=sqrt(ssa*ssb);
  return denom==0.0?0.0/0.0:sab/denom;
}
static int64_t __build_matrix(__pairfn_t fn, int64_t cols, int64_t names) {
  int64_t N = 0;
  for (struct __cons *p = (struct __cons *)(intptr_t)cols; p;
       p = (struct __cons *)(intptr_t)p->next) N++;
  int64_t *col_handles = (int64_t *)malloc((size_t)N * sizeof(int64_t));
  const char **col_names = (const char **)malloc((size_t)N * sizeof(const char *));
  {
    struct __cons *pc = (struct __cons *)(intptr_t)cols;
    struct __cons *pn = (struct __cons *)(intptr_t)names;
    for (int64_t i = 0; i < N; i++) {
      col_handles[i] = pc->value;
      col_names[i]   = pn ? (const char *)(intptr_t)pn->value : "";
      pc = (struct __cons *)(intptr_t)pc->next;
      if (pn) pn = (struct __cons *)(intptr_t)pn->next;
    }
  }
  int64_t out_ncols = 1 + N;
  struct __schema *sc = (struct __schema *)malloc(sizeof(struct __schema));
  sc->arity  = out_ncols;
  sc->fields = (struct __field *)calloc((size_t)out_ncols, sizeof(struct __field));
  sc->fields[0].name_ptr = (int64_t)(intptr_t)strdup("name");
  sc->fields[0].type_tag = 6;
  for (int64_t j = 0; j < N; j++) {
    sc->fields[1+j].name_ptr = (int64_t)(intptr_t)strdup(col_names[j]);
    sc->fields[1+j].type_tag = 4;
  }
  int64_t *out_cols = (int64_t *)calloc((size_t)out_ncols, sizeof(int64_t));
  {
    int64_t total = 0;
    for (int64_t i = 0; i < N; i++) total += (int64_t)strlen(col_names[i]);
    int32_t *offs  = (int32_t *)malloc((size_t)(N+1)*sizeof(int32_t));
    char    *chars = (char    *)malloc((size_t)(total+1));
    int32_t pos = 0;
    for (int64_t i = 0; i < N; i++) {
      offs[i] = pos;
      int64_t slen = (int64_t)strlen(col_names[i]);
      memcpy(chars+pos, col_names[i], (size_t)slen);
      pos += (int32_t)slen;
    }
    offs[N] = pos; chars[pos] = '\0';
    struct __frame_col *oc = (struct __frame_col *)calloc(1,sizeof(struct __frame_col));
    oc->type_tag=6; oc->length=N; oc->refcount=1;
    oc->offsets=offs; oc->values=chars;
    out_cols[0] = (int64_t)(intptr_t)oc;
  }
  for (int64_t j = 0; j < N; j++) {
    int64_t bytes   = N * (int64_t)sizeof(double);
    int64_t rounded = (bytes+63)&~((int64_t)63);
    void *buf = malloc((size_t)(sizeof(int64_t)+rounded));
    *(int64_t *)buf = rounded;
    double *dv = (double *)((char *)buf+sizeof(int64_t));
    for (int64_t i = 0; i < N; i++)
      dv[i] = fn(col_handles[i], col_handles[j]);
    struct __frame_col *oc = (struct __frame_col *)calloc(1,sizeof(struct __frame_col));
    oc->type_tag=4; oc->length=N; oc->refcount=1; oc->values=dv;
    out_cols[1+j] = (int64_t)(intptr_t)oc;
  }
  free(col_handles); free(col_names);
  struct __frame *out = (struct __frame *)malloc(sizeof(struct __frame));
  out->nrows = N; out->ncols = out_ncols;
  out->schema_ptr = (int64_t)(intptr_t)sc;
  out->columns = out_cols;
  return (int64_t)(intptr_t)out;
}
```

;;; cov -- sample covariance of two float64 columns (complete-cases).
;;;
;;; Parameters:
;;;   a -- :int  first column
;;;   b -- :int  second column (must be same length as a)
;;;
;;; Returns:
;;;   :float  sample covariance (n-1 denominator), or NaN if fewer than 2 pairs.
;;;
;;; Example:
;;;   (cov col-x col-y)
;;;
;;; Since: ST2
(defn cov [a : int b : int] : float
  ```c
  struct __frame_col *ca = (struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb = (struct __frame_col *)(intptr_t)b;
  double *va = (double *)ca->values;
  double *vb = (double *)cb->values;
  int64_t len = ca->length < cb->length ? ca->length : cb->length;
  double sa = 0.0, sb = 0.0; int64_t n = 0;
  for (int64_t i = 0; i < len; i++)
    if (__valid(ca->validity, i) && __valid(cb->validity, i)) {
      sa += va[i]; sb += vb[i]; n++;
    }
  if (n < 2) return 0.0/0.0;
  double ma = sa/(double)n, mb = sb/(double)n;
  double s = 0.0;
  for (int64_t i = 0; i < len; i++)
    if (__valid(ca->validity, i) && __valid(cb->validity, i))
      s += (va[i]-ma)*(vb[i]-mb);
  return s/(double)(n-1);
  ```)

;;; cor -- Pearson correlation of two float64 columns.
;;;
;;; Parameters:
;;;   a -- :int  first column
;;;   b -- :int  second column
;;;
;;; Returns:
;;;   :float  Pearson r in [-1, 1], or NaN if degenerate.
;;;
;;; Since: ST2
(defn cor [a : int b : int] : float
  ```c
  struct __frame_col *ca = (struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb = (struct __frame_col *)(intptr_t)b;
  double *va = (double *)ca->values;
  double *vb = (double *)cb->values;
  int64_t len = ca->length < cb->length ? ca->length : cb->length;
  double sa = 0.0, sb = 0.0; int64_t n = 0;
  for (int64_t i = 0; i < len; i++)
    if (__valid(ca->validity, i) && __valid(cb->validity, i)) {
      sa += va[i]; sb += vb[i]; n++;
    }
  if (n < 2) return 0.0/0.0;
  double ma = sa/(double)n, mb = sb/(double)n;
  double sab = 0.0, ssa = 0.0, ssb = 0.0;
  for (int64_t i = 0; i < len; i++)
    if (__valid(ca->validity, i) && __valid(cb->validity, i)) {
      double da = va[i]-ma, db = vb[i]-mb;
      sab += da*db; ssa += da*da; ssb += db*db;
    }
  double denom = sqrt(ssa * ssb);
  return denom == 0.0 ? 0.0/0.0 : sab/denom;
  ```)

;;; cor-spearman -- Spearman rank correlation of two float64 columns.
;;;
;;; Parameters:
;;;   a -- :int  first column
;;;   b -- :int  second column
;;;
;;; Returns:
;;;   :float  Spearman rho in [-1, 1].
;;;
;;; Since: ST2
(defn cor-spearman [a : int b : int] : float
  ```c
  struct __frame_col *ca = (struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb = (struct __frame_col *)(intptr_t)b;
  double *va = (double *)ca->values;
  double *vb = (double *)cb->values;
  int64_t len = ca->length < cb->length ? ca->length : cb->length;

  /* Collect complete-case indices. */
  int64_t n = 0;
  for (int64_t i = 0; i < len; i++)
    if (__valid(ca->validity, i) && __valid(cb->validity, i)) n++;
  if (n < 2) return 0.0/0.0;

  __pair_t *pa = (__pair_t *)malloc((size_t)n * sizeof(__pair_t));
  __pair_t *pb = (__pair_t *)malloc((size_t)n * sizeof(__pair_t));
  int64_t k = 0;
  for (int64_t i = 0; i < len; i++)
    if (__valid(ca->validity, i) && __valid(cb->validity, i)) {
      pa[k].val = va[i]; pa[k].idx = k;
      pb[k].val = vb[i]; pb[k].idx = k;
      k++;
    }

  qsort(pa, (size_t)n, sizeof(__pair_t), __cmp_pair);
  qsort(pb, (size_t)n, sizeof(__pair_t), __cmp_pair);

  /* Assign average ranks (handle ties). */
  double *ra = (double *)malloc((size_t)n * sizeof(double));
  double *rb = (double *)malloc((size_t)n * sizeof(double));
  for (int64_t i = 0; i < n; ) {
    int64_t j = i;
    while (j < n && pa[j].val == pa[i].val) j++;
    double avg = (double)(i + j - 1) / 2.0 + 1.0;
    for (int64_t kk = i; kk < j; kk++) ra[pa[kk].idx] = avg;
    i = j;
  }
  for (int64_t i = 0; i < n; ) {
    int64_t j = i;
    while (j < n && pb[j].val == pb[i].val) j++;
    double avg = (double)(i + j - 1) / 2.0 + 1.0;
    for (int64_t kk = i; kk < j; kk++) rb[pb[kk].idx] = avg;
    i = j;
  }

  /* Pearson on ranks. */
  double sa = 0.0, sb2 = 0.0;
  for (int64_t i = 0; i < n; i++) { sa += ra[i]; sb2 += rb[i]; }
  double ma = sa/(double)n, mb = sb2/(double)n;
  double sab = 0.0, ssa = 0.0, ssb = 0.0;
  for (int64_t i = 0; i < n; i++) {
    double da = ra[i]-ma, db = rb[i]-mb;
    sab += da*db; ssa += da*da; ssb += db*db;
  }
  free(pa); free(pb); free(ra); free(rb);
  double denom = sqrt(ssa * ssb);
  return denom == 0.0 ? 0.0/0.0 : sab/denom;
  ```)

;;; cov-matrix -- pairwise covariance matrix over a list of columns.
;;;
;;; Parameters:
;;;   cols  -- cons list of :int  (float64 column handles)
;;;   names -- cons list of :cstr (column names)
;;;
;;; Returns:
;;;   :int  frame with N rows and N+1 columns ("name" + one per input column).
;;;
;;; Since: ST2
(defn cov-matrix [cols : int names : int] : int
  ```c
  return __build_matrix(__cov_cols, cols, names);
  ```)

;;; cor-matrix -- Pearson correlation matrix over a list of columns.
;;;
;;; Parameters:
;;;   cols  -- cons list of :int  (float64 column handles)
;;;   names -- cons list of :cstr (column names)
;;;
;;; Returns:
;;;   :int  frame (N rows, N+1 columns).
;;;
;;; Since: ST2
(defn cor-matrix [cols : int names : int] : int
  ```c
  return __build_matrix(__cor_cols, cols, names);
  ```)

;;; cor-matrix-spearman -- Spearman correlation matrix.
;;;
;;; Parameters:
;;;   cols  -- cons list of :int  (float64 column handles)
;;;   names -- cons list of :cstr
;;;
;;; Returns:
;;;   :int  frame (N rows, N+1 columns).
;;;
;;; Since: ST2
(defn cor-matrix-spearman [cols : int names : int] : int
  ```c
  return __build_matrix(__spear_cols, cols, names);
  ```)

;; ---------------------------------------------------------------------------
;; Frame convenience variants.
;; ---------------------------------------------------------------------------

(defn __frame-numeric-cols [f : int names : int] : int
  ```c
  struct __frame *fr = (struct __frame *)(intptr_t)f;
  struct __schema *sc = (struct __schema *)(intptr_t)fr->schema_ptr;

  /* Walk the names cons list and look up each column. */
  int64_t result = 0;
  /* Build list in reverse then reverse at the end. */
  int64_t tmp = 0;
  for (struct __cons *pn = (struct __cons *)(intptr_t)names; pn;
       pn = (struct __cons *)(intptr_t)pn->next) {
    const char *want = (const char *)(intptr_t)pn->value;
    for (int64_t i = 0; i < sc->arity; i++) {
      const char *fn = (const char *)(intptr_t)sc->fields[i].name_ptr;
      if (fn && strcmp(fn, want) == 0) {
        struct __cons *c = (struct __cons *)malloc(sizeof(struct __cons));
        c->value = fr->columns[i];
        c->next  = tmp;
        tmp      = (int64_t)(intptr_t)c;
        break;
      }
    }
  }
  /* Reverse. */
  for (struct __cons *p = (struct __cons *)(intptr_t)tmp; p; ) {
    struct __cons *next = (struct __cons *)(intptr_t)p->next;
    p->next = result;
    result  = (int64_t)(intptr_t)p;
    p       = next;
  }
  return result;
  ```)

;;; frame-cor -- Pearson correlation matrix for named columns of a frame.
;;;
;;; Parameters:
;;;   f     -- :int  frame handle
;;;   names -- cons list of :cstr  column names
;;;
;;; Returns:
;;;   :int  correlation matrix frame.
;;;
;;; Since: ST2
(defn frame-cor [f : int names : int] : int
  (let [cols (__frame-numeric-cols f names)]
    (cor-matrix cols names)))

;;; frame-cor-spearman -- Spearman correlation matrix for named columns.
;;;
;;; Since: ST2
(defn frame-cor-spearman [f : int names : int] : int
  (let [cols (__frame-numeric-cols f names)]
    (cor-matrix-spearman cols names)))

) ;; end defmodule stats/cov
