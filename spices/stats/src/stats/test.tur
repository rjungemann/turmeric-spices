;; stats/test.tur -- hypothesis tests returning test-result structs.
;;
;; test-result layout (matches defstruct in plan):
;;   name       :cstr
;;   statistic  :float
;;   df1        :float
;;   df2        :float
;;   p-value    :float
;;   alt-tag    :int    0=two-sided 1=less 2=greater
;;   estimate   :float
;;   ci-low     :float
;;   ci-high    :float
;;   conf-level :float
;;
;; test-result is a heap-allocated struct; use test-result-free to free.

(defmodule stats/test
  (export alt-two-sided alt-less alt-greater
          make-test-result
          test-result-name test-result-statistic test-result-df1 test-result-df2
          test-result-p-value test-result-alt-tag test-result-estimate
          test-result-ci-low test-result-ci-high test-result-conf-level
          test-result-free
          t-test-1samp t-test-2samp t-test-paired
          anova-oneway
          chi2-gof chi2-contingency
          var-test cor-test
          mann-whitney wilcoxon-signed-rank
          ks-test-1samp ks-test-2samp)

  (import stats/dist :refer [pt pf-dist pchi2 cdf qt qf-dist qchi2 quantile
                               dist-t dist-f dist-chi2 dist-free])
  (import stats/summary :refer [col-count col-mean col-var col-sd col-median
                                  col-quantile col-min col-max])
  (import stats/cov :refer [cor])

;;; alt-two-sided -- alt-tag constant for two-sided tests.
;;; Since: ST5
(defn alt-two-sided [] : int ```c return 0; ```)

;;; alt-less -- alt-tag constant for one-sided less tests.
;;; Since: ST5
(defn alt-less [] : int ```c return 1; ```)

;;; alt-greater -- alt-tag constant for one-sided greater tests.
;;; Since: ST5
(defn alt-greater [] : int ```c return 2; ```)

;; Internal test-result struct layout.
(defn __tr-alloc [] : int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <math.h>
  typedef struct {
    const char *name; double statistic; double df1; double df2;
    double p_value; int64_t alt_tag; double estimate;
    double ci_low; double ci_high; double conf_level;
  } __test_result_t;
  __test_result_t *r = (__test_result_t *)malloc(sizeof(__test_result_t));
  r->name=""; r->statistic=0.0/0.0; r->df1=0.0/0.0; r->df2=0.0/0.0;
  r->p_value=0.0/0.0; r->alt_tag=0; r->estimate=0.0/0.0;
  r->ci_low=0.0/0.0; r->ci_high=0.0/0.0; r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; make-test-result -- construct a test-result from components.
;;; Since: ST5
(defn make-test-result [name : cstr statistic : float df1 : float df2 : float
                         p-value : float alt-tag : int estimate : float
                         ci-low : float ci-high : float conf-level : float] : int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  typedef struct {
    const char *name; double statistic; double df1; double df2;
    double p_value; int64_t alt_tag; double estimate;
    double ci_low; double ci_high; double conf_level;
  } __test_result_t;
  __test_result_t *r = (__test_result_t *)malloc(sizeof(__test_result_t));
  r->name=(const char *)(intptr_t)name;
  r->statistic=statistic; r->df1=df1; r->df2=df2;
  r->p_value=p_value; r->alt_tag=alt_tag; r->estimate=estimate;
  r->ci_low=ci_low; r->ci_high=ci_high; r->conf_level=conf_level;
  return (int64_t)(intptr_t)r;
  ```)

;;; test-result-free -- free a test-result.
;;; Since: ST5
(defn test-result-free [r : int] : void
  ```c
  #include <stdlib.h>
  free((void *)(intptr_t)r);
  ```)

;; Accessors.
(defn test-result-name       [r : int] : cstr  ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return (int64_t)(intptr_t)((__tr*)(intptr_t)r)->name; ```)
(defn test-result-statistic  [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->s; ```)
(defn test-result-df1        [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->d1; ```)
(defn test-result-df2        [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->d2; ```)
(defn test-result-p-value    [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->pv; ```)
(defn test-result-alt-tag    [r : int] : int   ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->at; ```)
(defn test-result-estimate   [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->e; ```)
(defn test-result-ci-low     [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->cl; ```)
(defn test-result-ci-high    [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->ch; ```)
(defn test-result-conf-level [r : int] : float ```c typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr; return ((__tr*)(intptr_t)r)->cf; ```)

;; ---------------------------------------------------------------------------
;; p-value helpers.
;; p_two_sided(t, df) = 2 * pt(-|t|, df)
;; ---------------------------------------------------------------------------

(defn __p-t-two [t : float df : float] : float
  (let [at (if (< t 0.0) t (- 0.0 t))]
    (* 2.0 (pt at df))))

(defn __p-t-sided [t : float df : float alt : int] : float
  (if (= alt 0) (__p-t-two t df)
    (if (= alt 1) (pt t df)
      (- 1.0 (pt t df)))))

(defn __p-chi2-sided [chi : float df : float alt : int] : float
  (if (= alt 0) (* 2.0 (min (pchi2 chi df) (- 1.0 (pchi2 chi df))))
    (if (= alt 2) (- 1.0 (pchi2 chi df))
      (pchi2 chi df))))

;;; t-test-1samp -- one-sample t-test: is mean(col) == mu?
;;;
;;; Parameters:
;;;   col        -- :int  float64 column
;;;   mu         -- :float  hypothesized mean
;;;   alt-tag    -- :int  (alt-two-sided), (alt-less), or (alt-greater)
;;;   conf-level -- :float  e.g. 0.95
;;;
;;; Returns:
;;;   :int  test-result handle.
;;;
;;; Since: ST5
(defn t-test-1samp [col : int mu : float alt-tag : int conf-level : float] : int
  (let [n    (col-count col)
        xbar (col-mean col)
        s    (col-sd col)
        se   (/ s (sqrt (float n)))
        t    (/ (- xbar mu) se)
        df   (float (- n 1))
        pv   (__p-t-sided t df alt-tag)
        a    (/ (- 1.0 conf-level) 2.0)
        tc   (qt (- 1.0 a) df)
        cilo (- xbar (* tc se))
        cihi (+ xbar (* tc se))]
    (make-test-result "One Sample t-test"
                      t df (nan) pv alt-tag xbar cilo cihi conf-level)))

;;; t-test-2samp -- two-sample t-test (Welch when pooled?=0).
;;;
;;; Parameters:
;;;   a          -- :int  first column
;;;   b          -- :int  second column
;;;   pooled     -- :int  0=Welch, 1=pooled
;;;   alt-tag    -- :int
;;;   conf-level -- :float
;;;
;;; Returns:
;;;   :int  test-result handle.
;;;
;;; Since: ST5
(defn t-test-2samp [a : int b : int pooled : int alt-tag : int conf-level : float] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>
  #include <string.h>

  /* We inline summary and test logic here to avoid inter-defn calls. */
  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static void __col_stats(int64_t ch, double *mean, double *var, int64_t *n) {
    struct __frame_col *c = (struct __frame_col *)(intptr_t)ch;
    double *v = (double *)c->values;
    double s=0.0; *n=0;
    for(int64_t i=0;i<c->length;i++) if(__valid(c->validity,i)){s+=v[i];(*n)++;}
    *mean = *n ? s/(double)*n : 0.0/0.0;
    double ss=0.0;
    for(int64_t i=0;i<c->length;i++) if(__valid(c->validity,i)){double d=v[i]-*mean;ss+=d*d;}
    *var = *n>=2 ? ss/(double)(*n-1) : 0.0/0.0;
  }

  /* pt via regularized incomplete beta. */
  static double __ibeta_t(double x, double aa, double bb) {
    if(x<=0.0)return 0.0;if(x>=1.0)return 1.0;
    int sw=0;if(x>(aa+1.0)/(aa+bb+2.0)){double t=aa;aa=bb;bb=t;x=1.0-x;sw=1;}
    double lb=lgamma(aa)+lgamma(bb)-lgamma(aa+bb);
    double front=exp(aa*log(x)+bb*log(1.0-x)-lb)/aa;
    double fpmin=1e-300,c=1.0,dd=1.0-(aa+bb)*x/(aa+1.0);
    if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double h=dd;
    for(int m=1;m<=200;m++){
      double m2=2.0*(double)m;
      double num=((double)m*(bb-(double)m)*x)/((aa+m2-1.0)*(aa+m2));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;h*=dd*c;
      num=-(aa+(double)m)*(aa+bb+(double)m)*x/((aa+m2)*(aa+m2+1.0));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;double del=dd*c;h*=del;
      if(fabs(del-1.0)<1e-12)break;
    }
    double val=front*h; return sw?1.0-val:val;
  }
  static double __pt(double t, double df) {
    double ib=__ibeta_t(df/(df+t*t),df/2.0,0.5);
    return t>=0.0?1.0-0.5*ib:0.5*ib;
  }
  /* Bisection quantile for t. */
  static double __qt(double p, double df) {
    if(p<=0.0)return -1.0/0.0; if(p>=1.0)return 1.0/0.0;
    double lo=-1e10,hi=1e10;
    for(int i=0;i<200;i++){double m=0.5*(lo+hi);if(__pt(m,df)<p)lo=m;else hi=m;if(hi-lo<1e-12)break;}
    return 0.5*(lo+hi);
  }

  double ma, mb, va, vb; int64_t na, nb;
  __col_stats(a, &ma, &va, &na);
  __col_stats(b, &mb, &vb, &nb);

  double t, df;
  if (!pooled) {
    /* Welch */
    double sea2 = va/(double)na, seb2 = vb/(double)nb;
    double se = sqrt(sea2+seb2);
    t = (ma-mb)/se;
    double num = (sea2+seb2)*(sea2+seb2);
    double den = sea2*sea2/(double)(na-1)+seb2*seb2/(double)(nb-1);
    df = num/den;
  } else {
    /* Pooled */
    double sp2 = ((double)(na-1)*va+(double)(nb-1)*vb)/(double)(na+nb-2);
    double se  = sqrt(sp2*(1.0/(double)na+1.0/(double)nb));
    t  = (ma-mb)/se;
    df = (double)(na+nb-2);
  }

  double pv;
  if (alt_tag==0) { double pt2=__pt(t<0.0?t:-t,df); pv=2.0*pt2; }
  else if (alt_tag==1) pv=__pt(t,df);
  else pv=1.0-__pt(t,df);

  double alpha=(1.0-conf_level)/2.0;
  double tc=__qt(1.0-alpha,df);

  /* SE of difference for CI. */
  double se_diff;
  if (!pooled) se_diff=sqrt(va/(double)na+vb/(double)nb);
  else { double sp2=((double)(na-1)*va+(double)(nb-1)*vb)/(double)(na+nb-2);
         se_diff=sqrt(sp2*(1.0/(double)na+1.0/(double)nb)); }

  typedef struct {
    const char *name; double statistic; double df1; double df2;
    double p_value; int64_t alt_tag; double estimate;
    double ci_low; double ci_high; double conf_level;
  } __test_result_t;
  __test_result_t *r = (__test_result_t *)malloc(sizeof(__test_result_t));
  r->name     = pooled ? "Two Sample t-test" : "Welch Two Sample t-test";
  r->statistic = t; r->df1=df; r->df2=0.0/0.0; r->p_value=pv;
  r->alt_tag=alt_tag; r->estimate=ma-mb;
  r->ci_low=(ma-mb)-tc*se_diff; r->ci_high=(ma-mb)+tc*se_diff;
  r->conf_level=conf_level;
  return (int64_t)(intptr_t)r;
  ```)

;;; t-test-paired -- paired t-test.
;;;
;;; Parameters:
;;;   a          -- :int  column of first observations
;;;   b          -- :int  column of second (same length as a)
;;;   alt-tag    -- :int
;;;   conf-level -- :float
;;;
;;; Returns:
;;;   :int  test-result handle.
;;;
;;; Since: ST5
(defn t-test-paired [a : int b : int alt-tag : int conf-level : float] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static double __ibeta_p(double x, double aa, double bb) {
    if(x<=0.0)return 0.0;if(x>=1.0)return 1.0;
    int sw=0;if(x>(aa+1.0)/(aa+bb+2.0)){double t=aa;aa=bb;bb=t;x=1.0-x;sw=1;}
    double lb=lgamma(aa)+lgamma(bb)-lgamma(aa+bb);
    double front=exp(aa*log(x)+bb*log(1.0-x)-lb)/aa;
    double fpmin=1e-300,c=1.0,dd=1.0-(aa+bb)*x/(aa+1.0);
    if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double h=dd;
    for(int m=1;m<=200;m++){
      double m2=2.0*(double)m;
      double num=((double)m*(bb-(double)m)*x)/((aa+m2-1.0)*(aa+m2));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;h*=dd*c;
      num=-(aa+(double)m)*(aa+bb+(double)m)*x/((aa+m2)*(aa+m2+1.0));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;double del=dd*c;h*=del;
      if(fabs(del-1.0)<1e-12)break;
    }
    double val=front*h;return sw?1.0-val:val;
  }
  static double __pt_p(double t, double df){double ib=__ibeta_p(df/(df+t*t),df/2.0,0.5);return t>=0.0?1.0-0.5*ib:0.5*ib;}
  static double __qt_p(double p, double df){
    if(p<=0.0)return -1.0/0.0;if(p>=1.0)return 1.0/0.0;
    double lo=-1e10,hi=1e10;
    for(int i=0;i<200;i++){double m=0.5*(lo+hi);if(__pt_p(m,df)<p)lo=m;else hi=m;if(hi-lo<1e-12)break;}
    return 0.5*(lo+hi);
  }

  struct __frame_col *ca=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)b;
  double *va=(double *)ca->values, *vb=(double *)cb->values;
  int64_t len=ca->length<cb->length?ca->length:cb->length;

  /* Build difference column. */
  double sum=0.0; int64_t n=0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)){sum+=va[i]-vb[i];n++;}
  double mean=n?sum/(double)n:0.0/0.0;
  double ss=0.0;
  for(int64_t i=0;i<len;i++)
    if(__valid(ca->validity,i)&&__valid(cb->validity,i)){double d=(va[i]-vb[i])-mean;ss+=d*d;}
  double sd=n>=2?sqrt(ss/(double)(n-1)):0.0/0.0;
  double se=sd/sqrt((double)n);
  double t=mean/se;
  double df=(double)(n-1);
  double pv;
  if(alt_tag==0){double pt2=__pt_p(t<0.0?t:-t,df);pv=2.0*pt2;}
  else if(alt_tag==1)pv=__pt_p(t,df);
  else pv=1.0-__pt_p(t,df);

  double alpha=(1.0-conf_level)/2.0;
  double tc=__qt_p(1.0-alpha,df);

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="Paired t-test";r->statistic=t;r->df1=df;r->df2=0.0/0.0;r->p_value=pv;
  r->alt_tag=alt_tag;r->estimate=mean;r->ci_low=mean-tc*se;r->ci_high=mean+tc*se;r->conf_level=conf_level;
  return (int64_t)(intptr_t)r;
  ```)

;;; var-test -- F-test for equality of variances.
;;;
;;; Parameters:
;;;   a b alt-tag conf-level
;;;
;;; Returns:
;;;   :int test-result with statistic=F, df1=na-1, df2=nb-1.
;;;
;;; Since: ST5
(defn var-test [a : int b : int alt-tag : int conf-level : float] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }

  /* ibeta for F CDF. */
  static double __ibeta_f(double x,double aa,double bb){
    if(x<=0.0)return 0.0;if(x>=1.0)return 1.0;
    int sw=0;if(x>(aa+1.0)/(aa+bb+2.0)){double t=aa;aa=bb;bb=t;x=1.0-x;sw=1;}
    double lb=lgamma(aa)+lgamma(bb)-lgamma(aa+bb);
    double front=exp(aa*log(x)+bb*log(1.0-x)-lb)/aa;
    double fpmin=1e-300,c=1.0,dd=1.0-(aa+bb)*x/(aa+1.0);
    if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double h=dd;
    for(int m=1;m<=200;m++){
      double m2=2.0*(double)m;
      double num=((double)m*(bb-(double)m)*x)/((aa+m2-1.0)*(aa+m2));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;h*=dd*c;
      num=-(aa+(double)m)*(aa+bb+(double)m)*x/((aa+m2)*(aa+m2+1.0));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;double del=dd*c;h*=del;
      if(fabs(del-1.0)<1e-12)break;
    }
    double val=front*h;return sw?1.0-val:val;
  }
  static double __pf(double x,double d1,double d2){return x<=0.0?0.0:__ibeta_f(d1*x/(d1*x+d2),d1/2.0,d2/2.0);}
  static double __qf(double p,double d1,double d2){
    double lo=0.0,hi=1e10;
    for(int i=0;i<200;i++){double m=0.5*(lo+hi);if(__pf(m,d1,d2)<p)lo=m;else hi=m;if(hi-lo<1e-12)break;}
    return 0.5*(lo+hi);
  }

  struct __frame_col *ca=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)b;
  double *va2=(double *)ca->values,*vb2=(double *)cb->values;
  int64_t na=0,nb=0; double sa=0.0,sb=0.0;
  for(int64_t i=0;i<ca->length;i++) if(__valid(ca->validity,i)){sa+=va2[i];na++;}
  for(int64_t i=0;i<cb->length;i++) if(__valid(cb->validity,i)){sb+=vb2[i];nb++;}
  double ma=na?sa/(double)na:0.0/0.0,mb=nb?sb/(double)nb:0.0/0.0;
  double ssa=0.0,ssb=0.0;
  for(int64_t i=0;i<ca->length;i++) if(__valid(ca->validity,i)){double d=va2[i]-ma;ssa+=d*d;}
  for(int64_t i=0;i<cb->length;i++) if(__valid(cb->validity,i)){double d=vb2[i]-mb;ssb+=d*d;}
  double vara=na>=2?ssa/(double)(na-1):0.0/0.0;
  double varb=nb>=2?ssb/(double)(nb-1):0.0/0.0;
  double F=vara/varb;
  double df1=(double)(na-1),df2=(double)(nb-1);
  double pf_val=__pf(F,df1,df2);
  double pv;
  if(alt_tag==0)pv=2.0*(pf_val<0.5?pf_val:1.0-pf_val);
  else if(alt_tag==2)pv=1.0-pf_val;
  else pv=pf_val;

  double alpha=(1.0-conf_level)/2.0;
  double cilo=F/__qf(1.0-alpha,df1,df2);
  double cihi=F*__qf(1.0-alpha,df2,df1);

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="F test to compare two variances";r->statistic=F;r->df1=df1;r->df2=df2;r->p_value=pv;
  r->alt_tag=alt_tag;r->estimate=F;r->ci_low=cilo;r->ci_high=cihi;r->conf_level=conf_level;
  return (int64_t)(intptr_t)r;
  ```)

;;; cor-test -- Pearson correlation test.
;;;
;;; Parameters:
;;;   a b alt-tag conf-level
;;;
;;; Returns:
;;;   :int test-result with estimate=r, statistic=t.
;;;
;;; Since: ST5
(defn cor-test [a : int b : int alt-tag : int conf-level : float] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static double __ibeta_c(double x,double aa,double bb){
    if(x<=0.0)return 0.0;if(x>=1.0)return 1.0;
    int sw=0;if(x>(aa+1.0)/(aa+bb+2.0)){double t=aa;aa=bb;bb=t;x=1.0-x;sw=1;}
    double lb=lgamma(aa)+lgamma(bb)-lgamma(aa+bb);
    double front=exp(aa*log(x)+bb*log(1.0-x)-lb)/aa;
    double fpmin=1e-300,c=1.0,dd=1.0-(aa+bb)*x/(aa+1.0);
    if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double h=dd;
    for(int m=1;m<=200;m++){
      double m2=2.0*(double)m;
      double num=((double)m*(bb-(double)m)*x)/((aa+m2-1.0)*(aa+m2));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;h*=dd*c;
      num=-(aa+(double)m)*(aa+bb+(double)m)*x/((aa+m2)*(aa+m2+1.0));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;double del=dd*c;h*=del;
      if(fabs(del-1.0)<1e-12)break;
    }
    double val=front*h;return sw?1.0-val:val;
  }
  static double __pt_c(double t,double df){double ib=__ibeta_c(df/(df+t*t),df/2.0,0.5);return t>=0.0?1.0-0.5*ib:0.5*ib;}
  static double __qt_c(double p,double df){
    double lo=-1e10,hi=1e10;
    for(int i=0;i<200;i++){double m=0.5*(lo+hi);if(__pt_c(m,df)<p)lo=m;else hi=m;if(hi-lo<1e-12)break;}
    return 0.5*(lo+hi);
  }

  struct __frame_col *ca=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)b;
  double *va=(double *)ca->values,*vb=(double *)cb->values;
  int64_t len=ca->length<cb->length?ca->length:cb->length;
  double sa=0.0,sb=0.0; int64_t n=0;
  for(int64_t i=0;i<len;i++) if(__valid(ca->validity,i)&&__valid(cb->validity,i)){sa+=va[i];sb+=vb[i];n++;}
  if(n<3){typedef struct{const char*name;double s,d1,d2,pv;int64_t at;double e,cl,ch,cf;}__tr;__tr*r=(__tr*)malloc(sizeof(__tr));r->name="Pearson's product-moment correlation";r->s=0.0/0.0;r->d1=(double)(n-2);r->d2=0.0/0.0;r->pv=0.0/0.0;r->at=alt_tag;r->e=0.0/0.0;r->cl=0.0/0.0;r->ch=0.0/0.0;r->cf=conf_level;return(int64_t)(intptr_t)r;}
  double ma=sa/(double)n,mb=sb/(double)n,sab=0.0,ssa=0.0,ssb=0.0;
  for(int64_t i=0;i<len;i++) if(__valid(ca->validity,i)&&__valid(cb->validity,i)){double da=va[i]-ma,db=vb[i]-mb;sab+=da*db;ssa+=da*da;ssb+=db*db;}
  double r_val=sab/sqrt(ssa*ssb);
  double t=r_val*sqrt((double)(n-2)/(1.0-r_val*r_val));
  double df=(double)(n-2);
  double pv;
  if(alt_tag==0){double pt2=__pt_c(t<0.0?t:-t,df);pv=2.0*pt2;}
  else if(alt_tag==1)pv=__pt_c(t,df);
  else pv=1.0-__pt_c(t,df);

  /* Fisher z CI for r. */
  double z=0.5*log((1.0+r_val)/(1.0-r_val));
  double se_z=1.0/sqrt((double)(n-3));
  /* Use normal approx for CI on z, then transform back. */
  double z_crit=1.959963985; /* qnorm(0.975) */
  if(conf_level!=0.95){ double alpha=(1.0-conf_level)/2.0;z_crit=__qt_c(1.0-alpha,(double)(n-3)); }
  double zlo=z-z_crit*se_z,zhi=z+z_crit*se_z;
  double rlo=tanh(zlo),rhi=tanh(zhi);

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *res=(__tr *)malloc(sizeof(__tr));
  res->name="Pearson's product-moment correlation";res->statistic=t;res->df1=df;res->df2=0.0/0.0;
  res->p_value=pv;res->alt_tag=alt_tag;res->estimate=r_val;res->ci_low=rlo;res->ci_high=rhi;res->conf_level=conf_level;
  return (int64_t)(intptr_t)res;
  ```)

;;; anova-oneway -- one-way ANOVA on a list of group columns.
;;;
;;; Parameters:
;;;   cols -- cons list of :int  (float64 columns, one per group)
;;;
;;; Returns:
;;;   :int  test-result with statistic=F, df1=k-1, df2=N-k.
;;;
;;; Since: ST6
(defn anova-oneway [cols : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __cons { int64_t value; int64_t next; };
  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static double __ibeta_a(double x,double aa,double bb){
    if(x<=0.0)return 0.0;if(x>=1.0)return 1.0;
    int sw=0;if(x>(aa+1.0)/(aa+bb+2.0)){double t=aa;aa=bb;bb=t;x=1.0-x;sw=1;}
    double lb=lgamma(aa)+lgamma(bb)-lgamma(aa+bb);
    double front=exp(aa*log(x)+bb*log(1.0-x)-lb)/aa;
    double fpmin=1e-300,c=1.0,dd=1.0-(aa+bb)*x/(aa+1.0);
    if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double h=dd;
    for(int m=1;m<=200;m++){
      double m2=2.0*(double)m;
      double num=((double)m*(bb-(double)m)*x)/((aa+m2-1.0)*(aa+m2));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;h*=dd*c;
      num=-(aa+(double)m)*(aa+bb+(double)m)*x/((aa+m2)*(aa+m2+1.0));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;double del=dd*c;h*=del;
      if(fabs(del-1.0)<1e-12)break;
    }
    double val=front*h;return sw?1.0-val:val;
  }
  static double __pf_a(double x,double d1,double d2){return x<=0.0?0.0:__ibeta_a(d1*x/(d1*x+d2),d1/2.0,d2/2.0);}

  /* Count groups and collect stats. */
  int64_t k=0;
  for(struct __cons *p=(struct __cons *)(intptr_t)cols;p;p=(struct __cons *)(intptr_t)p->next) k++;

  double *group_means=(double *)malloc((size_t)k*sizeof(double));
  int64_t *group_ns=(int64_t *)malloc((size_t)k*sizeof(int64_t));
  int64_t N=0; double grand_sum=0.0;

  { int64_t j=0;
    for(struct __cons *p=(struct __cons *)(intptr_t)cols;p;p=(struct __cons *)(intptr_t)p->next,j++){
      struct __frame_col *c=(struct __frame_col *)(intptr_t)p->value;
      double *v=(double *)c->values; double s=0.0; int64_t n=0;
      for(int64_t i=0;i<c->length;i++) if(__valid(c->validity,i)){s+=v[i];n++;}
      group_means[j]=n?s/(double)n:0.0/0.0; group_ns[j]=n; N+=n; grand_sum+=s;
    }
  }
  double grand_mean=N?grand_sum/(double)N:0.0/0.0;

  /* SSB: sum of ni*(mean_i - grand_mean)^2 */
  double SSB=0.0;
  { int64_t j=0;
    for(struct __cons *p=(struct __cons *)(intptr_t)cols;p;p=(struct __cons *)(intptr_t)p->next,j++){
      double d=group_means[j]-grand_mean; SSB+=group_ns[j]*d*d;
    }
  }
  /* SSW: sum of (xi - mean_i)^2 */
  double SSW=0.0;
  { int64_t j=0;
    for(struct __cons *p=(struct __cons *)(intptr_t)cols;p;p=(struct __cons *)(intptr_t)p->next,j++){
      struct __frame_col *c=(struct __frame_col *)(intptr_t)p->value;
      double *v=(double *)c->values;
      for(int64_t i=0;i<c->length;i++) if(__valid(c->validity,i)){double d=v[i]-group_means[j];SSW+=d*d;}
    }
  }

  double df1=(double)(k-1),df2=(double)(N-k);
  double MSB=SSB/df1,MSW=SSW/df2;
  double F=MSB/MSW;
  double pv=1.0-__pf_a(F,df1,df2);

  free(group_means);free(group_ns);

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="One-way ANOVA";r->statistic=F;r->df1=df1;r->df2=df2;r->p_value=pv;
  r->alt_tag=2;r->estimate=0.0/0.0;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; chi2-gof -- chi-squared goodness-of-fit test.
;;;
;;; Parameters:
;;;   observed -- :int  column of observed counts
;;;   expected -- :int  column of expected counts (same length)
;;;
;;; Returns:
;;;   :int  test-result with statistic=chi^2, df=k-1.
;;;
;;; Since: ST6
(defn chi2-gof [observed : int expected : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static double __igamma_g(double a, double x) {
    if(x<=0.0)return 0.0;
    if(x>a+1.0){double fpmin=1e-300,b=x+1.0-a,c=1.0/fpmin,dd=1.0/b,h=dd;
      for(int i=1;i<=200;i++){double an=-(double)i*((double)i-a);b+=2.0;c=b+an/c;if(fabs(c)<fpmin)c=fpmin;dd=b+an*dd;if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double del=dd*c;h*=del;if(fabs(del-1.0)<1e-12)break;}
      return 1.0-exp(-x+a*log(x)-lgamma(a))*h;}
    double ap=a,sum=1.0/a,del=sum;
    for(int i=0;i<200;i++){ap++;del*=x/ap;sum+=del;if(fabs(del)<fabs(sum)*1e-12)break;}
    return sum*exp(-x+a*log(x)-lgamma(a));
  }

  struct __frame_col *co=(struct __frame_col *)(intptr_t)observed;
  struct __frame_col *ce=(struct __frame_col *)(intptr_t)expected;
  double *vo=(double *)co->values, *ve=(double *)ce->values;
  int64_t k=co->length<ce->length?co->length:ce->length;
  double chi2=0.0; int64_t df=0;
  for(int64_t i=0;i<k;i++){
    if(__valid(co->validity,i)&&__valid(ce->validity,i)&&ve[i]>0.0){
      double d=vo[i]-ve[i]; chi2+=d*d/ve[i]; df++;
    }
  }
  df--; /* df = k-1 */
  double pv=1.0-__igamma_g((double)df/2.0,chi2/2.0);

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="Chi-squared goodness-of-fit test";r->statistic=chi2;r->df1=(double)df;r->df2=0.0/0.0;
  r->p_value=pv;r->alt_tag=2;r->estimate=0.0/0.0;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; chi2-contingency -- chi-squared test of independence on a contingency frame.
;;;
;;; Parameters:
;;;   f -- :int  frame where each column is one category and each row is
;;;              another; cell values are counts (float64).
;;;
;;; Returns:
;;;   :int  test-result.
;;;
;;; Since: ST6
(defn chi2-contingency [f : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  struct __schema { int64_t arity; int64_t *fields_ptr; };
  struct __frame {
    int64_t nrows; int64_t ncols; int64_t schema_ptr; int64_t *columns;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static double __igamma_ct(double a, double x) {
    if(x<=0.0)return 0.0;
    if(x>a+1.0){double fpmin=1e-300,b=x+1.0-a,c=1.0/fpmin,dd=1.0/b,h=dd;
      for(int i=1;i<=200;i++){double an=-(double)i*((double)i-a);b+=2.0;c=b+an/c;if(fabs(c)<fpmin)c=fpmin;dd=b+an*dd;if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double del=dd*c;h*=del;if(fabs(del-1.0)<1e-12)break;}
      return 1.0-exp(-x+a*log(x)-lgamma(a))*h;}
    double ap=a,sum=1.0/a,del=sum;
    for(int i=0;i<200;i++){ap++;del*=x/ap;sum+=del;if(fabs(del)<fabs(sum)*1e-12)break;}
    return sum*exp(-x+a*log(x)-lgamma(a));
  }

  struct __frame *fr=(struct __frame *)(intptr_t)f;
  int64_t nrows=fr->nrows, ncols=fr->ncols;

  /* Row and column sums. */
  double *row_sums=(double *)calloc((size_t)nrows,sizeof(double));
  double *col_sums=(double *)calloc((size_t)ncols,sizeof(double));
  double grand=0.0;
  for(int64_t j=0;j<ncols;j++){
    struct __frame_col *c=(struct __frame_col *)(intptr_t)fr->columns[j];
    double *v=(double *)c->values;
    for(int64_t i=0;i<nrows;i++) if(__valid(c->validity,i)){
      row_sums[i]+=v[i]; col_sums[j]+=v[i]; grand+=v[i];
    }
  }

  double chi2=0.0;
  for(int64_t j=0;j<ncols;j++){
    struct __frame_col *c=(struct __frame_col *)(intptr_t)fr->columns[j];
    double *v=(double *)c->values;
    for(int64_t i=0;i<nrows;i++) if(__valid(c->validity,i)&&grand>0.0){
      double expected=row_sums[i]*col_sums[j]/grand;
      if(expected>0.0){double d=v[i]-expected;chi2+=d*d/expected;}
    }
  }
  free(row_sums);free(col_sums);

  double df=(double)((nrows-1)*(ncols-1));
  double pv=1.0-__igamma_ct(df/2.0,chi2/2.0);

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="Pearson's Chi-squared test";r->statistic=chi2;r->df1=df;r->df2=0.0/0.0;
  r->p_value=pv;r->alt_tag=2;r->estimate=0.0/0.0;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; mann-whitney -- Mann-Whitney U rank-sum test.
;;;
;;; Parameters:
;;;   a b alt-tag
;;;
;;; Returns:
;;;   :int  test-result with statistic=U.
;;;
;;; Since: ST6
(defn mann-whitney [a : int b : int alt-tag : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }

  struct __frame_col *ca=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)b;
  double *va=(double *)ca->values,*vb=(double *)cb->values;
  int64_t na=0,nb=0;
  for(int64_t i=0;i<ca->length;i++) if(__valid(ca->validity,i)) na++;
  for(int64_t i=0;i<cb->length;i++) if(__valid(cb->validity,i)) nb++;

  /* Merge and rank. */
  typedef struct{double val;int group;} __ob;
  __ob *obs=(__ob *)malloc((size_t)(na+nb)*sizeof(__ob));
  int64_t k=0;
  for(int64_t i=0;i<ca->length;i++) if(__valid(ca->validity,i)){obs[k].val=va[i];obs[k].group=0;k++;}
  for(int64_t i=0;i<cb->length;i++) if(__valid(cb->validity,i)){obs[k].val=vb[i];obs[k].group=1;k++;}
  int64_t N=na+nb;
  /* Sort by value. */
  for(int64_t i=0;i<N-1;i++) for(int64_t j=i+1;j<N;j++) if(obs[j].val<obs[i].val){__ob t=obs[i];obs[i]=obs[j];obs[j]=t;}
  /* Assign average ranks. */
  double *ranks=(double *)malloc((size_t)N*sizeof(double));
  for(int64_t i=0;i<N;){
    int64_t j=i;while(j<N&&obs[j].val==obs[i].val)j++;
    double avg=(double)(i+j-1)/2.0+1.0;
    for(int64_t kk=i;kk<j;kk++) ranks[kk]=avg; i=j;
  }
  double Ra=0.0;
  for(int64_t i=0;i<N;i++) if(obs[i].group==0) Ra+=ranks[i];
  free(obs);free(ranks);

  double U=Ra-(double)na*(double)(na+1)/2.0;
  double mu_U=(double)na*(double)nb/2.0;
  double sigma_U=sqrt((double)na*(double)nb*((double)(na+nb)+1.0)/12.0);
  double z=(U-mu_U)/sigma_U;
  /* Normal approx p-value. */
  double pv;
  if(alt_tag==0) pv=2.0*(0.5*(1.0+erf((z<0.0?z:-z)/1.41421356237309504880)));
  else if(alt_tag==1) pv=0.5*(1.0+erf(z/1.41421356237309504880));
  else pv=1.0-0.5*(1.0+erf(z/1.41421356237309504880));

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="Wilcoxon rank sum test (Mann-Whitney U)";r->statistic=U;r->df1=0.0/0.0;r->df2=0.0/0.0;
  r->p_value=pv;r->alt_tag=alt_tag;r->estimate=U;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; wilcoxon-signed-rank -- Wilcoxon signed-rank test on paired observations.
;;;
;;; Parameters:
;;;   a b alt-tag
;;;
;;; Returns:
;;;   :int  test-result with statistic=W.
;;;
;;; Since: ST6
(defn wilcoxon-signed-rank [a : int b : int alt-tag : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }

  struct __frame_col *ca=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)b;
  double *va=(double *)ca->values,*vb=(double *)cb->values;
  int64_t len=ca->length<cb->length?ca->length:cb->length;

  /* Build differences, drop zeros. */
  typedef struct{double abs_d;int sign;} __dif;
  __dif *diffs=(__dif *)malloc((size_t)len*sizeof(__dif));
  int64_t n=0;
  for(int64_t i=0;i<len;i++) if(__valid(ca->validity,i)&&__valid(cb->validity,i)){
    double d=va[i]-vb[i];
    if(d!=0.0){diffs[n].abs_d=fabs(d);diffs[n].sign=d>0.0?1:-1;n++;}
  }
  /* Sort by abs_d. */
  for(int64_t i=0;i<n-1;i++) for(int64_t j=i+1;j<n;j++) if(diffs[j].abs_d<diffs[i].abs_d){__dif t=diffs[i];diffs[i]=diffs[j];diffs[j]=t;}
  /* Assign average ranks. */
  double *ranks=(double *)malloc((size_t)n*sizeof(double));
  for(int64_t i=0;i<n;){
    int64_t j=i;while(j<n&&diffs[j].abs_d==diffs[i].abs_d)j++;
    double avg=(double)(i+j-1)/2.0+1.0;
    for(int64_t kk=i;kk<j;kk++) ranks[kk]=avg; i=j;
  }
  double Wp=0.0;
  for(int64_t i=0;i<n;i++) if(diffs[i].sign>0) Wp+=ranks[i];
  free(diffs);free(ranks);

  double mu_W=(double)n*(double)(n+1)/4.0;
  double sigma_W=sqrt((double)n*(double)(n+1)*(double)(2*n+1)/24.0);
  double z=(Wp-mu_W)/sigma_W;
  double pv;
  if(alt_tag==0) pv=2.0*(0.5*(1.0+erf((z<0.0?z:-z)/1.41421356237309504880)));
  else if(alt_tag==1) pv=0.5*(1.0+erf(z/1.41421356237309504880));
  else pv=1.0-0.5*(1.0+erf(z/1.41421356237309504880));

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="Wilcoxon signed rank test";r->statistic=Wp;r->df1=0.0/0.0;r->df2=0.0/0.0;
  r->p_value=pv;r->alt_tag=alt_tag;r->estimate=Wp;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; ks-test-1samp -- one-sample Kolmogorov-Smirnov test against a continuous distribution.
;;;
;;; Parameters:
;;;   col     -- :int  float64 column
;;;   d-dist  -- :int  distribution handle (from stats/dist)
;;;   alt-tag -- :int
;;;
;;; Returns:
;;;   :int  test-result with statistic=D.
;;;
;;; Since: ST6
(defn ks-test-1samp [col : int d-dist : int alt-tag : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static int __cmp_dbl(const void *a, const void *b) {
    double x=*(const double *)a,y=*(const double *)b; return (x>y)-(x<y);
  }

  /* We call the cdf function via the Turmeric interpreter is not possible here;
     instead we inline the logic for the distribution types we support.
     For a one-sample KS test the caller is expected to pass a dist handle
     from stats/dist; we read its tag and parameters. */
  typedef struct { int64_t tag; double p1, p2; int64_t ip1; } __dist_t;
  __dist_t *dist = (__dist_t *)(intptr_t)d_dist;

  struct __frame_col *c=(struct __frame_col *)(intptr_t)col;
  double *v=(double *)c->values;
  int64_t n=0;
  for(int64_t i=0;i<c->length;i++) if(__valid(c->validity,i)) n++;
  if(!n){
    typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
    __tr *r=(__tr *)malloc(sizeof(__tr));
    r->name="One-sample Kolmogorov-Smirnov test";r->statistic=0.0/0.0;r->df1=0.0/0.0;r->df2=0.0/0.0;
    r->p_value=0.0/0.0;r->alt_tag=alt_tag;r->estimate=0.0/0.0;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
    return (int64_t)(intptr_t)r;
  }

  double *tmp=(double *)malloc((size_t)n*sizeof(double));
  int64_t k=0;
  for(int64_t i=0;i<c->length;i++) if(__valid(c->validity,i)) tmp[k++]=v[i];
  qsort(tmp,(size_t)n,sizeof(double),__cmp_dbl);

  /* CDF inline for normal only (common case); others use bisection on ibeta/igamma. */
  #define DIST_NORMAL  1
  #define DIST_UNIFORM 5
  #define DIST_EXP     8

  static double __ibeta_ks(double x,double aa,double bb){
    if(x<=0.0)return 0.0;if(x>=1.0)return 1.0;
    int sw=0;if(x>(aa+1.0)/(aa+bb+2.0)){double t=aa;aa=bb;bb=t;x=1.0-x;sw=1;}
    double lb=lgamma(aa)+lgamma(bb)-lgamma(aa+bb);
    double front=exp(aa*log(x)+bb*log(1.0-x)-lb)/aa;
    double fpmin=1e-300,c=1.0,dd=1.0-(aa+bb)*x/(aa+1.0);
    if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double h=dd;
    for(int m=1;m<=200;m++){
      double m2=2.0*(double)m;
      double num=((double)m*(bb-(double)m)*x)/((aa+m2-1.0)*(aa+m2));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;h*=dd*c;
      num=-(aa+(double)m)*(aa+bb+(double)m)*x/((aa+m2)*(aa+m2+1.0));
      dd=1.0+num*dd;if(fabs(dd)<fpmin)dd=fpmin;c=1.0+num/c;if(fabs(c)<fpmin)c=fpmin;dd=1.0/dd;double del=dd*c;h*=del;
      if(fabs(del-1.0)<1e-12)break;
    }
    double val=front*h;return sw?1.0-val:val;
  }
  static double __igamma_ks(double a,double x){
    if(x<=0.0)return 0.0;
    if(x>a+1.0){double fpmin=1e-300,b=x+1.0-a,c=1.0/fpmin,dd=1.0/b,h=dd;
      for(int i=1;i<=200;i++){double an=-(double)i*((double)i-a);b+=2.0;c=b+an/c;if(fabs(c)<fpmin)c=fpmin;dd=b+an*dd;if(fabs(dd)<fpmin)dd=fpmin;dd=1.0/dd;double del=dd*c;h*=del;if(fabs(del-1.0)<1e-12)break;}
      return 1.0-exp(-x+a*log(x)-lgamma(a))*h;}
    double ap=a,sum=1.0/a,del=sum;
    for(int i=0;i<200;i++){ap++;del*=x/ap;sum+=del;if(fabs(del)<fabs(sum)*1e-12)break;}
    return sum*exp(-x+a*log(x)-lgamma(a));
  }

  double cdf_ks(double xv){
    switch(dist->tag){
      case 1: {double z=(xv-dist->p1)/(dist->p2*1.41421356237309504880);return 0.5*(1.0+erf(z));}
      case 2: {double vv=dist->p1,ib=__ibeta_ks(vv/(vv+xv*xv),vv/2.0,0.5);return xv>=0.0?1.0-0.5*ib:0.5*ib;}
      case 3: return __igamma_ks(dist->p1/2.0,xv/2.0);
      case 4: {double d1=dist->p1,d2=dist->p2;return xv<=0.0?0.0:__ibeta_ks(d1*xv/(d1*xv+d2),d1/2.0,d2/2.0);}
      case 5: {double aa=dist->p1,bb=dist->p2;if(xv<=aa)return 0.0;if(xv>=bb)return 1.0;return(xv-aa)/(bb-aa);}
      case 8: return xv<=0.0?0.0:1.0-exp(-dist->p1*xv);
      case 9: return __ibeta_ks(xv,dist->p1,dist->p2);
      case 10: return __igamma_ks(dist->p1,dist->p2*xv);
      default: return 0.0/0.0;
    }
  }

  double D=0.0;
  for(int64_t i=0;i<n;i++){
    double Fn_hi=(double)(i+1)/(double)n;
    double Fn_lo=(double)i/(double)n;
    double Fx=cdf_ks(tmp[i]);
    double d_hi=fabs(Fn_hi-Fx), d_lo=fabs(Fn_lo-Fx);
    double d=d_hi>d_lo?d_hi:d_lo;
    if(d>D)D=d;
  }
  free(tmp);

  /* Kolmogorov distribution p-value (asymptotic). */
  double sqrtN=sqrt((double)n);
  double z=sqrtN*D;
  double pv=0.0;
  for(int j=1;j<=100;j++){
    double sign=j%2==0?-1.0:1.0;
    pv+=sign*exp(-2.0*(double)j*(double)j*z*z);
  }
  pv=2.0*pv; if(pv<0.0)pv=0.0; if(pv>1.0)pv=1.0;

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="One-sample Kolmogorov-Smirnov test";r->statistic=D;r->df1=0.0/0.0;r->df2=0.0/0.0;
  r->p_value=pv;r->alt_tag=alt_tag;r->estimate=D;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

;;; ks-test-2samp -- two-sample Kolmogorov-Smirnov test.
;;;
;;; Parameters:
;;;   a b alt-tag
;;;
;;; Returns:
;;;   :int  test-result with statistic=D.
;;;
;;; Since: ST6
(defn ks-test-2samp [a : int b : int alt-tag : int] : int
  ```c
  #include <stdint.h>
  #include <math.h>
  #include <stdlib.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  static inline int __valid(void *validity, int64_t i) {
    if (!validity) return 1;
    uint8_t *bm = (uint8_t *)validity;
    return (bm[i >> 3] >> (i & 7)) & 1;
  }
  static int __cmp_dbl(const void *a, const void *b) {
    double x=*(const double *)a,y=*(const double *)b; return (x>y)-(x<y);
  }

  struct __frame_col *ca=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *cb=(struct __frame_col *)(intptr_t)b;
  int64_t na=0,nb=0;
  for(int64_t i=0;i<ca->length;i++) if(__valid(ca->validity,i)) na++;
  for(int64_t i=0;i<cb->length;i++) if(__valid(cb->validity,i)) nb++;

  double *ta=(double *)malloc((size_t)na*sizeof(double));
  double *tb=(double *)malloc((size_t)nb*sizeof(double));
  int64_t ka=0,kb=0;
  for(int64_t i=0;i<ca->length;i++) if(__valid(ca->validity,i)) ta[ka++]=((double *)ca->values)[i];
  for(int64_t i=0;i<cb->length;i++) if(__valid(cb->validity,i)) tb[kb++]=((double *)cb->values)[i];
  qsort(ta,(size_t)na,sizeof(double),__cmp_dbl);
  qsort(tb,(size_t)nb,sizeof(double),__cmp_dbl);

  double D=0.0; int64_t ia=0,ib=0;
  while(ia<na&&ib<nb){
    double xa=ta[ia],xb=tb[ib];
    double x=xa<xb?xa:xb;
    /* Advance both past x. */
    while(ia<na&&ta[ia]<=x)ia++;
    while(ib<nb&&tb[ib]<=x)ib++;
    double d=fabs((double)ia/(double)na-(double)ib/(double)nb);
    if(d>D)D=d;
  }
  free(ta);free(tb);

  double en=sqrt((double)(na*nb)/(double)(na+nb));
  double z=(en+0.12+0.11/en)*D;
  double pv=0.0;
  for(int j=1;j<=100;j++){
    double sign=j%2==0?-1.0:1.0;
    pv+=sign*exp(-2.0*(double)j*(double)j*z*z);
  }
  pv=2.0*pv; if(pv<0.0)pv=0.0; if(pv>1.0)pv=1.0;

  typedef struct{const char*name;double statistic,df1,df2,p_value;int64_t alt_tag;double estimate,ci_low,ci_high,conf_level;}__tr;
  __tr *r=(__tr *)malloc(sizeof(__tr));
  r->name="Two-sample Kolmogorov-Smirnov test";r->statistic=D;r->df1=0.0/0.0;r->df2=0.0/0.0;
  r->p_value=pv;r->alt_tag=alt_tag;r->estimate=D;r->ci_low=0.0/0.0;r->ci_high=0.0/0.0;r->conf_level=0.95;
  return (int64_t)(intptr_t)r;
  ```)

) ;; end defmodule stats/test
