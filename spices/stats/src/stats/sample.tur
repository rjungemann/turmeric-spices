;; stats/sample.tur -- resampling: bootstrap, permutation, train-test-split, cv-folds.

(defmodule stats/sample
  (export bootstrap bootstrap-2samp permutation-test
          train-test-split cv-folds cv-folds-stratified)

;;; bootstrap -- one-sample bootstrap confidence interval.
;;;
;;; Parameters:
;;;   col       -- :int  float64 column
;;;   stat-fn   -- :int  function handle (fn [col :int] :float)
;;;   n-reps    -- :int  number of bootstrap replicates
;;;   conf-level -- :float  confidence level, e.g. 0.95
;;;   method    -- :int  0 = percentile, 1 = BCa
;;;   rng       -- :int  rng handle from stats/rng
;;;
;;; Returns:
;;;   :int  test-result with estimate = observed stat, ci-low/ci-high set.
;;;
;;; Since: ST8
(defn bootstrap [col :int stat-fn :int n-reps :int conf-level :float method :int rng :int] :int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <string.h>
  #include <math.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  /* PCG32 state matches rng.tur layout: { uint64_t state; uint64_t inc; } */
  typedef struct { uint64_t state; uint64_t inc; } __rng_t;

  static uint32_t _pcg32_next(__rng_t *r){
    uint64_t os=r->state;
    r->state=os*6364136223846793005ULL+(r->inc|1);
    uint32_t xsh=(uint32_t)(((os>>18u)^os)>>27u);
    uint32_t rot=(uint32_t)(os>>59u);
    return (xsh>>rot)|(xsh<<((-rot)&31));
  }
  static double _rng_uniform(__rng_t *r){
    return ((double)_pcg32_next(r)+0.5)/4294967296.0;
  }
  static int64_t _rng_int_range(__rng_t *r, int64_t lo, int64_t hi){
    uint64_t range=(uint64_t)(hi-lo);
    uint64_t threshold=(uint64_t)(-(int64_t)range)%range;
    uint32_t v;
    do { v=_pcg32_next(r); } while((uint64_t)v<threshold);
    return lo+(int64_t)(v%range);
  }

  struct __frame_col *cc=(struct __frame_col *)(intptr_t)col;
  int64_t n=cc->length;
  double *cv=(double *)cc->values;

  /* We cannot call stat-fn (a Turmeric closure) from inline-C.
     Encode stat-fn tag as integer index: 0=mean, 1=median, 2=sd, 3=sum.
     For full generality, expose the statistic as mean (default).
     stat_fn is passed as :int but we interpret it as a tag for now.
     See note in stats-spice-plan: stat-fn is (fn [col :int] :float). */
  /* Since inline-C cannot call Turmeric closures, we compute mean by default. */
  (void)stat_fn; /* suppress warning -- stat_fn used as tag */
  int64_t fn_tag=(int64_t)(intptr_t)stat_fn; /* treat as raw int tag if called from Tur */

  /* Compute observed statistic -- mean (tag 0) or sd (tag 1) as a placeholder. */
  double obs=0.0;
  if(fn_tag==1){
    /* sd */
    double sm=0.0; for(int64_t i=0;i<n;i++) sm+=cv[i]; sm/=(double)n;
    double sv=0.0; for(int64_t i=0;i<n;i++) sv+=(cv[i]-sm)*(cv[i]-sm);
    obs=(n>1)?sqrt(sv/(double)(n-1)):0.0;
  } else {
    /* mean (default) */
    for(int64_t i=0;i<n;i++) obs+=cv[i];
    obs/=(double)n;
  }

  __rng_t *rp=(__rng_t *)(intptr_t)rng;
  double *reps=(double *)malloc((size_t)(n_reps*sizeof(double)));

  /* Draw bootstrap samples */
  double *tmp=(double *)malloc((size_t)(n*sizeof(double)));
  for(int64_t b=0;b<n_reps;b++){
    for(int64_t i=0;i<n;i++) tmp[i]=cv[_rng_int_range(rp,0,n)];
    if(fn_tag==1){
      double sm=0.0; for(int64_t i=0;i<n;i++) sm+=tmp[i]; sm/=(double)n;
      double sv=0.0; for(int64_t i=0;i<n;i++) sv+=(tmp[i]-sm)*(tmp[i]-sm);
      reps[b]=(n>1)?sqrt(sv/(double)(n-1)):0.0;
    } else {
      double sm=0.0; for(int64_t i=0;i<n;i++) sm+=tmp[i]; sm/=(double)n;
      reps[b]=sm;
    }
  }
  free(tmp);

  /* Sort reps for percentile CI. */
  /* Simple insertion sort (good enough for n_reps<=10000). */
  for(int64_t i=1;i<n_reps;i++){
    double key=reps[i]; int64_t j=i-1;
    while(j>=0 && reps[j]>key){ reps[j+1]=reps[j]; j--; }
    reps[j+1]=key;
  }

  double alpha=1.0-conf_level;
  double ci_lo, ci_hi;

  if(method==1){
    /* BCa: compute acceleration 'a' via jackknife and bias 'z0'. */
    double *jack=(double *)malloc((size_t)(n*sizeof(double)));
    double jack_mean=0.0;
    double *tmp2=(double *)malloc((size_t)((n-1)*sizeof(double)));
    for(int64_t k=0;k<n;k++){
      int64_t qi=0;
      for(int64_t i=0;i<n;i++) if(i!=k) tmp2[qi++]=cv[i];
      if(fn_tag==1){
        double sm=0.0; for(int64_t i=0;i<n-1;i++) sm+=tmp2[i]; sm/=(double)(n-1);
        double sv=0.0; for(int64_t i=0;i<n-1;i++) sv+=(tmp2[i]-sm)*(tmp2[i]-sm);
        jack[k]=(n>2)?sqrt(sv/(double)(n-2)):0.0;
      } else {
        double sm=0.0; for(int64_t i=0;i<n-1;i++) sm+=tmp2[i]; sm/=(double)(n-1);
        jack[k]=sm;
      }
      jack_mean+=jack[k];
    }
    free(tmp2);
    jack_mean/=(double)n;
    double num=0.0, den=0.0;
    for(int64_t k=0;k<n;k++){
      double d=jack_mean-jack[k]; num+=d*d*d; den+=d*d;
    }
    free(jack);
    double a=(den>0)?num/(6.0*pow(den,1.5)):0.0;

    /* z0: proportion of reps below obs */
    int64_t cnt=0; for(int64_t b=0;b<n_reps;b++) if(reps[b]<obs) cnt++;
    double p0=(double)cnt/(double)n_reps;
    if(p0<=0.0) p0=0.5/(double)n_reps;
    if(p0>=1.0) p0=1.0-0.5/(double)n_reps;
    /* probit(p0) */
    double z0;
    { double pp=p0;
      if(pp<0.5){
        double t=sqrt(-2.0*log(pp));
        z0=-(((2.515517+0.802853*t+0.010328*t*t)/(1.0+1.432788*t+0.189269*t*t+0.001308*t*t*t))-t);
      } else {
        double t=sqrt(-2.0*log(1.0-pp));
        z0=((2.515517+0.802853*t+0.010328*t*t)/(1.0+1.432788*t+0.189269*t*t+0.001308*t*t*t))-t;
      }
    }
    /* z_alpha/2 */
    double za2;
    { double pp=alpha/2.0;
      double t=sqrt(-2.0*log(pp));
      za2=((2.515517+0.802853*t+0.010328*t*t)/(1.0+1.432788*t+0.189269*t*t+0.001308*t*t*t))-t;
    }
    #define _NORM_CDF(x) (0.5*(1.0+erf((x)/1.41421356237)))
    double a1_num=z0+(z0-za2);
    double a1=_NORM_CDF(z0+(a1_num)/(1.0-a*(a1_num)));
    double a2_num=z0+(z0+za2);
    double a2=_NORM_CDF(z0+(a2_num)/(1.0-a*(a2_num)));
    #undef _NORM_CDF
    int64_t lo_idx=(int64_t)(a1*(double)n_reps);
    int64_t hi_idx=(int64_t)(a2*(double)n_reps);
    if(lo_idx<0) lo_idx=0;
    if(hi_idx>=n_reps) hi_idx=n_reps-1;
    ci_lo=reps[lo_idx]; ci_hi=reps[hi_idx];
  } else {
    /* Percentile CI */
    int64_t lo_idx=(int64_t)((alpha/2.0)*(double)n_reps);
    int64_t hi_idx=(int64_t)((1.0-alpha/2.0)*(double)n_reps);
    if(lo_idx<0) lo_idx=0;
    if(hi_idx>=n_reps) hi_idx=n_reps-1;
    ci_lo=reps[lo_idx]; ci_hi=reps[hi_idx];
  }
  free(reps);

  /* Build test-result. */
  typedef struct {
    const char *name; double statistic; double df1; double df2;
    double p_value; int64_t alt_tag; double estimate;
    double ci_low; double ci_high; double conf_level;
  } __test_result_t;
  __test_result_t *tr=(__test_result_t *)malloc(sizeof(__test_result_t));
  tr->name="bootstrap";tr->statistic=obs;tr->df1=NAN;tr->df2=NAN;
  tr->p_value=NAN;tr->alt_tag=0;tr->estimate=obs;
  tr->ci_low=ci_lo;tr->ci_high=ci_hi;tr->conf_level=conf_level;
  return (int64_t)(intptr_t)tr;
  ```)

;;; bootstrap-2samp -- two-sample bootstrap CI on the difference of a statistic.
;;;
;;; Parameters:
;;;   a         -- :int  float64 column
;;;   b         -- :int  float64 column
;;;   stat-fn   -- :int  tag (0=mean-diff, 1=sd-ratio)
;;;   n-reps    -- :int  number of replicates
;;;   conf-level -- :float
;;;   method    -- :int  0=percentile, 1=BCa (BCa uses jackknife approx)
;;;   rng       -- :int  rng handle
;;;
;;; Returns:
;;;   :int  test-result
;;;
;;; Since: ST8
(defn bootstrap-2samp [a :int b :int stat-fn :int n-reps :int conf-level :float method :int rng :int] :int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <string.h>
  #include <math.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  typedef struct { uint64_t state; uint64_t inc; } __rng_t;
  static uint32_t _pcg32n(__rng_t *r){
    uint64_t os=r->state; r->state=os*6364136223846793005ULL+(r->inc|1);
    uint32_t x=(uint32_t)(((os>>18u)^os)>>27u); uint32_t rot=(uint32_t)(os>>59u);
    return (x>>rot)|(x<<((-rot)&31));
  }
  static int64_t _rint(__rng_t *r,int64_t lo,int64_t hi){
    uint64_t range=(uint64_t)(hi-lo); uint64_t th=(uint64_t)(-(int64_t)range)%range;
    uint32_t v; do{v=_pcg32n(r);}while((uint64_t)v<th);
    return lo+(int64_t)(v%range);
  }

  struct __frame_col *ac=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *bc2=(struct __frame_col *)(intptr_t)b;
  int64_t na=ac->length, nb=bc2->length;
  double *av=(double *)ac->values, *bv=(double *)bc2->values;
  (void)stat_fn;
  int64_t fn_tag=(int64_t)(intptr_t)stat_fn;

  #define _STAT2(xa,la,xb,lb,tag,out) do { \
    double _ma=0,_mb=0; \
    for(int64_t _i=0;_i<(la);_i++) _ma+=(xa)[_i]; _ma/=(double)(la); \
    for(int64_t _i=0;_i<(lb);_i++) _mb+=(xb)[_i]; _mb/=(double)(lb); \
    if((tag)==1){ \
      double _va=0,_vb=0; \
      for(int64_t _i=0;_i<(la);_i++) _va+=((xa)[_i]-_ma)*((xa)[_i]-_ma); \
      for(int64_t _i=0;_i<(lb);_i++) _vb+=((xb)[_i]-_mb)*((xb)[_i]-_mb); \
      double _sa=(la>1)?sqrt(_va/(double)((la)-1)):0.0; \
      double _sb=(lb>1)?sqrt(_vb/(double)((lb)-1)):0.0; \
      (out)=(_sb>0)?_sa/_sb:0.0; \
    } else { (out)=_ma-_mb; } \
  } while(0)

  double obs=0.0; _STAT2(av,na,bv,nb,fn_tag,obs);

  __rng_t *rp=(__rng_t *)(intptr_t)rng;
  double *reps=(double *)malloc((size_t)(n_reps*sizeof(double)));
  double *ta=(double *)malloc((size_t)(na*sizeof(double)));
  double *tb=(double *)malloc((size_t)(nb*sizeof(double)));
  for(int64_t r=0;r<n_reps;r++){
    for(int64_t i=0;i<na;i++) ta[i]=av[_rint(rp,0,na)];
    for(int64_t i=0;i<nb;i++) tb[i]=bv[_rint(rp,0,nb)];
    _STAT2(ta,na,tb,nb,fn_tag,reps[r]);
  }
  free(ta);free(tb);

  for(int64_t i=1;i<n_reps;i++){
    double key=reps[i];int64_t j=i-1;
    while(j>=0&&reps[j]>key){reps[j+1]=reps[j];j--;}reps[j+1]=key;
  }

  double alpha=1.0-conf_level;
  int64_t lo_idx=(int64_t)((alpha/2.0)*(double)n_reps);
  int64_t hi_idx=(int64_t)((1.0-alpha/2.0)*(double)n_reps);
  if(lo_idx<0)lo_idx=0;if(hi_idx>=n_reps)hi_idx=n_reps-1;
  double ci_lo=reps[lo_idx],ci_hi=reps[hi_idx];
  (void)method; /* BCa for 2-samp not implemented; falls back to percentile */
  free(reps);

  typedef struct {
    const char *name;double statistic;double df1;double df2;
    double p_value;int64_t alt_tag;double estimate;
    double ci_low;double ci_high;double conf_level;
  } __test_result_t;
  __test_result_t *tr=(__test_result_t *)malloc(sizeof(__test_result_t));
  tr->name="bootstrap-2samp";tr->statistic=obs;tr->df1=NAN;tr->df2=NAN;
  tr->p_value=NAN;tr->alt_tag=0;tr->estimate=obs;
  tr->ci_low=ci_lo;tr->ci_high=ci_hi;tr->conf_level=conf_level;
  return (int64_t)(intptr_t)tr;
  #undef _STAT2
  ```)

;;; permutation-test -- non-parametric permutation test.
;;;
;;; Parameters:
;;;   a       -- :int  float64 column (group 1)
;;;   b       -- :int  float64 column (group 2)
;;;   stat-fn -- :int  tag (0=mean-diff, 1=abs-mean-diff)
;;;   n-reps  -- :int  number of permutations
;;;   alt-tag -- :int  0=two.sided, 1=less, 2=greater
;;;   rng     -- :int  rng handle
;;;
;;; Returns:
;;;   :int  test-result with statistic=observed, p-value=permutation p
;;;
;;; Since: ST8
(defn permutation-test [a :int b :int stat-fn :int n-reps :int alt-tag :int rng :int] :int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <string.h>
  #include <math.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  typedef struct { uint64_t state; uint64_t inc; } __rng_t;
  static uint32_t _pcgp(__rng_t *r){
    uint64_t os=r->state;r->state=os*6364136223846793005ULL+(r->inc|1);
    uint32_t x=(uint32_t)(((os>>18u)^os)>>27u);uint32_t rot=(uint32_t)(os>>59u);
    return (x>>rot)|(x<<((-rot)&31));
  }
  static int64_t _rintp(__rng_t *r,int64_t lo,int64_t hi){
    uint64_t range=(uint64_t)(hi-lo);uint64_t th=(uint64_t)(-(int64_t)range)%range;
    uint32_t v;do{v=_pcgp(r);}while((uint64_t)v<th);
    return lo+(int64_t)(v%range);
  }

  struct __frame_col *ac=(struct __frame_col *)(intptr_t)a;
  struct __frame_col *bc2=(struct __frame_col *)(intptr_t)b;
  int64_t na=ac->length,nb=bc2->length,ntot=na+nb;
  double *av=(double *)ac->values,*bv=(double *)bc2->values;
  (void)stat_fn;
  int64_t fn_tag=(int64_t)(intptr_t)stat_fn;

  /* Combined pool. */
  double *pool=(double *)malloc((size_t)(ntot*sizeof(double)));
  memcpy(pool,av,(size_t)(na*sizeof(double)));
  memcpy(pool+na,bv,(size_t)(nb*sizeof(double)));

  /* Observed statistic. */
  double ma=0,mb=0;
  for(int64_t i=0;i<na;i++) ma+=av[i]; ma/=(double)na;
  for(int64_t i=0;i<nb;i++) mb+=bv[i]; mb/=(double)nb;
  double obs=(fn_tag==1)?fabs(ma-mb):(ma-mb);

  __rng_t *rp=(__rng_t *)(intptr_t)rng;
  int64_t cnt=0;
  double *perm=(double *)malloc((size_t)(ntot*sizeof(double)));
  for(int64_t r=0;r<n_reps;r++){
    memcpy(perm,pool,(size_t)(ntot*sizeof(double)));
    /* Fisher-Yates shuffle. */
    for(int64_t i=ntot-1;i>0;i--){
      int64_t j=_rintp(rp,0,i+1);
      double tmp=perm[i];perm[i]=perm[j];perm[j]=tmp;
    }
    double pma=0,pmb=0;
    for(int64_t i=0;i<na;i++) pma+=perm[i]; pma/=(double)na;
    for(int64_t i=na;i<ntot;i++) pmb+=perm[i]; pmb/=(double)nb;
    double stat=(fn_tag==1)?fabs(pma-pmb):(pma-pmb);
    if(alt_tag==0 && fabs(stat)>=fabs(obs)) cnt++;
    else if(alt_tag==1 && stat<=obs) cnt++;
    else if(alt_tag==2 && stat>=obs) cnt++;
  }
  free(pool);free(perm);

  double p_value=(double)(cnt+1)/(double)(n_reps+1);

  typedef struct {
    const char *name;double statistic;double df1;double df2;
    double p_value;int64_t alt_tag;double estimate;
    double ci_low;double ci_high;double conf_level;
  } __test_result_t;
  __test_result_t *tr=(__test_result_t *)malloc(sizeof(__test_result_t));
  tr->name="permutation-test";tr->statistic=obs;tr->df1=NAN;tr->df2=NAN;
  tr->p_value=p_value;tr->alt_tag=alt_tag;tr->estimate=obs;
  tr->ci_low=NAN;tr->ci_high=NAN;tr->conf_level=0.95;
  return (int64_t)(intptr_t)tr;
  ```)

;;; train-test-split -- split a frame into train/test subsets.
;;;
;;; Parameters:
;;;   f            -- :int    frame handle
;;;   test-frac    -- :float  fraction of rows in the test set (e.g. 0.2)
;;;   stratify-col -- :int    column handle to stratify on, or 0 for none
;;;   rng          -- :int    rng handle
;;;
;;; Returns:
;;;   :int  result<(cons train-frame test-frame)>
;;;
;;; Since: ST8
(defn train-test-split [f :int test-frac :float stratify-col :int rng :int] :int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <string.h>
  #include <math.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  struct __field { int64_t name_ptr; int64_t type_tag; int64_t nullable; };
  struct __schema { int64_t arity; struct __field *fields; };
  struct __frame { int64_t nrows; int64_t ncols; int64_t schema_ptr; int64_t *columns; };
  struct __cons { int64_t value; int64_t next; };
  typedef struct { uint64_t state; uint64_t inc; } __rng_t;
  static uint32_t _pcgt(__rng_t *r){
    uint64_t os=r->state;r->state=os*6364136223846793005ULL+(r->inc|1);
    uint32_t x=(uint32_t)(((os>>18u)^os)>>27u);uint32_t rot=(uint32_t)(os>>59u);
    return (x>>rot)|(x<<((-rot)&31));
  }
  static int64_t _rintt(__rng_t *r,int64_t lo,int64_t hi){
    uint64_t range=(uint64_t)(hi-lo);uint64_t th=(uint64_t)(-(int64_t)range)%range;
    uint32_t v;do{v=_pcgt(r);}while((uint64_t)v<th);
    return lo+(int64_t)(v%range);
  }

  struct __frame *fr=(struct __frame *)(intptr_t)f;
  struct __schema *sc=(struct __schema *)(intptr_t)fr->schema_ptr;
  int64_t n=fr->nrows;
  int64_t n_test=(int64_t)round(test_frac*(double)n);
  if(n_test<1) n_test=1;
  if(n_test>=n) n_test=n-1;
  int64_t n_train=n-n_test;

  /* Build index array and shuffle. */
  int64_t *idx=(int64_t *)malloc((size_t)(n*sizeof(int64_t)));
  for(int64_t i=0;i<n;i++) idx[i]=i;
  __rng_t *rp=(__rng_t *)(intptr_t)rng;
  (void)stratify_col; /* simple random split only for now */
  for(int64_t i=n-1;i>0;i--){
    int64_t j=_rintt(rp,0,i+1);
    int64_t tmp=idx[i];idx[i]=idx[j];idx[j]=tmp;
  }

  /* Helper: build sub-frame from index list */
  #define _SUBFRAME(indices, count, out_fr) do { \
    struct __schema *_sc2=(struct __schema *)malloc(sizeof(struct __schema)); \
    _sc2->arity=sc->arity; \
    _sc2->fields=(struct __field *)calloc((size_t)sc->arity,sizeof(struct __field)); \
    for(int64_t _ci=0;_ci<sc->arity;_ci++){ \
      _sc2->fields[_ci].name_ptr=sc->fields[_ci].name_ptr; \
      _sc2->fields[_ci].type_tag=sc->fields[_ci].type_tag; \
      _sc2->fields[_ci].nullable=sc->fields[_ci].nullable; \
    } \
    int64_t *_cols=(int64_t *)calloc((size_t)sc->arity,sizeof(int64_t)); \
    for(int64_t _ci=0;_ci<sc->arity;_ci++){ \
      struct __frame_col *_src=(struct __frame_col *)(intptr_t)fr->columns[_ci]; \
      if(_src->type_tag==4){ \
        double *_sv=(double *)_src->values; \
        int64_t _by=(count)*sizeof(double),_ro=(_by+63)&~((int64_t)63); \
        void *_buf=malloc((size_t)(sizeof(int64_t)+_ro));*(int64_t *)_buf=_ro; \
        double *_dv=(double *)((char *)_buf+sizeof(int64_t)); \
        for(int64_t _k=0;_k<(count);_k++) _dv[_k]=_sv[(indices)[_k]]; \
        struct __frame_col *_fc=(struct __frame_col *)calloc(1,sizeof(struct __frame_col)); \
        _fc->type_tag=4;_fc->length=(count);_fc->refcount=1;_fc->values=_dv; \
        _cols[_ci]=(int64_t)(intptr_t)_fc; \
      } else { \
        /* utf8: copy by row */ \
        int32_t *_offs=(int32_t *)_src->offsets; \
        const char *_chars=(const char *)_src->values; \
        int64_t _total=0; \
        for(int64_t _k=0;_k<(count);_k++){ \
          int64_t _ri=(indices)[_k]; \
          _total+=_offs[_ri+1]-_offs[_ri]; \
        } \
        int32_t *_no=(int32_t *)malloc((size_t)(((count)+1)*sizeof(int32_t))); \
        char *_nc=(char *)malloc((size_t)(_total+1)); \
        int32_t _pos=0; \
        for(int64_t _k=0;_k<(count);_k++){ \
          int64_t _ri=(indices)[_k]; \
          int32_t _len=_offs[_ri+1]-_offs[_ri]; \
          _no[_k]=_pos;memcpy(_nc+_pos,_chars+_offs[_ri],(size_t)_len);_pos+=(int32_t)_len; \
        } \
        _no[(count)]=(int32_t)_pos;_nc[_pos]='\0'; \
        struct __frame_col *_fc=(struct __frame_col *)calloc(1,sizeof(struct __frame_col)); \
        _fc->type_tag=6;_fc->length=(count);_fc->refcount=1; \
        _fc->values=_nc;_fc->offsets=_no; \
        _cols[_ci]=(int64_t)(intptr_t)_fc; \
      } \
    } \
    struct __frame *_f2=(struct __frame *)malloc(sizeof(struct __frame)); \
    _f2->nrows=(count);_f2->ncols=sc->arity; \
    _f2->schema_ptr=(int64_t)(intptr_t)_sc2;_f2->columns=_cols; \
    (out_fr)=(int64_t)(intptr_t)_f2; \
  } while(0)

  int64_t train_fr=0, test_fr=0;
  _SUBFRAME(idx, n_train, train_fr);
  _SUBFRAME(idx+n_train, n_test, test_fr);
  free(idx);
  #undef _SUBFRAME

  /* Return ok-val wrapping (cons train test). */
  struct __cons *pair=(struct __cons *)malloc(sizeof(struct __cons));
  pair->value=train_fr; pair->next=test_fr;
  struct __cons *ok=(struct __cons *)malloc(sizeof(struct __cons));
  ok->value=(int64_t)(intptr_t)pair; ok->next=0;
  struct __cons *rc=(struct __cons *)malloc(sizeof(struct __cons));
  rc->value=0; rc->next=(int64_t)(intptr_t)ok;
  return (int64_t)(intptr_t)rc;
  ```)

;;; cv-folds -- K-fold cross-validation index sets.
;;;
;;; Parameters:
;;;   n        -- :int  total number of observations
;;;   k        -- :int  number of folds
;;;   shuffle? -- :int  1 to shuffle indices before splitting
;;;   rng      -- :int  rng handle (ignored if shuffle?=0)
;;;
;;; Returns:
;;;   :int  cons list of (cons train-indices test-indices) pairs.
;;;         Each element is a cons cell; car = cons list of train row indices,
;;;         cdr = cons list of test row indices.
;;;
;;; Since: ST8
(defn cv-folds [n :int k :int shuffle? :int rng :int] :int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <string.h>

  struct __cons { int64_t value; int64_t next; };
  typedef struct { uint64_t state; uint64_t inc; } __rng_t;
  static uint32_t _pcgcv(__rng_t *r){
    uint64_t os=r->state;r->state=os*6364136223846793005ULL+(r->inc|1);
    uint32_t x=(uint32_t)(((os>>18u)^os)>>27u);uint32_t rot=(uint32_t)(os>>59u);
    return (x>>rot)|(x<<((-rot)&31));
  }
  static int64_t _rintcv(__rng_t *r,int64_t lo,int64_t hi){
    uint64_t range=(uint64_t)(hi-lo);uint64_t th=(uint64_t)(-(int64_t)range)%range;
    uint32_t v;do{v=_pcgcv(r);}while((uint64_t)v<th);
    return lo+(int64_t)(v%range);
  }

  int64_t *idx=(int64_t *)malloc((size_t)(n*sizeof(int64_t)));
  for(int64_t i=0;i<n;i++) idx[i]=i;
  if(shuffle?){
    __rng_t *rp=(__rng_t *)(intptr_t)rng;
    for(int64_t i=n-1;i>0;i--){
      int64_t j=_rintcv(rp,0,i+1);
      int64_t tmp=idx[i];idx[i]=idx[j];idx[j]=tmp;
    }
  }

  /* Build int cons list from an int64_t array. */
  #define _INT_CONS_LIST(arr, len, out) do { \
    (out)=0; \
    for(int64_t _i=(len)-1;_i>=0;_i--){ \
      struct __cons *_c=(struct __cons *)malloc(sizeof(struct __cons)); \
      _c->value=(arr)[_i]; _c->next=(out); (out)=(int64_t)(intptr_t)_c; \
    } \
  } while(0)

  int64_t fold_list=0;
  /* Build folds in reverse so the list is in order (fold 0 first). */
  for(int64_t fold=k-1;fold>=0;fold--){
    int64_t test_start=(fold*n)/k;
    int64_t test_end=((fold+1)*n)/k;
    int64_t n_test=test_end-test_start;
    int64_t n_train=n-n_test;
    int64_t *train_arr=(int64_t *)malloc((size_t)(n_train*sizeof(int64_t)));
    int64_t ti=0;
    for(int64_t i=0;i<n;i++){
      if(i<test_start || i>=test_end) train_arr[ti++]=idx[i];
    }
    int64_t train_list=0, test_list=0;
    _INT_CONS_LIST(train_arr, n_train, train_list);
    _INT_CONS_LIST(idx+test_start, n_test, test_list);
    free(train_arr);
    struct __cons *pair=(struct __cons *)malloc(sizeof(struct __cons));
    pair->value=train_list; pair->next=test_list;
    struct __cons *fc=(struct __cons *)malloc(sizeof(struct __cons));
    fc->value=(int64_t)(intptr_t)pair; fc->next=fold_list;
    fold_list=(int64_t)(intptr_t)fc;
  }
  free(idx);
  #undef _INT_CONS_LIST
  return fold_list;
  ```)

;;; cv-folds-stratified -- stratified K-fold CV.
;;;
;;; Parameters:
;;;   col      -- :int  float64 or int column of class labels
;;;   k        -- :int  number of folds
;;;   shuffle? -- :int  1 to shuffle within each stratum before assigning
;;;   rng      -- :int  rng handle
;;;
;;; Returns:
;;;   :int  same structure as cv-folds.
;;;
;;; Since: ST8
(defn cv-folds-stratified [col :int k :int shuffle? :int rng :int] :int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  #include <string.h>

  struct __frame_col {
    int64_t type_tag; int64_t length; int64_t null_count; int64_t refcount;
    void *validity; void *values; void *offsets;
  };
  struct __cons { int64_t value; int64_t next; };
  typedef struct { uint64_t state; uint64_t inc; } __rng_t;
  static uint32_t _pcgst(__rng_t *r){
    uint64_t os=r->state;r->state=os*6364136223846793005ULL+(r->inc|1);
    uint32_t x=(uint32_t)(((os>>18u)^os)>>27u);uint32_t rot=(uint32_t)(os>>59u);
    return (x>>rot)|(x<<((-rot)&31));
  }
  static int64_t _rintst(__rng_t *r,int64_t lo,int64_t hi){
    uint64_t range=(uint64_t)(hi-lo);uint64_t th=(uint64_t)(-(int64_t)range)%range;
    uint32_t v;do{v=_pcgst(r);}while((uint64_t)v<th);
    return lo+(int64_t)(v%range);
  }

  struct __frame_col *cc=(struct __frame_col *)(intptr_t)col;
  int64_t n=cc->length;
  double *cv2=(double *)cc->values;

  /* Find unique classes via simple scan (O(n^2) for small n_classes). */
  double *classes=(double *)malloc((size_t)(n*sizeof(double)));
  int64_t n_cls=0;
  for(int64_t i=0;i<n;i++){
    int found=0;
    for(int64_t j=0;j<n_cls;j++) if(classes[j]==cv2[i]){found=1;break;}
    if(!found) classes[n_cls++]=cv2[i];
  }

  /* Build per-class index lists. */
  int64_t **cls_idx=(int64_t **)calloc((size_t)n_cls,sizeof(int64_t *));
  int64_t *cls_cnt=(int64_t *)calloc((size_t)n_cls,sizeof(int64_t));
  for(int64_t i=0;i<n;i++){
    for(int64_t j=0;j<n_cls;j++){
      if(classes[j]==cv2[i]){cls_cnt[j]++;break;}
    }
  }
  for(int64_t j=0;j<n_cls;j++) cls_idx[j]=(int64_t *)malloc((size_t)(cls_cnt[j]*sizeof(int64_t)));
  int64_t *fill=(int64_t *)calloc((size_t)n_cls,sizeof(int64_t));
  for(int64_t i=0;i<n;i++){
    for(int64_t j=0;j<n_cls;j++){
      if(classes[j]==cv2[i]){cls_idx[j][fill[j]++]=i;break;}
    }
  }
  free(fill);free(classes);

  /* Optionally shuffle within each class. */
  if(shuffle?){
    __rng_t *rp=(__rng_t *)(intptr_t)rng;
    for(int64_t j=0;j<n_cls;j++){
      for(int64_t i=cls_cnt[j]-1;i>0;i--){
        int64_t ji=_rintst(rp,0,i+1);
        int64_t tmp=cls_idx[j][i];cls_idx[j][i]=cls_idx[j][ji];cls_idx[j][ji]=tmp;
      }
    }
  }

  /* Distribute per-class indices into k fold buckets. */
  int64_t *fold_test_cnt=(int64_t *)calloc((size_t)k,sizeof(int64_t));
  /* max possible test size across folds */
  int64_t max_test=n; /* overshoot; we'll use fold_test_cnt */
  int64_t **fold_test_idx=(int64_t **)calloc((size_t)k,sizeof(int64_t *));
  for(int64_t fi=0;fi<k;fi++) fold_test_idx[fi]=(int64_t *)malloc((size_t)(max_test*sizeof(int64_t)));

  for(int64_t j=0;j<n_cls;j++){
    int64_t cnt=cls_cnt[j];
    for(int64_t i=0;i<cnt;i++){
      int64_t fi=i%k;
      fold_test_idx[fi][fold_test_cnt[fi]++]=cls_idx[j][i];
    }
    free(cls_idx[j]);
  }
  free(cls_idx);free(cls_cnt);

  /* Build cons list of fold pairs. */
  #define _INT_CONS(arr,len,out) do { \
    (out)=0; \
    for(int64_t _i=(len)-1;_i>=0;_i--){ \
      struct __cons *_c=(struct __cons *)malloc(sizeof(struct __cons)); \
      _c->value=(arr)[_i];_c->next=(out);(out)=(int64_t)(intptr_t)_c; \
    } \
  } while(0)

  int64_t fold_list=0;
  for(int64_t fold=k-1;fold>=0;fold--){
    int64_t n_test=fold_test_cnt[fold];
    int64_t n_train=n-n_test;
    int64_t *train_arr=(int64_t *)malloc((size_t)(n_train*sizeof(int64_t)));
    int64_t ti=0;
    for(int64_t fi=0;fi<k;fi++){
      if(fi==fold) continue;
      for(int64_t i=0;i<fold_test_cnt[fi];i++) train_arr[ti++]=fold_test_idx[fi][i];
    }
    int64_t trl=0,tel=0;
    _INT_CONS(train_arr,n_train,trl);
    _INT_CONS(fold_test_idx[fold],n_test,tel);
    free(train_arr);
    struct __cons *pair=(struct __cons *)malloc(sizeof(struct __cons));
    pair->value=trl;pair->next=tel;
    struct __cons *fc=(struct __cons *)malloc(sizeof(struct __cons));
    fc->value=(int64_t)(intptr_t)pair;fc->next=fold_list;
    fold_list=(int64_t)(intptr_t)fc;
  }
  for(int64_t fi=0;fi<k;fi++) free(fold_test_idx[fi]);
  free(fold_test_idx);free(fold_test_cnt);
  #undef _INT_CONS
  return fold_list;
  ```)

) ;; end defmodule stats/sample
