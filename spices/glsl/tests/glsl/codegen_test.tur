;; tests/glsl/codegen_test.tur -- unit tests for glsl/codegen, glsl/types, and glsl/core.

(import glsl/codegen  :refer [compile-glsl glsl-join glsl-cat2 glsl-cat3 glsl-cat4
                               glsl-indent glsl-stmts glsl-int->str
                               glsl-sprintf1 glsl-sprintf2 glsl-sprintf3 glsl-sprintf4])
(import glsl/types    :refer [glsl-type])
(import glsl/core     :refer [glsl-let glsl-set! glsl-return glsl-discard
                               glsl-inc! glsl-dec! glsl-binop
                               glsl-if glsl-if-only glsl-for glsl-for1
                               glsl-param glsl-defn])
(import test/assert   :refer [assert-true])
(import test/suite    :refer [describe it])
(import test/runner   :refer [run-all])

;;; cstr= -- compare two C strings for equality.
(defn cstr= [a :cstr b :cstr] :bool
  ```c
  #include <string.h>
  return strcmp(a, b) == 0;
  ```)

(describe "glsl/codegen -- string helpers"

  (it "glsl-cat2 concatenates two strings"
    (assert-true (cstr= (glsl-cat2 "vec3 " "pos") "vec3 pos")))

  (it "glsl-cat3 concatenates three strings"
    (assert-true (cstr= (glsl-cat3 "if (" "x" ") {") "if (x) {")))

  (it "glsl-cat4 concatenates four strings"
    (assert-true (cstr= (glsl-cat4 "a" "b" "c" "d") "abcd")))

  (it "glsl-sprintf1 formats one argument"
    (assert-true (cstr= (glsl-sprintf1 "return %s;" "x") "return x;")))

  (it "glsl-sprintf2 formats two arguments"
    (assert-true (cstr= (glsl-sprintf2 "%s = %s;" "x" "1.0") "x = 1.0;")))

  (it "glsl-sprintf3 formats three arguments"
    (assert-true (cstr= (glsl-sprintf3 "%s %s = %s;" "float" "x" "1.0")
                        "float x = 1.0;")))

  (it "glsl-sprintf4 formats four arguments"
    (assert-true (cstr= (glsl-sprintf4 "%s %s(%s) {" "float" "square" "float x")
                        "float square(float x) {")))

  (it "glsl-int->str converts zero"
    (assert-true (cstr= (glsl-int->str 0) "0")))

  (it "glsl-int->str converts positive int"
    (assert-true (cstr= (glsl-int->str 42) "42")))

  (it "glsl-join with empty list returns empty string"
    (assert-true (cstr= (glsl-join ", " 0) "")))

  (it "glsl-join with single item returns that item"
    (assert-true (cstr= (glsl-join ", " (cons "float x" 0)) "float x")))

  (it "glsl-join with two items joins with separator"
    (assert-true (cstr= (glsl-join ", " (cons "float x" (cons "vec3 n" 0)))
                        "float x, vec3 n")))

  (it "glsl-join with three items"
    (assert-true (cstr= (glsl-join ", " (cons "a" (cons "b" (cons "c" 0))))
                        "a, b, c")))

  (it "glsl-indent adds four spaces to single line"
    (assert-true (cstr= (glsl-indent "return x;") "    return x;")))

  (it "glsl-indent adds four spaces to each line of multi-line input"
    (assert-true (cstr= (glsl-indent "a;\nb;") "    a;\n    b;")))

  (it "glsl-stmts joins with newlines"
    (assert-true (cstr= (glsl-stmts (cons "float x = 1.0;" (cons "float y = 2.0;" 0)))
                        "float x = 1.0;\nfloat y = 2.0;")))

  (it "compile-glsl is identity"
    (assert-true (cstr= (compile-glsl "void main() {}") "void main() {}"))))

(describe "glsl/types -- type keyword mapping"

  (it "maps :float to float"
    (assert-true (cstr= (glsl-type ":float") "float")))

  (it "maps :int to int"
    (assert-true (cstr= (glsl-type ":int") "int")))

  (it "maps :uint to uint"
    (assert-true (cstr= (glsl-type ":uint") "uint")))

  (it "maps :bool to bool"
    (assert-true (cstr= (glsl-type ":bool") "bool")))

  (it "maps :void to void"
    (assert-true (cstr= (glsl-type ":void") "void")))

  (it "maps :vec2 to vec2"
    (assert-true (cstr= (glsl-type ":vec2") "vec2")))

  (it "maps :vec3 to vec3"
    (assert-true (cstr= (glsl-type ":vec3") "vec3")))

  (it "maps :vec4 to vec4"
    (assert-true (cstr= (glsl-type ":vec4") "vec4")))

  (it "maps :mat4 to mat4"
    (assert-true (cstr= (glsl-type ":mat4") "mat4")))

  (it "maps :sampler-2d to sampler2D"
    (assert-true (cstr= (glsl-type ":sampler-2d") "sampler2D")))

  (it "maps :sampler-cube to samplerCube"
    (assert-true (cstr= (glsl-type ":sampler-cube") "samplerCube"))))

(describe "glsl/core -- control flow forms"

  (it "glsl-let generates typed variable declaration"
    (assert-true (cstr= (glsl-let "x" ":float" "1.0") "float x = 1.0;")))

  (it "glsl-let with vec3 type"
    (assert-true (cstr= (glsl-let "color" ":vec3" "vec3(1.0, 0.0, 0.0)")
                        "vec3 color = vec3(1.0, 0.0, 0.0);")))

  (it "glsl-set! generates assignment"
    (assert-true (cstr= (glsl-set! "x" "2.0") "x = 2.0;")))

  (it "glsl-set! with compound name"
    (assert-true (cstr= (glsl-set! "gl_Position" "vec4(pos, 1.0)")
                        "gl_Position = vec4(pos, 1.0);")))

  (it "glsl-return generates return statement"
    (assert-true (cstr= (glsl-return "x * x") "return x * x;")))

  (it "glsl-discard generates discard statement"
    (assert-true (cstr= (glsl-discard) "discard;")))

  (it "glsl-inc! generates post-increment"
    (assert-true (cstr= (glsl-inc! "i") "i++;")))

  (it "glsl-dec! generates post-decrement"
    (assert-true (cstr= (glsl-dec! "i") "i--;")))

  (it "glsl-binop wraps in parentheses"
    (assert-true (cstr= (glsl-binop "+" "a" "b") "(a + b)")))

  (it "glsl-binop with multiplication"
    (assert-true (cstr= (glsl-binop "*" "diff" "lightColor") "(diff * lightColor)")))

  (it "glsl-if generates if/else"
    (assert-true (cstr= (glsl-if "x > 0.0" "y = 1.0;" "y = -1.0;")
                        "if (x > 0.0) {\n    y = 1.0;\n} else {\n    y = -1.0;\n}")))

  (it "glsl-if-only generates if without else"
    (assert-true (cstr= (glsl-if-only "alpha < 0.01" "discard;")
                        "if (alpha < 0.01) {\n    discard;\n}")))

  (it "glsl-for generates for loop with pre-built init"
    (assert-true (cstr= (glsl-for "int i = 0" "i < 4" "i++" "sum += arr[i];")
                        "for (int i = 0; i < 4; i++) {\n    sum += arr[i];\n}")))

  (it "glsl-for1 generates typed for loop"
    (assert-true (cstr= (glsl-for1 "i" ":int" "0" "i < 4" "i++" "sum += v[i];")
                        "for (int i = 0; i < 4; i++) {\n    sum += v[i];\n}")))

  (it "glsl-param generates parameter string"
    (assert-true (cstr= (glsl-param "normal" ":vec3") "vec3 normal")))

  (it "glsl-defn generates function definition"
    (let [body (glsl-return "(x * x)")]
      (assert-true (cstr= (glsl-defn "square"
                                     (cons (glsl-param "x" ":float") 0)
                                     ":float" body)
                          "float square(float x) {\n    return (x * x);\n}"))))

  (it "glsl-defn with multiple params"
    (let [params (cons (glsl-param "x" ":float") (cons (glsl-param "y" ":float") 0))
          body   (glsl-return "(x + y)")]
      (assert-true (cstr= (glsl-defn "add" params ":float" body)
                          "float add(float x, float y) {\n    return (x + y);\n}"))))

  (it "integration: glsl-stmts composes multiple statements"
    (let [stmts (cons (glsl-let "x" ":float" "1.0")
                  (cons (glsl-let "y" ":float" "2.0")
                    (cons (glsl-return "(x + y)") 0)))]
      (assert-true (cstr= (glsl-stmts stmts)
                          "float x = 1.0;\nfloat y = 2.0;\nreturn (x + y);")))))

(run-all)
