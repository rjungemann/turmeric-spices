  (print-bool "d4 = 62:       " (= (note->midi "d4") 62))
  (print-bool "e4 = 64:       " (= (note->midi "e4") 64))
  (print-bool "f4 = 65:       " (= (note->midi "f4") 65))
  (print-bool "g4 = 67:       " (= (note->midi "g4") 67))
  (print-bool "a4 = 69:       " (= (note->midi "a4") 69))
  (print-bool "b4 = 71:       " (= (note->midi "b4") 71))
  (print-bool "eb4 = 63:      " (= (note->midi "eb4") 63))
  (print-bool "f#4 = 66:      " (= (note->midi "f#4") 66))
  (print-bool "bb5 = 82:      " (= (note->midi "bb5") 82))
  (print-bool "60 = 60:       " (= (note->midi "60") 60))
  (print-bool "rest ~ = -1:   " (= (note->midi "~") -1))
  (print-bool "c5 = 72:       " (= (note->midi "c5") 72))
  (print-bool "c3 = 48:       " (= (note->midi "c3") 48))

  (println "")
  (println "=== parse-notation: basic sequence ===")

  (let [r (parse-notation "bd sd cp")]
    (print-bool "parse ok?:     " (ok? r))
    (let [p    (ok-val r)
          evts (pattern-events p 0)]
      (print-bool "has events:    " (not (list-nil? evts)))
      (let [e0 (head evts)
            e1 (head (tail evts))
            e2 (head (tail (tail evts)))]
        (print-bool "3rd event:     " (not (list-nil? (tail (tail evts)))))
        (print-bool "onset e0=0:    " (< (tidal-ev-onset e0) 0.001))
        (print-bool "dur e0~0.333:  " (< (- (tidal-ev-dur e0) 0.333) 0.002)))
      (notation-free p)))

  (println "")
  (println "=== parse-notation: subsequence ===")

  (let [r (parse-notation "[bd sd] cp")]
    (print-bool "parse ok?:     " (ok? r))
    (let [p    (ok-val r)
          evts (pattern-events p 0)]
      (print-bool "has events:    " (not (list-nil? evts)))
      ;; should have 3 events: bd, sd, cp
      (let [evts2 (tail evts)
            evts3 (tail evts2)]
        (print-bool "3 events:      " (not (list-nil? evts3)))
        (print-bool "no 4th event:  " (list-nil? (tail evts3))))
      (notation-free p)))

  (println "")
  (println "=== parse-notation: alternating <...> ===")

  (let [r (parse-notation "<60 62 64>")]
    (print-bool "parse ok?:     " (ok? r))
    (let [p     (ok-val r)
          evts0 (pattern-events p 0)
          evts1 (pattern-events p 1)
          evts2 (pattern-events p 2)]
      (print-bool "cycle 0 evts:  " (not (list-nil? evts0)))
      (print-bool "cycle 1 evts:  " (not (list-nil? evts1)))
      (print-bool "cycle 2 evts:  " (not (list-nil? evts2)))
      (let [v0 (tidal-ev-value (head evts0))
            v1 (tidal-ev-value (head evts1))
            v2 (tidal-ev-value (head evts2))]
        (print-bool "cycle0 = 60:   " (scscm-cstr-eq? v0 "60"))
        (print-bool "cycle1 = 62:   " (scscm-cstr-eq? v1 "62"))
        (print-bool "cycle2 = 64:   " (scscm-cstr-eq? v2 "64")))
      (notation-free p)))

  (println "")
  (println "=== parse-notation: repeat *n ===")

  (let [r (parse-notation "bd*3")]
    (print-bool "parse ok?:     " (ok? r))
    (let [p    (ok-val r)
          evts (pattern-events p 0)]
      ;; should yield 3 bd events
      (print-bool "event 1:       " (not (list-nil? evts)))
      (print-bool "event 2:       " (not (list-nil? (tail evts))))
      (print-bool "event 3:       " (not (list-nil? (tail (tail evts)))))
      (print-bool "no event 4:    " (list-nil? (tail (tail (tail evts)))))
      (notation-free p)))

  (println "")
  (println "=== parse-notation: Euclidean rhythm ===")

  (let [r (parse-notation "bd(3,8)")]
    (print-bool "parse ok?:     " (ok? r))
    (let [p    (ok-val r)
          evts (pattern-events p 0)]
      (print-bool "has events:    " (not (list-nil? evts)))
      ;; 3 pulses in 8 steps
      (let [count (list-length evts)]
        (print-bool "3 pulses:      " (= count 3)))
      (notation-free p)))

  (println "")
  (println "=== render-events ===")

  (let [r (parse-notation "c4 d4 e4")]
    (let [p     (ok-val r)
          table (render-events p 0)]
      (println table)
      (notation-free p)))

  (println "")
  (println "=== render-sclang ===")

  (let [r (parse-notation "c4 d4")]
    (let [p  (ok-val r)
          sc (render-sclang p "piano")]
      (println sc)
      (notation-free p)))

  (println "")
  (println "=== render-pbind ===")

  (let [r (parse-notation "c4 d4")]
    (let [p     (ok-val r)
          scscm (render-pbind p "piano")]
      (println scscm)
      (notation-free p)))

  (println "")
  (println "=== pattern-fast combinator ===")

  (let [r (parse-notation "c4 d4")]
    (let [p    (ok-val r)
          fast (let [node (tidal-pat-alloc 10)]
                 (tidal-pat-set-param-f node 2.0)
                 (tidal-pat-add-child node p 1.0)
                 node)
          evts0 (tidal-eval-to-cons fast 0)]
      (print-bool "fast has evts: " (not (list-nil? evts0)))
      (tidal-pat-free-raw fast)))

  (println "")
  (println "Done.")

  )
  0


  (defn main [] :int 0))
