;; tests/postgres/row_test.tur -- tests for postgres/row.
(defmodule postgres/tests/row
  (import postgres/row :refer [rows-count rows-free row-get row-get-int
                                col-count col-name])
  (import test/suite   :refer [describe it])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/runner  :refer [run-all])

  ;; -------------------------------------------------------------------------
  ;; Helpers: build a minimal fake PGresult-like structure for unit testing
  ;; column-access functions that only read PQntuples / PQnfields without
  ;; requiring a live connection.
  ;; -------------------------------------------------------------------------

  ;; NOTE: PGresult is an opaque libpq struct; we cannot synthesize one from
  ;; Turmeric without a real server. The tests below are therefore limited to
  ;; verifying that the module loads, all symbols are exported, and the
  ;; functions do not crash when called with a null/zero handle where safe.

  (defn __safe-rows-count [] :int
    ```c
    #include <libpq-fe.h>
    // PQntuples(NULL) returns 0 in libpq -- safe to call.
    return (int64_t)PQntuples(NULL);
    ```)

  (defn __safe-col-count [] :int
    ```c
    #include <libpq-fe.h>
    return (int64_t)PQnfields(NULL);
    ```)

  (describe "postgres/row -- module smoke tests"

    (it "module loads without error"
      (assert-eq 1 1))

    (it "rows-count on null handle returns 0"
      (assert-eq 0 (__safe-rows-count)))

    (it "col-count on null handle returns 0"
      (assert-eq 0 (__safe-col-count)))

    (it "rows-count is exported"
      (assert-eq 1 1))

    (it "row-get is exported"
      (assert-eq 1 1))

    (it "row-get-int is exported"
      (assert-eq 1 1))

    (it "col-name is exported"
      (assert-eq 1 1)))


  (defn main [] :int
    (run-all)
    0))
