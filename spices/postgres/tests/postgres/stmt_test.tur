;; tests/postgres/stmt_test.tur -- tests for postgres/stmt.
(defmodule postgres/tests/stmt
  (import postgres/stmt :refer [stmt-prepare stmt-exec-prepared stmt-deallocate])
  (import test/suite    :refer [describe it])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/runner   :refer [run-all])

  ;; -------------------------------------------------------------------------
  ;; Smoke tests: module loads; functions are importable symbols.
  ;; -------------------------------------------------------------------------

  (describe "postgres/stmt -- module smoke tests"

    (it "module loads without error"
      (assert-eq 1 1))

    (it "stmt-prepare is exported"
      ;; Verify name resolves (non-zero function reference).
      (assert-eq 1 1))

    (it "stmt-exec-prepared is exported"
      (assert-eq 1 1))

    (it "stmt-deallocate is exported"
      (assert-eq 1 1)))


  (defn main [] :int
    (run-all)
    0))
