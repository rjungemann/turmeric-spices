;; tests/http/codec_test.tur -- P4 typed client JSON codecs.
;;
;; Exercises the typed client body helpers without a network or TLS: it
;; builds a request with `json-request` and inspects the resulting record,
;; and decodes a typed struct out of a synthesized response body with
;; `response-decode`. Only http/request + http/response are imported, so the
;; mbedtls client path is never linked.

(defmodule http/tests/codec
  (import http/request  :refer [json-request])
  (import http/response :refer [response-decode])
  (import json/encode   :refer [derive-json])
  (import test/suite    :refer [describe it])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/runner   :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; -- Inspect the opaque request record built by `json-request`. -----------

  (defn __req-method [req : int] : cstr
    ```c
    struct __req { char *method; char *url; char *body; int64_t headers; };
    return (int64_t)(intptr_t)((struct __req *)(intptr_t)req)->method;
    ```)

  (defn __req-body [req : int] : cstr
    ```c
    struct __req { char *method; char *url; char *body; int64_t headers; };
    return (int64_t)(intptr_t)((struct __req *)(intptr_t)req)->body;
    ```)

  ;; Look up a header value by key in the alternating key/value cons-list, or
  ;; "" when absent.
  (defn __req-header [req : int key : cstr] : cstr
    ```c
    #include <string.h>
    struct __req { char *method; char *url; char *body; int64_t headers; };
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)(intptr_t)((struct __req *)(intptr_t)req)->headers;
    while (c && c->next) {
      const char *k = (const char *)(intptr_t)c->value;
      struct __cons *v = (struct __cons *)(intptr_t)c->next;
      if (k && strcmp(k, (const char *)key) == 0)
        return (int64_t)(intptr_t)(const char *)(intptr_t)v->value;
      c = (struct __cons *)(intptr_t)v->next;
    }
    return (int64_t)(intptr_t)"";
    ```)

  ;; -- Synthesize a response handle carrying `body` (no network). -----------

  (defn __mk-resp [body : cstr] : int
    ```c
    #include <stdlib.h>
    #include <string.h>
    struct __resp { int status; char *body; char **hdr_keys; char **hdr_vals; int hdr_count; };
    struct __resp *r = malloc(sizeof(*r));
    r->status = 200;
    r->body = strdup((const char *)body);
    r->hdr_keys = NULL; r->hdr_vals = NULL; r->hdr_count = 0;
    return (int64_t)(intptr_t)r;
    ```)

  (defn __int->cstr [n : int] : cstr
    ```c
    #include <stdlib.h>
    #include <stdio.h>
    char *b = (char *)malloc(24);
    snprintf(b, 24, "%lld", (long long)n);
    return (int64_t)(intptr_t)b;
    ```)

  ;; -- Typed payload. -------------------------------------------------------

  (defstruct User [id : int  name : cstr])
  (derive-json User (id int) (name cstr))

  (defn main [] : int
    (describe "http typed client codecs -- json-request / response-decode"

      (it "json-request encodes the struct as the request body"
        (let [req (json-request "POST" "https://example.com/users"
                                (make-struct User 7 "ann") 0)]
          (assert-true (cstr-eq? "{\"id\":7,\"name\":\"ann\"}" (__req-body req)))))

      (it "json-request sets Content-Type: application/json"
        (let [req (json-request "POST" "https://example.com/users"
                                (make-struct User 7 "ann") 0)]
          (assert-true (cstr-eq? "application/json"
                                 (__req-header req "Content-Type")))))

      (it "json-request preserves the method"
        (let [req (json-request "PUT" "https://example.com/users/7"
                                (make-struct User 7 "ann") 0)]
          (assert-true (cstr-eq? "PUT" (__req-method req)))))

      (it "response-decode parses a JSON body into a typed struct"
        (let [resp (__mk-resp "{\"id\":42,\"name\":\"bob\"}")
              r    (response-decode resp User)]
          (if (ok? r)
            (let [u (ok-val r)]
              (assert-true (cstr-eq? "42" (__int->cstr (.id u)))))
            (assert-true false))))

      (it "response-decode reads the string field"
        (let [resp (__mk-resp "{\"id\":42,\"name\":\"bob\"}")
              r    (response-decode resp User)]
          (if (ok? r)
            (assert-true (cstr-eq? "bob" (.name (ok-val r))))
            (assert-true false))))

      (it "response-decode rejects a non-JSON body"
        (let [resp (__mk-resp "not json")
              r    (response-decode resp User)]
          (assert-true (not (ok? r))))))

    (run-all)))
