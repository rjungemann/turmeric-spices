;; U2/P5 negative fixture: decoding a response body into a type that has no
;; json `Decode` instance must be rejected at elaboration. `response-decode`
;; dispatches the `decode` method through a `(Result T cstr)` ascription, so a
;; `T` with no `(definstance Decode [T] ...)` (i.e. one never passed to
;; `derive-json`) has no instance to resolve.
;;
;; Verify (from the http spice root):
;;   tur check tests/errors/response-decode-missing-decode-instance.tur
;;   => error: no instance 'Decode NoCodec'
;; (reported at the `decode` call inside the `response-decode` macro expansion
;;  in http/response.tur; the point is that this fixture fails to compile.)
;;
;; Lives under tests/errors/ so the non-recursive `tur test tests` run skips
;; it -- it is a compile-fail fixture, not a runnable test. The positive
;; companion is tests/http/codec_test.tur.

(defmodule response_decode_missing_decode_instance_test (export)
  (import http/response :refer [response-decode])

  ;; NoCodec is never run through derive-json, so it has no Decode instance.
  (defstruct NoCodec [x : int])

  (defn decode-it [resp : int] : int
    (let [r (response-decode resp NoCodec)]   ;; ERROR: no instance 'Decode NoCodec'
      0))

  (defn main [] : int 0))
