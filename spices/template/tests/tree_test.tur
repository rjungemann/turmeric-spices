;; tests/tree_test.tur -- template/tree (U5 Fix TplF AST + cata).
;;
;; Pure-Turmeric: no lexer/parser/render, runs anywhere. Builds template
;; ASTs with the smart constructors and exercises the generic catamorphism
;; (size / directive-count / depth / round-trip-to-source).

(defmodule template/tests/tree
  (import template/tree :refer [Tpl tpl-end tpl-lit tpl-emit tpl-if tpl-for tpl-let
                                tpl-size tpl-directives tpl-depth tpl->str])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c return strcmp((const char *)a, (const char *)b) == 0; ```)

  ;; <% if logged-in %>Welcome back, <%= name %>!<% else %>Please sign in.<% end %>
  ;; (the canonical form of the if-else fixture)
  (defn ex-if [] : Tpl
    (tpl-if "logged-in"
            (tpl-lit "Welcome back, " (tpl-emit "name" (tpl-lit "!" (tpl-end))))
            (tpl-lit "Please sign in." (tpl-end))
            (tpl-end)))

  ;; <ul><% for [item items] %><%= item %><% end %></ul>
  (defn ex-for [] : Tpl
    (tpl-lit "<ul>"
             (tpl-for "item" "items"
                      (tpl-emit "item" (tpl-end))
                      (tpl-lit "</ul>" (tpl-end)))))

  ;; a for nested inside an if -- block depth 2
  (defn ex-nested [] : Tpl
    (tpl-if "show"
            (tpl-for "x" "xs" (tpl-emit "x" (tpl-end)) (tpl-end))
            (tpl-end)
            (tpl-end)))

  (defn main [] : int
    (do
      (describe "tpl-size (cata)"
        ;; if + then{lit,emit,lit} + else{lit} = 1 + 3 + 1 = 5
        (it "counts every content node" (assert-eq 5 (tpl-size (ex-if))))
        (it "an empty template is zero" (assert-eq 0 (tpl-size (tpl-end))))
        (it "a lone literal is one"     (assert-eq 1 (tpl-size (tpl-lit "hi" (tpl-end))))))

      (describe "tpl-directives (cata)"
        ;; ex-if has one If and one Emit (literals don't count)
        (it "counts only dynamic directives" (assert-eq 2 (tpl-directives (ex-if))))
        (it "a pure-literal template has none"
          (assert-eq 0 (tpl-directives (tpl-lit "static" (tpl-end))))))

      (describe "tpl-depth (cata)"
        (it "a flat template is depth 1" (assert-eq 1 (tpl-depth (ex-if))))
        (it "a for-in-if is depth 2"     (assert-eq 2 (tpl-depth (ex-nested))))
        (it "no blocks is depth 0"       (assert-eq 0 (tpl-depth (tpl-emit "x" (tpl-end))))))

      (describe "tpl->str (cata, round-trip to source)"
        (it "reconstructs an if/else template"
          (assert-true (cstr-eq?
            "<% if logged-in %>Welcome back, <%= name %>!<% else %>Please sign in.<% end %>"
            (tpl->str (ex-if)))))
        (it "reconstructs a for template"
          (assert-true (cstr-eq?
            "<ul><% for [item items] %><%= item %><% end %></ul>"
            (tpl->str (ex-for)))))
        (it "reconstructs a let template"
          (assert-true (cstr-eq?
            "<% let [greeting hi] %><%= greeting %><% end %>"
            (tpl->str (tpl-let "greeting" "hi"
                               (tpl-emit "greeting" (tpl-end))
                               (tpl-end))))))
        (it "round-trips a bare literal"
          (assert-true (cstr-eq? "<h1>x</h1>"
                                 (tpl->str (tpl-lit "<h1>x</h1>" (tpl-end)))))))

      (run-all)
      0)))
