;; E1 lifts the explicit arity cap from 3 (E1') to 5. This test exercises
;; the 4-component path -- not expressible with the E1' family. Spawn 100
;; entities each carrying four int-carried components A=i, B=2*i, C=3*i,
;; D=4*i, and check that for-each over [A B C D] reaches every slot and
;; the per-entity sum matches A+B+C+D = 10*i. Closed-form total = 10 * 99*100/2 = 49500.

(defmodule for-each-arity-4-test (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each])

(defcomponent A)
(defcomponent B)
(defcomponent C)
(defcomponent D)

(defworld FourWorld [A B C D])

(defn main [] : int
  (let [w (make-struct FourWorld (vec-new) (dense-new) (dense-new) (dense-new) (dense-new))]
    (do
      (let [^mut i 0]
        (while (< i 100)
          (let [e (world-alloc-entity! (.gens w))
                idx (entity-index e)]
            (dense-set! (.A w) idx i)
            (dense-set! (.B w) idx (* 2 i))
            (dense-set! (.C w) idx (* 3 i))
            (dense-set! (.D w) idx (* 4 i)))
          (set! i (+ i 1))))
      (let [^mut total 0]
        (for-each w [A B C D] [e a b c d]
          (set! total (+ total (+ a (+ b (+ c d))))))
        (println total)
        (if (= total 49500) 0 1)))))

) ;; end defmodule
