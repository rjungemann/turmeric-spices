;; E2c slice 2 -- (SizedSparse n A) round-trip + cross-domain probe.
;;
;; Two SizedSparse storages share the world's id-domain `n`. The
;; cross-parameter unifier rejects domain mismatches at compile time;
;; this fixture exercises the accept case and the runtime round-trip.
;;
;; Expected output:
;;   3
;;   2
;;   1000
;;   2000
;;   3000
;;   5

(defmodule sized_sparse_rt_test
  (export)

(import ecs/sized-sparse :refer [SizedSparse
                                  sized-sparse-new sized-sparse-len
                                  sized-sparse-set! sized-sparse-get
                                  sized-sparse-has? sized-sparse-del!
                                  sized-sparse-free sized-sparse-zip-domain])

(defn main [] : int
  (let [a : (SizedSparse (Static 128) int) (sized-sparse-new)
        b : (SizedSparse (Static 128) int) (sized-sparse-new)]
    (do
      (sized-sparse-set! a 7 1000)
      (sized-sparse-set! a 42 2000)
      (sized-sparse-set! a 99 3000)
      (sized-sparse-set! b 1 9999)
      (sized-sparse-set! b 2 8888)
      (println (sized-sparse-len a))                  ;; 3
      (println (sized-sparse-len b))                  ;; 2
      (println (sized-sparse-get a 7))                ;; 1000
      (println (sized-sparse-get a 42))               ;; 2000
      (println (sized-sparse-get a 99))               ;; 3000
      ;; Domain unification: both storages carry (Static 128).
      (println (sized-sparse-zip-domain a b))         ;; 5
      (sized-sparse-free a)
      (sized-sparse-free b)
      0)))

) ;; end defmodule sized_sparse_rt_test
