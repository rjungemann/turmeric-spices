;; E1' regression: spawn 1000 entities, write a multi-field Pos{x y} via
;; dense-set!/dense-get, then sum (.x p) across the storage. Validates that
;; the struct-ABI monomorphization fix lets a real defstruct flow through
;; the generic dense storage API. Sum is 0 + 1 + ... + 999 = 499500.

(defmodule spawn1k_pos_test
  (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])

(defstruct Pos [x : int y : int])

(defcomponent Pos)

(defworld GameWorld [Pos])

(defn main [] : int
  (let [w (make-struct GameWorld (vec-new) (dense-new))]
    (do
      (let [^mut i 0]
        (while (< i 1000)
          (let [e (world-alloc-entity! (.gens w))
                p (make-struct Pos i (* i 2))]
            (dense-set! (.Pos w) (entity-index e) p))
          (set! i (+ i 1))))
      (let [^mut sum 0
            ^mut j   0
            n        (dense-len (.Pos w))]
        (while (< j n)
          (let [p : Pos (dense-get (.Pos w) j)]
            (set! sum (+ sum (.x p))))
          (set! j (+ j 1)))
        (println sum)
        (if (= sum 499500) 0 1)))))

) ;; end defmodule spawn1k_pos_test
