;; E1: the recursive variadic for-each has NO arity cap. 12 components
;; would have failed in the dispatch-ladder era (cap was 8). Confirm
;; end-to-end with a 12-component sum.

(defmodule for-each-arity-12-test (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each])

(defopaque A :int)
(defcomponent A)
(defopaque B :int)
(defcomponent B)
(defopaque C :int)
(defcomponent C)
(defopaque D :int)
(defcomponent D)
(defopaque E :int)
(defcomponent E)
(defopaque F :int)
(defcomponent F)
(defopaque G :int)
(defcomponent G)
(defopaque H :int)
(defcomponent H)
(defopaque I :int)
(defcomponent I)
(defopaque J :int)
(defcomponent J)
(defopaque K :int)
(defcomponent K)
(defopaque L :int)
(defcomponent L)

;; defworld caps at 5 components; widen by hand for 12.
(defstruct TwelveWorld
  [gens : int
   A : (Storage A) B : (Storage B) C : (Storage C) D : (Storage D)
   E : (Storage E) F : (Storage F) G : (Storage G) H : (Storage H)
   I : (Storage I) J : (Storage J) K : (Storage K) L : (Storage L)])

(defn main [] : int
  (let [w (make-struct TwelveWorld (vec-new)
            (:: (dense-new) (Storage A)) (:: (dense-new) (Storage B)) (:: (dense-new) (Storage C)) (:: (dense-new) (Storage D))
            (:: (dense-new) (Storage E)) (:: (dense-new) (Storage F)) (:: (dense-new) (Storage G)) (:: (dense-new) (Storage H))
            (:: (dense-new) (Storage I)) (:: (dense-new) (Storage J)) (:: (dense-new) (Storage K)) (:: (dense-new) (Storage L)))]
    (do
      ;; Spawn 10 entities; component N gets value (N+1)*i.
      (let [^mut i 0]
        (while (< i 10)
          (let [ent (world-alloc-entity! (.gens w))
                idx (entity-index ent)]
            (dense-set! (.A w) idx (:: (* 1 i) :A))
            (dense-set! (.B w) idx (:: (* 2 i) :B))
            (dense-set! (.C w) idx (:: (* 3 i) :C))
            (dense-set! (.D w) idx (:: (* 4 i) :D))
            (dense-set! (.E w) idx (:: (* 5 i) :E))
            (dense-set! (.F w) idx (:: (* 6 i) :F))
            (dense-set! (.G w) idx (:: (* 7 i) :G))
            (dense-set! (.H w) idx (:: (* 8 i) :H))
            (dense-set! (.I w) idx (:: (* 9 i) :I))
            (dense-set! (.J w) idx (:: (* 10 i) :J))
            (dense-set! (.K w) idx (:: (* 11 i) :K))
            (dense-set! (.L w) idx (:: (* 12 i) :L)))
          (set! i (+ i 1))))
      ;; Per-entity sum: (1+2+...+12)*i = 78*i. Total: 78 * 9*10/2 = 3510.
      (let [^mut total 0]
        (for-each w [A B C D E F G H I J K L] [ent a b c d ee f g h i-c j k l]
          (set! total (+ total
                         (+ (:: a :int) (+ (:: b :int) (+ (:: c :int) (+ (:: d :int) (+ (:: ee :int) (+ (:: f :int)
                            (+ (:: g :int) (+ (:: h :int) (+ (:: i-c :int) (+ (:: j :int) (+ (:: k :int) (:: l :int)))))))))))))))
        (println total)
        (if (= total 3510) 0 1)))))

) ;; end defmodule
