;; X3 cross-world cycle detection. The plan rejects a stage in which
;; two systems impose a mutual cross-world ordering dependency: if S
;; writes a (world, component) that T reads *and* T writes a (world,
;; component) that S reads, no wave order can satisfy both. Such a
;; stage is ill-formed -- the user must split it with a sequencing
;; barrier. `xstage-has-cycle?` is the static check.
;;
;; S: reads (sim,A), writes (ren,B)   -- produces ren.B from sim.A
;; T: reads (ren,B), writes (sim,A)   -- produces sim.A from ren.B
;; Edges: S->T (T reads ren.B that S writes) and T->S (S reads sim.A
;; that T writes) => cycle.
;;
;; T2: reads nothing, writes (sim,A)  -- only T2->S, no back edge => acyclic.
;;
;; Expected output:
;;   cycle-detected
;;   no-cycle
;;   ok

(defmodule xworld_cycle_test
  (export)

(import ecs/system  :refer [cid-bit])
(import ecs/xsystem :refer [XSystem make-xsystem])
(import ecs/xstage  :refer [BoundXSystem make-bound-xsystem
                            XStage xstage-new xstage-add!
                            xstage-has-cycle? xstage-free!])

(def A-cid 0)   ;; component in sim
(def B-cid 0)   ;; component in ren

(defn xnoop [w0 : int w1 : int] : nil nil)

(defn main [] : int
  ;; slot 0 = sim (world-id 0), slot 1 = ren (world-id 1).
  ;; make-bound-xsystem: w0-id w0-reads w0-writes w0  w1-id w1-reads w1-writes w1  run-fn
  (let [s  (make-bound-xsystem 0 (cid-bit A-cid) 0 0  1 0 (cid-bit B-cid) 0  xnoop)
        t  (make-bound-xsystem 0 0 (cid-bit A-cid) 0  1 (cid-bit B-cid) 0 0  xnoop)
        t2 (make-bound-xsystem 0 0 (cid-bit A-cid) 0  1 0 0 0  xnoop)]
    (let [cyc (xstage-new)]
      (xstage-add! cyc s)
      (xstage-add! cyc t)
      (let [has-cyc (xstage-has-cycle? cyc)]
        (println (if has-cyc "cycle-detected" "FAIL-no-cycle"))
        (let [acyc (xstage-new)]
          (xstage-add! acyc s)
          (xstage-add! acyc t2)
          (let [no-cyc (xstage-has-cycle? acyc)]
            (println (if no-cyc "FAIL-cycle" "no-cycle"))
            (let [ok (and has-cyc (not no-cyc))]
              (xstage-free! cyc)
              (xstage-free! acyc)
              (if ok (do (println "ok") 0) (do (println "FAIL") 1)))))))))

) ;; end defmodule xworld_cycle_test
