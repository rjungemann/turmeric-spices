;; X2/X3 cross-world render-extract: a single `defxsystem` body reads
;; `Pos` from a `SimWorld` and writes `RenderPos` into a `RenderWorld`,
;; scheduled through an `XStage`. This is motivating use case #1 (render
;; extraction): the sim world holds the simulation components; a single
;; extract system projects the renderer's view into a separate world.
;;
;; The cap types pin the world: `sim-Pos-read-cap : (XReadCap SimWorld
;; Pos)` and `ren-RenderPos-write-cap : (XWriteCap RenderWorld
;; RenderPos)`. A `set-RenderPos!` minted for RenderWorld will only
;; accept the RenderWorld-keyed cap, so the body cannot write into the
;; world it only declared `:reads-from`.
;;
;; Expected output:
;;   11
;;   22
;;   ok

(defmodule xworld_extract_test
  (export)

(import ecs/sized-storage :refer [SizedDense])
(import ecs/sized-world   :refer [sized-defworld-mono])
(import ecs/xworld        :refer [sized-defcomponent-accessors-xmono])
(import ecs/xcap          :refer [XWriteCap XReadCap
                                  make-write-cap make-read-cap use-cap!])
(import ecs/xsystem       :refer [XSystem make-xsystem defxsystem])
(import ecs/xstage        :refer [BoundXSystem bind-xsystem
                                  XStage xstage-new xstage-add!
                                  xstage-n-waves xstage-run! xstage-free!])

(defopaque Pos       :int)
(defopaque RenderPos :int)

;; Two distinct world types. Component ids are world-local; both use
;; bit 0 without colliding because the conflict key is (world-id, bit).
(sized-defworld-mono SimWorld    (Static 8) [Pos])
(sized-defcomponent-accessors-xmono SimWorld Pos)

(sized-defworld-mono RenderWorld (Static 8) [RenderPos])
(sized-defcomponent-accessors-xmono RenderWorld RenderPos)

(def Pos-cid       0)
(def RenderPos-cid 0)

;; Per-world box/load/free (referenced by the C struct name, like
;; sized-stage / hstage tests).
(defn box-SimWorld [w : SimWorld] : int
  ```c
  #include <stdlib.h>
  SimWorld *p = (SimWorld *)malloc(sizeof(SimWorld));
  *p = w;
  return (int64_t)(intptr_t)p;
  ```)
(defn load-SimWorld [wp : int] : SimWorld
  ```c
  return *(SimWorld *)(intptr_t)wp;
  ```)
(defn free-SimWorld-box [wp : int] : nil
  ```c
  #include <stdlib.h>
  free((SimWorld *)(intptr_t)wp);
  ```)

(defn box-RenderWorld [w : RenderWorld] : int
  ```c
  #include <stdlib.h>
  RenderWorld *p = (RenderWorld *)malloc(sizeof(RenderWorld));
  *p = w;
  return (int64_t)(intptr_t)p;
  ```)
(defn load-RenderWorld [wp : int] : RenderWorld
  ```c
  return *(RenderWorld *)(intptr_t)wp;
  ```)
(defn free-RenderWorld-box [wp : int] : nil
  ```c
  #include <stdlib.h>
  free((RenderWorld *)(intptr_t)wp);
  ```)

;; The extract system: read Pos from sim slots 0,1; write RenderPos into
;; ren slots 0,1. Worlds in declaration order: slot 0 = sim, slot 1 = ren.
(defxsystem extract-renderables
  [sim SimWorld  ren RenderWorld]
  :reads-from  sim [Pos]
  :writes-to   sim []
  :reads-from  ren []
  :writes-to   ren [RenderPos]
  (do
    (set-RenderPos! ren-RenderPos-write-cap ren 0
      (:: (:: (get-Pos sim-Pos-read-cap sim 0) :int) :RenderPos))
    (set-RenderPos! ren-RenderPos-write-cap ren 1
      (:: (:: (get-Pos sim-Pos-read-cap sim 1) :int) :RenderPos))))

(defn main [] : int
  (let [sim : SimWorld    (make-SimWorld 8)
        ren : RenderWorld  (make-RenderWorld 8)
        ;; populate sim directly via the world-keyed setter.
        scap            (:: (make-write-cap Pos-cid) (XWriteCap SimWorld Pos))]
    (set-Pos! scap sim 0 (:: 11 :Pos))
    (let [scap2 (:: (make-write-cap Pos-cid) (XWriteCap SimWorld Pos))]
      (set-Pos! scap2 sim 1 (:: 22 :Pos)))
    (let [sp (box-SimWorld sim)
          rp (box-RenderWorld ren)
          xs (xstage-new)
          ws (bind-xsystem extract-renderables 0 sp 1 rp)]
      (xstage-add! xs ws)
      (xstage-run! xs)
      (let [ren2 : RenderWorld (load-RenderWorld rp)
            rcap            (:: (make-read-cap RenderPos-cid) (XReadCap RenderWorld RenderPos))
            v0              (:: (get-RenderPos rcap ren2 0) :int)
            v1              (:: (get-RenderPos rcap ren2 1) :int)]
        (println v0)   ;; 11
        (println v1)   ;; 22
        (let [ok (and (= v0 11) (= v1 22))]
          (xstage-free! xs)
          (free-SimWorld-box sp)
          (free-RenderWorld-box rp)
          (if ok (do (println "ok") 0) (do (println "FAIL") 1)))))))

) ;; end defmodule xworld_extract_test
