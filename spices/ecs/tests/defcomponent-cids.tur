;; GEN-V0: `defcomponent-cids` auto-numbers a component vector,
;; retiring the hand-written `(def Pos-cid 0) (def Vel-cid 1) ...`
;; boilerplate that every cross-world setup previously had to keep in
;; sync with its component declaration.
;;
;; Two `defcomponent-cids` calls in one TU must not collide: cids are
;; per-world, so `Pos-cid` and `RPos-cid` numbered independently from 0
;; is the correct behavior (matches the `(world, cid)` conflict-key
;; discipline -- see `tests/hstage-cross-world.tur`).
;;
;; Expected output:
;;   0
;;   1
;;   2
;;   0
;;   1

(defmodule defcomponent_cids_test
  (export)

(import ecs/world :refer [defcomponent-cids])

(defopaque Pos     :int)
(defopaque Vel     :int)
(defopaque Sprite  :int)
(defopaque RPos    :int)
(defopaque RSprite :int)

;; First world's cids: numbered 0..2 in declaration order.
(defcomponent-cids [Pos Vel Sprite])

;; Second world's cids: independently numbered from 0, even though the
;; component names differ. Because cids are per-world, `Pos-cid` (0) and
;; `RPos-cid` (0) do not collide -- each is used only with its own
;; world's cap discipline.
(defcomponent-cids [RPos RSprite])

(defn main [] : int
  (do
    (println Pos-cid)      ;; 0
    (println Vel-cid)      ;; 1
    (println Sprite-cid)   ;; 2
    (println RPos-cid)     ;; 0
    (println RSprite-cid)  ;; 1
    0))

) ;; end defmodule defcomponent_cids_test
