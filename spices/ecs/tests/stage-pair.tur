;; E2 smoke: two systems run sequentially via stage-run-seq, then run
;; in parallel via stage-run-pair-parallel because their masks don't
;; conflict. Each system sums a slice of a shared accumulator (gated
;; by mutex inside the impl). The final value must be the same in
;; both orderings.
;;
;; Expected output:
;;   2000               -- sequential total
;;   2000               -- parallel total
;;   conflict-check-ok
;;   ok

(defmodule stage_pair_test
  (export)

(import ecs/system :refer [System make-system system-conflicts? cid-bit])
(import ecs/stage  :refer [stage-run-seq stage-run-pair-parallel])

;; Component IDs are just bit positions. The test invents two
;; disjoint bits so the two systems don't conflict.
(def pos-cid 0)
(def vel-cid 1)
(def hp-cid  2)

;; Heap-allocated accumulator + mutex-protected helpers. Each system
;; body bumps the same int64_t through accum-add! so the final value
;; reflects both runs regardless of which thread saw which increments.
(defn make-accum [] : ptr<void>
  ```c
  #include <stdlib.h>
  int64_t *p = (int64_t *)calloc(1, sizeof(int64_t));
  return p;
  ```)

(defn accum-read [p : ptr<void>] : int
  ```c
  return *(int64_t *)p;
  ```)

(defn accum-add! [p : ptr<void> delta : int] : nil
  ```c
  #include <pthread.h>
  static pthread_mutex_t mu = PTHREAD_MUTEX_INITIALIZER;
  pthread_mutex_lock(&mu);
  *(int64_t *)p += delta;
  pthread_mutex_unlock(&mu);
  ```)

(defn accum-reset! [p : ptr<void>] : nil
  ```c
  #include <pthread.h>
  static pthread_mutex_t mu = PTHREAD_MUTEX_INITIALIZER;
  pthread_mutex_lock(&mu);
  *(int64_t *)p = 0;
  pthread_mutex_unlock(&mu);
  ```)

;; Two system impls. Each takes a world handle that's really our
;; accum pointer cast to int. Both bump the shared accumulator.
(defn physics-impl [w : int] : nil
  (let [^mut i 0]
    (while (< i 500)
      (accum-add! (:: w :ptr<void>) 1)
      (set! i (+ i 1)))))

(defn render-impl [w : int] : nil
  (let [^mut i 0]
    (while (< i 1500)
      (accum-add! (:: w :ptr<void>) 1)
      (set! i (+ i 1)))))

(defn main [] : int
  (let [accum (make-accum)
        world (:: accum :int)]
    (let [physics (make-system (cid-bit pos-cid) (cid-bit pos-cid) physics-impl)
          render  (make-system (cid-bit hp-cid)  (cid-bit hp-cid)  render-impl)]
      ;; Sequential run.
      (accum-reset! accum)
      (stage-run-seq physics render world)
      (let [seq-total (accum-read accum)]
        (println seq-total)                       ;; expect 2000
        ;; Reset, then parallel run -- non-conflicting (physics writes
        ;; POS, render writes HP, no overlap with each other's reads).
        (accum-reset! accum)
        (stage-run-pair-parallel physics render world)
        (let [par-total (accum-read accum)]
          (println par-total)                     ;; expect 2000
          (if (system-conflicts? physics render)
            (println "conflict-check-broken")
            (println "conflict-check-ok"))
          (if (and (= seq-total 2000)
                   (and (= par-total 2000)
                        (not (system-conflicts? physics render))))
            (do (println "ok") 0)
            (do (println "FAIL") 1)))))))

) ;; end defmodule stage_pair_test
