;; E2c slice 5 -- sized-for-each round-trip.
;;
;; Declares a (GameWorld n) with two int-carried component fields (Pos
;; and Vel, following the same defopaque convention as the other
;; sized-world tests). Populates four entity slots out of cap=8, then
;; iterates the slots with sized-for-each.
;;
;; The iteration walks 0..cap (= 8 here -- the static cap from the
;; world's `n`) and skips unpopulated slots via the per-component
;; sized-dense-has? checks the macro generates. Only slots 0 and 2 have
;; both Pos and Vel populated, so the body fires twice with the
;; matching pairs; slot 1 has only Pos and slot 3 has only Vel, so
;; both are skipped.
;;
;; Rectangularity is structural: every `(.Comp w)` field of
;; `w : (GameWorld (Static 8))` carries (SizedDense (Static 8) Comp),
;; so the macro's per-component sized-dense-get / sized-dense-has? calls
;; all run against (SizedDense (Static 8) _) handles -- the SZ8 cross-
;; parameter unifier already proved rectangularity at the world's
;; defstruct field types, no per-iteration min-cap probe needed.
;;
;; Expected output:
;;   0      ;; slot 0, Pos value (printed as int)
;;   100    ;; slot 0, Vel value
;;   2      ;; slot 2, Pos value
;;   300    ;; slot 2, Vel value
;;   2      ;; number of iterations the body ran (entities with both)

(defmodule sized_for_each_test
  (export)

(import ecs/sized-storage :refer [SizedDense sized-dense-set!])
(import ecs/sized-world   :refer [sized-defworld])
(import ecs/sized-query   :refer [sized-for-each])

(defopaque Pos :int)
(defopaque Vel :int)

(sized-defworld GameWorld [Pos Vel])

(defn main [] : int
  (let [w : (GameWorld (Static 8)) (make-GameWorld 8)]
    (do
      ;; slot 0: both Pos + Vel
      (sized-dense-set! (.Pos w) 0 (:: 0   :Pos))
      (sized-dense-set! (.Vel w) 0 (:: 100 :Vel))
      ;; slot 1: only Pos -- should be skipped by the intersection
      (sized-dense-set! (.Pos w) 1 (:: 1   :Pos))
      ;; slot 2: both Pos + Vel
      (sized-dense-set! (.Pos w) 2 (:: 2   :Pos))
      (sized-dense-set! (.Vel w) 2 (:: 300 :Vel))
      ;; slot 3: only Vel -- should be skipped by the intersection
      (sized-dense-set! (.Vel w) 3 (:: 400 :Vel))
      ;; slots 4..7 untouched
      (let [^mut hits 0]
        (do
          (sized-for-each w [Pos Vel] [e p v]
            (do
              (println (:: p :int))
              (println (:: v :int))
              (set! hits (+ hits 1))))
          (println hits)
          0)))))

) ;; end defmodule sized_for_each_test
