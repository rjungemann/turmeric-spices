;; X3 cross-world scheduling: the conflict key is (world-id,
;; component), so two systems that write the *same* component in
;; *different* worlds never conflict and coalesce into one wave, while
;; two that write the same (world, component) are forced into separate
;; waves -- the v1 non-conflict rule lifted point-wise over worlds.
;;
;; We build XSystems with explicit masks (this test targets the
;; scheduler, not the `defxsystem` surface) and bind them to worlds 0
;; (sim) and 1 (ren). `Pos` has cid 0 in both worlds; the bit alone is
;; identical, so only the world-id distinguishes the lock targets.
;;
;; Expected output:
;;   ok-diffworld     -- write (sim,Pos) vs write (ren,Pos): no conflict
;;   ok-sameworld     -- write (ren,Pos) vs write (ren,Pos): conflict
;;   1                -- {writeSim, writeRen} share one wave
;;   2                -- {writeRen, writeRen2} need two waves
;;   ok

(defmodule xworld_scheduling_test
  (export)

(import ecs/system :refer [cid-bit])
(import ecs/xsystem :refer [XSystem make-xsystem])
(import ecs/xstage  :refer [BoundXSystem make-bound-xsystem
                            xsystem-conflicts?
                            XStage xstage-new xstage-add!
                            xstage-n-waves xstage-run! xstage-free!])

(def Pos-cid 0)

;; A trivial two-world run-fn (the scheduler dispatches it; the bodies
;; are irrelevant to wave assignment).
(defn xnoop [w0 : int w1 : int] : nil nil)

;; Single-world write systems (slot 1 unused -> world-id -1 when bound).
;; writeP : reads nothing, writes Pos (bit 0) in its slot-0 world.
(defn make-writeP [] : XSystem
  (make-xsystem 0 (cid-bit Pos-cid) 0 0 xnoop))

(defn main [] : int
  (let [wsim-tmpl (make-writeP)
        wren-tmpl  (make-writeP)
        wren2-tmpl (make-writeP)
        ;; bind: writeSim -> world 0, writeRen / writeRen2 -> world 1.
        wsim  (make-bound-xsystem 0 0 (cid-bit Pos-cid) 0  (- 0 1) 0 0 0  xnoop)
        wren  (make-bound-xsystem 1 0 (cid-bit Pos-cid) 0  (- 0 1) 0 0 0  xnoop)
        wren2 (make-bound-xsystem 1 0 (cid-bit Pos-cid) 0  (- 0 1) 0 0 0  xnoop)
        diffworld (xsystem-conflicts? wsim wren)    ;; world 0 vs world 1 -> false
        sameworld (xsystem-conflicts? wren wren2)]  ;; both world 1 -> true
    (println (if (not diffworld) "ok-diffworld" "FAIL-diffworld"))
    (println (if sameworld      "ok-sameworld" "FAIL-sameworld"))
    ;; Stage 1: cross-world pair -> one wave.
    (let [s1 (xstage-new)]
      (xstage-add! s1 wsim)
      (xstage-add! s1 wren)
      (xstage-run! s1)
      (let [n1 (xstage-n-waves s1)]
        ;; Stage 2: same-world pair -> two waves.
        (let [s2 (xstage-new)]
          (xstage-add! s2 wren)
          (xstage-add! s2 wren2)
          (xstage-run! s2)
          (let [n2 (xstage-n-waves s2)]
            (println n1)   ;; 1
            (println n2)   ;; 2
            (let [ok (and (not diffworld)
                     (and sameworld
                     (and (= n1 1) (= n2 2))))]
              (xstage-free! s1)
              (xstage-free! s2)
              (if ok (do (println "ok") 0) (do (println "FAIL") 1)))))))))

) ;; end defmodule xworld_scheduling_test
