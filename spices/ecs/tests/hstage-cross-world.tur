;; E2c sized-scheduler direction 2 -- heterogeneous (cross-world)
;; scheduling. Two *differently-typed* sized worlds are scheduled in one
;; HStage, each system dispatched against its own boxed world.
;;
;; This is what gap-H (turmeric PRs #447/#448) unblocked: the bounded
;; world-/backend-polymorphic system surface now monomorphises at
;; heterogeneous backends, so a single stage can carry systems whose
;; worlds have distinct ABIs. The HStage carries a per-system world-id +
;; boxed world pointer; `hstage-run!` calls each run-fn against its bound
;; world rather than the single shared world `ecs/stage` passes.
;;
;; The load-bearing new guarantee is the (World, Component) conflict key:
;; `physics` writes Pos in GameWorld (world 0) and `combat` writes Hp in
;; AltWorld (world 1). Both occupy component bit 0 -- in a single-world
;; Stage their identical write masks would force two sequential waves --
;; but because they target *distinct worlds* the scheduler proves they
;; cannot race and coalesces them into one parallel wave. Meanwhile
;; `physics2` also writes Pos in GameWorld (world 0), so it *does* conflict
;; with `physics` and is pushed to a second wave. Net: 2 waves, with the
;; cross-world pair sharing wave 0.
;;
;; Expected output:
;;   ok-xworld   -- cross-world systems (same mask, different world) don't conflict
;;   ok-sameworld-- same-world systems with overlapping writes do conflict
;;   2           -- wave count: {physics, combat} then {physics2}
;;   99          -- GameWorld Pos slot 0: physics(42) then physics2(99), last wins
;;   7           -- AltWorld Hp slot 0: combat
;;   ok

(defmodule hstage_cross_world_test
  (export)

(import ecs/sized-storage :refer [SizedDense])
(import ecs/sized-world   :refer [sized-defworld-mono
                                   sized-defcomponent-accessors-mono
                                   sized-defsystem-scheduled])
(import ecs/cap           :refer [WriteCap ReadCap
                                   make-write-cap make-read-cap use-cap!])
(import ecs/system        :refer [System make-system cid-bit])
(import ecs/hstage        :refer [WorldSystem make-world-system bind-system
                                   world-system-conflicts?
                                   HStage hstage-new hstage-add! hstage-n-waves
                                   hstage-run! hstage-free!])

(defopaque Pos :int)
(defopaque Hp  :int)

;; Two distinct world TYPES. Each owns its own component bit space, so
;; Pos-cid and Hp-cid can both be 0 without colliding -- the conflict key
;; is (world-id, bit), not bit alone.
(sized-defworld-mono GameWorld (Static 8) [Pos])
(sized-defcomponent-accessors-mono GameWorld Pos)

(sized-defworld-mono AltWorld (Static 8) [Hp])
(sized-defcomponent-accessors-mono AltWorld Hp)

(def Pos-cid 0)
(def Hp-cid  0)

;; Per-world box/load/free. As in sized-stage.tur these reference the C
;; struct name verbatim, so they stay user-written.
(defn box-GameWorld [w : GameWorld] : int
  ```c
  #include <stdlib.h>
  GameWorld *p = (GameWorld *)malloc(sizeof(GameWorld));
  *p = w;
  return (int64_t)(intptr_t)p;
  ```)
(defn load-GameWorld [wp : int] : GameWorld
  ```c
  return *(GameWorld *)(intptr_t)wp;
  ```)
(defn free-GameWorld-box [wp : int] : nil
  ```c
  #include <stdlib.h>
  free((GameWorld *)(intptr_t)wp);
  ```)

(defn box-AltWorld [w : AltWorld] : int
  ```c
  #include <stdlib.h>
  AltWorld *p = (AltWorld *)malloc(sizeof(AltWorld));
  *p = w;
  return (int64_t)(intptr_t)p;
  ```)
(defn load-AltWorld [wp : int] : AltWorld
  ```c
  return *(AltWorld *)(intptr_t)wp;
  ```)
(defn free-AltWorld-box [wp : int] : nil
  ```c
  #include <stdlib.h>
  free((AltWorld *)(intptr_t)wp);
  ```)

;; physics + physics2 both write Pos in GameWorld; combat writes Hp in
;; AltWorld. physics2 runs after physics (separate wave), so Pos ends 99.
(sized-defsystem-scheduled physics  GameWorld [Pos] [Pos]
  (set-Pos! Pos-write-cap w 0 (:: 42 :Pos)))
(sized-defsystem-scheduled physics2 GameWorld [Pos] [Pos]
  (set-Pos! Pos-write-cap w 0 (:: 99 :Pos)))
(sized-defsystem-scheduled combat   AltWorld  [Hp]  [Hp]
  (set-Hp! Hp-write-cap w 0 (:: 7 :Hp)))

(defn main [] : int
  (let [wa  : GameWorld (make-GameWorld 8)
        wb  : AltWorld  (make-AltWorld 8)
        wpa            (box-GameWorld wa)
        wpb            (box-AltWorld wb)
        ;; Bind each system to its world (world-id 0 = GameWorld, 1 = AltWorld).
        wphysics        (bind-system physics  0 wpa)
        wphysics2       (bind-system physics2 0 wpa)
        wcombat         (bind-system combat   1 wpb)]
    ;; Direct conflict-key checks.
    (let [xworld   (world-system-conflicts? wphysics wcombat)   ;; diff world -> false
          sameworld (world-system-conflicts? wphysics wphysics2)] ;; same world, both write Pos -> true
      (println (if (not xworld)   "ok-xworld"    "FAIL-xworld"))
      (println (if sameworld      "ok-sameworld" "FAIL-sameworld"))
      (let [hs (hstage-new)]
        (hstage-add! hs wphysics)
        (hstage-add! hs wcombat)
        (hstage-add! hs wphysics2)
        (hstage-run! hs)
        (let [n     (hstage-n-waves hs)
              wa2   : GameWorld (load-GameWorld wpa)
              wb2   : AltWorld  (load-AltWorld  wpb)
              pcap            (:: (make-read-cap Pos-cid) (ReadCap Pos))
              hcap            (:: (make-read-cap Hp-cid)  (ReadCap Hp))
              p-val           (get-Pos pcap wa2 0)
              h-val           (get-Hp  hcap wb2 0)]
          (println n)                       ;; 2
          (println (:: p-val :int))         ;; 99
          (println (:: h-val :int))         ;; 7
          (let [ok (and (not xworld)
                   (and sameworld
                   (and (= n 2)
                   (and (= (:: p-val :int) 99)
                        (= (:: h-val :int) 7)))))]
            (hstage-free! hs)
            (free-GameWorld-box wpa)
            (free-AltWorld-box wpb)
            (if ok (do (println "ok") 0) (do (println "FAIL") 1))))))))

) ;; end defmodule hstage_cross_world_test
