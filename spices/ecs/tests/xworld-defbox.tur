;; GEN-V0: `defworld-box-helpers` emits `box-<W>` / `load-<W>` /
;; `free-<W>-box` from a single macro call instead of three hand-rolled
;; inline-C blocks. Same end-to-end shape as `xworld-extract.tur`: an
;; extract system reads `Pos` from a `SimWorld` and writes `RenderPos`
;; into a `RenderWorld`, scheduled via `XStage`. The macro-emitted
;; helpers must be call-compatible with the cross-world plumbing
;; (`bind-xsystem` / `xstage-add!` / `xstage-run!`), and the round-trip
;; values must match the hand-written-helpers fixture exactly.
;;
;; Expected output:
;;   11
;;   22
;;   ok

(defmodule xworld_defbox_test
  (export)

(import ecs/sized-storage :refer [SizedDense])
(import ecs/sized-world   :refer [sized-defworld-mono])
(import ecs/xworld        :refer [sized-defcomponent-accessors-xmono
                                  defworld-box-helpers])
(import ecs/xcap          :refer [XWriteCap XReadCap
                                  make-write-cap make-read-cap use-cap!])
(import ecs/xsystem       :refer [XSystem make-xsystem defxsystem])
(import ecs/xstage        :refer [BoundXSystem bind-xsystem
                                  XStage xstage-new xstage-add!
                                  xstage-n-waves xstage-run! xstage-free!])

(defopaque Pos       :int)
(defopaque RenderPos :int)

(sized-defworld-mono SimWorld    (Static 8) [Pos])
(sized-defcomponent-accessors-xmono SimWorld Pos)
(defworld-box-helpers SimWorld)

(sized-defworld-mono RenderWorld (Static 8) [RenderPos])
(sized-defcomponent-accessors-xmono RenderWorld RenderPos)
(defworld-box-helpers RenderWorld)

(def Pos-cid       0)
(def RenderPos-cid 0)

(defxsystem extract-renderables
  [sim SimWorld  ren RenderWorld]
  :reads-from sim [Pos]
  :writes-to  ren [RenderPos]
  (do
    (set-RenderPos! ren-RenderPos-write-cap ren 0
      (:: (:: (get-Pos sim-Pos-read-cap sim 0) :int) :RenderPos))
    (set-RenderPos! ren-RenderPos-write-cap ren 1
      (:: (:: (get-Pos sim-Pos-read-cap sim 1) :int) :RenderPos))))

(defn main [] : int
  (let [sim : SimWorld    (make-SimWorld 8)
        ren : RenderWorld  (make-RenderWorld 8)
        scap            (:: (make-write-cap Pos-cid) (XWriteCap SimWorld Pos))]
    (set-Pos! scap sim 0 (:: 11 :Pos))
    (set-Pos! scap sim 1 (:: 22 :Pos))
    (use-cap! scap)
    (let [sp (box-SimWorld sim)
          rp (box-RenderWorld ren)
          xs (xstage-new)
          ws (bind-xsystem extract-renderables 0 sp 1 rp)]
      (xstage-add! xs ws)
      (xstage-run! xs)
      (let [ren2 : RenderWorld (load-RenderWorld rp)
            rcap            (:: (make-read-cap RenderPos-cid) (XReadCap RenderWorld RenderPos))
            v0              (:: (get-RenderPos rcap ren2 0) :int)
            v1              (:: (get-RenderPos rcap ren2 1) :int)]
        (println v0)
        (println v1)
        (let [ok (and (= v0 11) (= v1 22))]
          (xstage-free! xs)
          (free-SimWorld-box sp)
          (free-RenderWorld-box rp)
          (if ok (do (println "ok") 0) (do (println "FAIL") 1)))))))

) ;; end defmodule xworld_defbox_test
