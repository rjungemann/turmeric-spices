;; E2c slice 11 follow-up -- sized-defworld-world-resize: grow a sized
;; world to a fresh *runtime* capacity, handed back inside the
;; size-hiding existential (exists [n'] (GameWorld n')). This is the
;; thin client layer over copy-into-<Name>: it allocates the larger
;; world, threads the gens array + components through copy-into, and
;; packs the result so the caller recovers an abstract n' via `open`
;; and drives the sized API (accessors, sized-for-each) against it.
;;
;; Setup mirrors sized-world-copy-into.tur's src so the resize path is
;; checked against the same generational invariants:
;;   (GameWorld (Static 4)) -- src
;;     spawn 4 entities, populate Pos = slot * 10
;;     despawn entity 1 (frees its slot, bumps gens[1])
;;
;;   (world-resize-GameWorld src 8) -- grow to runtime cap 8, sealed as
;;     (exists [n'] (GameWorld n'))
;;
;; After opening the resized world:
;;   - Pos values at slots 0, 2, 3 round-trip into the resized world
;;   - sized-alive? agrees for the still-live src entities (gens copied)
;;   - the despawned entity 1 stays not-alive (gen mismatch)
;;   - live count equals 3 (copied from src.live)
;;   - sized-for-each over the opened abstract-n' world visits every
;;     slot whose Pos storage is populated (loop bound is the runtime
;;     cap 8, has?-gated). Note despawn bumps a slot's generation but
;;     does NOT clear its component storage -- aliveness is the
;;     generational guard, storage presence is independent -- so slot 1
;;     still carries Pos=10 and copy-into preserves it. for-each
;;     therefore visits it; sized-alive? is what distinguishes the
;;     despawned handle, not storage presence.
;;
;; Expected output:
;;   0                ;; resized Pos at slot 0
;;   20               ;; resized Pos at slot 2
;;   30               ;; resized Pos at slot 3
;;   true             ;; e0 alive in resized world
;;   true             ;; e2 alive in resized world
;;   true             ;; e3 alive in resized world
;;   false            ;; despawned e1 still not-alive
;;   3                ;; resized live count
;;   0                ;; sized-for-each: slot 0 Pos
;;   10               ;; sized-for-each: slot 1 Pos (despawned, storage kept)
;;   20               ;; sized-for-each: slot 2 Pos
;;   30               ;; sized-for-each: slot 3 Pos

(defmodule sized_world_resize_test
  (export)

(import ecs/sized-storage :refer [SizedDense sized-dense-set!
                                   sized-dense-get])
(import ecs/sized-world   :refer [sized-defworld
                                   sized-defworld-copy-into
                                   sized-defworld-world-resize
                                   sized-spawn! sized-despawn
                                   sized-alive? sized-live])
(import ecs/sized-query   :refer [sized-for-each])
(import ecs/entity        :refer [entity-index])

(defopaque Pos :int)

(sized-defworld GameWorld [Pos])
(sized-defworld-copy-into GameWorld [Pos])
(sized-defworld-world-resize GameWorld)

(defn main [] : int
  (let [src : (GameWorld (Static 4)) (make-GameWorld 4)]
    (do
      (let [e0 (sized-spawn! (.state src))
            e1 (sized-spawn! (.state src))
            e2 (sized-spawn! (.state src))
            e3 (sized-spawn! (.state src))]
        (do
          (sized-dense-set! (.Pos src) (entity-index e0) (:: 0  :Pos))
          (sized-dense-set! (.Pos src) (entity-index e1) (:: 10 :Pos))
          (sized-dense-set! (.Pos src) (entity-index e2) (:: 20 :Pos))
          (sized-dense-set! (.Pos src) (entity-index e3) (:: 30 :Pos))
          ;; Despawn e1 -- bumps gens[1] in src, so e1 must stay dead in
          ;; the resized world even though we never touch its gens.
          (sized-despawn (.state src) e1)
          ;; The resize: grow to runtime cap 8, sealed existentially.
          (let [packed (world-resize-GameWorld src 8)]
            (open packed [n' dst]
              (do
                (println (:: (sized-dense-get (.Pos dst) 0) :int))  ;; 0
                (println (:: (sized-dense-get (.Pos dst) 2) :int))  ;; 20
                (println (:: (sized-dense-get (.Pos dst) 3) :int))  ;; 30
                (println (sized-alive? (.state dst) e0))            ;; true
                (println (sized-alive? (.state dst) e2))            ;; true
                (println (sized-alive? (.state dst) e3))            ;; true
                (println (sized-alive? (.state dst) e1))            ;; false
                (println (sized-live  (.state dst)))                ;; 3
                ;; The payoff: iterate the opened abstract-n' world. The
                ;; loop bound is the runtime cap (8); has?-gating visits
                ;; every populated Pos slot. Slot 1's data survives the
                ;; despawn (storage is not cleared), so it appears here
                ;; even though e1 is no longer sized-alive?.
                (sized-for-each dst [Pos] [e p]
                  (println (:: (sized-dense-get (.Pos dst) e) :int)))
                0))))))))

) ;; end defmodule sized_world_resize_test
