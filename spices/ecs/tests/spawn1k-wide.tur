;; E2d-P5b regression: a `defworld` with EIGHT components -- past the old
;; arity-5 cascade cap. Proves the variadic `defworld` collapse: the field
;; list is computed at macro-expansion time (`world-fields` recursion +
;; `~@` splice) instead of a per-arity helper, so arity is unbounded.
;;
;; Spawns 1000 entities, writes value `i` into all eight components for each,
;; then sums one component's column. Expected: 0 + 1 + ... + 999 = 499500.
;; A non-trivial subset (c3, c8) is also summed to confirm the later fields
;; in the struct -- the ones the old cascade could not emit -- round-trip.

(defmodule spawn1k_wide_test
  (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])

;; Eight payload-less marker components (int carrier, as in spawn1k).
(defopaque C1 :int) (defopaque C2 :int) (defopaque C3 :int) (defopaque C4 :int)
(defopaque C5 :int) (defopaque C6 :int) (defopaque C7 :int) (defopaque C8 :int)

(defcomponent C1) (defcomponent C2) (defcomponent C3) (defcomponent C4)
(defcomponent C5) (defcomponent C6) (defcomponent C7) (defcomponent C8)

;; Eight components -> eight `(Storage Cn)` fields. Uncapped arity.
(defworld WideWorld [C1 C2 C3 C4 C5 C6 C7 C8])

(defn main [] : int
  (let [w (make-struct WideWorld (vec-new)
            (:: (dense-new) (Storage C1)) (:: (dense-new) (Storage C2))
            (:: (dense-new) (Storage C3)) (:: (dense-new) (Storage C4))
            (:: (dense-new) (Storage C5)) (:: (dense-new) (Storage C6))
            (:: (dense-new) (Storage C7)) (:: (dense-new) (Storage C8)))]
    (do
      (let [^mut i 0]
        (while (< i 1000)
          (let [e   (world-alloc-entity! (.gens w))
                idx (entity-index e)]
            (dense-set! (.C1 w) idx (:: i :C1))
            (dense-set! (.C2 w) idx (:: i :C2))
            (dense-set! (.C3 w) idx (:: i :C3))
            (dense-set! (.C4 w) idx (:: i :C4))
            (dense-set! (.C5 w) idx (:: i :C5))
            (dense-set! (.C6 w) idx (:: i :C6))
            (dense-set! (.C7 w) idx (:: i :C7))
            (dense-set! (.C8 w) idx (:: i :C8)))
          (set! i (+ i 1))))
      ;; Sum the last field (C8) -- the one the old 5-arity cascade
      ;; physically could not emit -- and a middle field (C3).
      (let [^mut s3 0
            ^mut s8 0
            ^mut j  0
            n       (dense-len (.C8 w))]
        (while (< j n)
          (let [v3 : C3 (dense-get (.C3 w) j)
                v8 : C8 (dense-get (.C8 w) j)]
            (set! s3 (+ s3 (:: v3 :int)))
            (set! s8 (+ s8 (:: v8 :int))))
          (set! j (+ j 1)))
        (println s3)
        (println s8)
        (if (and (= s3 499500) (= s8 499500)) 0 1)))))

) ;; end defmodule spawn1k_wide_test
