;; I2 regression: defcomponent-class-instance emits per-(World, Comp)
;; mint helpers `mint-<World>-<Comp>-write-cap` / `mint-<World>-<Comp>-read-cap`.
;; Minting + consuming a WriteCap<Pos> from GameWorld's helper
;; elaborates under -Xsubstructural; minting + consuming a WriteCap<Vel>
;; from the same world's helper is a distinct nominal type.
;;
;; Expected output:
;;   ok

(defmodule cap_mint_per_instance_test
  (export)

(import ecs/world :refer [defcomponent-class defcomponent-class-instance])
(import ecs/cap   :refer [WriteCap ReadCap make-write-cap make-read-cap use-cap!])

(defstruct Pos [x : int])
(defstruct Vel [x : int])
(defstruct GameWorld [Pos : int Vel : int])

(defcomponent-class Pos)
(defcomponent-class Vel)
(defcomponent-class-instance GameWorld Pos)
(defcomponent-class-instance GameWorld Vel)

(def pos-cid 0)
(def vel-cid 1)

(defn main [] : int
  (let [pos-cap (mint-GameWorld-Pos-write-cap pos-cid)
        vel-cap (mint-GameWorld-Vel-write-cap vel-cid)]
    (use-cap! pos-cap)
    (use-cap! vel-cap)
    (println "ok")
    0))

) ;; end defmodule cap_mint_per_instance_test
