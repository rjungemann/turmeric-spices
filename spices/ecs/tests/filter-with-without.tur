;; E1' filter smoke test: spawn 100 entities with Pos = i, mark every 5th
;; entity Dead, every 3rd Player. Iterate Pos AND tagged Player AND NOT
;; Dead, sum. Verifies that world-tagged? / world-untagged? compose with
;; for-each1 inside the body.
;;
;; Players (i % 3 == 0):  0, 3, 6, ..., 99
;; Dead    (i % 5 == 0):  0, 5, 10, ..., 95
;; Player AND NOT Dead:   3,6,9,12,18,21,24,27,33,36,...
;;                        (i % 3 == 0 AND i % 5 != 0)
;; Sum of those i in [0, 100) = (0+3+6+...+99) - (0+15+30+45+60+75+90)
;;                            = 1683 - 315 = 1368.

(defmodule filter_test
  (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-set!])
(import ecs/tag     :refer [tag-new tag-set!])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each1 world-tagged? world-untagged?])

(defcomponent Pos)

;; defworld emits fields named after each component; both Player and Dead
;; here are tag bitsets sharing the same field-naming convention.
(defworld GameWorld [Pos Player Dead])

(defn main [] : int
  (let [w (make-struct GameWorld (vec-new) (dense-new) (tag-new) (tag-new))]
    (do
      (let [^mut i 0]
        (while (< i 100)
          (let [e (world-alloc-entity! (.gens w))
                idx (entity-index e)]
            (dense-set! (.Pos w) idx i)
            (when (= 0 (mod i 3)) (tag-set! (.Player w) idx))
            (when (= 0 (mod i 5)) (tag-set! (.Dead w)   idx)))
          (set! i (+ i 1))))
      (let [^mut sum 0]
        (for-each1 w Pos e p
          (when (and (world-tagged? w Player e)
                     (world-untagged? w Dead e))
            (set! sum (+ sum p))))
        (println sum)
        (if (= sum 1368) 0 1)))))

) ;; end defmodule filter_test
