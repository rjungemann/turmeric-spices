;; E2d-P6 regression: the StorageOps class drives insert/get/has? by the
;; storage handle's type. A single helper sequence -- written against the
;; StorageOps methods -- is reused over both a (Dense Hp) and a (Sparse Hp)
;; handle. Swapping the backend is one line at the call site (`dense-new`
;; vs `sparse-new`); the insert/get/has? code is identical. That is the
;; "swap the backend with one line" claim, now carried by the type system
;; rather than prose.
;;
;; `Hp` is an int-carried opaque, matching the plan's P6 scope: every
;; storage handle and every element here rides the int64 carrier, so the
;; method C signatures are honest. (A by-value *struct* element would
;; monomorphise the instance's Elem to the int64 carrier and mismatch the
;; struct ABI -- the value-level projection caveat the plan gates P6
;; against; struct components keep the dense-* path until that lands.)
;;
;; `storage-get` is ascribed at its use site (`(:: ... Hp)`) because the
;; associated Elem is not yet projected in return position; see the
;; ecs/storage-ops docstring. Polymorphic-wrapper note: a body bounded on
;; `[S] [(StorageOps S)]` does not link today (same monomorphisation gap as
;; defcomponent-class's typeclass-bounded wrappers), so this dispatches
;; through monomorphic helpers typed against concrete handles -- the
;; shipped surface.
;;
;; Expected output:
;;   70   -- dense get-back
;;   true -- dense has?
;;   99   -- sparse get-back
;;   true -- sparse has?
;;   ok

(defmodule storage_ops_poly_test
  (export)

(import ecs/storage     :refer [Dense  dense-new])
(import ecs/sparse      :refer [Sparse sparse-new])
;; Importing ecs/storage-ops brings the StorageOps class and its
;; Dense/Sparse instances into scope transitively (they are not exported
;; value names, like Component).
(import ecs/storage-ops)

;; An int-carried marker component (no struct payload).
(defopaque Hp :int)

;; Monomorphic dispatch through StorageOps over a dense handle.
(defn dense-store-read [s : (Dense Hp) e : int v : Hp] : Hp
  (storage-insert! s e v)
  (:: (storage-get s e) Hp))

;; The identical method call sequence over a sparse handle -- only the
;; handle's type changed.
(defn sparse-store-read [s : (Sparse Hp) e : int v : Hp] : Hp
  (storage-insert! s e v)
  (:: (storage-get s e) Hp))

(defn dense-present? [s : (Dense Hp) e : int] : bool
  (storage-has? s e))

(defn sparse-present? [s : (Sparse Hp) e : int] : bool
  (storage-has? s e))

(defn main [] : int
  (let [d   (:: (dense-new)  (Dense  Hp))
        sp  (:: (sparse-new) (Sparse Hp))
        dv  (dense-store-read  d  0 (:: 70 Hp))
        spv (sparse-store-read sp 0 (:: 99 Hp))
        dh  (dense-present?  d  0)
        sph (sparse-present? sp 0)]
    (println (:: dv  int))   ;; 70
    (println dh)             ;; true
    (println (:: spv int))   ;; 99
    (println sph)            ;; true
    (if (and (= (:: dv int) 70)
        (and dh
        (and (= (:: spv int) 99) sph)))
      (do (println "ok") 0)
      (do (println "FAIL") 1))))

) ;; end defmodule storage_ops_poly_test
