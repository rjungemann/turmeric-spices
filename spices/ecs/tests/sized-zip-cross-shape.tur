;; E2c slice 2 -- cross-shape rectangularity probe.
;;
;; The load-bearing demonstration that one `n` index unifies across
;; every storage representation in a world. A (SizedDense (Static 64))
;; + (SizedSparse (Static 64)) + (SizedTag (Static 64)) all share the
;; same `n`, so sized-zip-all-three type-checks and runs without a
;; per-shape min-cap probe.
;;
;; Expected output:
;;   1
;;   1

(defmodule sized_zip_cross_shape_test
  (export)

(import ecs/sized-storage :refer [SizedDense sized-dense-new sized-dense-len
                                   sized-dense-set! sized-dense-free])
(import ecs/sized-sparse  :refer [SizedSparse sized-sparse-new sized-sparse-set!
                                   sized-sparse-free])
(import ecs/sized-tag     :refer [SizedTag sized-tag-new sized-tag-set!
                                   sized-tag-free])
(import ecs/sized-zip     :refer [sized-zip-all-three])

(defn main [] : int
  (let [d : (SizedDense  (Static 64) int) (sized-dense-new 64)
        s : (SizedSparse (Static 64) int) (sized-sparse-new)
        t : (SizedTag    (Static 64))     (sized-tag-new 64)]
    (do
      (sized-dense-set!  d 0 42)
      (sized-sparse-set! s 1 100)
      (sized-sparse-set! s 2 200)
      (sized-sparse-set! s 3 300)
      (sized-tag-set!    t 5)
      ;; Force same-TU instantiation of the generic sized-dense-len
      ;; the cross-shape probe will call from inside another generic.
      (println (sized-dense-len d))                   ;; 1
      ;; All three storages share n=(Static 64); the cross-shape
      ;; type-checks. Probe returns dense-len = 1 (we wrote slot 0).
      ;; Sparse + tag participate only in the static unification.
      (println (sized-zip-all-three d s t))           ;; 1
      (sized-dense-free  d)
      (sized-sparse-free s)
      (sized-tag-free    t)
      0)))

) ;; end defmodule sized_zip_cross_shape_test
