;; E2 + gap H regression: defcomponent-class + defcomponent-class-instance
;; mint a `Has<Comp>` typeclass and bind a (world, component) pair
;; into it. Methods dispatch on receiver type, so a monomorphic call
;; site routes correctly to the per-world instance.
;;
;; gap H item 2 (typed-method-param SEGV) is fixed; items 1 and 3
;; remain open, so polymorphic-wrapper systems are NOT supported here
;; -- only direct dispatch through a concrete world receiver. The
;; ECS plan's "typeclass-bounded systems" path needs items 1/3 too.
;;
;; Expected output:
;;   100  -- direct call to Pos-storage-of
;;   200  -- direct call to Vel-storage-of
;;   ok

(defmodule has_component_class_test
  (export)

(import ecs/world :refer [defcomponent-class defcomponent-class-instance])
;; I2: defcomponent-class-instance now also emits per-component cap-mint
;; helpers that reference ecs/cap symbols at the call site's scope.
(import ecs/cap   :refer [WriteCap ReadCap make-write-cap make-read-cap])

(defstruct GameWorld [Pos : int Vel : int])

(defcomponent-class Pos)
(defcomponent-class Vel)
(defcomponent-class-instance GameWorld Pos)
(defcomponent-class-instance GameWorld Vel)

(defn main [] : int
  (let [w (make-struct GameWorld 100 200)]
    (println (Pos-storage-of w))     ;; 100
    (println (Vel-storage-of w))     ;; 200
    (if (and (= (Pos-storage-of w) 100)
             (= (Vel-storage-of w) 200))
      (do (println "ok") 0)
      (do (println "FAIL") 1))))

) ;; end defmodule has_component_class_test
