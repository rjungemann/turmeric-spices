;; E2c sized-scheduler -- wire a sized (GameWorld) through the parallel
;; Stage scheduler via the report's recommended "by heap pointer"
;; direction (now resolved -- see docs/archive/sized-scheduler-system-
;; stage-world-carrier.md, direction 1). The sized world is a multi-int64
;; struct so it cannot ride the one-word run-fn carrier by value; instead
;; we heap-box the world, pass its pointer reinterpreted as :int through
;; the existing System / Stage run-fn carrier, and have each system's
;; run-fn load the world struct back from the pointer to drive the
;; cap-gated typed accessors.
;;
;; The `box-GameWorld` / `load-GameWorld` / `free-GameWorld-box` triple is
;; three short inline-C blocks referencing the C struct name verbatim --
;; macros cannot splice identifiers into inline-C text (see
;; docs/archive/history/macro-cannot-emit-inline-c-block.md), so the
;; triple stays user-written. Everything downstream -- the typed body,
;; the int-carrier wrapper, the System value packed with the right reads/
;; writes masks -- is collapsed into one `sized-defsystem-scheduled`
;; call, and cap-binding / auto-consume come back compared to the prior
;; hand-rolled `[wp : int]` run-fns that bypassed them.
;;
;; The Pos and Hp fields are independent storage handles inside the world
;; struct; the two systems read/write disjoint masks so the wave scheduler
;; runs them concurrently in a single wave. Mutations applied through the
;; loaded copy of the world flow through the shared int64 storage handles,
;; so re-loading the boxed world after `stage-run!` observes the writes.
;;
;; Expected output:
;;   1               -- single conflict-free wave
;;   42              -- Pos slot 0 mutated by physics
;;   7               -- Hp  slot 0 mutated by combat
;;   ok

(defmodule sized_stage_test
  (export)

(import ecs/sized-storage :refer [SizedDense])
(import ecs/sized-world   :refer [sized-defworld-mono
                                   sized-defcomponent-accessors-mono
                                   sized-defsystem-scheduled])
(import ecs/cap           :refer [WriteCap ReadCap
                                   make-write-cap make-read-cap use-cap!])
(import ecs/system        :refer [System make-system cid-bit])
(import ecs/stage         :refer [Stage stage-new stage-add! stage-n-waves
                                   stage-run! stage-free!])

(defopaque Pos :int)
(defopaque Hp  :int)

(sized-defworld-mono GameWorld (Static 8) [Pos Hp])
(sized-defcomponent-accessors-mono GameWorld Pos)
(sized-defcomponent-accessors-mono GameWorld Hp)

(def Pos-cid 0)
(def Hp-cid  1)

;; Heap-box / load / free for GameWorld. The struct is { Pos:i64, Hp:i64,
;; state:i64 } -- three int64 handles into shared heap storage -- so a
;; by-value copy after `load-GameWorld` keeps every accessor pointed at
;; the same underlying dense arrays and state cell. These three helpers
;; are the per-world boilerplate `sized-defsystem-scheduled` cannot
;; auto-generate (inline-C text is opaque to the reader; the C struct
;; name `GameWorld` cannot be spliced from a macro).
(defn box-GameWorld [w : GameWorld] : int
  ```c
  #include <stdlib.h>
  GameWorld *p = (GameWorld *)malloc(sizeof(GameWorld));
  *p = w;
  return (int64_t)(intptr_t)p;
  ```)

(defn load-GameWorld [wp : int] : GameWorld
  ```c
  return *(GameWorld *)(intptr_t)wp;
  ```)

(defn free-GameWorld-box [wp : int] : nil
  ```c
  #include <stdlib.h>
  free((GameWorld *)(intptr_t)wp);
  ```)

;; physics -- writes Pos slot 0. Cap-bound: Pos-write-cap is in scope
;; from the macro's `defsystem--with-write-caps` lowering and is
;; auto-consumed at body end. Disjoint mask from combat so the wave
;; scheduler places both systems in the same wave.
(sized-defsystem-scheduled physics GameWorld [Pos] [Pos]
  (set-Pos! Pos-write-cap w 0 (:: 42 :Pos)))

;; combat -- writes Hp slot 0.
(sized-defsystem-scheduled combat GameWorld [Hp] [Hp]
  (set-Hp! Hp-write-cap w 0 (:: 7 :Hp)))

(defn main [] : int
  (let [w     : GameWorld (make-GameWorld 8)
        wp                (box-GameWorld w)
        stage             (stage-new)]
    (do
      (stage-add! stage physics)
      (stage-add! stage combat)
      (stage-run! stage wp)
      (let [n-waves (stage-n-waves stage)]
        (println n-waves))                              ;; 1
      ;; Re-load the boxed world to read the mutations the systems applied
      ;; through the shared storage handles.
      (let [w2    : GameWorld (load-GameWorld wp)
            pcap              (:: (make-read-cap Pos-cid) (ReadCap Pos))
            hcap              (:: (make-read-cap Hp-cid)  (ReadCap Hp))
            p-val             (get-Pos pcap w2 0)
            h-val             (get-Hp  hcap w2 0)]
        (do
          (println (:: p-val :int))                     ;; 42
          (println (:: h-val :int))                     ;; 7
          (let [ok (and (= (stage-n-waves stage) 1)
                        (and (= (:: p-val :int) 42)
                             (= (:: h-val :int) 7)))]
            (stage-free! stage)
            (free-GameWorld-box wp)
            (if ok
              (do (println "ok") 0)
              (do (println "FAIL") 1))))))))

) ;; end defmodule sized_stage_test
