;; E2c slice 4 -- sized-spawn! / sized-despawn over a (GameWorld n).
;;
;; A bounded-capacity world of n=4 (cap=4) is filled with 4 spawn!
;; calls; each returns the slot id. sized-despawn (slice 4b)
;; decrements the live count and pushes the freed slot onto the
;; free-list; the freed slot is then handed back by the next spawn.
;; The slice-4b slot-reuse story is exercised by tests/sized-world-
;; reuse.tur; this test stays focused on the spawn / despawn /
;; sized-live / sized-cap surface.
;;
;; The fallible variant `sized-spawn : ... -> (Result int WorldFull)`
;; the design plan calls out is deferred until the M3 struct-carrier
;; path handles generic ok/err calls correctly; until then callers
;; guard with sized-live/sized-cap before sized-spawn!.
;;
;; Expected output:
;;   4
;;   0
;;   1
;;   2
;;   3
;;   4
;;   true
;;   3
;;   4

(defmodule sized_world_spawn_test
  (export)

(import ecs/sized-storage :refer [SizedDense])
(import ecs/sized-world   :refer [sized-defworld
                                   sized-spawn! sized-despawn
                                   sized-live sized-cap])

(defopaque Pos :int)

(sized-defworld GameWorld [Pos])

(defn main [] : int
  (let [w : (GameWorld (Static 4)) (make-GameWorld 4)]
    (do
      (println (sized-cap (.state w)))                ;; 4
      (println (sized-spawn! (.state w)))             ;; 0
      (println (sized-spawn! (.state w)))             ;; 1
      (println (sized-spawn! (.state w)))             ;; 2
      (println (sized-spawn! (.state w)))             ;; 3
      (println (sized-live (.state w)))               ;; 4
      ;; The pre-check pattern callers should use today:
      (println (= (sized-live (.state w))
                  (sized-cap  (.state w))))           ;; true (world full)
      (sized-despawn (.state w) 0)
      (println (sized-live (.state w)))               ;; 3
      (println (sized-cap  (.state w)))               ;; 4
      0)))

) ;; end defmodule sized_world_spawn_test
