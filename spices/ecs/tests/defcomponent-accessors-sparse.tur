;; E2d-P6 regression: defcomponent-accessors now lowers to the StorageOps
;; methods (storage-insert! / storage-get / storage-has?) instead of the
;; hard-coded dense-* family, so the *same* accessor body drives whichever
;; backend the component's Component instance selects. This is the "swap
;; the backend with one line" payoff: Vel registers its Storage as
;; (Sparse Vel), so set-Vel! / get-Vel / has-Vel? dispatch the sparse
;; StorageOps instance -- byte-identical accessor code to the dense
;; defcomponent-accessors test, only the Component registration changed.
;;
;; Struct round-trip through the sparse backend exercises the parametric
;; struct-element projection that landed in turmeric 2026-06-19 (without it
;; storage-get's Elem carrier-collapsed to int64 and truncated the struct).
;;
;; Expected output:
;;   3    -- get-Vel returned Vel with x=3
;;   4    -- get-Vel returned Vel with y=4
;;   true -- has-Vel? returns true after set
;;   ok

(defmodule defcomponent_accessors_sparse_test
  (export)

(import ecs/entity  :refer [entity-index])
(import ecs/sparse  :refer [sparse-new])
(import ecs/world   :refer [defworld defcomponent-accessors world-alloc-entity!])
(import ecs/cap     :refer [WriteCap ReadCap make-write-cap make-read-cap use-cap!])

(defstruct Vel [x : int y : int])

;; Register Vel against the *sparse* backend by hand. `defcomponent` only
;; spells the dense default today; this is the explicit sparse spelling, and
;; the routed accessors pick it up with no other change.
(definstance Component [Vel]
  (type Storage = (Sparse Vel)))

(defworld GameWorld [Vel])
(defcomponent-accessors GameWorld Vel)

(def Vel-cid 0)

(defn main [] : int
  (let [w   (make-struct GameWorld (vec-new) (:: (sparse-new) (Storage Vel)))
        e   (world-alloc-entity! (.gens w))
        wc  (:: (make-write-cap Vel-cid) (WriteCap Vel))
        rc  (:: (make-read-cap  Vel-cid) (ReadCap  Vel))]
    (set-Vel! wc w (entity-index e) (make-struct Vel 3 4))
    (let [p       (get-Vel rc w (entity-index e))
          present (has-Vel? w (entity-index e))]
      (println (.x p))                 ;; 3
      (println (.y p))                 ;; 4
      (println present)                ;; true
      (use-cap! wc)
      (if (and (= (.x p) 3)
               (and (= (.y p) 4) present))
        (do (println "ok") 0)
        (do (println "FAIL") 1)))))

) ;; end defmodule defcomponent_accessors_sparse_test
