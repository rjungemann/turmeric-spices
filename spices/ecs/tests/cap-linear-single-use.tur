;; I1 regression: WriteCap<T> is a parametric :linear opaque; minting
;; one and consuming it exactly once via use-cap! elaborates and runs.
;;
;; Expected output:
;;   ok

(defmodule cap_linear_single_use_test
  (export)

(import ecs/cap :refer [WriteCap make-write-cap use-cap!])

(defstruct Pos [x : int y : int])

(defn main [] : int
  (let [cap (:: (make-write-cap 0) (WriteCap Pos))]
    (use-cap! cap)
    (println "ok")
    0))

) ;; end defmodule cap_linear_single_use_test
