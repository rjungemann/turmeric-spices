(defmodule query-type-test (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [Query make-query query-world])

(defstruct Pos [x : int y : int])
(defstruct Vel [x : int y : int])
(defcomponent Pos)
(defcomponent Vel)

(defworld GameWorld [Pos Vel])

;; A row-typed Query handle: phantom #row{Pos Vel} input, #row{Pos} output.
;; The (Query #row{...} #row{...}) ascription pins the row arguments at the
;; type level. Rows erase at codegen.
(defn make-pv-query [w : int] : (Query #row{Pos Vel} #row{Pos})
  (:: (make-struct Query w) (Query #row{Pos Vel} #row{Pos})))

;; Polymorphic over the input/output rows: extracts the world handle from
;; any Query, regardless of its component-row arguments.
(defn extract [^&in ^&out] [q : (Query in out)] : int
  (.world q))

(defn main [] : int
  (let [w (make-struct GameWorld (vec-new) (:: (dense-new) (Storage Pos)) (:: (dense-new) (Storage Vel)))
        q (make-pv-query 42)
        h (extract q)]
    (println h)
    (if (= h 42) 0 1)))

) ;; end defmodule
