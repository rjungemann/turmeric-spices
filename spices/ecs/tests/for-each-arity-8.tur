;; E1 lifts the for-each arity cap to 8. This test exercises the
;; highest-arity dispatch path with 30 entities, each carrying
;; A=i, B=2i, C=3i, D=4i, E=5i, F=6i, G=7i, H=8i. Per-entity sum is
;; 36*i; total = 36 * 29*30/2 = 15660.

(defmodule for-each-arity-8-test (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each])

(defopaque A :int)
(defcomponent A)
(defopaque B :int)
(defcomponent B)
(defopaque C :int)
(defcomponent C)
(defopaque D :int)
(defcomponent D)
(defopaque E :int)
(defcomponent E)
(defopaque F :int)
(defcomponent F)
(defopaque G :int)
(defcomponent G)
(defopaque H :int)
(defcomponent H)

;; defworld caps at 5 components; we widen for this test inline by
;; declaring the world struct directly.
(defstruct EightWorld
  [gens : int
   A : (Storage A) B : (Storage B) C : (Storage C) D : (Storage D)
   E : (Storage E) F : (Storage F) G : (Storage G) H : (Storage H)])

(defn main [] : int
  (let [w (make-struct EightWorld (vec-new)
            (:: (dense-new) (Storage A)) (:: (dense-new) (Storage B))
            (:: (dense-new) (Storage C)) (:: (dense-new) (Storage D))
            (:: (dense-new) (Storage E)) (:: (dense-new) (Storage F))
            (:: (dense-new) (Storage G)) (:: (dense-new) (Storage H)))]
    (do
      (let [^mut i 0]
        (while (< i 30)
          (let [ent (world-alloc-entity! (.gens w))
                idx (entity-index ent)]
            (dense-set! (.A w) idx (:: i :A))
            (dense-set! (.B w) idx (:: (* 2 i) :B))
            (dense-set! (.C w) idx (:: (* 3 i) :C))
            (dense-set! (.D w) idx (:: (* 4 i) :D))
            (dense-set! (.E w) idx (:: (* 5 i) :E))
            (dense-set! (.F w) idx (:: (* 6 i) :F))
            (dense-set! (.G w) idx (:: (* 7 i) :G))
            (dense-set! (.H w) idx (:: (* 8 i) :H)))
          (set! i (+ i 1))))
      (let [^mut total 0]
        (for-each w [A B C D E F G H] [ent a b c d ee f g h]
          (set! total (+ total (+ (:: a :int) (+ (:: b :int) (+ (:: c :int) (+ (:: d :int) (+ (:: ee :int) (+ (:: f :int) (+ (:: g :int) (:: h :int)))))))))))
        (println total)
        (if (= total 15660) 0 1)))))

) ;; end defmodule
