;; E2c slice 11 -- sized-defworld-copy-into round-trip: grow a sized
;; world by copying into a larger one, with Entity-handle preservation
;; across the resize.
;;
;; Setup:
;;   (GameWorld (Static 4)) -- src
;;     spawn 4 entities (fills the world)
;;     populate Pos = slot * 10 for each
;;     despawn entity 1 (so its slot is free and gens[1] bumps to 1)
;;
;;   (GameWorld (Static 8)) -- dst, twice the capacity
;;     copy-into-GameWorld src dst
;;
;; After the copy:
;;   - Pos values at slots 0, 2, 3 round-trip into dst
;;   - sized-alive? agrees on dst for the still-live src entities
;;     (gens copied, so e0/e2/e3 still match dst.gens[idx])
;;   - The despawned entity 1 stays not-alive in dst (gen mismatch)
;;   - dst.live equals 3 (copied from src.live)
;;
;; Expected output:
;;   0                ;; dst Pos at slot 0
;;   20               ;; dst Pos at slot 2
;;   30               ;; dst Pos at slot 3
;;   true             ;; e0 alive in dst
;;   true             ;; e2 alive in dst
;;   true             ;; e3 alive in dst
;;   false            ;; despawned e1 still not-alive in dst
;;   3                ;; dst live count

(defmodule sized_world_copy_into_test
  (export)

(import ecs/sized-storage :refer [SizedDense sized-dense-set!
                                   sized-dense-get])
(import ecs/sized-world   :refer [sized-defworld
                                   sized-defworld-copy-into
                                   sized-spawn! sized-despawn
                                   sized-alive? sized-live])
(import ecs/entity        :refer [entity-index])

(defopaque Pos :int)

(sized-defworld GameWorld [Pos])
(sized-defworld-copy-into GameWorld [Pos])

(defn main [] : int
  (let [src : (GameWorld (Static 4)) (make-GameWorld 4)
        dst : (GameWorld (Static 8)) (make-GameWorld 8)]
    (do
      (let [e0 (sized-spawn! (.state src))
            e1 (sized-spawn! (.state src))
            e2 (sized-spawn! (.state src))
            e3 (sized-spawn! (.state src))]
        (do
          (sized-dense-set! (.Pos src) (entity-index e0) (:: 0  :Pos))
          (sized-dense-set! (.Pos src) (entity-index e1) (:: 10 :Pos))
          (sized-dense-set! (.Pos src) (entity-index e2) (:: 20 :Pos))
          (sized-dense-set! (.Pos src) (entity-index e3) (:: 30 :Pos))
          ;; Despawn e1 -- bumps gens[1] in src, so e1 is no longer
          ;; alive in src and (after the copy) is no longer alive in
          ;; dst either, even though we never touched dst's gens.
          (sized-despawn (.state src) e1)
          ;; The actual resize: copy every populated slot + the full
          ;; gens array from src to dst.
          (copy-into-GameWorld src dst)
          (let [p0 : Pos (sized-dense-get (.Pos dst) 0)
                p2 : Pos (sized-dense-get (.Pos dst) 2)
                p3 : Pos (sized-dense-get (.Pos dst) 3)]
            (do
              (println (:: p0 :int))                       ;; 0
              (println (:: p2 :int))                       ;; 20
              (println (:: p3 :int))                       ;; 30
              (println (sized-alive? (.state dst) e0))     ;; true
              (println (sized-alive? (.state dst) e2))     ;; true
              (println (sized-alive? (.state dst) e3))     ;; true
              ;; Despawned-then-resized entity stays dead in dst.
              (println (sized-alive? (.state dst) e1))     ;; false
              (println (sized-live  (.state dst)))         ;; 3
              0)))))))

) ;; end defmodule sized_world_copy_into_test
