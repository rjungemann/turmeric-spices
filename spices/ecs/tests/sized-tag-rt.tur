;; E2c slice 2 -- (SizedTag n) round-trip + cross-cap probe.
;;
;; Allocates two SizedTag bitsets at (Static 128); sets/tests/clears,
;; then the cross-parameter unifier proves their `n` matches.
;;
;; Expected output:
;;   128
;;   true
;;   true
;;   false
;;   2
;;   1
;;   128

(defmodule sized_tag_rt_test
  (export)

(import ecs/sized-tag :refer [SizedTag
                               sized-tag-new sized-tag-cap sized-tag-count
                               sized-tag-set! sized-tag-clear! sized-tag-has?
                               sized-tag-free sized-tag-zip-cap])

(defn main [] : int
  (let [a : (SizedTag (Static 128)) (sized-tag-new 128)
        b : (SizedTag (Static 128)) (sized-tag-new 128)]
    (do
      (sized-tag-set! a 5)
      (sized-tag-set! a 100)
      (sized-tag-set! b 7)
      (println (sized-tag-cap a))                     ;; 128
      (println (sized-tag-has? a 5))                  ;; true
      (println (sized-tag-has? a 100))                ;; true
      (println (sized-tag-has? a 6))                  ;; false
      (println (sized-tag-count a))                   ;; 2
      (println (sized-tag-count b))                   ;; 1
      (println (sized-tag-zip-cap a b))               ;; 128
      (sized-tag-free a)
      (sized-tag-free b)
      0)))

) ;; end defmodule sized_tag_rt_test
