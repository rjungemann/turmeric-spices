;; E1 functional surface: `defquery` names a for-each iteration as a
;; defn over a concrete world type; `run-query!` calls it. This is the
;; closest mapping of the plan's
;;   def integrate-q (query in out fn ...)
;;   run-query! integrate-q world
;; shape that the current macro system supports cleanly.

(defmodule defquery-integrate-test (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each defquery run-query!])

(defcomponent Pos)
(defcomponent Vel)

(defworld GameWorld [Pos Vel])

;; defquery: name the Pos += Vel iteration as a callable defn over a
;; GameWorld value. Syntax: (defquery name world-name WorldType comps binds body).
;; The world is borrowed so callers can reuse it after run-query!.
(defquery integrate w GameWorld [Pos Vel] [e p v]
  (dense-set! (.Pos w) e (+ p v)))

(defn main [] : int
  (let [w (make-struct GameWorld (vec-new) (dense-new) (dense-new))]
    (do
      ;; Spawn 500 entities, same shape as integrate2: Pos=i, Vel=2.
      (let [^mut i 0]
        (while (< i 500)
          (let [ent (world-alloc-entity! (.gens w))]
            (dense-set! (.Pos w) (entity-index ent) i)
            (dense-set! (.Vel w) (entity-index ent) 2))
          (set! i (+ i 1))))
      ;; Apply the named query via run-query!.
      (run-query! integrate w)
      ;; Verify the closed form: sum of (i+2) for i in 0..499 = 125750.
      (let [^mut sum 0
            ^mut j   0
            n        (dense-len (.Pos w))]
        (while (< j n)
          (when (dense-has? (.Pos w) j)
            (set! sum (+ sum (dense-get (.Pos w) j))))
          (set! j (+ j 1)))
        (println sum)
        (if (= sum 125750) 0 1)))))

) ;; end defmodule
