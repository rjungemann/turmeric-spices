;; E1 for-each smoke test: the variadic-looking surface
;;   (for-each w [Pos Vel] [e p v] body)
;; expands by dispatch to for-each2 and produces the same result as the
;; E1' integrate2 fixture. Pos += Vel for 500 entities, sum the
;; post-integration Pos values, check the closed-form total.

(defmodule for-each-variadic-test (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each])

(defcomponent Pos)
(defcomponent Vel)

(defworld GameWorld [Pos Vel])

(defn main [] : int
  (let [w (make-struct GameWorld (vec-new) (dense-new) (dense-new))]
    (do
      (let [^mut i 0]
        (while (< i 500)
          (let [e (world-alloc-entity! (.gens w))]
            (dense-set! (.Pos w) (entity-index e) i)
            (dense-set! (.Vel w) (entity-index e) 2))
          (set! i (+ i 1))))
      (for-each w [Pos Vel] [e p v]
        (dense-set! (.Pos w) e (+ p v)))
      (let [^mut sum 0
            ^mut j   0
            n        (dense-len (.Pos w))]
        (while (< j n)
          (when (dense-has? (.Pos w) j)
            (set! sum (+ sum (dense-get (.Pos w) j))))
          (set! j (+ j 1)))
        (println sum)
        (if (= sum 125750) 0 1)))))

) ;; end defmodule
