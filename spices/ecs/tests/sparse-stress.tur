;; E1' patch-1 stress test: interleave set!/del! against a parallel
;; ground-truth tag bitset for 10,000 ops over a 2,000-index keyspace
;; (cap will settle around 4096, target load ~0.4). After each op,
;; assert sparse-len == popcount(bitset). At the end, every key the
;; bitset reports live must round-trip through sparse-has? and back.
;;
;; A linear-congruential generator drives the index choices so the
;; test is deterministic and exit code reflects pass/fail without
;; reading stdout.
;;
;; Expected: "ok" on one line, exit 0.

(defmodule sparse_stress
  (export)

(import ecs/sparse :refer [sparse-new sparse-len sparse-set!
                            sparse-has? sparse-del! sparse-free])
(import ecs/tag    :refer [tag-new tag-count tag-set! tag-clear!
                            tag-has? tag-free])

(defn lcg [seed : int] : int
  ```c
  /* Numerical Recipes LCG constants. */
  return (int64_t)((uint64_t)seed * 1664525ULL + 1013904223ULL);
  ```)

(defn main [] : int
  (let [s (sparse-new)
        b (tag-new)]
    (do
      (let [^mut state 12345
            ^mut op    0
            ^mut bad   0]
        (while (< op 10000)
          (set! state (lcg state))
          (let [idx (mod (mod state 4000) 2000)]    ;; keyspace [0, 2000)
            (set! state (lcg state))
            (if (= 0 (mod state 2))
              ;; insert
              (do
                (sparse-set! s idx op)
                (tag-set! b idx))
              ;; delete
              (do
                (sparse-del! s idx)
                (tag-clear! b idx)))
            (when (not (= (sparse-len s) (tag-count b)))
              (set! bad (+ bad 1))))
          (set! op (+ op 1)))
        ;; Final consistency sweep: every index the bitset says is live
        ;; must register as present in the sparse storage.
        (let [^mut k 0]
          (while (< k 2000)
            (when (and (tag-has? b k) (not (sparse-has? s k)))
              (set! bad (+ bad 1)))
            (when (and (not (tag-has? b k)) (sparse-has? s k))
              (set! bad (+ bad 1)))
            (set! k (+ k 1))))
        (sparse-free s)
        (tag-free b)
        (if (= bad 0)
          (do (println "ok") 0)
          (do (println bad) 1))))))

) ;; end defmodule sparse_stress
