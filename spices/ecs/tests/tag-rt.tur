;; E1' tag bitset round-trip: mark every 7th entity in [0, 1000), check
;; popcount, clear half, recount.
;;
;; Expected:
;;   143   -- ceil(1000/7) = 143
;;   1000  -- cap grew past the highest set bit
;;   72    -- after clearing every other set bit

(defmodule tag_rt_test
  (export)

(import ecs/tag :refer [tag-new tag-cap tag-count tag-set! tag-clear!
                         tag-has? tag-free])

(defn main [] : int
  (let [t (tag-new)]
    (do
      (let [^mut i 0]
        (while (< i 1000)
          (when (= 0 (mod i 7))
            (tag-set! t i))
          (set! i (+ i 1))))
      (println (tag-count t))                              ;; 143
      (if (tag-has? t 0)  (println "ok-0")  (println "missing-0"))
      (if (tag-has? t 1)  (println "phantom-1") (println "ok-1"))
      (if (tag-has? t 994) (println "ok-994") (println "missing-994"))
      (if (>= (tag-cap t) 1000) (println "cap-ok") (println "cap-low"))
      (let [^mut j 0]
        (while (< j 1000)
          (when (and (= 0 (mod j 7)) (= 0 (mod (/ j 7) 2)))
            (tag-clear! t j))
          (set! j (+ j 1))))
      (println (tag-count t))                              ;; 71
      (tag-free t)
      0)))

) ;; end defmodule tag_rt_test
