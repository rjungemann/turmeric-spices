;; E1' for-each2 smoke test: integrate Pos += Vel for 500 entities, then
;; sum every entity's Pos. Pos and Vel are int-carried (encode (x*1000+y))
;; so the int-carrier API path is exercised end-to-end. The sum check
;; equals the closed form 500 * (initial + Vel*1) per axis.

(defmodule integrate2_test
  (export)

(import ecs/entity  :refer [entity-index])
(import ecs/storage :refer [dense-new dense-len dense-set! dense-get dense-has?])
(import ecs/world   :refer [defcomponent defworld world-alloc-entity!])
(import ecs/query   :refer [for-each2])

(defopaque Pos :int)
(defcomponent Pos)
(defopaque Vel :int)
(defcomponent Vel)

(defworld GameWorld [Pos Vel])

(defn main [] : int
  (let [w (make-struct GameWorld (vec-new) (:: (dense-new) (Storage Pos)) (:: (dense-new) (Storage Vel)))]
    (do
      ;; Spawn 500 entities. Entity i gets Pos=i, Vel=2.
      (let [^mut i 0]
        (while (< i 500)
          (let [e (world-alloc-entity! (.gens w))]
            (dense-set! (.Pos w) (entity-index e) (:: i :Pos))
            (dense-set! (.Vel w) (entity-index e) (:: 2 :Vel)))
          (set! i (+ i 1))))
      ;; Integrate: Pos += Vel for every entity with both components.
      (for-each2 w Pos Vel e p v
        (dense-set! (.Pos w) e (:: (+ (:: p :int) (:: v :int)) :Pos)))
      ;; Sum the post-integration Pos values.
      (let [^mut sum 0
            ^mut j   0
            n        (dense-len (.Pos w))]
        (while (< j n)
          (when (dense-has? (.Pos w) j)
            (let [pv : Pos (dense-get (.Pos w) j)] (set! sum (+ sum (:: pv :int)))))
          (set! j (+ j 1)))
        (println sum)
        ;; Sum of (i+2) for i in 0..499 = (0+1+...+499) + 500*2 = 124750 + 1000 = 125750.
        (if (= sum 125750) 0 1)))))

) ;; end defmodule integrate2_test
