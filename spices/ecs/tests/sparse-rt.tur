;; E1' sparse storage round-trip: insert N items at sparse indices, verify
;; len, presence, value round-trip, and delete-of-half. Tunable N so the
;; backward-shift logic is exercised across a growing capacity.

(defmodule sparse_rt_test
  (export)

(import ecs/sparse :refer [sparse-new sparse-len sparse-set! sparse-get
                            sparse-has? sparse-del! sparse-free])

(defn main [] : int
  (let [s (sparse-new)]
    (do
      ;; Insert 100 entries at odd indices 1, 3, 5, ..., 199.
      (let [^mut i 0]
        (while (< i 100)
          (sparse-set! s (+ (* i 2) 1) (* i 10))
          (set! i (+ i 1))))
      (println (sparse-len s))           ;; 100
      ;; Check round-trip on a sampled key.
      (println (sparse-get s 21))        ;; 100 (i=10)
      ;; Even indices should be absent.
      (if (sparse-has? s 0) (println "phantom-0") (do))
      (if (sparse-has? s 4) (println "phantom-4") (do))
      ;; Delete every key, verify count returns to 0.
      (let [^mut j 0]
        (while (< j 100)
          (sparse-del! s (+ (* j 2) 1))
          (set! j (+ j 1))))
      (println (sparse-len s))           ;; 0
      (sparse-free s)
      (if (= 0 (sparse-len (sparse-new))) 0 1))))

) ;; end defmodule sparse_rt_test
