;; E2c slice 3 -- sized-defworld macro round-trip.
;;
;; Declares a polymorphic bounded-capacity world `(GameWorld n)` with
;; two int-carried component fields (Pos and Vel are encoded as ints,
;; following the integrate2.tur convention -- struct-by-value
;; components hit a pre-existing monomorphization gap, see
;; docs/archive/history/generic-inline-c-struct-arg-monomorphises-to-int64.md
;; and the M3 long tail). The macro emits a defstruct + a
;; make-GameWorld constructor; this fixture exercises both and the
;; cross-parameter unifier on (.Pos w) + (.Vel w).
;;
;; Expected output:
;;   42
;;   7
;;   2
;;   2

(defmodule sized_world_rt_test
  (export)

(import ecs/sized-storage :refer [SizedDense sized-dense-new sized-dense-len
                                   sized-dense-set! sized-dense-get
                                   sized-dense-zip-len])
(import ecs/sized-world   :refer [sized-defworld])

;; Components are int-carried defopaque newtypes; this gives Pos and
;; Vel real types that the sized-defworld's (SizedDense n Pos) field
;; types can name without involving struct-by-value monomorphization.
(defopaque Pos :int)
(defopaque Vel :int)

(sized-defworld GameWorld [Pos Vel])

(defn main [] : int
  (let [w : (GameWorld (Static 64)) (make-GameWorld 64)]
    (do
      (sized-dense-set! (.Pos w) 0 (:: 42  :Pos))
      (sized-dense-set! (.Pos w) 1 (:: 7   :Pos))
      (sized-dense-set! (.Vel w) 0 (:: 100 :Vel))
      (sized-dense-set! (.Vel w) 1 (:: 200 :Vel))
      (let [p0 : Pos (sized-dense-get (.Pos w) 0)
            p1 : Pos (sized-dense-get (.Pos w) 1)]
        (do
          (println (:: p0 :int))                        ;; 42
          (println (:: p1 :int))))
      (println (sized-dense-len (.Pos w)))              ;; 2
      (println (sized-dense-zip-len (.Pos w) (.Vel w))) ;; 2
      0)))

) ;; end defmodule sized_world_rt_test
