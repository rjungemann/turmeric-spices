(defmodule poly-call-test (export)
(import ecs/query :refer [Query make-query query-world])

(defstruct Pos [x : int y : int])

;; Row-polymorphic caller using query-world (the previously-broken case).
(defn extract [^&in ^&out] [q : (Query in out)] : int
  (query-world q))

(defn main [] : int
  (let [q (:: (make-struct Query 99) (Query #row{Pos} #row{Pos}))]
    (println (extract q))
    0))
) ;; end defmodule
