;; tests/session/file_store_test.tur -- filesystem store round-trip + escaping.
(defmodule session/tests/file-store
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-true assert-eq])
  (import test/runner :refer [run-all])
  (import session/data       :refer [sessmap-new sessmap-set! sessmap-get
                                     sessmap-count sessmap-free])
  (import session/store      :refer [store-load store-save store-delete])
  (import session/file-store :refer [file-store-new])

(defn seq? [a : cstr b : cstr] : bool
  ```c
  #include <string.h>
  return strcmp((const char *)a, (const char *)b) == 0;
  ```)

(defn loaded-val? [h : int key : cstr want : cstr] : bool
  (let [r (sessmap-get (:: h :SessMap) key)]
    (if (.is-ok r) (seq? (.ok-val r) want) false)))

(defn tmpdir [] : cstr
  ```c
  #include <stdlib.h>
  #include <string.h>
  char tpl[] = "/tmp/tursess-test-XXXXXX";
  char *d = mkdtemp(tpl);
  return (const char *)strdup(d ? d : "/tmp/tursess-test-fb");
  ```)

(defn main [] : int
 (do
  (describe "session/file-store"
    (it "misses an unknown id"
      (let [s (file-store-new (tmpdir))]
        (assert-eq (store-load s "nope") 0)))

    (it "round-trips values, escaping quotes and tabs"
      (let [s (file-store-new (tmpdir))
            m (sessmap-new)]
        (sessmap-set! (:: m :SessMap) "user_id" "42")
        (sessmap-set! (:: m :SessMap) "note" "he said \"hi\"\tbye")
        (store-save s "id1" (:: m :SessMap) 3600)
        (sessmap-free (:: m :SessMap))
        (let [h (store-load s "id1")
              ok (and (loaded-val? h "user_id" "42")
                      (and (loaded-val? h "note" "he said \"hi\"\tbye")
                           (= (sessmap-count (:: h :SessMap)) 2)))]
          (sessmap-free (:: h :SessMap))
          (assert-true ok))))

    (it "deletes a session file"
      (let [s (file-store-new (tmpdir))
            m (sessmap-new)]
        (sessmap-set! (:: m :SessMap) "k" "v")
        (store-save s "id2" (:: m :SessMap) 3600)
        (sessmap-free (:: m :SessMap))
        (store-delete s "id2")
        (assert-eq (store-load s "id2") 0)))

    (it "ttl<=0 persists as a non-expiring session"
      (let [s (file-store-new (tmpdir))
            m (sessmap-new)]
        (sessmap-set! (:: m :SessMap) "k" "v")
        (store-save s "id3" (:: m :SessMap) 0)   ;; 0 = no expiry
        (sessmap-free (:: m :SessMap))
        (let [h (store-load s "id3")
              ok (loaded-val? h "k" "v")]
          (sessmap-free (:: h :SessMap))
          (assert-true ok)))))
  (run-all)
  0))

) ;; end module
