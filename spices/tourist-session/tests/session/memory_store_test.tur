;; tests/session/memory_store_test.tur -- memory store via the Store vtable.
(defmodule session/tests/memory-store
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-true assert-eq])
  (import test/runner :refer [run-all])
  (import session/data         :refer [sessmap-new sessmap-set! sessmap-get
                                       sessmap-free])
  (import session/store        :refer [store-load store-save store-delete])
  (import session/memory-store :refer [memory-store-new memory-store-count])

(defn seq? [a : cstr b : cstr] : bool
  ```c
  #include <string.h>
  return strcmp((const char *)a, (const char *)b) == 0;
  ```)

(defn loaded-val? [h : int key : cstr want : cstr] : bool
  (let [r (sessmap-get (:: h :SessMap) key)]
    (if (.is-ok r) (seq? (.ok-val r) want) false)))

(defn main [] : int
 (do
  (describe "session/memory-store"
    (it "misses an unknown id"
      (let [s (memory-store-new)]
        (assert-eq (store-load s "nope") 0)))

    (it "saves and loads a session"
      (let [s (memory-store-new)
            m (sessmap-new)]
        (sessmap-set! (:: m :SessMap) "user_id" "42")
        (store-save s "id1" (:: m :SessMap) 3600)
        (sessmap-free (:: m :SessMap))
        (let [h (store-load s "id1")
              ok (loaded-val? h "user_id" "42")]
          (sessmap-free (:: h :SessMap))
          (assert-true (and ok (= (memory-store-count s) 1))))))

    (it "loaded copy is isolated from the master"
      (let [s (memory-store-new)
            m (sessmap-new)]
        (sessmap-set! (:: m :SessMap) "k" "orig")
        (store-save s "id2" (:: m :SessMap) 3600)
        (sessmap-free (:: m :SessMap))
        (let [h1 (store-load s "id2")]
          (sessmap-set! (:: h1 :SessMap) "k" "mutated")
          (sessmap-free (:: h1 :SessMap)))
        (let [h2 (store-load s "id2")
              ok (loaded-val? h2 "k" "orig")]
          (sessmap-free (:: h2 :SessMap))
          (assert-true ok))))

    (it "deletes a session"
      (let [s (memory-store-new)
            m (sessmap-new)]
        (sessmap-set! (:: m :SessMap) "k" "v")
        (store-save s "id3" (:: m :SessMap) 3600)
        (sessmap-free (:: m :SessMap))
        (store-delete s "id3")
        (assert-true (and (= (store-load s "id3") 0)
                          (= (memory-store-count s) 0))))))
  (run-all)
  0))

) ;; end module
