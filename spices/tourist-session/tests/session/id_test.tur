;; tests/session/id_test.tur -- session ID generation properties.
(defmodule session/tests/id
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-true assert-eq])
  (import test/runner :refer [run-all])
  (import session/id  :refer [session-id-new])

(defn clen [s : cstr] : int
  ```c
  #include <string.h>
  return (int64_t)strlen((const char *)s);
  ```)

(defn all-hex? [s : cstr] : bool
  ```c
  for (const char *p = (const char *)s; *p; p++) {
    char c = *p;
    if (!((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f'))) return false;
  }
  return true;
  ```)

(defn differ? [a : cstr b : cstr] : bool
  ```c
  #include <string.h>
  return strcmp((const char *)a, (const char *)b) != 0;
  ```)

(defn main [] : int
 (do
  (describe "session/id"
    (it "is 64 characters"
      (assert-eq (clen (session-id-new)) 64))
    (it "is lowercase hex"
      (assert-true (all-hex? (session-id-new))))
    (it "is unique across calls"
      (assert-true (differ? (session-id-new) (session-id-new)))))
  (run-all)
  0))

) ;; end module
