;; tests/session/data_test.tur -- SessMap behaviour.
(defmodule session/tests/data
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq assert-true assert-false])
  (import test/runner :refer [run-all])
  (import session/data :refer [sessmap-new sessmap-set! sessmap-get sessmap-del!
                               sessmap-count sessmap-clone sessmap-free])

(defn seq? [a : cstr b : cstr] : bool
  ```c
  #include <string.h>
  return strcmp((const char *)a, (const char *)b) == 0;
  ```)

(defn val-is? [m : int key : cstr want : cstr] : bool
  (let [r (sessmap-get (:: m :SessMap) key)]
    (if (.is-ok r) (seq? (.ok-val r) want) false)))

(defn missing? [m : int key : cstr] : bool
  (let [r (sessmap-get (:: m :SessMap) key)] (if (.is-ok r) false true)))

(defn main [] : int
 (do
  (describe "session/data"
  (it "sets and gets values"
    (let [m (sessmap-new)]
      (sessmap-set! (:: m :SessMap) "user_id" "42")
      (assert-true (val-is? (:: m :int) "user_id" "42"))))

  (it "overwrites an existing key in place"
    (let [m (sessmap-new)]
      (sessmap-set! (:: m :SessMap) "k" "1")
      (sessmap-set! (:: m :SessMap) "k" "2")
      (assert-true (and (val-is? (:: m :int) "k" "2")
                        (= (sessmap-count (:: m :SessMap)) 1)))))

  (it "reports missing keys"
    (let [m (sessmap-new)]
      (assert-true (missing? (:: m :int) "nope"))))

  (it "deletes keys"
    (let [m (sessmap-new)]
      (sessmap-set! (:: m :SessMap) "a" "1")
      (sessmap-set! (:: m :SessMap) "b" "2")
      (sessmap-del! (:: m :SessMap) "a")
      (assert-true (and (missing? (:: m :int) "a")
                        (= (sessmap-count (:: m :SessMap)) 1)))))

  (it "clone is an independent deep copy"
    (let [m (sessmap-new)]
      (sessmap-set! (:: m :SessMap) "x" "orig")
      (let [c (sessmap-clone (:: m :SessMap))]
        (sessmap-set! (:: m :SessMap) "x" "changed")
        (assert-true (and (val-is? (:: c :int) "x" "orig")
                          (val-is? (:: m :int) "x" "changed"))))))) ;; describe
  (run-all)
  0))

) ;; end module
