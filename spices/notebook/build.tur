(defpackage tur-notebook
  :name        "tur-notebook"
  :version     "0.1.0"
  :description "Literate .tur.md notebooks for Turmeric"
  :license     "MIT"
  :spices #{
    "test" #{:url      "https://github.com/rjungemann/turmeric-spices"
             :ref      "test-v0.1.0"
             :subdir   "spices/test"
             :optional true}
    "ansi" #{:url    "https://github.com/rjungemann/turmeric-spices"
             :ref    "ansi-v0.1.3"
             :subdir "spices/ansi"}
    "png" #{:url    "https://github.com/rjungemann/turmeric-spices"
            :ref    "main"
            :subdir "spices/png"}
  }
  :exports #{
    "notebook/cmark" ["md-tag-document" "md-tag-heading" "md-tag-paragraph"
                      "md-tag-blockquote" "md-tag-list" "md-tag-list-item"
                      "md-tag-code-block" "md-tag-thematic-break"
                      "md-tag-table" "md-tag-table-row" "md-tag-table-cell"
                      "md-tag-text" "md-tag-emph" "md-tag-strong"
                      "md-tag-code-span" "md-tag-link" "md-tag-image"
                      "md-tag-strikethrough"
                      "md-tag-autolink" "md-tag-hard-break" "md-tag-soft-break"
                      "md-tag-math-block" "md-tag-math-inline"
                      "md-parse"
                      "md-node-tag" "md-node-children" "md-node-text"
                      "md-node-info" "md-node-meta" "md-source-span"
                      "md-emit" "md-emit-html"]
    "notebook/cell"  ["parse-attrs" "attr-get" "attr-get-bool" "attr-get-int"
                      "attr-name" "attr-value"
                      "cell-make" "cell-id" "cell-lang" "cell-source" "cell-attrs"
                      "cell-start-line" "cell-end-line"
                      "cells-assign-ids"]
    "notebook/format" ["parse-file" "parse-string"
                      "node-tag" "node-prose" "node-cell"
                      "nodes->str" "nodes-update-cell"]
    "notebook/session" ["notebook-session-autolink-hint"
                       "output-status-ok" "output-status-error" "output-status-skipped"
                       "session-open" "session-close" "session-reset" "session-eval"
                       "cell-output-make"
                       "cell-output-cell-id" "cell-output-status" "cell-output-stdout"
                       "cell-output-value-repr" "cell-output-error-msg"
                       "cell-output-elapsed-ms" "cell-output-image-paths"]
    "notebook/cache" ["cache-open" "cache-close" "cache-get" "cache-put" "cache-clear"]
    "notebook/image" ["image-marker" "image-hook-record-path"
                      "image-hook-install" "image-hook-take"
                      "png->data-url" "image-display-tui"]
    "notebook/eval" ["eval-cell" "eval-all" "eval-from"]
    "notebook/keys" ["default-keybindings" "load-keybindings" "action-dispatch"]
    "notebook/render-md" ["render-opts-make"
                          "render-opts-output-dir" "render-opts-use-cache"
                          "render-opts-include-source" "render-opts-include-output"
                          "render-opts-fail-fast"
                          "default-render-opts"
                          "render-md-string" "render-md"]
    "notebook/render-html" ["render-html-string" "render-html-string-at" "render-html"]
    "notebook/tui" ["tui-opts-make" "default-tui-opts" "tui-run" "tui-run-nodes"]
  })
