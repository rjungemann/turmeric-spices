;; tests/cell_test.tur -- NB3 tests for notebook/cell.

(defmodule notebook/tests/cell
  (import notebook/cell :refer [parse-attrs attr-get attr-get-bool attr-get-int
                                cell-make cell-id cell-lang cell-source cell-attrs
                                cell-start-line cell-end-line
                                cells-assign-ids])

  (defn test-list-nil? [lst : int] #{Unsafe} : bool
    ```c
    return lst == 0;
    ```)

  (defn test-head [lst : int] #{Unsafe} : int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    return cell ? cell->head : 0;
    ```)

  (defn test-tail [lst : int] #{Unsafe} : int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    return cell ? cell->tail : 0;
    ```)

  (defn test-cons [value : int next : int] #{Unsafe} : int
    ```c
    struct { int64_t head; int64_t tail; } *cell = malloc(sizeof(*cell));
    cell->head = value;
    cell->tail = next;
    return (int64_t)(intptr_t)cell;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] #{Unsafe} : bool
    ```c
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap-line [idx : int name : cstr ok : bool] #{Unsafe} : void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count : int fails : int] #{Unsafe} : void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld notebook cell tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld notebook cell tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok : bool] : int
    (if ok 0 1))

  (defn run-case [idx : int name : cstr ok : bool] #{Unsafe} : int
    (do
      (tap-line idx name ok)
      (bool->fail ok)))

  (defn test-attrs [] #{Unsafe} : bool
    (let [attrs (parse-attrs "turmeric {id=load eval=false cache=true depends=a,b retries=3}")
          a1 (test-head attrs)
          a2 (test-head (test-tail attrs))]
      (and (cstr-eq? (attr-get attrs "id" "") "load")
           (and (= (attr-get-bool attrs "eval" 1) 0)
                (and (= (attr-get-bool attrs "cache" 0) 1)
                     (and (= (attr-get-int attrs "retries" 0) 3)
                          (and (cstr-eq? (attr-get attrs "depends" "") "a,b")
                               (and (not (test-list-nil? attrs))
                                    (not (= a1 a2))))))))))

  (defn test-cell-make [] #{Unsafe} : bool
    (let [attrs (parse-attrs "turmeric {id=demo}")
          cell (cell-make "demo" 0 "(+ 1 2)" attrs 10 12)]
      (and (cstr-eq? (cell-id cell) "demo")
           (and (= (cell-lang cell) 0)
                (and (cstr-eq? (cell-source cell) "(+ 1 2)")
                     (and (= (cell-start-line cell) 10)
                          (and (= (cell-end-line cell) 12)
                               (= (cell-attrs cell) attrs))))))))

  (defn test-assign-ids [] #{Unsafe} : bool
    (let [cells (cells-assign-ids
                  (test-cons (cell-make "" 0 "a" 0 1 3)
                    (test-cons (cell-make "keep" 1 "b" 0 5 7)
                      (test-cons (cell-make "" 0 "c" 0 9 11) 0))))
          c1 (test-head cells)
          c2 (test-head (test-tail cells))
          c3 (test-head (test-tail (test-tail cells)))]
      (and (cstr-eq? (cell-id c1) "cell-1")
           (and (cstr-eq? (cell-id c2) "keep")
                (cstr-eq? (cell-id c3) "cell-3")))))

  (defn main [] #{Unsafe} : int
    (let [f1 (run-case 1 "parses fence attributes" (test-attrs))
          f2 (run-case 2 "builds cell handles" (test-cell-make))
          f3 (run-case 3 "assigns missing cell ids" (test-assign-ids))]
      (tap-plan 3 (+ f1 (+ f2 f3)))
      (if (= (+ f1 (+ f2 f3)) 0) 0 1)))

) ;; end defmodule notebook/tests/cell
