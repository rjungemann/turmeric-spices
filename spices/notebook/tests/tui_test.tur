;;; tests/tui_test.tur -- NB8 tests for notebook/keys and notebook/tui.
;; tests/tui_test.tur -- keybinding loading, dispatch, and scripted TUI smoke tests.

(defmodule notebook/tests/tui
  (import notebook/format :refer [parse-string])
  (import notebook/keys :refer [default-keybindings load-keybindings action-dispatch])
  (import notebook/tui :refer [tui-opts-make tui-run tui-run-nodes])

  (defn test-ok? [r :int] #{Unsafe} :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res && res->is_ok;
    ```)

  (defn test-ok-val [r :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res ? res->ok_val : 0;
    ```)

  (defn binding-action [bindings :int key :cstr] #{Unsafe} :cstr
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct { char *key; char *action; } NotebookKeyBinding;
    const char *want = key ? (const char *)(intptr_t)key : "";
    for (Cons *cur = (Cons *)(intptr_t)bindings; cur; cur = (Cons *)(intptr_t)cur->tail) {
      NotebookKeyBinding *binding = (NotebookKeyBinding *)(intptr_t)cur->head;
      if (binding && binding->key && strcmp(binding->key, want) == 0) {
        return binding->action ? binding->action : "";
      }
    }
    return "";
    ```)

  (defn cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    return strcmp(sa, sb) == 0;
    ```)

  (defn cstr-contains? [haystack :cstr needle :cstr] #{Unsafe} :bool
    ```c
    const char *hay = haystack ? (const char *)(intptr_t)haystack : "";
    const char *need = needle ? (const char *)(intptr_t)needle : "";
    return need[0] != '\0' && strstr(hay, need) != NULL;
    ```)

  (defn tap-line [idx :int name :cstr ok :bool] #{Unsafe} :void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count :int fails :int] #{Unsafe} :void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) fprintf(stderr, "# All %lld notebook tui tests passed.\n", (long long)count);
    else fprintf(stderr, "# %lld notebook tui tests failed.\n", (long long)fails);
    ```)

  (defn bool->fail [ok :bool] :int
    (if ok 0 1))

  (defn run-case [idx :int name :cstr ok :bool] #{Unsafe} :int
    (do
      (tap-line idx name ok)
      (bool->fail ok)))

  (defn temp-dir [label :cstr] #{Unsafe} :cstr
    ```c
    char buf[256];
    snprintf(buf, sizeof(buf), "/tmp/%s-%lld-%d", (const char *)label, (long long)time(NULL), (int)getpid());
    mkdir(buf, 0755);
    return strdup(buf);
    ```)

  (defn path-join [a :cstr b :cstr] #{Unsafe} :cstr
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    size_t need = strlen(sa) + strlen(sb) + 2;
    char *out = malloc(need);
    snprintf(out, need, "%s/%s", sa, sb);
    return out;
    ```)

  (defn write-file [path :cstr s :cstr] #{Unsafe} :bool
    ```c
    const char *dst = path ? (const char *)(intptr_t)path : "";
    const char *src = s ? (const char *)(intptr_t)s : "";
    FILE *fp = fopen(dst, "wb");
    if (!fp) return false;
    size_t want = strlen(src);
    size_t wrote = fwrite(src, 1, want, fp);
    fclose(fp);
    return wrote == want;
    ```)

  (defn slurp [path :cstr] #{Unsafe} :cstr
    ```c
    const char *p = path ? (const char *)(intptr_t)path : "";
    FILE *fp = fopen(p, "rb");
    if (!fp) return strdup("");
    fseek(fp, 0, SEEK_END);
    long sz = ftell(fp);
    rewind(fp);
    char *buf = malloc((size_t)sz + 1);
    size_t got = fread(buf, 1, (size_t)sz, fp);
    fclose(fp);
    buf[got] = '\0';
    return buf;
    ```)

  (defn set-test-keys [keys :cstr] #{Unsafe} :void
    ```c
    setenv("TURNB_TEST_KEYS", (const char *)(intptr_t)keys, 1);
    ```)

  (defn clear-test-keys [] #{Unsafe} :void
    ```c
    unsetenv("TURNB_TEST_KEYS");
    ```)

  (defn set-test-editor-text [s :cstr] #{Unsafe} :void
    ```c
    setenv("TURNB_TEST_EDITOR_TEXT", (const char *)(intptr_t)s, 1);
    ```)

  (defn clear-test-editor-text [] #{Unsafe} :void
    ```c
    unsetenv("TURNB_TEST_EDITOR_TEXT");
    ```)

  (defn set-test-search-query [s :cstr] #{Unsafe} :void
    ```c
    setenv("TURNB_TEST_SEARCH_QUERY", (const char *)(intptr_t)s, 1);
    ```)

  (defn clear-test-search-query [] #{Unsafe} :void
    ```c
    unsetenv("TURNB_TEST_SEARCH_QUERY");
    ```)

  (defn set-test-trace [path :cstr] #{Unsafe} :void
    ```c
    setenv("TURNB_TEST_TRACE", (const char *)(intptr_t)path, 1);
    ```)

  (defn clear-test-trace [] #{Unsafe} :void
    ```c
    unsetenv("TURNB_TEST_TRACE");
    ```)

  (defn fake-state-make [cell_count :int focus :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
    } NotebookTuiState;
    NotebookTuiState *st = calloc(1, sizeof(*st));
    st->path = strdup("");
    st->cell_count = cell_count;
    st->focus = focus;
    st->status = strdup("");
    return (int64_t)(intptr_t)st;
    ```)

  (defn fake-state-focus [state :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
    } NotebookTuiState;
    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    return st ? st->focus : -1;
    ```)

  (defn fake-state-effect [state :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
    } NotebookTuiState;
    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    return st ? st->pending_effect : -1;
    ```)

  (defn fake-state-quit? [state :int] #{Unsafe} :bool
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
    } NotebookTuiState;
    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    return st ? st->quit_requested != 0 : false;
    ```)

  (defn fake-state-quit-confirm [state :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
    } NotebookTuiState;
    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    return st ? st->quit_confirm : 0;
    ```)

  (defn test-default-keybindings [] #{Unsafe} :bool
    (let [bindings (default-keybindings)]
      (and (cstr-eq? (binding-action bindings "j") "cell-next")
           (and (cstr-eq? (binding-action bindings "gg") "cell-top")
                (and (cstr-eq? (binding-action bindings "e") "cell-edit")
                     (and (cstr-eq? (binding-action bindings "dd") "cell-delete")
                          (and (cstr-eq? (binding-action bindings "/") "search-prompt")
                               (and (cstr-eq? (binding-action bindings "?") "help-toggle")
                                    (cstr-eq? (binding-action bindings "o") "output-toggle")))))))))

  (defn test-load-keybindings [] #{Unsafe} :bool
    (let [dir (temp-dir "turnb-keybindings")
          path (path-join dir "keys.txt")
          _ (write-file path "# comment\nx quit\n<Enter> cell-run\n")
          loaded (load-keybindings path)]
      (and (test-ok? loaded)
           (cstr-eq? (binding-action (test-ok-val loaded) "x") "quit"))))

  (defn test-action-dispatch [] #{Unsafe} :bool
    (let [state (fake-state-make 3 1)]
      (do
        (action-dispatch state "cell-prev")
        (action-dispatch state "search-prev")
        (and (= (fake-state-focus state) 0)
             (and (= (fake-state-effect state) 13)
                  (and (not (fake-state-quit? state))
                       (= (fake-state-quit-confirm state) 0)))))))

  (defn test-tui-run-nodes-scripted [] #{Unsafe} :bool
    (let [parsed (parse-string "```turmeric {id=one}\n(+ 1 2)\n```\n\n```turmeric {id=two}\n(+ 3 4)\n```")
          nodes (test-ok-val parsed)
          opts (tui-opts-make 0 0 1000 "")]
      (do
        (set-test-keys "j\n<Enter>\nq\n")
        (let [run (tui-run-nodes nodes opts)]
          (do
            (clear-test-keys)
            (and (test-ok? run)
                 (= (test-ok-val run) 0)))))))

  (defn test-tui-edit-save-and-quit [] #{Unsafe} :bool
    (let [dir (temp-dir "turnb-edit-save")
          path (path-join dir "demo.tur.md")
          _ (write-file path "```turmeric {id=one}\n(+ 1 2)\n```")
          opts (tui-opts-make 0 0 1000 "")]
      (do
        (set-test-editor-text "(+ 5 8)")
        (set-test-keys "e\ns\nq\n")
        (let [run (tui-run path opts)
              text (slurp path)]
          (do
            (clear-test-editor-text)
            (clear-test-keys)
            (and (test-ok? run)
                 (and (= (test-ok-val run) 0)
                      (cstr-eq? text "```turmeric {id=one}\n(+ 5 8)\n```"))))))))

  (defn test-tui-dirty-quit-warning [] #{Unsafe} :bool
    (let [parsed (parse-string "```turmeric {id=one}\n(+ 1 2)\n```")
          nodes (test-ok-val parsed)
          opts (tui-opts-make 0 0 1000 "")]
      (do
        (set-test-keys "a\nq\nq\n")
        (let [run (tui-run-nodes nodes opts)]
          (do
            (clear-test-keys)
            (and (test-ok? run)
                 (= (test-ok-val run) 1)))))))

  (defn test-tui-search-and-output-toggle [] #{Unsafe} :bool
    (let [dir (temp-dir "turnb-search")
          trace (path-join dir "trace.txt")
          _ (write-file trace "")
          parsed (parse-string "```turmeric {id=one}\n(+ 1 2)\n```\n\n```turmeric {id=two}\nneedle value\n```")
          nodes (test-ok-val parsed)
          opts (tui-opts-make 0 0 1000 "")]
      (do
        (set-test-trace trace)
        (set-test-search-query "needle")
        (set-test-keys "/\no\nq\n")
        (let [run (tui-run-nodes nodes opts)
              logged (slurp trace)]
          (do
            (clear-test-trace)
            (clear-test-search-query)
            (clear-test-keys)
            (and (test-ok? run)
                 (and (= (test-ok-val run) 0)
                      (and (cstr-contains? logged "focus:1")
                           (and (cstr-contains? logged "status:search: needle")
                                (cstr-contains? logged "status:hid output"))))))))))

  (defn test-tui-help-overlay [] #{Unsafe} :bool
    (let [dir (temp-dir "turnb-help")
          trace (path-join dir "trace.txt")
          _ (write-file trace "")
          parsed (parse-string "```turmeric {id=one}\n(+ 1 2)\n```")
          nodes (test-ok-val parsed)
          opts (tui-opts-make 0 0 1000 "")]
      (do
        (set-test-trace trace)
        (set-test-keys "?\nq\nq\n")
        (let [run (tui-run-nodes nodes opts)
              logged (slurp trace)]
          (do
            (clear-test-trace)
            (clear-test-keys)
            (and (test-ok? run)
                 (and (= (test-ok-val run) 0)
                      (cstr-contains? logged "status:help overlay"))))))))

  (defn test-tui-keybinding-overrides [] #{Unsafe} :bool
    (let [dir (temp-dir "turnb-override")
          trace (path-join dir "trace.txt")
          keyfile (path-join dir "keys.txt")
          _ (write-file trace "")
          _ (write-file keyfile "x quit\n")
          parsed (parse-string "```turmeric {id=one}\n(+ 1 2)\n```\n\n```turmeric {id=two}\nneedle two\n```")
          nodes (test-ok-val parsed)
          opts (tui-opts-make 0 0 1000 keyfile)]
      (do
        (set-test-trace trace)
        (set-test-search-query "needle")
        (set-test-keys "/\nx\n")
        (let [run (tui-run-nodes nodes opts)
              logged (slurp trace)]
          (do
            (clear-test-trace)
            (clear-test-search-query)
            (clear-test-keys)
            (and (test-ok? run)
                 (and (= (test-ok-val run) 0)
                      (cstr-contains? logged "status:search: needle"))))))))

  (defn main [] #{Unsafe} :int
    (let [f1 (run-case 1 "returns the built-in NB10 keybindings" (test-default-keybindings))
          f2 (run-case 2 "loads custom keybindings files" (test-load-keybindings))
          f3 (run-case 3 "dispatches navigation and NB10 search actions" (test-action-dispatch))
          f4 (run-case 4 "runs the TUI loop with scripted keys" (test-tui-run-nodes-scripted))
          f5 (run-case 5 "edits, saves, and cleanly quits a file-backed notebook" (test-tui-edit-save-and-quit))
          f6 (run-case 6 "warns before quitting with unsaved changes" (test-tui-dirty-quit-warning))
          f7 (run-case 7 "searches and toggles focused output" (test-tui-search-and-output-toggle))
          f8 (run-case 8 "opens and dismisses the help overlay" (test-tui-help-overlay))
          f9 (run-case 9 "merges keybinding overrides onto defaults" (test-tui-keybinding-overrides))]
      (tap-plan 9 (+ f1 (+ f2 (+ f3 (+ f4 (+ f5 (+ f6 (+ f7 (+ f8 f9)))))))))
      (if (= (+ f1 (+ f2 (+ f3 (+ f4 (+ f5 (+ f6 (+ f7 (+ f8 f9)))))))) 0) 0 1)))

) ;; end defmodule notebook/tests/tui
