;; tests/eval_test.tur -- NB4 tests for notebook/eval.

(defmodule notebook/tests/eval
  (import notebook/cell :refer [parse-attrs cell-make])
  (import notebook/cache :refer [cache-open cache-close cache-clear])
  (import notebook/eval :refer [eval-cell eval-all eval-from])
  (import notebook/session :refer [session-open session-close session-reset session-eval
                                   output-status-ok output-status-error output-status-skipped
                                   cell-output-status cell-output-value-repr])

  (defn test-cons [value :int next :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = malloc(sizeof(*cell));
    cell->head = value;
    cell->tail = next;
    return (int64_t)(intptr_t)cell;
    ```)

  (defn test-head [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    return cell ? cell->head : 0;
    ```)

  (defn test-tail [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    return cell ? cell->tail : 0;
    ```)

  (defn cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap-line [idx :int name :cstr ok :bool] #{Unsafe} :void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count :int fails :int] #{Unsafe} :void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld notebook eval tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld notebook eval tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok :bool] :int
    (if ok 0 1))

  (defn run-case [idx :int name :cstr ok :bool] #{Unsafe} :int
    (do
      (tap-line idx name ok)
      (bool->fail ok)))

  (defn temp-cache-dir [label :cstr] #{Unsafe} :cstr
    ```c
    char buf[256];
    snprintf(buf, sizeof(buf), "/tmp/%s-%lld-%d", (const char *)label, (long long)time(NULL), (int)getpid());
    return strdup(buf);
    ```)

  (defn test-eval-false [] #{Unsafe} :bool
    (let [s (session-open)
          cell (cell-make "skip" 0 "(+ 1 2)" (parse-attrs "turmeric {eval=false}") 1 3)
          out (eval-cell s cell 0)]
      (do
        (session-close s)
        (= (cell-output-status out) (output-status-skipped)))))

  (defn test-eval-all-halt [] #{Unsafe} :bool
    (let [s (session-open)
          c1 (cell-make "a" 0 "(def n 2)" (parse-attrs "turmeric {id=a}") 1 3)
          c2 (cell-make "b" 0 "(+ missing 1)" (parse-attrs "turmeric {id=b}") 5 7)
          c3 (cell-make "c" 0 "(+ n 4)" (parse-attrs "turmeric {id=c}") 9 11)
          outs (eval-all s (test-cons c1 (test-cons c2 (test-cons c3 0))) 0 0)
          o1 (test-head outs)
          o2 (test-head (test-tail outs))]
      (do
        (session-close s)
        (and (= (cell-output-status o1) (output-status-ok))
             (and (= (cell-output-status o2) (output-status-error))
                  (= (test-tail (test-tail outs)) 0))))))

  (defn test-eval-all-continue [] #{Unsafe} :bool
    (let [s (session-open)
          c1 (cell-make "a" 0 "(def n 2)" (parse-attrs "turmeric {id=a}") 1 3)
          c2 (cell-make "b" 0 "(+ missing 1)" (parse-attrs "turmeric {id=b error=continue}") 5 7)
          c3 (cell-make "c" 0 "(+ n 4)" (parse-attrs "turmeric {id=c}") 9 11)
          outs (eval-all s (test-cons c1 (test-cons c2 (test-cons c3 0))) 0 0)
          o3 (test-head (test-tail (test-tail outs)))]
      (do
        (session-close s)
        (and (= (cell-output-status o3) (output-status-ok))
             (cstr-eq? (cell-output-value-repr o3) "6")))))

  (defn test-eval-from [] #{Unsafe} :bool
    (let [s (session-open)
          c1 (cell-make "a" 0 "(def n 2)" (parse-attrs "turmeric {id=a}") 1 3)
          c2 (cell-make "b" 0 "(+ n 5)" (parse-attrs "turmeric {id=b}") 5 7)
          c3 (cell-make "c" 0 "(+ n 7)" (parse-attrs "turmeric {id=c}") 9 11)
          _ (eval-cell s c1 0)
          outs (eval-from s (test-cons c1 (test-cons c2 (test-cons c3 0))) "b" 0 0)
          o1 (test-head outs)
          o2 (test-head (test-tail outs))]
      (do
        (session-close s)
        (and (cstr-eq? (cell-output-value-repr o1) "7")
             (cstr-eq? (cell-output-value-repr o2) "9")))))

  (defn test-cache-hit-across-reset [] #{Unsafe} :bool
    (let [dir (temp-cache-dir "turnb-eval-cache-hit")
          cache (cache-open dir)
          s (session-open)
          c1 (cell-make "cached" 0 "secret" (parse-attrs "turmeric {id=cached cache=true}") 1 3)]
      (do
        (cache-clear cache)
        (let [_ (session-eval s "(def secret 7)" 0)
              o1 (eval-cell s c1 cache)]
          (session-reset s)
          (let [o2 (eval-cell s c1 cache)]
            (session-close s)
            (cache-close cache)
            (and (cstr-eq? (cell-output-value-repr o1) "7")
                 (and (= (cell-output-status o2) (output-status-ok))
                     (cstr-eq? (cell-output-value-repr o2) "7"))))))))

  (defn test-depends-busts-downstream-cache [] #{Unsafe} :bool
    (let [dir (temp-cache-dir "turnb-eval-deps")
          cache (cache-open dir)
          s (session-open)
          a1 (cell-make "a" 0 "(def n 2)" (parse-attrs "turmeric {id=a cache=true}") 1 3)
          b1 (cell-make "b" 0 "(+ n 1)" (parse-attrs "turmeric {id=b cache=true depends=a}") 5 7)]
      (do
        (cache-clear cache)
        (let [outs1 (eval-all s (test-cons a1 (test-cons b1 0)) cache 0)
              b1-out (test-head (test-tail outs1))]
          (session-reset s)
          (let [a2 (cell-make "a" 0 "(def n 5)" (parse-attrs "turmeric {id=a cache=true}") 1 3)
                b2 (cell-make "b" 0 "(+ n 1)" (parse-attrs "turmeric {id=b cache=true depends=a}") 5 7)
                outs2 (eval-all s (test-cons a2 (test-cons b2 0)) cache 0)
                b2-out (test-head (test-tail outs2))]
            (session-close s)
            (cache-close cache)
            (and (cstr-eq? (cell-output-value-repr b1-out) "3")
                 (cstr-eq? (cell-output-value-repr b2-out) "6")))))))

  (defn main [] #{Unsafe} :int
    (let [f1 (run-case 1 "skips eval=false cells" (test-eval-false))
          f2 (run-case 2 "halts eval-all on error by default" (test-eval-all-halt))
          f3 (run-case 3 "continues eval-all when error=continue" (test-eval-all-continue))
          f4 (run-case 4 "evaluates from a named starting cell" (test-eval-from))
          f5 (run-case 5 "reuses cache across session resets" (test-cache-hit-across-reset))
          f6 (run-case 6 "invalidates downstream caches when dependencies change" (test-depends-busts-downstream-cache))]
      (tap-plan 6 (+ f1 (+ f2 (+ f3 (+ f4 (+ f5 f6))))))
      (if (= (+ f1 (+ f2 (+ f3 (+ f4 (+ f5 f6))))) 0) 0 1)))

) ;; end defmodule notebook/tests/eval
