;; tests/format_spec.tur -- NB3 tests for notebook/format.

(defmodule notebook/tests/nbformat
  (import notebook/format :refer [parse-file parse-string node-tag node-prose node-cell
                                  nodes->str nodes-update-cell])

  (defn test-list-nil? [lst :int] #{Unsafe} :bool
    ```c
    return lst == 0;
    ```)

  (defn test-head [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    return cell ? cell->head : 0;
    ```)

  (defn test-tail [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    return cell ? cell->tail : 0;
    ```)

  (defn cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn test-md-node-tag [node :int] #{Unsafe} :int
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    MdNode *n = (MdNode *)(intptr_t)node;
    return n ? n->kind : -1;
    ```)

  (defn test-cell-id [cell :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      char *id;
      int64_t lang;
      char *source;
      int64_t attrs;
      int64_t start_line;
      int64_t end_line;
    } Cell;
    Cell *c = (Cell *)(intptr_t)cell;
    return c && c->id ? c->id : "";
    ```)

  (defn test-cell-lang [cell :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *id;
      int64_t lang;
      char *source;
      int64_t attrs;
      int64_t start_line;
      int64_t end_line;
    } Cell;
    Cell *c = (Cell *)(intptr_t)cell;
    return c ? c->lang : -1;
    ```)

  (defn test-cell-source [cell :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      char *id;
      int64_t lang;
      char *source;
      int64_t attrs;
      int64_t start_line;
      int64_t end_line;
    } Cell;
    Cell *c = (Cell *)(intptr_t)cell;
    return c && c->source ? c->source : "";
    ```)

  (defn test-cell-attrs [cell :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *id;
      int64_t lang;
      char *source;
      int64_t attrs;
      int64_t start_line;
      int64_t end_line;
    } Cell;
    Cell *c = (Cell *)(intptr_t)cell;
    return c ? c->attrs : 0;
    ```)

  (defn test-attr-get [attrs :int name :cstr fallback :cstr] #{Unsafe} :cstr
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct { char *name; char *value; } Attr;
    const char *want = name ? (const char *)(intptr_t)name : "";
    const char *fallback_value = fallback ? (const char *)(intptr_t)fallback : "";
    Cons *lst = (Cons *)(intptr_t)attrs;
    while (lst) {
      Attr *attr = (Attr *)(intptr_t)lst->head;
      if (attr && attr->name && strcmp(attr->name, want) == 0) {
        return attr->value ? attr->value : fallback_value;
      }
      lst = (Cons *)(intptr_t)lst->tail;
    }
    return fallback_value;
    ```)

  (defn test-ok? [r :int] #{Unsafe} :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void*)(intptr_t)r;
    return res && res->is_ok;
    ```)

  (defn test-ok-val [r :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void*)(intptr_t)r;
    return res ? res->ok_val : 0;
    ```)

  (defn test-err? [r :int] #{Unsafe} :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void*)(intptr_t)r;
    return !res || !res->is_ok;
    ```)

  (defn tap-line [idx :int name :cstr ok :bool] #{Unsafe} :void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count :int fails :int] #{Unsafe} :void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld notebook format tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld notebook format tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok :bool] :int
    (if ok 0 1))

  (defn run-case [idx :int name :cstr ok :bool] #{Unsafe} :int
    (do
      (tap-line idx name ok)
      (bool->fail ok)))

  (defn __write-file [path :cstr s :cstr] #{Unsafe} :int
    ```c
    const char *p = (const char *)(intptr_t)path;
    const char *bs = (const char *)(intptr_t)s;
    FILE *fp = fopen(p, "wb");
    if (!fp) return 0;
    size_t len = bs ? strlen(bs) : 0;
    size_t wrote = bs ? fwrite(bs, 1, len, fp) : 0;
    fclose(fp);
    return (wrote == len) ? 1 : 0;
    ```)

  (defn test-parse-string [] #{Unsafe} :bool
    (let [r (parse-string "# Title\n\nParagraph.\n\n```turmeric {id=load eval=false}\n(+ 1 2)\n```\n\nAfter.")
          nodes (test-ok-val r)
          n1 (test-head nodes)
          n2 (test-head (test-tail nodes))
          n3 (test-head (test-tail (test-tail nodes)))
          n4 (test-head (test-tail (test-tail (test-tail nodes))))
          cell (node-cell n3)]
      (and (test-ok? r)
           (and (= (node-tag n1) 0)
                (and (= (test-md-node-tag (node-prose n1)) 1)
                     (and (= (test-md-node-tag (node-prose n2)) 2)
                          (and (= (node-tag n3) 1)
                               (and (cstr-eq? (test-cell-id cell) "load")
                                    (and (= (test-cell-lang cell) 0)
                                         (and (cstr-eq? (test-cell-source cell) "(+ 1 2)")
                                              (and (= (node-tag n4) 0)
                                                   (cstr-eq? (test-attr-get (test-cell-attrs cell) "eval" "") "false"))))))))))))

  (defn test-nodes->str [] #{Unsafe} :bool
    (let [source "# Title\n\nParagraph.\n\n```sweet-exp {echo=false}\nprintln(\"hi\")\n```\n\nAfter."
          r (parse-string source)]
      (and (test-ok? r)
           (cstr-eq? (nodes->str (test-ok-val r)) source))))

  (defn test-update-cell [] #{Unsafe} :bool
    (let [r (parse-string "```turmeric {id=load}\n(+ 1 2)\n```")
          updated (nodes-update-cell (test-ok-val r) "load" "(+ 2 3)")]
      (and (test-ok? updated)
           (cstr-eq? (nodes->str (test-ok-val updated)) "```turmeric {id=load}\n(+ 2 3)\n```"))))

  (defn test-parse-file [] #{Unsafe} :bool
    (let [path "/tmp/notebook-format-test.tur.md"
          _ (__write-file path "```turmeric {id=file}\n(+ 4 5)\n```")
          r (parse-file path)
          nodes (test-ok-val r)
          node (test-head nodes)]
      (and (test-ok? r)
           (and (= (node-tag node) 1)
                (cstr-eq? (test-cell-id (node-cell node)) "file")))))

  (defn test-update-miss [] #{Unsafe} :bool
    (let [r (parse-string "```turmeric {id=load}\n(+ 1 2)\n```")
          updated (nodes-update-cell (test-ok-val r) "missing" "(+ 2 3)")]
      (test-err? updated)))

  (defn main [] #{Unsafe} :int
    (let [f1 (run-case 1 "parses notebook strings into prose and cell nodes" (test-parse-string))
          f2 (run-case 2 "serializes notebook nodes back to markdown" (test-nodes->str))
          f3 (run-case 3 "updates named cells immutably" (test-update-cell))
          f4 (run-case 4 "parses notebook files from disk" (test-parse-file))
          f5 (run-case 5 "returns an error for missing cell ids" (test-update-miss))]
      (tap-plan 5 (+ f1 (+ f2 (+ f3 (+ f4 f5)))))
      (if (= (+ f1 (+ f2 (+ f3 (+ f4 f5)))) 0) 0 1)))

) ;; end defmodule notebook/tests/nbformat
