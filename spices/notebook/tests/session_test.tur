;; tests/session_test.tur -- NB4 tests for notebook/session.

(defmodule notebook/tests/session
  (import notebook/session :refer [session-open session-close session-reset session-eval
                                   output-status-ok output-status-error
                                   cell-output-status cell-output-stdout
                                   cell-output-value-repr cell-output-error-msg])

  (defn cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap-line [idx :int name :cstr ok :bool] #{Unsafe} :void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count :int fails :int] #{Unsafe} :void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld notebook session tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld notebook session tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok :bool] :int
    (if ok 0 1))

  (defn run-case [idx :int name :cstr ok :bool] #{Unsafe} :int
    (do
      (tap-line idx name ok)
      (bool->fail ok)))

  (defn test-persistent-env [] #{Unsafe} :bool
    (let [s (session-open)
          _ (session-eval s "(def answer 41)" 0)
          out (session-eval s "(+ answer 1)" 0)]
      (do
        (session-close s)
        (and (= (cell-output-status out) (output-status-ok))
             (cstr-eq? (cell-output-value-repr out) "42")))))

  (defn test-reset [] #{Unsafe} :bool
    (let [s (session-open)
          _ (session-eval s "(def answer 41)" 0)]
      (do
        (session-reset s)
        (let [out (session-eval s "(+ answer 1)" 0)]
          (session-close s)
          (and (= (cell-output-status out) (output-status-error))
               (not (cstr-eq? (cell-output-error-msg out) "")))))))

  (defn test-stdout-capture [] #{Unsafe} :bool
    (let [s (session-open)
          out (session-eval s "(do (println \"hi\") 7)" 0)]
      (do
        (session-close s)
        (and (= (cell-output-status out) (output-status-ok))
             (and (cstr-eq? (cell-output-value-repr out) "7")
                  (not (cstr-eq? (cell-output-stdout out) "")))))))

  (defn test-sweet-exp [] #{Unsafe} :bool
    (let [s (session-open)
          out (session-eval s "+(5 3)" 1)]
      (do
        (session-close s)
        (and (= (cell-output-status out) (output-status-ok))
             (cstr-eq? (cell-output-value-repr out) "8")))))

  (defn main [] #{Unsafe} :int
    (let [f1 (run-case 1 "persists definitions across eval calls" (test-persistent-env))
          f2 (run-case 2 "resets the embedded session" (test-reset))
          f3 (run-case 3 "captures stdout and value repr" (test-stdout-capture))
          f4 (run-case 4 "evaluates sweet-exp cells" (test-sweet-exp))]
      (tap-plan 4 (+ f1 (+ f2 (+ f3 f4))))
      (if (= (+ f1 (+ f2 (+ f3 f4))) 0) 0 1)))

) ;; end defmodule notebook/tests/session
