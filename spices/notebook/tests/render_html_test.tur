;; tests/render_html_test.tur -- NB7 tests for notebook/render-html.

(defmodule notebook/tests/render-html
  (import notebook/format :refer [parse-string])
  (import notebook/session :refer [cell-output-make])
  (import notebook/render-md :refer [render-opts-make default-render-opts])
  (import notebook/render-html :refer [render-html-string render-html-string-at render-html])

  (defn test-cons [value : int next : int] #fx{Unsafe} : int
    ```c
    struct { int64_t head; int64_t tail; } *cell = malloc(sizeof(*cell));
    cell->head = value;
    cell->tail = next;
    return (int64_t)(intptr_t)cell;
    ```)

  (defn cstr-as-int [s : cstr] #fx{Unsafe} : int
    ```c
    return (int64_t)(intptr_t)s;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] #fx{Unsafe} : bool
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    return strcmp(sa, sb) == 0;
    ```)

  (defn cstr-contains? [haystack : cstr needle : cstr] #fx{Unsafe} : bool
    ```c
    const char *h = haystack ? (const char *)(intptr_t)haystack : "";
    const char *n = needle ? (const char *)(intptr_t)needle : "";
    return strstr(h, n) != NULL;
    ```)

  (defn test-ok? [r : int] #fx{Unsafe} : bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void*)(intptr_t)r;
    return res && res->is_ok;
    ```)

  (defn test-ok-val [r : int] #fx{Unsafe} : int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void*)(intptr_t)r;
    return res ? res->ok_val : 0;
    ```)

  (defn int-as-cstr [value : int] #fx{Unsafe} : cstr
    ```c
    return (const char *)(intptr_t)value;
    ```)

  (defn tap-line [idx : int name : cstr ok : bool] #fx{Unsafe} : void
    ```c
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    ```)

  (defn tap-plan [count : int fails : int] #fx{Unsafe} : void
    ```c
    printf("1..%lld\n", (long long)count);
    if (fails == 0) {
      fprintf(stderr, "# All %lld notebook render-html tests passed.\n", (long long)count);
    } else {
      fprintf(stderr, "# %lld notebook render-html tests failed.\n", (long long)fails);
    }
    ```)

  (defn bool->fail [ok : bool] : int
    (if ok 0 1))

  (defn run-case [idx : int name : cstr ok : bool] #fx{Unsafe} : int
    (do
      (tap-line idx name ok)
      (bool->fail ok)))

  (defn __write-file [path : cstr s : cstr] #fx{Unsafe} : int
    ```c
    const char *p = (const char *)(intptr_t)path;
    const char *bs = s ? (const char *)(intptr_t)s : "";
    FILE *fp = fopen(p, "wb");
    if (!fp) return 0;
    size_t len = strlen(bs);
    size_t wrote = fwrite(bs, 1, len, fp);
    fclose(fp);
    return wrote == len ? 1 : 0;
    ```)

  (defn __write-tiny-png [path : cstr] #fx{Unsafe} : int
    ```c
    static const unsigned char png[] = {
      0x89,0x50,0x4e,0x47,0x0d,0x0a,0x1a,0x0a,
      0x00,0x00,0x00,0x0d,0x49,0x48,0x44,0x52,
      0x00,0x00,0x00,0x01,0x00,0x00,0x00,0x01,
      0x08,0x06,0x00,0x00,0x00,0x1f,0x15,0xc4,
      0x89,0x00,0x00,0x00,0x0d,0x49,0x44,0x41,
      0x54,0x78,0x9c,0x63,0xf8,0xcf,0xc0,0x00,
      0x00,0x03,0x01,0x01,0x00,0xc9,0xfe,0x92,
      0xef,0x00,0x00,0x00,0x00,0x49,0x45,0x4e,
      0x44,0xae,0x42,0x60,0x82
    };
    FILE *fp = fopen((const char *)(intptr_t)path, "wb");
    if (!fp) return 0;
    size_t wrote = fwrite(png, 1, sizeof(png), fp);
    fclose(fp);
    return wrote == sizeof(png) ? 1 : 0;
    ```)

  (defn __slurp [path : cstr] #fx{Unsafe} : cstr
    ```c
    const char *p = path ? (const char *)(intptr_t)path : "";
    FILE *fp = fopen(p, "rb");
    if (!fp) return strdup("");
    fseek(fp, 0, SEEK_END);
    long sz = ftell(fp);
    rewind(fp);
    char *buf = malloc((size_t)sz + 1);
    size_t got = fread(buf, 1, (size_t)sz, fp);
    fclose(fp);
    buf[got] = '\0';
    return buf;
    ```)

  (defn __file-exists? [path : cstr] #fx{Unsafe} : bool
    ```c
    FILE *fp = fopen((const char *)(intptr_t)path, "rb");
    if (!fp) return false;
    fclose(fp);
    return true;
    ```)

  (defn temp-dir [label : cstr] #fx{Unsafe} : cstr
    ```c
    char buf[256];
    snprintf(buf, sizeof(buf), "/tmp/%s-%lld-%d", (const char *)label, (long long)time(NULL), (int)getpid());
    mkdir(buf, 0755);
    return strdup(buf);
    ```)

  (defn path-join [a : cstr b : cstr] #fx{Unsafe} : cstr
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    size_t need = strlen(sa) + strlen(sb) + 2;
    char *out = malloc(need);
    snprintf(out, need, "%s/%s", sa, sb);
    return out;
    ```)

  (defn test-render-html-string [] #fx{Unsafe} : bool
    (let [parsed (parse-string "# Title\n\n```turmeric {id=calc}\n(+ 1 2)\n```")
          nodes (test-ok-val parsed)
          outputs (test-cons (cell-output-make "calc" 0 "" "3" "" 12 0) 0)
          rendered (render-html-string nodes outputs (default-render-opts))]
      (and (cstr-contains? rendered "<h1>Title</h1>")
           (and (cstr-contains? rendered "turmeric-cell")
                (cstr-contains? rendered "cell-id=calc status=ok")))))

  (defn test-render-html-toggle-pair [] #fx{Unsafe} : bool
    (let [parsed (parse-string "```turmeric {id=t1}\n(+ 1 2)\n```\n\n```sweet-exp {id=s1}\n+(1 2)\n```")
          nodes (test-ok-val parsed)
          outputs (test-cons (cell-output-make "t1" 0 "" "3" "" 5 0)
                             (test-cons (cell-output-make "s1" 0 "" "3" "" 5 0) 0))
          rendered (render-html-string nodes outputs (default-render-opts))]
      (and (cstr-contains? rendered "code-syntax-toggle")
           (and (cstr-contains? rendered "turmeric-version")
                (cstr-contains? rendered "sweet-exp-version")))))

  (defn test-render-html-inline-image [] #fx{Unsafe} : bool
    (let [dir (temp-dir "turnb-render-html-image")
          png (path-join dir "plot.png")
          _ (__write-tiny-png png)
          parsed (parse-string "```turmeric {id=plot image=inline}\n(plot)\n```")
          nodes (test-ok-val parsed)
          images (test-cons (cstr-as-int png) 0)
          outputs (test-cons (cell-output-make "plot" 0 "" "" "" 9 images) 0)
          rendered (render-html-string nodes outputs (default-render-opts))]
      (cstr-contains? rendered "data:image/png;base64,")))

  (defn test-render-html-file-image [] #fx{Unsafe} : bool
    (let [dir (temp-dir "turnb-render-html-file")
          png (path-join dir "plot.png")
          html-path (path-join dir "page.html")
          copied (path-join dir "page-plot-1.png")
          _ (__write-tiny-png png)
          parsed (parse-string "```turmeric {id=plot image=file}\n(plot)\n```")
          nodes (test-ok-val parsed)
          images (test-cons (cstr-as-int png) 0)
          outputs (test-cons (cell-output-make "plot" 0 "" "" "" 9 images) 0)
          rendered (render-html-string-at nodes outputs (default-render-opts) html-path)]
      (and (__file-exists? copied)
           (cstr-contains? rendered "src=\"page-plot-1.png\""))))

  (defn test-render-html-writes-file-and-style [] #fx{Unsafe} : bool
    (let [dir (temp-dir "turnb-render-html")
          src (path-join dir "sample.tur.md")
          outdir (path-join dir "site")
          _ (__write-file src "# Demo\n\n```turmeric {id=demo}\n(+ 20 22)\n```")
          opts (render-opts-make outdir 0 1 1 1)
          r (render-html src opts)
          out-path (if (test-ok? r) (int-as-cstr (test-ok-val r)) "")
          style-path (path-join outdir "style.css")
          text (__slurp out-path)
          style (__slurp style-path)]
      (and (test-ok? r)
           (and (cstr-contains? out-path "/site/sample.html")
                (and (__file-exists? style-path)
                     (and (cstr-contains? text "link rel=\"stylesheet\" href=\"style.css\"")
                          (cstr-contains? style ".notebook-document")))))))

  (defn main [] #fx{Unsafe} : int
    (let [f1 (run-case 1 "renders standalone html with code and outputs" (test-render-html-string))
          f2 (run-case 2 "wraps adjacent turmeric and sweet-exp cells in a toggle" (test-render-html-toggle-pair))
          f3 (run-case 3 "embeds inline images as data urls" (test-render-html-inline-image))
          f4 (run-case 4 "copies file-mode images beside the html page" (test-render-html-file-image))
          f5 (run-case 5 "writes html pages and stylesheet assets" (test-render-html-writes-file-and-style))]
      (tap-plan 5 (+ f1 (+ f2 (+ f3 (+ f4 f5)))))
      (if (= (+ f1 (+ f2 (+ f3 (+ f4 f5)))) 0) 0 1)))

) ;; end defmodule notebook/tests/render-html
