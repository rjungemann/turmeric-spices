  (defn __tui-state-set-status [state :int value :cstr] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
    } NotebookTuiState;
    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    if (!st) return state;
    if (st->status) free(st->status);
    st->status = value ? strdup((const char *)(intptr_t)value) : strdup("");
    const char *trace = getenv("TURNB_TEST_TRACE");
    if (trace && trace[0]) {
      FILE *fp = fopen(trace, "ab");
      if (fp) {
        fprintf(fp, "status:%s\n", st->status ? st->status : "");
        fclose(fp);
      }
    }
    return state;
    ```)

