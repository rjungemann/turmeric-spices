  (defn __tui-binding-action [bindings :int key :cstr] #{Unsafe} :cstr
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct { char *key; char *action; } NotebookKeyBinding;
    const char *want = key ? (const char *)(intptr_t)key : "";
    for (Cons *cur = (Cons *)(intptr_t)bindings; cur; cur = (Cons *)(intptr_t)cur->tail) {
      NotebookKeyBinding *binding = (NotebookKeyBinding *)(intptr_t)cur->head;
      if (binding && binding->key && strcmp(binding->key, want) == 0) {
        return binding->action ? binding->action : "";
      }
    }
    return "";
    ```)

  (defn __tui-binding-has-prefix [bindings :int key :cstr] #{Unsafe} :bool
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct { char *key; char *action; } NotebookKeyBinding;
    const char *want = key ? (const char *)(intptr_t)key : "";
    size_t n = strlen(want);
    for (Cons *cur = (Cons *)(intptr_t)bindings; cur; cur = (Cons *)(intptr_t)cur->tail) {
      NotebookKeyBinding *binding = (NotebookKeyBinding *)(intptr_t)cur->head;
      if (!binding || !binding->key) continue;
      if (strncmp(binding->key, want, n) == 0 && strlen(binding->key) > n) return true;
    }
    return false;
    ```)

  (defn __tui-output-message [cell :int output :int] #{Unsafe} :cstr
    (let [cell-name (cell-id cell)
          elapsed (__tui-int->cstr (cell-output-elapsed-ms output))]
      (if (= (cell-output-status output) 0)
        (__tui-str-concat "ran " (__tui-str-concat cell-name (__tui-str-concat " in " (__tui-str-concat elapsed "ms"))))
        (if (= (cell-output-status output) 2)
          (__tui-str-concat "skipped " cell-name)
          (__tui-str-concat "error in " (__tui-str-concat cell-name (__tui-str-concat ": " (cell-output-error-msg output))))))))

  (defn __tui-cell-matches-query? [cell :int output :int query :cstr] #{Unsafe} :bool
    (or (__tui-cstr-contains-ci? (cell-source cell) query)
        (__tui-cstr-contains-ci? (cell-output-stdout output) query)
        (__tui-cstr-contains-ci? (cell-output-value-repr output) query)
        (__tui-cstr-contains-ci? (cell-output-error-msg output) query)))

  (defn __tui-wrap-index [idx :int count :int] #{Unsafe} :int
    ```c
    int64_t n = count;
    int64_t i = idx;
    if (n <= 0) return 0;
    while (i < 0) i += n;
    while (i >= n) i -= n;
    return i;
    ```)

  (defn __tui-find-match [cells :int outputs :int query :cstr idx :int step :int count :int remaining :int] #{Unsafe} :int
    (if (or (<= remaining 0) (__tui-cstr-empty? query))
      -1
      (let [wrapped (__tui-wrap-index idx count)
            cell (__tui-list-nth cells wrapped)
            output (__tui-list-nth outputs wrapped)]
        (if (__tui-cell-matches-query? cell output query)
          wrapped
          (__tui-find-match cells outputs query (+ wrapped step) step count (- remaining 1))))))

  (defn __tui-read-search-query [] #{Unsafe} :cstr
    ```c
    const char *override = getenv("TURNB_TEST_SEARCH_QUERY");
    if (override) return strdup(override);

    char buf[1024];
    fprintf(stdout, "/");
    fflush(stdout);
    if (!fgets(buf, sizeof(buf), stdin)) return strdup("");
    size_t len = strlen(buf);
    while (len > 0 && (buf[len - 1] == '\n' || buf[len - 1] == '\r')) {
      buf[len - 1] = '\0';
      len--;
    }
    return strdup(buf);
    ```)

  (defn __tui-search [state :int query :cstr step :int from-current? :bool] #{Unsafe} :int
    (let [count (__tui-state-cell-count state)]
      (if (or (<= count 0) (__tui-cstr-empty? query))
        (__tui-state-set-status state "no active search")
        (let [start (if from-current?
                      (__tui-state-focus state)
                      (+ (__tui-state-focus state) step))
              found (__tui-find-match (__tui-state-cells state)
                                      (__tui-state-outputs state)
                                      query
                                      start
                                      step
                                      count
                                      count)]
          (if (< found 0)
            (__tui-state-set-status state (__tui-str-concat "no matches for " query))
            (do
              (__tui-state-set-focus state found)
              (__tui-state-set-status state (__tui-str-concat "search: " query))))))))

  (defn __tui-rebuild-state [state :int new_nodes :int focus_idx :int status :cstr dirty_value :int] #{Unsafe} :int
    (let [new_cells (cells-assign-ids (__tui-reverse (__tui-cells-from-nodes-rev new_nodes (__tui-nil-value))
                                                     (__tui-nil-value)))
          count (__tui-list-length new_cells)
          clamped_focus (if (<= count 0)
                          0
                          (if (>= focus_idx count) (- count 1) (if (< focus_idx 0) 0 focus_idx)))]
      (do
        (__tui-state-set-nodes state new_nodes)
        (__tui-state-set-cells state new_cells)
        (__tui-state-set-cell-count state count)
        (__tui-state-set-focus state clamped_focus)
        (session-reset (__tui-state-session state))
        (__tui-state-set-outputs state (if (<= count 0) (__tui-nil-value) (eval-all (__tui-state-session state) new_cells 0 0)))
        (__tui-state-set-output-hidden state (__tui-zero-list count))
        (__tui-state-set-dirty state dirty_value)
        (__tui-state-set-help-visible state 0)
        (__tui-state-set-quit-confirm state 0)
        (__tui-state-set-status state status))))

  (defn __tui-edit-source [source :cstr] #{Unsafe} :cstr
    ```c
    /* __tur_include__: #include <unistd.h> */
    const char *override = getenv("TURNB_TEST_EDITOR_TEXT");
    if (override) return strdup(override);

    const char *src = source ? (const char *)(intptr_t)source : "";
    char tmpl[] = "/tmp/turnb-edit-XXXXXX";
    int fd = mkstemp(tmpl);
    if (fd < 0) return (const char *)(intptr_t)0;
    size_t want = strlen(src);
    if (want > 0) {
      ssize_t wrote = write(fd, src, want);
      if (wrote < 0 || (size_t)wrote != want) {
        close(fd);
        unlink(tmpl);
        return (const char *)(intptr_t)0;
      }
    }
    close(fd);

    const char *editor = getenv("VISUAL");
    if (!editor || !editor[0]) editor = getenv("EDITOR");
    if (!editor || !editor[0]) editor = "vi";

    char cmd[2048];
    snprintf(cmd, sizeof(cmd), "%s \"%s\"", editor, tmpl);
    if (system(cmd) != 0) {
      unlink(tmpl);
      return (const char *)(intptr_t)0;
    }

    FILE *fp = fopen(tmpl, "rb");
    if (!fp) { unlink(tmpl); return (const char *)(intptr_t)0; }
    if (fseek(fp, 0, SEEK_END) != 0) { fclose(fp); unlink(tmpl); return (const char *)(intptr_t)0; }
    long sz = ftell(fp);
    if (sz < 0) { fclose(fp); unlink(tmpl); return (const char *)(intptr_t)0; }
    rewind(fp);
    char *buf = malloc((size_t)sz + 1);
    size_t got = fread(buf, 1, (size_t)sz, fp);
    fclose(fp);
    unlink(tmpl);
    buf[got] = '\0';
    return buf;
    ```)

  (defn __tui-run-current [state :int move-next? :bool] #{Unsafe} :int
    (let [idx (__tui-state-focus state)
          cell (__tui-list-nth (__tui-state-cells state) idx)
          output (eval-cell (__tui-state-session state) cell 0)
          outputs (__tui-list-set (__tui-state-outputs state) idx output)
          _ (__tui-state-set-outputs state outputs)
          _ (__tui-state-set-quit-confirm state 0)
          _ (__tui-state-set-status state (__tui-output-message cell output))]
      (if (and move-next? (< (+ idx 1) (__tui-state-cell-count state)))
        (action-dispatch state "cell-next")
        state)))

  (defn __tui-run-all [state :int] #{Unsafe} :int
    (do
      (session-reset (__tui-state-session state))
      (__tui-state-set-outputs state (eval-all (__tui-state-session state) (__tui-state-cells state) 0 0))
      (__tui-state-set-quit-confirm state 0)
      (__tui-state-set-status state "reran notebook")
      state))

  (defn __tui-save [state :int] #{Unsafe} :int
    (let [path (__tui-state-path state)]
      (if (__tui-cstr-empty? path)
        (__tui-state-set-status state "save unavailable for in-memory notebook")
        (if (__tui-write-file path (nodes->str (__tui-state-nodes state)))
          (do
            (__tui-state-set-dirty state 0)
            (__tui-state-set-quit-confirm state 0)
            (__tui-state-set-status state (__tui-str-concat "saved " path)))
          (__tui-state-set-status state (__tui-str-concat "failed to save " path))))))

  (defn __tui-edit-current [state :int] #{Unsafe} :int
    (let [current (__tui-current-cell state)]
      (if (= current 0)
        (__tui-state-set-status state "no cell selected to edit")
        (do
          (term-disable-raw)
          (let [edited (__tui-edit-source (cell-source current))]
            (do
              (term-enable-raw)
              (if (not (__tui-cstr-empty? edited))
                (let [updated (if (__tui-cstr-eq? edited (cell-source current))
                                0
                                (nodes-update-cell (__tui-state-nodes state) (cell-id current) edited))]
                  (if (__tui-cstr-eq? edited (cell-source current))
                    (__tui-state-set-status state (__tui-str-concat "no changes to " (cell-id current)))
                    (if (__tui-result-ok? updated)
                      (__tui-rebuild-state state
                                           (__tui-result-ok-val updated)
                                           (__tui-state-focus state)
                                           (__tui-str-concat "edited " (cell-id current))
                                           1)
                      (__tui-state-set-status state (__tui-str-concat "failed to edit " (cell-id current))))))
                (__tui-state-set-status state (__tui-str-concat "editor failed for " (cell-id current))))))))))

  (defn __tui-add-cell [state :int above? :bool] #{Unsafe} :int
    (let [current (__tui-current-cell state)
          new_cell (__tui-blank-cell state current)
          new_node (__tui-node-cell-make new_cell)
          current_id (if (= current 0) "" (cell-id current))
          current_idx (__tui-state-focus state)
          new_nodes (if (= current 0)
                      (__tui-append-node (__tui-state-nodes state) new_node)
                      (if above?
                        (__tui-insert-node-before (__tui-state-nodes state) current_id new_node)
                        (__tui-insert-node-after (__tui-state-nodes state) current_id new_node)))
          next_focus (if above? current_idx (+ current_idx 1))]
      (__tui-rebuild-state state
                           new_nodes
                           (if (= current 0) 0 next_focus)
                           (__tui-str-concat "inserted " (cell-id new_cell))
                           1)))

  (defn __tui-delete-current [state :int] #{Unsafe} :int
    (let [current (__tui-current-cell state)]
      (if (= current 0)
        (__tui-state-set-status state "no cell selected to delete")
        (let [deleted (__tui-delete-node-pair (__tui-state-nodes state) (cell-id current))
              new_nodes (__tui-head deleted)
              clip (__tui-tail deleted)]
          (if (= clip 0)
            (__tui-state-set-status state (__tui-str-concat "failed to delete " (cell-id current)))
            (do
              (__tui-state-set-clipboard state clip)
              (__tui-rebuild-state state
                                   new_nodes
                                   (__tui-state-focus state)
                                   (__tui-str-concat "deleted " (cell-id current))
                                   1)))))))

  (defn __tui-paste-cell [state :int] #{Unsafe} :int
    (let [clip (__tui-state-clipboard state)
          current (__tui-current-cell state)]
      (if (= clip 0)
        (__tui-state-set-status state "clipboard is empty")
        (let [fresh_id (__tui-fresh-cell-id (__tui-state-cells state))
              copy (__tui-copy-cell clip fresh_id (cell-source clip))
              new_node (__tui-node-cell-make copy)
              new_nodes (if (= current 0)
                          (__tui-append-node (__tui-state-nodes state) new_node)
                          (__tui-insert-node-after (__tui-state-nodes state) (cell-id current) new_node))
              next_focus (if (= current 0) 0 (+ (__tui-state-focus state) 1))]
          (__tui-rebuild-state state
                               new_nodes
                               next_focus
                               (__tui-str-concat "pasted " fresh_id)
                               1)))))

  (defn __tui-request-quit [state :int] #{Unsafe} :int
    (if (= (__tui-state-dirty state) 1)
      (if (= (__tui-state-quit-confirm state) 1)
        (do
          (__tui-state-set-quit state 1 1)
          (__tui-state-set-status state "quit with unsaved changes"))
        (do
          (__tui-state-set-quit-confirm state 1)
          (__tui-state-set-status state "unsaved changes: press q again to quit or s to save")))
      (do
        (__tui-state-set-quit state 1 0)
        (__tui-state-set-status state "quit"))))

  (defn __tui-search-prompt [state :int] #{Unsafe} :int
    (do
      (__tui-state-set-status state "/")
      (__tui-render state)
      (term-disable-raw)
      (let [query (__tui-read-search-query)]
        (do
          (term-enable-raw)
          (if (__tui-cstr-empty? query)
            (__tui-state-set-status state "search cancelled")
            (do
              (__tui-state-set-search-query state query)
              (__tui-search state query 1 true)))))))

  (defn __tui-search-next [state :int] #{Unsafe} :int
    (__tui-search state (__tui-state-search-query state) 1 false))

  (defn __tui-search-prev [state :int] #{Unsafe} :int
    (__tui-search state (__tui-state-search-query state) -1 false))

  (defn __tui-toggle-help [state :int] #{Unsafe} :int
    (let [next (if (= (__tui-state-help-visible state) 1) 0 1)]
      (do
        (__tui-state-set-help-visible state next)
        (__tui-state-set-status state (if (= next 1) "help overlay" "command mode")))))

  (defn __tui-toggle-output [state :int] #{Unsafe} :int
    (let [idx (__tui-state-focus state)
          hidden (__tui-state-output-hidden state)
          next (if (= (__tui-list-nth hidden idx) 1) 0 1)
          updated (__tui-list-set hidden idx next)]
      (do
        (__tui-state-set-output-hidden state updated)
        (__tui-state-set-status state (if (= next 1) "hid output" "showed output")))))

  (defn __tui-apply-effect [state :int] #{Unsafe} :int
    (let [effect (__tui-state-pending-effect state)
          _ (__tui-state-set-pending-effect state 0)]
      (if (= effect 1)
        (__tui-run-current state false)
        (if (= effect 2)
          (__tui-run-current state true)
          (if (= effect 3)
            (__tui-run-all state)
            (if (= effect 4)
              (__tui-save state)
              (if (= effect 5)
                (__tui-edit-current state)
                (if (= effect 6)
                  (__tui-add-cell state true)
                  (if (= effect 7)
                    (__tui-add-cell state false)
                    (if (= effect 8)
                      (__tui-delete-current state)
                      (if (= effect 9)
                        (__tui-paste-cell state)
                        (if (= effect 10)
                          (__tui-request-quit state)
                          (if (= effect 11)
                            (__tui-search-prompt state)
                            (if (= effect 12)
                              (__tui-search-next state)
                              (if (= effect 13)
                                (__tui-search-prev state)
                                (if (= effect 14)
                                  (__tui-toggle-help state)
                                  (if (= effect 15)
                                    (__tui-toggle-output state)
                                    state)))))))))))))))))

  (defn __tui-render [state :int] #{Unsafe} :int
    ```c
    /* __tur_include__: #include <sys/ioctl.h> */
    /* __tur_include__: #include <unistd.h> */
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct {
      char *id;
      int64_t lang;
      char *source;
      int64_t attrs;
      int64_t start_line;
      int64_t end_line;
    } Cell;
    typedef struct {
      char *cell_id;
      int64_t status;
      char *stdout_text;
      char *value_repr;
      char *error_msg;
      int64_t elapsed_ms;
      int64_t image_paths;
    } NotebookCellOutput;
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
      int64_t output_hidden;
      char *search_query;
      int64_t help_visible;
    } NotebookTuiState;

    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    if (!st) return 0;

    struct winsize ws;
    int cols = 80;
    if (ioctl(STDOUT_FILENO, TIOCGWINSZ, &ws) == 0 && ws.ws_col > 0) cols = ws.ws_col;

    fputs("\033[2J\033[H", stdout);
    if (st->color) fputs("\033[1;38;5;111m", stdout);
    fprintf(stdout, "tur-notebook -- command mode");
    if (st->color) fputs("\033[0m", stdout);
    fprintf(stdout, "%s    j/k gg G Enter Shift-Enter r R e a b dd p / n N ? o s q\n",
            st->dirty ? " [modified]" : "");
    fprintf(stdout, "status: %s\n\n", st->status ? st->status : "");

    if (st->help_visible) {
      fprintf(stdout, "----- help -----\n");
      fprintf(stdout, "j/k or arrows  move between cells\n");
      fprintf(stdout, "Enter / Shift-Enter / r / R  run cells\n");
      fprintf(stdout, "e edit   a/b insert   dd delete   p paste\n");
      fprintf(stdout, "/ search   n/N next/prev match   o toggle output\n");
      fprintf(stdout, "s save   q quit   ? close help\n");
      fprintf(stdout, "\npress any key to return\n");
      fflush(stdout);
      return 0;
    }

    int idx = 0;
    for (Cons *cur = (Cons *)(intptr_t)st->cells; cur; cur = (Cons *)(intptr_t)cur->tail, idx++) {
      Cell *cell = (Cell *)(intptr_t)cur->head;
      NotebookCellOutput *out = NULL;
      Cons *out_cur = (Cons *)(intptr_t)st->outputs;
      for (int j = 0; out_cur && j < idx; j++) out_cur = (Cons *)(intptr_t)out_cur->tail;
      if (out_cur) out = (NotebookCellOutput *)(intptr_t)out_cur->head;

      const char *marker = idx == st->focus ? ">" : " ";
      const char *status = "pending";
      if (out) {
        if (out->status == 0) status = "ok";
        else if (out->status == 1) status = "error";
        else if (out->status == 2) status = "skipped";
      }

      const char *src = cell && cell->source ? cell->source : "";
      char preview[96];
      size_t i = 0;
      while (src[i] && src[i] != '\n' && i + 1 < sizeof(preview)) {
        preview[i] = src[i];
        i++;
      }
      preview[i] = '\0';
      if (st->color && idx == st->focus) fputs("\033[38;5;81m", stdout);
      fprintf(stdout, "%s [%s] %s -- %s\n",
              marker,
              status,
              cell && cell->id ? cell->id : "cell",
              preview[0] ? preview : "(empty cell)");
      if (st->color && idx == st->focus) fputs("\033[0m", stdout);
    }

    Cell *focus_cell = NULL;
    NotebookCellOutput *focus_out = NULL;
    int focus_hidden = 0;
    Cons *cell_cur = (Cons *)(intptr_t)st->cells;
    for (int j = 0; cell_cur && j < st->focus; j++) cell_cur = (Cons *)(intptr_t)cell_cur->tail;
    if (cell_cur) focus_cell = (Cell *)(intptr_t)cell_cur->head;
    Cons *out_cur = (Cons *)(intptr_t)st->outputs;
    for (int j = 0; out_cur && j < st->focus; j++) out_cur = (Cons *)(intptr_t)out_cur->tail;
    if (out_cur) focus_out = (NotebookCellOutput *)(intptr_t)out_cur->head;
    Cons *hidden_cur = (Cons *)(intptr_t)st->output_hidden;
    for (int j = 0; hidden_cur && j < st->focus; j++) hidden_cur = (Cons *)(intptr_t)hidden_cur->tail;
    if (hidden_cur) focus_hidden = ((Cons *)(intptr_t)hidden_cur)->head != 0;

    fprintf(stdout, "\n");
    if (focus_cell) {
      if (st->color) fputs("\033[1m", stdout);
      fprintf(stdout, "cell %s\n", focus_cell->id ? focus_cell->id : "cell");
      if (st->color) fputs("\033[0m", stdout);
      fprintf(stdout, "----- source -----\n");
      fprintf(stdout, "%s\n", focus_cell->source ? focus_cell->source : "");
      if (focus_hidden) {
        fprintf(stdout, "(output hidden; press o to show)\n");
      } else {
        fprintf(stdout, "----- output -----\n");
        if (!focus_out) {
          fprintf(stdout, "(not run yet)\n");
        } else if (focus_out->status == 0) {
          if (focus_out->stdout_text && focus_out->stdout_text[0]) fprintf(stdout, "%s", focus_out->stdout_text);
          if (focus_out->value_repr && focus_out->value_repr[0]) fprintf(stdout, "=> %s\n", focus_out->value_repr);
          if ((!focus_out->stdout_text || !focus_out->stdout_text[0]) &&
              (!focus_out->value_repr || !focus_out->value_repr[0])) fprintf(stdout, "(ok)\n");
        } else if (focus_out->status == 2) {
          fprintf(stdout, "(skipped)\n");
        } else {
          fprintf(stdout, "%s\n", focus_out->error_msg ? focus_out->error_msg : "error");
        }
        /* Display any captured image paths using the best available protocol. */
        if (focus_out && focus_out->image_paths) {
          const char *term_prog = getenv("TERM_PROGRAM") ? getenv("TERM_PROGRAM") : "";
          const char *kit_win  = getenv("KITTY_WINDOW_ID") ? getenv("KITTY_WINDOW_ID") : "";
          int use_kitty  = kit_win[0] != '\0';
          int use_iterm2 = !use_kitty &&
            (strstr(term_prog, "iTerm") || strstr(term_prog, "WezTerm") ||
             strstr(term_prog, "Hyper"));

          for (Cons *img_cur = (Cons *)(intptr_t)focus_out->image_paths;
               img_cur; img_cur = (Cons *)(intptr_t)img_cur->tail) {
            const char *img_path = (const char *)(intptr_t)img_cur->head;
            if (!img_path || !img_path[0]) continue;

            if (!use_kitty && !use_iterm2) {
              fprintf(stdout, "[image: %s]\n", img_path);
              continue;
            }

            FILE *imgf = fopen(img_path, "rb");
            if (!imgf) { fprintf(stdout, "[image: %s (not found)]\n", img_path); continue; }
            fseek(imgf, 0, SEEK_END);
            long imgfsz = ftell(imgf);
            fseek(imgf, 0, SEEK_SET);
            if (imgfsz <= 0) { fclose(imgf); fprintf(stdout, "[image: %s (empty)]\n", img_path); continue; }
            unsigned char *imgraw = malloc((size_t)imgfsz);
            if (!imgraw) { fclose(imgf); fprintf(stdout, "[image: %s (oom)]\n", img_path); continue; }
            if ((long)fread(imgraw, 1, (size_t)imgfsz, imgf) != imgfsz) {
              free(imgraw); fclose(imgf);
              fprintf(stdout, "[image: %s (read error)]\n", img_path); continue;
            }
            fclose(imgf);

            static const char imgb64[] =
              "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
            size_t enc_len = ((size_t)imgfsz + 2) / 3 * 4 + 1;
            char *imgenc = malloc(enc_len);
            char *imgdst = imgenc;
            const unsigned char *imgsrc = imgraw;
            size_t imgrem = (size_t)imgfsz;
            while (imgrem >= 3) {
              imgdst[0] = imgb64[imgsrc[0] >> 2];
              imgdst[1] = imgb64[((imgsrc[0] & 0x03) << 4) | (imgsrc[1] >> 4)];
              imgdst[2] = imgb64[((imgsrc[1] & 0x0f) << 2) | (imgsrc[2] >> 6)];
              imgdst[3] = imgb64[imgsrc[2] & 0x3f];
              imgsrc += 3; imgdst += 4; imgrem -= 3;
            }
            if (imgrem == 1) {
              imgdst[0] = imgb64[imgsrc[0] >> 2];
              imgdst[1] = imgb64[(imgsrc[0] & 0x03) << 4];
              imgdst[2] = '='; imgdst[3] = '='; imgdst += 4;
            } else if (imgrem == 2) {
              imgdst[0] = imgb64[imgsrc[0] >> 2];
              imgdst[1] = imgb64[((imgsrc[0] & 0x03) << 4) | (imgsrc[1] >> 4)];
              imgdst[2] = imgb64[(imgsrc[1] & 0x0f) << 2];
              imgdst[3] = '='; imgdst += 4;
            }
            *imgdst = '\0';
            free(imgraw);
            size_t imgtotal = (size_t)(imgdst - imgenc);

            if (use_kitty) {
              size_t imgpos = 0;
              int imgfirst = 1;
              while (imgpos < imgtotal) {
                size_t chunk = imgtotal - imgpos;
                if (chunk > 4096) chunk = 4096;
                int more = (imgpos + chunk < imgtotal) ? 1 : 0;
                if (imgfirst) {
                  fprintf(stdout, "\033_Ga=T,f=100,m=%d;", more);
                  imgfirst = 0;
                } else {
                  fprintf(stdout, "\033_Gm=%d;", more);
                }
                fwrite(imgenc + imgpos, 1, chunk, stdout);
                fputs("\033\\", stdout);
                imgpos += chunk;
              }
              fputc('\n', stdout);
            } else {
              fprintf(stdout, "\033]1337;File=inline=1;size=%zu:", (size_t)imgfsz);
              fwrite(imgenc, 1, imgtotal, stdout);
              fputs("\a\n", stdout);
            }
            free(imgenc);
          }
        }
      }
    } else {
      fprintf(stdout, "no executable cells found\n");
    }

    fflush(stdout);
    return 0;
    ```)

  (defn __tui-handle-key [state :int pending :cstr key :cstr] #{Unsafe} :cstr
    (if (= (__tui-state-help-visible state) 1)
      (do
        (__tui-state-set-help-visible state 0)
        (__tui-state-set-status state "command mode")
        "")
      (let [_ (if (and (= (__tui-state-quit-confirm state) 1)
                     (not (__tui-cstr-eq? key "q")))
              (__tui-state-set-quit-confirm state 0)
              state)
          bindings (__tui-state-bindings state)
          combo (if (__tui-cstr-empty? pending) key (__tui-str-concat pending key))
          combo-action (__tui-binding-action bindings combo)]
        (if (not (__tui-cstr-empty? combo-action))
        (do
          (action-dispatch state combo-action)
          (__tui-apply-effect state)
          "")
        (if (__tui-binding-has-prefix bindings combo)
          combo
          (let [single-action (__tui-binding-action bindings key)]
            (if (not (__tui-cstr-empty? single-action))
              (do
                (action-dispatch state single-action)
                (__tui-apply-effect state)
                "")
              (do
                (__tui-state-set-status state (__tui-str-concat "unbound key: " key))
                ""))))))))

  (defn __tui-loop [state :int pending :cstr] #{Unsafe} :int
    (do
      (__tui-render state)
      (if (__tui-state-quit? state)
        (__tui-ok (__tui-state-exit-code state))
        (let [key (term-read-key)
              next-pending (__tui-handle-key state pending key)]
          (__tui-loop state next-pending)))))

  (defn __tui-load-bindings [opts :int] #{Unsafe} :int
    (let [path (__tui-opts-keybindings-file opts)]
      (if (__tui-cstr-empty? path)
        (__tui-ok (default-keybindings))
        (let [loaded (load-keybindings path)]
          (if (__tui-result-ok? loaded)
            (__tui-ok (__tui-concat-lists (__tui-result-ok-val loaded) (default-keybindings)))
            (__tui-err (__tui-result-err-val loaded)))))))

  (defn __tui-run-with-path [path :cstr nodes :int opts :int] #{Unsafe} :int
    (let [cells (cells-assign-ids (__tui-reverse (__tui-cells-from-nodes-rev nodes (__tui-nil-value))
                                                 (__tui-nil-value)))
          bindings-result (__tui-load-bindings opts)]
      (if (not (__tui-result-ok? bindings-result))
        (__tui-err (__tui-result-err-val bindings-result))
        (let [session (session-open)
              state (__tui-state-make path
                                      nodes
                                      cells
                                      (__tui-result-ok-val bindings-result)
                                      session
                                      opts)
              _ (__tui-state-set-outputs state (__tui-zero-list (__tui-state-cell-count state)))
              _ (__tui-state-set-output-hidden state (__tui-zero-list (__tui-state-cell-count state)))]
          (do
            (term-enable-raw)
            (let [result (__tui-loop state "")]
              (do
                (term-disable-raw)
                (style-reset)
                (session-close session)
                result)))))))

  ;;; tui-run -- parse a notebook file and launch the command-mode TUI.
  (defn tui-run [path :cstr opts :int] #{Unsafe} :int
    (let [parsed (parse-file path)]
      (if (not (__tui-result-ok? parsed))
        (__tui-err "failed to parse notebook file")
        (__tui-run-with-path path (__tui-result-ok-val parsed) opts))))

  ;;; tui-run-nodes -- launch the command-mode TUI with an already-parsed node list.
  (defn tui-run-nodes [nodes :int opts :int] #{Unsafe} :int
    (__tui-run-with-path "" nodes opts))

) ;; end defmodule notebook/tui
