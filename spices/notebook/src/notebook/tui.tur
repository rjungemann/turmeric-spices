  (defn __tui-state-cell-count [state :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
