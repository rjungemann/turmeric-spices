  (defn __tui-state-set-focus [state :int value :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
    } NotebookTuiState;
    NotebookTuiState *st = (NotebookTuiState *)(intptr_t)state;
    if (st) {
      st->focus = value;
      const char *trace = getenv("TURNB_TEST_TRACE");
      if (trace && trace[0]) {
        FILE *fp = fopen(trace, "ab");
        if (fp) {
          fprintf(fp, "focus:%lld\n", (long long)value);
          fclose(fp);
        }
      }
    }
    return state;
    ```)

