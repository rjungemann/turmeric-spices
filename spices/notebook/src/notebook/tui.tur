;;; notebook/tui -- command-mode terminal UI for .tur.md notebooks.
;; notebook/tui -- focus navigation, per-cell execution, and notebook redraws.

(defmodule notebook/tui
  (import notebook/format :refer [parse-file node-tag node-cell nodes->str nodes-update-cell])
  (import notebook/cell :refer [cell-make cells-assign-ids cell-id cell-lang cell-source
                                cell-attrs cell-start-line cell-end-line])
  (import notebook/session :refer [session-open session-close session-reset
                                   cell-output-status cell-output-elapsed-ms cell-output-stdout
                                   cell-output-value-repr cell-output-error-msg])
  (import notebook/eval :refer [eval-cell eval-all])
  (import ansi/term  :refer [term-enable-raw term-disable-raw term-read-key])
  (import ansi/style :refer [style-reset])
  (import notebook/keys :refer [default-keybindings load-keybindings action-dispatch])
  (export tui-opts-make default-tui-opts tui-run tui-run-nodes)

  (defn __tui-nil-value [] #{Unsafe} :int
    ```c
    return 0;
    ```)

  (defn __tui-cons [value :int next :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = malloc(sizeof(*cell));
    cell->head = value;
    cell->tail = next;
    return (int64_t)(intptr_t)cell;
    ```)

  (defn __tui-list-nil? [lst :int] #{Unsafe} :bool
    ```c
    return lst == 0;
    ```)

  (defn __tui-head [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void *)(intptr_t)lst;
    return cell ? cell->head : 0;
    ```)

  (defn __tui-tail [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void *)(intptr_t)lst;
    return cell ? cell->tail : 0;
    ```)

  (defn __tui-ok [value :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = true;
    r->ok_val = value;
    r->err_val = 0;
    return (int64_t)(intptr_t)r;
    ```)

  (defn __tui-err [value :cstr] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = false;
    r->ok_val = 0;
    r->err_val = (int64_t)(intptr_t)(value ? strdup((const char *)(intptr_t)value) : strdup("error"));
    return (int64_t)(intptr_t)r;
    ```)

  (defn __tui-result-ok? [result :int] #{Unsafe} :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void *)(intptr_t)result;
    return r && r->is_ok;
    ```)

  (defn __tui-result-ok-val [result :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void *)(intptr_t)result;
    return r ? r->ok_val : 0;
    ```)

  (defn __tui-result-err-val [result :int] #{Unsafe} :cstr
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void *)(intptr_t)result;
    return (r && !r->is_ok) ? (const char *)(intptr_t)r->err_val : "";
    ```)

  (defn __tui-cstr-empty? [s :cstr] #{Unsafe} :bool
    ```c
    const char *src = s ? (const char *)(intptr_t)s : "";
    return src[0] == '\0';
    ```)

  (defn __tui-cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    return strcmp(sa, sb) == 0;
    ```)

  (defn __tui-str-concat [a :cstr b :cstr] #{Unsafe} :cstr
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    size_t la = strlen(sa), lb = strlen(sb);
    char *out = malloc(la + lb + 1);
    memcpy(out, sa, la);
    memcpy(out + la, sb, lb);
    out[la + lb] = '\0';
    return out;
    ```)

  (defn __tui-cstr-drop-last [s :cstr] #{Unsafe} :cstr
    ```c
    const char *src = s ? (const char *)(intptr_t)s : "";
    size_t len = strlen(src);
    if (len == 0) return strdup("");
    char *out = malloc(len);
    memcpy(out, src, len - 1);
    out[len - 1] = '\0';
    return out;
    ```)

  (defn __tui-cstr-contains-ci? [haystack :cstr needle :cstr] #{Unsafe} :bool
    ```c
    /* __tur_include__: #include <ctype.h> */
    const char *hay = haystack ? (const char *)(intptr_t)haystack : "";
    const char *need = needle ? (const char *)(intptr_t)needle : "";
    if (!need[0]) return false;
    size_t hn = strlen(hay);
    size_t nn = strlen(need);
    if (nn > hn) return false;
    for (size_t i = 0; i + nn <= hn; i++) {
      size_t j = 0;
      while (j < nn && tolower((unsigned char)hay[i + j]) == tolower((unsigned char)need[j])) j++;
      if (j == nn) return true;
    }
    return false;
    ```)

  (defn __tui-int->cstr [value :int] #{Unsafe} :cstr
    ```c
    char buf[64];
    snprintf(buf, sizeof(buf), "%lld", (long long)value);
    return strdup(buf);
    ```)

  ;;; tui-opts-make -- build notebook/tui options.
  (defn tui-opts-make [color :int cell_width :int scrollback :int keybindings_file :cstr] #{Unsafe} :int
    ```c
    typedef struct {
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      char *keybindings_file;
    } NotebookTuiOpts;
    NotebookTuiOpts *opts = malloc(sizeof(*opts));
    opts->color = color;
    opts->cell_width = cell_width;
    opts->scrollback = scrollback;
    opts->keybindings_file = keybindings_file ? strdup((const char *)(intptr_t)keybindings_file) : strdup("");
    return (int64_t)(intptr_t)opts;
    ```)

  (defn __tui-opts-color [opts :int] #{Unsafe} :int
    ```c
    typedef struct {
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      char *keybindings_file;
    } NotebookTuiOpts;
    NotebookTuiOpts *o = (NotebookTuiOpts *)(intptr_t)opts;
    return o ? o->color : 1;
    ```)

  (defn __tui-opts-cell-width [opts :int] #{Unsafe} :int
    ```c
    typedef struct {
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      char *keybindings_file;
    } NotebookTuiOpts;
    NotebookTuiOpts *o = (NotebookTuiOpts *)(intptr_t)opts;
    return o ? o->cell_width : 0;
    ```)

  (defn __tui-opts-scrollback [opts :int] #{Unsafe} :int
    ```c
    typedef struct {
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      char *keybindings_file;
    } NotebookTuiOpts;
    NotebookTuiOpts *o = (NotebookTuiOpts *)(intptr_t)opts;
    return o ? o->scrollback : 1000;
    ```)

  (defn __tui-opts-keybindings-file [opts :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      char *keybindings_file;
    } NotebookTuiOpts;
    NotebookTuiOpts *o = (NotebookTuiOpts *)(intptr_t)opts;
    return (o && o->keybindings_file) ? o->keybindings_file : "";
    ```)

  ;;; default-tui-opts -- default options for the command-mode notebook TUI.
  (defn default-tui-opts [] #{Unsafe} :int
    (tui-opts-make 1 0 1000 ""))

  (defn __tui-node-cell-make [cell :int] #{Unsafe} :int
    ```c
    typedef struct { int64_t tag; int64_t prose; int64_t cell; } NotebookNode;
    NotebookNode *node = malloc(sizeof(*node));
    node->tag = 1;
    node->prose = 0;
    node->cell = cell;
    return (int64_t)(intptr_t)node;
    ```)

  (defn __tui-copy-cell [cell :int next_id :cstr next_source :cstr] #{Unsafe} :int
    (cell-make next_id
               (cell-lang cell)
               next_source
               (cell-attrs cell)
               (cell-start-line cell)
               (cell-end-line cell)))

  (defn __tui-current-cell [state :int] #{Unsafe} :int
    (__tui-list-nth (__tui-state-cells state) (__tui-state-focus state)))

  (defn __tui-cells-have-id? [cells :int want :cstr] #{Unsafe} :bool
    (if (__tui-list-nil? cells)
      false
      (if (__tui-cstr-eq? (cell-id (__tui-head cells)) want)
        true
        (__tui-cells-have-id? (__tui-tail cells) want))))

  (defn __tui-fresh-cell-id [cells :int] #{Unsafe} :cstr
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct {
      char *id;
      int64_t lang;
      char *source;
      int64_t attrs;
      int64_t start_line;
      int64_t end_line;
    } Cell;
    for (int idx = 1;; idx++) {
      char buf[64];
      snprintf(buf, sizeof(buf), "cell-%d", idx);
      int found = 0;
      for (Cons *cur = (Cons *)(intptr_t)cells; cur; cur = (Cons *)(intptr_t)cur->tail) {
        Cell *cell = (Cell *)(intptr_t)cur->head;
        if (cell && cell->id && strcmp(cell->id, buf) == 0) {
          found = 1;
          break;
        }
      }
      if (!found) return strdup(buf);
    }
    ```)

  (defn __tui-append-node [nodes :int new_node :int] #{Unsafe} :int
    (if (__tui-list-nil? nodes)
      (__tui-cons new_node (__tui-nil-value))
      (__tui-cons (__tui-head nodes) (__tui-append-node (__tui-tail nodes) new_node))))

  (defn __tui-insert-node-before [nodes :int target_id :cstr new_node :int] #{Unsafe} :int
    (if (__tui-list-nil? nodes)
      (__tui-cons new_node (__tui-nil-value))
      (let [node (__tui-head nodes)]
        (if (and (= (node-tag node) 1)
                 (__tui-cstr-eq? (cell-id (node-cell node)) target_id))
          (__tui-cons new_node nodes)
          (__tui-cons node (__tui-insert-node-before (__tui-tail nodes) target_id new_node))))))

  (defn __tui-insert-node-after [nodes :int target_id :cstr new_node :int] #{Unsafe} :int
    (if (__tui-list-nil? nodes)
      (__tui-cons new_node (__tui-nil-value))
      (let [node (__tui-head nodes)]
        (if (and (= (node-tag node) 1)
                 (__tui-cstr-eq? (cell-id (node-cell node)) target_id))
          (__tui-cons node (__tui-cons new_node (__tui-tail nodes)))
          (__tui-cons node (__tui-insert-node-after (__tui-tail nodes) target_id new_node))))))

  (defn __tui-delete-node-pair [nodes :int target_id :cstr] #{Unsafe} :int
    (if (__tui-list-nil? nodes)
      (__tui-cons (__tui-nil-value) 0)
      (let [node (__tui-head nodes)]
        (if (and (= (node-tag node) 1)
                 (__tui-cstr-eq? (cell-id (node-cell node)) target_id))
          (__tui-cons (__tui-tail nodes) (node-cell node))
          (let [rest (__tui-delete-node-pair (__tui-tail nodes) target_id)]
            (__tui-cons (__tui-cons node (__tui-head rest))
                        (__tui-tail rest)))))))

  (defn __tui-blank-cell [state :int current :int] #{Unsafe} :int
    (let [lang (if (= current 0) 0 (cell-lang current))
          fresh_id (__tui-fresh-cell-id (__tui-state-cells state))]
      (cell-make fresh_id lang "" (__tui-nil-value) 0 0)))

  (defn __tui-cells-from-nodes-rev [nodes :int acc :int] #{Unsafe} :int
    (if (__tui-list-nil? nodes)
      acc
      (let [node (__tui-head nodes)]
        (if (= (node-tag node) 1)
          (__tui-cells-from-nodes-rev (__tui-tail nodes) (__tui-cons (node-cell node) acc))
          (__tui-cells-from-nodes-rev (__tui-tail nodes) acc)))))

  (defn __tui-reverse [lst :int acc :int] #{Unsafe} :int
    (if (__tui-list-nil? lst)
      acc
      (__tui-reverse (__tui-tail lst) (__tui-cons (__tui-head lst) acc))))

  (defn __tui-list-length [lst :int] #{Unsafe} :int
    (if (__tui-list-nil? lst)
      0
      (+ 1 (__tui-list-length (__tui-tail lst)))))

  (defn __tui-zero-list [count :int] #{Unsafe} :int
    (if (<= count 0)
      (__tui-nil-value)
      (__tui-cons 0 (__tui-zero-list (- count 1)))))

  (defn __tui-list-nth [lst :int idx :int] #{Unsafe} :int
    (if (__tui-list-nil? lst)
      0
      (if (<= idx 0)
        (__tui-head lst)
        (__tui-list-nth (__tui-tail lst) (- idx 1)))))

  (defn __tui-list-set [lst :int idx :int value :int] #{Unsafe} :int
    (if (<= idx 0)
      (__tui-cons value (if (__tui-list-nil? lst) (__tui-nil-value) (__tui-tail lst)))
      (if (__tui-list-nil? lst)
        (__tui-cons 0 (__tui-list-set (__tui-nil-value) (- idx 1) value))
        (__tui-cons (__tui-head lst) (__tui-list-set (__tui-tail lst) (- idx 1) value)))))

  (defn __tui-concat-lists [left :int right :int] #{Unsafe} :int
    (if (__tui-list-nil? left)
      right
      (__tui-cons (__tui-head left) (__tui-concat-lists (__tui-tail left) right))))

  (defn __tui-write-file [path :cstr text :cstr] #{Unsafe} :bool
    ```c
    const char *dst = path ? (const char *)(intptr_t)path : "";
    const char *src = text ? (const char *)(intptr_t)text : "";
    FILE *fp = fopen(dst, "wb");
    if (!fp) return false;
    size_t want = strlen(src);
    size_t wrote = fwrite(src, 1, want, fp);
    fclose(fp);
    return wrote == want;
    ```)

  (defn __tui-state-make [path :cstr nodes :int cells :int bindings :int session :int opts :int] #{Unsafe} :int
    ```c
    typedef struct {
      char *path;
      int64_t nodes;
      int64_t cells;
      int64_t outputs;
      int64_t cell_count;
      int64_t focus;
      int64_t session;
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      int64_t keybindings;
      char *status;
      int64_t pending_effect;
      int64_t quit_requested;
      int64_t exit_code;
      int64_t clipboard;
      int64_t dirty;
      int64_t quit_confirm;
      int64_t output_hidden;
      char *search_query;
      int64_t help_visible;
    } NotebookTuiState;
    typedef struct {
      int64_t color;
      int64_t cell_width;
      int64_t scrollback;
      char *keybindings_file;
    } NotebookTuiOpts;
    NotebookTuiOpts *o = (NotebookTuiOpts *)(intptr_t)opts;
    NotebookTuiState *st = malloc(sizeof(*st));
    st->path = path ? strdup((const char *)(intptr_t)path) : strdup("");
    st->nodes = nodes;
    st->cells = cells;
    st->outputs = 0;
    st->cell_count = 0;
    for (struct { int64_t head; int64_t tail; } *cur = (void *)(intptr_t)cells; cur; cur = (void *)(intptr_t)cur->tail) st->cell_count++;
    st->focus = 0;
    st->session = session;
    st->color = o ? o->color : 1;
    st->cell_width = o ? o->cell_width : 0;
    st->scrollback = o ? o->scrollback : 1000;
    st->keybindings = bindings;
    st->status = strdup("command mode");
    st->pending_effect = 0;
    st->quit_requested = 0;
    st->exit_code = 0;
    st->clipboard = 0;
    st->dirty = 0;
    st->quit_confirm = 0;
    st->output_hidden = 0;
    st->search_query = strdup("");
    st->help_visible = 0;
    return (int64_t)(intptr_t)st;
    ```)

