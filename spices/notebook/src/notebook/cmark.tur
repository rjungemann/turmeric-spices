;; notebook/cmark -- block-level CommonMark subset parser for tur-notebook.

(defmodule notebook/cmark
  (export md-tag-document md-tag-heading md-tag-paragraph
          md-tag-blockquote md-tag-list md-tag-list-item
          md-tag-code-block md-tag-thematic-break
          md-tag-table md-tag-table-row md-tag-table-cell
          md-tag-text md-tag-emph md-tag-strong
          md-tag-code-span md-tag-link md-tag-image
          md-tag-strikethrough
          md-tag-autolink md-tag-hard-break md-tag-soft-break
          md-tag-math-block md-tag-math-inline
          md-parse
          md-node-tag md-node-children md-node-text
          md-node-info md-node-meta md-source-span
          md-emit md-emit-html)

  ;; Minimal cons helpers so the module stays self-contained.
  (defn nil-value [] #{Unsafe} :int
    ```c
    return 0;
    ```)

  (defn list-nil? [lst :int] #{Unsafe} :bool
    ```c
    return lst == 0;
    ```)

  (defn cons [value :int next :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = malloc(sizeof(*cell));
    cell->head = value;
    cell->tail = next;
    return (int64_t)(intptr_t)cell;
    ```)

  (defn head [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    if (!cell) { fprintf(stderr, "head: empty list\n"); exit(1); }
    return cell->head;
    ```)

  (defn tail [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    if (!cell) { fprintf(stderr, "tail: empty list\n"); exit(1); }
    return cell->tail;
    ```)

  (defn __str-concat [a :cstr b :cstr] #{Unsafe} :cstr
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    size_t la = strlen(sa), lb = strlen(sb);
    char *out = malloc(la + lb + 1);
    memcpy(out, sa, la);
    memcpy(out + la, sb, lb);
    out[la + lb] = '\0';
    return out;
    ```)

  (defn __repeat-char [ch :int count :int] #{Unsafe} :cstr
    ```c
    if (count <= 0) {
      char *out = malloc(1);
      out[0] = '\0';
      return out;
    }
    char *out = malloc((size_t)count + 1);
    for (int i = 0; i < count; i++) out[i] = (char)ch;
    out[count] = '\0';
    return out;
    ```)

  (defn __int->cstr [value :int] #{Unsafe} :cstr
    ```c
    char buf[32];
    snprintf(buf, sizeof(buf), "%lld", (long long)value);
    return strdup(buf);
    ```)

  (defn __int-as-cstr [value :int] #{Unsafe} :cstr
    ```c
    return (const char *)(intptr_t)value;
    ```)

  (defn __cstr-as-int [value :cstr] #{Unsafe} :int
    ```c
    return (int64_t)(intptr_t)value;
    ```)

  (defn __cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    return strcmp(sa, sb) == 0;
    ```)

  (defn __prefix-lines [prefix :cstr body :cstr] #{Unsafe} :cstr
    ```c
    const char *p = prefix ? (const char *)(intptr_t)prefix : "";
    const char *s = body ? (const char *)(intptr_t)body : "";
    size_t lp = strlen(p), ls = strlen(s);
    size_t cap = lp + ls + 16;
    char *out = malloc(cap);
    size_t len = 0;
    bool need_prefix = true;
    if (ls == 0) {
      memcpy(out, p, lp);
      out[lp] = '\0';
      return out;
    }
    for (size_t i = 0; i < ls; i++) {
      if (need_prefix) {
        if (len + lp + 2 >= cap) { cap *= 2; out = realloc(out, cap); }
        memcpy(out + len, p, lp);
        len += lp;
        need_prefix = false;
      }
      if (len + 2 >= cap) { cap *= 2; out = realloc(out, cap); }
      out[len++] = s[i];
      if (s[i] == '\n') need_prefix = true;
    }
    out[len] = '\0';
    return out;
    ```)

  (defn __format-list-item [prefix :cstr body :cstr] #{Unsafe} :cstr
    ```c
    const char *p = prefix ? (const char *)(intptr_t)prefix : "";
    const char *s = body ? (const char *)(intptr_t)body : "";
    size_t lp = strlen(p), ls = strlen(s);
    char *indent = malloc(lp + 1);
    memset(indent, ' ', lp);
    indent[lp] = '\0';
    size_t cap = lp + ls + 16;
    char *out = malloc(cap);
    size_t len = 0;
    memcpy(out + len, p, lp);
    len += lp;
    if (ls == 0) {
      out[len] = '\0';
      free(indent);
      return out;
    }
    bool at_line_start = true;
    for (size_t i = 0; i < ls; i++) {
      if (at_line_start) {
        if (len + strlen(indent) + 2 >= cap) { cap *= 2; out = realloc(out, cap); }
        if (i == 0) {
          at_line_start = false;
        } else {
          memcpy(out + len, indent, lp);
          len += lp;
          at_line_start = false;
        }
      }
      if (len + 2 >= cap) { cap *= 2; out = realloc(out, cap); }
      out[len++] = s[i];
      if (s[i] == '\n') at_line_start = true;
    }
    out[len] = '\0';
    free(indent);
    return out;
    ```)

  ;; AST tags used in NB0.
  (defn md-tag-document [] :int 0)
  (defn md-tag-heading [] :int 1)
  (defn md-tag-paragraph [] :int 2)
  (defn md-tag-blockquote [] :int 3)
  (defn md-tag-list [] :int 4)
  (defn md-tag-list-item [] :int 5)
  (defn md-tag-code-block [] :int 6)
  (defn md-tag-thematic-break [] :int 7)
  (defn md-tag-table [] :int 8)
  (defn md-tag-table-row [] :int 9)
  (defn md-tag-table-cell [] :int 10)
  (defn md-tag-text [] :int 11)
  (defn md-tag-emph [] :int 12)
  (defn md-tag-strong [] :int 13)
  (defn md-tag-code-span [] :int 14)
  (defn md-tag-link [] :int 15)
  (defn md-tag-image [] :int 16)
  (defn md-tag-strikethrough [] :int 17)
  (defn md-tag-autolink [] :int 18)
  (defn md-tag-hard-break [] :int 19)
  (defn md-tag-soft-break [] :int 20)
  (defn md-tag-math-block [] :int 22)
  (defn md-tag-math-inline [] :int 23)

  ;;; md-node-tag -- return the block tag of a parsed markdown node.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle returned by md-parse or md-node-children
  ;;;
  ;;; Returns:
  ;;;   One of the md-tag-* integer constants implemented in NB0.
  ;;;
  ;;; Example:
  ;;;   (md-node-tag (md-parse "# Hi"))
  ;;;
  ;;; Since: NB0
  (defn md-node-tag [n :int] #{Unsafe} :int
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    MdNode *node = (MdNode*)(intptr_t)n;
    return node ? node->kind : -1;
    ```)

  ;;; md-node-children -- return the children of a node as a cons list.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle
  ;;;
  ;;; Returns:
  ;;;   A cons list of child node handles in document order.
  ;;;
  ;;; Example:
  ;;;   (md-node-children doc)
  ;;;
  ;;; Since: NB0
  (defn md-node-children [n :int] #{Unsafe} :int
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    typedef struct { int64_t head; int64_t tail; } Cons;
    MdNode *node = (MdNode*)(intptr_t)n;
    int64_t out = 0;
    if (!node) return 0;
    for (int i = node->child_count - 1; i >= 0; i--) {
      Cons *cell = malloc(sizeof(*cell));
      cell->head = node->children[i];
      cell->tail = out;
      out = (int64_t)(intptr_t)cell;
    }
    return out;
    ```)

  ;;; md-node-text -- return the node text payload for block-level nodes.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle
  ;;;
  ;;; Returns:
  ;;;   Paragraph text, heading text, or code-block body depending on node kind.
  ;;;
  ;;; Example:
  ;;;   (md-node-text heading)
  ;;;
  ;;; Since: NB0
  (defn md-node-text [n :int] #{Unsafe} :cstr
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    MdNode *node = (MdNode*)(intptr_t)n;
    return node && node->text ? node->text : "";
    ```)

  ;;; md-node-info -- return the node info payload.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle
  ;;;
  ;;; Returns:
  ;;;   Fence info string for code blocks, or list marker info for list nodes.
  ;;;
  ;;; Example:
  ;;;   (md-node-info code-block)
  ;;;
  ;;; Since: NB0
  (defn md-node-info [n :int] #{Unsafe} :cstr
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    MdNode *node = (MdNode*)(intptr_t)n;
    return node && node->info ? node->info : "";
    ```)

  ;;; md-node-meta -- return the node integer metadata field.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle
  ;;;
  ;;; Returns:
  ;;;   Heading level for headings or list start number for ordered lists.
  ;;;
  ;;; Example:
  ;;;   (md-node-meta heading)
  ;;;
  ;;; Since: NB0
  (defn md-node-meta [n :int] #{Unsafe} :int
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    MdNode *node = (MdNode*)(intptr_t)n;
    return node ? node->meta : 0;
    ```)

  ;;; md-source-span -- return the start/end line pair for a node.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle
  ;;;
  ;;; Returns:
  ;;;   A cons pair (start-line . end-line), both 1-based.
  ;;;
  ;;; Example:
  ;;;   (md-source-span node)
  ;;;
  ;;; Since: NB0
  (defn md-source-span [n :int] #{Unsafe} :int
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    typedef struct { int64_t head; int64_t tail; } Cons;
    MdNode *node = (MdNode*)(intptr_t)n;
    Cons *b = malloc(sizeof(*b));
    Cons *a = malloc(sizeof(*a));
    b->head = node ? node->end_line : 0;
    b->tail = 0;
    a->head = node ? node->start_line : 0;
    a->tail = (int64_t)(intptr_t)b;
    return (int64_t)(intptr_t)a;
    ```)

  (defn __md-void [] #{Unsafe} :void
    ```c
    (void)0;
    ```)

  (defn __md-inline-fill [n :int] #{Unsafe} :void
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    #define NEW_NODE(K,T,I,M,S,E) ({ \
      MdNode *nn = malloc(sizeof(*nn)); \
      nn->kind = (K); \
      nn->text = (T) ? strdup(T) : NULL; \
      nn->info = (I) ? strdup(I) : NULL; \
      nn->meta = (M); \
      nn->start_line = (S); \
      nn->end_line = (E); \
      nn->children = NULL; \
      nn->child_count = 0; \
      nn->child_cap = 0; \
      (int64_t)(intptr_t)nn; \
    })
    #define ADD_CHILD(P,C) do { \
      MdNode *pp = (MdNode*)(intptr_t)(P); \
      if (pp->child_count >= pp->child_cap) { \
        pp->child_cap = pp->child_cap ? pp->child_cap * 2 : 4; \
        pp->children = realloc(pp->children, (size_t)pp->child_cap * sizeof(int64_t)); \
      } \
      pp->children[pp->child_count++] = (C); \
    } while (0)
    #define TBUF_INIT() size_t tlen = 0, tcap = 64; char *tbuf = malloc(tcap); tbuf[0] = '\0'
    #define TBUF_APPEND_CH(CH) do { \
      if (tlen + 2 > tcap) { tcap *= 2; tbuf = realloc(tbuf, tcap); } \
      tbuf[tlen++] = (char)(CH); \
      tbuf[tlen] = '\0'; \
    } while (0)
    #define TBUF_APPEND_BYTES(PTR,LEN) do { \
      size_t need = tlen + (size_t)(LEN) + 1; \
      while (need > tcap) { tcap *= 2; tbuf = realloc(tbuf, tcap); } \
      memcpy(tbuf + tlen, (PTR), (size_t)(LEN)); \
      tlen += (size_t)(LEN); \
      tbuf[tlen] = '\0'; \
    } while (0)
    #define TBUF_FLUSH() do { \
      if (tlen > 0) { \
        ADD_CHILD(n, NEW_NODE(11, tbuf, NULL, 0, node->start_line, node->end_line)); \
        tlen = 0; \
        tbuf[0] = '\0'; \
      } \
    } while (0)
    MdNode *node = (MdNode*)(intptr_t)n;
    if (!node || !node->text || node->child_count > 0) return;
    const char *src = node->text;
    size_t slen = strlen(src);
    TBUF_INIT();
    for (size_t i = 0; i < slen; ) {
      if (src[i] == '\\') {
        if (i + 1 < slen && src[i + 1] == '\n') {
          TBUF_FLUSH();
          ADD_CHILD(n, NEW_NODE(19, NULL, NULL, 0, node->start_line, node->end_line));
          i += 2;
          continue;
        }
        if (i + 1 < slen && strchr("!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~", src[i + 1])) {
          TBUF_APPEND_CH(src[i + 1]);
          i += 2;
          continue;
        }
      }
      if (src[i] == '\n') {
        int hard = 0;
        if (i >= 2 && src[i - 1] == ' ' && src[i - 2] == ' ') {
          if (tlen >= 2) { tlen -= 2; tbuf[tlen] = '\0'; }
          hard = 1;
        }
        TBUF_FLUSH();
        ADD_CHILD(n, NEW_NODE(hard ? 19 : 20, NULL, NULL, 0, node->start_line, node->end_line));
        i++;
        continue;
      }
      if (src[i] == '&') {
        if (strncmp(src + i, "&amp;", 5) == 0) { TBUF_APPEND_CH('&'); i += 5; continue; }
        if (strncmp(src + i, "&lt;", 4) == 0) { TBUF_APPEND_CH('<'); i += 4; continue; }
        if (strncmp(src + i, "&gt;", 4) == 0) { TBUF_APPEND_CH('>'); i += 4; continue; }
        if (strncmp(src + i, "&quot;", 6) == 0) { TBUF_APPEND_CH('"'); i += 6; continue; }
        if (strncmp(src + i, "&apos;", 6) == 0) { TBUF_APPEND_CH('\''); i += 6; continue; }
        if (i + 3 < slen && src[i + 1] == '#') {
          size_t j = i + 2;
          int base = 10;
          if (j < slen && (src[j] == 'x' || src[j] == 'X')) { base = 16; j++; }
          char numbuf[16];
          size_t npos = 0;
          while (j < slen && src[j] != ';' && npos + 1 < sizeof(numbuf)) numbuf[npos++] = src[j++];
          if (j < slen && src[j] == ';' && npos > 0) {
            numbuf[npos] = '\0';
            long val = strtol(numbuf, NULL, base);
            if (val > 0 && val < 128) {
              TBUF_APPEND_CH((char)val);
              i = j + 1;
              continue;
            }
          }
        }
      }
      if (src[i] == '`') {
        size_t ticks = 1;
        while (i + ticks < slen && src[i + ticks] == '`') ticks++;
        size_t j = i + ticks;
        int found = 0;
        while (j + ticks <= slen) {
          if (strncmp(src + j, src + i, ticks) == 0) { found = 1; break; }
          j++;
        }
        if (found) {
          TBUF_FLUSH();
          char *code = malloc((j - (i + ticks)) + 1);
          size_t out = 0;
          for (size_t k = i + ticks; k < j; k++) code[out++] = (src[k] == '\n') ? ' ' : src[k];
          code[out] = '\0';
          ADD_CHILD(n, NEW_NODE(14, code, NULL, 0, node->start_line, node->end_line));
          free(code);
          i = j + ticks;
          continue;
        }
      }
      if (src[i] == '$') {
        char nxt = (i + 1 < slen) ? src[i + 1] : '\0';
        char prv = (i > 0) ? src[i - 1] : '\0';
        bool opener = nxt != '\0'
                      && nxt != ' ' && nxt != '\t' && nxt != '\n'
                      && !(nxt >= '0' && nxt <= '9')
                      && prv != '\\';
        if (opener) {
          size_t j = i + 1;
          int found = 0;
          while (j < slen) {
            if (src[j] == '\\' && j + 1 < slen) { j += 2; continue; }
            if (src[j] == '\n') break;
            if (src[j] == '$' && j > i + 1) {
              char pj = src[j - 1];
              if (pj != ' ' && pj != '\t' && pj != '\n') { found = 1; break; }
            }
            j++;
          }
          if (found) {
            TBUF_FLUSH();
            size_t bl = j - (i + 1);
            char *inner = malloc(bl + 1);
            memcpy(inner, src + i + 1, bl);
            inner[bl] = '\0';
            ADD_CHILD(n, NEW_NODE(23, inner, NULL, 0, node->start_line, node->end_line));
            free(inner);
            i = j + 1;
            continue;
          }
        }
      }
      if (src[i] == '~' && i + 1 < slen && src[i + 1] == '~') {
        size_t j = i + 2;
        int found = 0;
        while (j + 1 < slen) {
          if (src[j] == '~' && src[j + 1] == '~') { found = 1; break; }
          j++;
        }
        if (found) {
          TBUF_FLUSH();
          char *inner = malloc((j - (i + 2)) + 1);
          memcpy(inner, src + i + 2, j - (i + 2));
          inner[j - (i + 2)] = '\0';
          int64_t strike = NEW_NODE(17, NULL, NULL, 0, node->start_line, node->end_line);
          if (inner[0] != '\0') ADD_CHILD(strike, NEW_NODE(11, inner, NULL, 0, node->start_line, node->end_line));
          ADD_CHILD(n, strike);
          free(inner);
          i = j + 2;
          continue;
        }
      }
      if ((src[i] == '*' || src[i] == '_') && i + 1 < slen && src[i + 1] == src[i]) {
        char delim = src[i];
        size_t j = i + 2;
        int found = 0;
        while (j + 1 < slen) {
          if (src[j] == delim && src[j + 1] == delim) { found = 1; break; }
          j++;
        }
        if (found) {
          TBUF_FLUSH();
          char *inner = malloc((j - (i + 2)) + 1);
          memcpy(inner, src + i + 2, j - (i + 2));
          inner[j - (i + 2)] = '\0';
          int64_t strong = NEW_NODE(13, NULL, NULL, 0, node->start_line, node->end_line);
          if (inner[0] != '\0') ADD_CHILD(strong, NEW_NODE(11, inner, NULL, 0, node->start_line, node->end_line));
          ADD_CHILD(n, strong);
          free(inner);
          i = j + 2;
          continue;
        }
      }
      if (src[i] == '*' || src[i] == '_') {
        char delim = src[i];
        size_t j = i + 1;
        int found = 0;
        while (j < slen) {
          if (src[j] == delim) { found = 1; break; }
          j++;
        }
        if (found) {
          TBUF_FLUSH();
          char *inner = malloc((j - (i + 1)) + 1);
          memcpy(inner, src + i + 1, j - (i + 1));
          inner[j - (i + 1)] = '\0';
          int64_t emph = NEW_NODE(12, NULL, NULL, 0, node->start_line, node->end_line);
          if (inner[0] != '\0') ADD_CHILD(emph, NEW_NODE(11, inner, NULL, 0, node->start_line, node->end_line));
          ADD_CHILD(n, emph);
          free(inner);
          i = j + 1;
          continue;
        }
      }
      if (src[i] == '!' && i + 1 < slen && src[i + 1] == '[') {
        size_t close = i + 2;
        while (close < slen && src[close] != ']') close++;
        if (close + 1 < slen && src[close] == ']' && src[close + 1] == '(') {
          size_t pend = close + 2;
          while (pend < slen && src[pend] != ')') pend++;
          if (pend < slen) {
            size_t split = close + 2;
            while (split < pend && src[split] != ' ') split++;
            char *alt = malloc((close - (i + 2)) + 1);
            memcpy(alt, src + i + 2, close - (i + 2));
            alt[close - (i + 2)] = '\0';
            char *dest = malloc((split - (close + 2)) + 1);
            memcpy(dest, src + close + 2, split - (close + 2));
            dest[split - (close + 2)] = '\0';
            char *title = strdup("");
            if (split < pend) {
              size_t ts = split;
              while (ts < pend && src[ts] == ' ') ts++;
              if (ts < pend && (src[ts] == '"' || src[ts] == '\'')) {
                char q = src[ts++];
                size_t te = ts;
                while (te < pend && src[te] != q) te++;
                free(title);
                title = malloc((te - ts) + 1);
                memcpy(title, src + ts, te - ts);
                title[te - ts] = '\0';
              }
            }
            TBUF_FLUSH();
            int64_t img = NEW_NODE(16, title, dest, 0, node->start_line, node->end_line);
            if (alt[0] != '\0') ADD_CHILD(img, NEW_NODE(11, alt, NULL, 0, node->start_line, node->end_line));
            ADD_CHILD(n, img);
            free(alt);
            free(dest);
            free(title);
            i = pend + 1;
            continue;
          }
        }
      }
      if (src[i] == '[') {
        size_t close = i + 1;
        while (close < slen && src[close] != ']') close++;
        if (close + 1 < slen && src[close] == ']' && src[close + 1] == '(') {
          size_t pend = close + 2;
          while (pend < slen && src[pend] != ')') pend++;
          if (pend < slen) {
            size_t split = close + 2;
            while (split < pend && src[split] != ' ') split++;
            char *label = malloc((close - (i + 1)) + 1);
            memcpy(label, src + i + 1, close - (i + 1));
            label[close - (i + 1)] = '\0';
