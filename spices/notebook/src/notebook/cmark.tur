  (defn __md-upgrade-gfm-list [nodes :int] #{Unsafe} :void
    (if (list-nil? nodes)
      (__md-void)
      (do
        (__md-upgrade-gfm (head nodes))
        (__md-upgrade-gfm-list (tail nodes)))))

  (defn __md-upgrade-gfm [n :int] #{Unsafe} :void
    (do
      (__md-upgrade-gfm-node n)
      (let [tag (md-node-tag n)]
        (if (or (= tag (md-tag-document))
                (or (= tag (md-tag-blockquote))
                    (or (= tag (md-tag-list))
                        (or (= tag (md-tag-list-item))
                            (or (= tag (md-tag-table))
                                (= tag (md-tag-table-row)))))))
          (__md-upgrade-gfm-list (md-node-children n))
          (__md-void)))))

  (defn __md-annotate-inline-list [nodes :int] #{Unsafe} :void
    (if (list-nil? nodes)
      (__md-void)
      (do
        (__md-annotate-inlines (head nodes))
        (__md-annotate-inline-list (tail nodes)))))

  (defn __md-annotate-inlines [n :int] #{Unsafe} :void
    (let [tag (md-node-tag n)]
      (if (or (= tag (md-tag-heading))
              (or (= tag (md-tag-paragraph))
                  (= tag (md-tag-table-cell))))
        (__md-inline-fill n)
        (if (or (= tag (md-tag-document))
                (or (= tag (md-tag-blockquote))
                    (or (= tag (md-tag-list))
                        (or (= tag (md-tag-list-item))
                            (or (= tag (md-tag-table))
                                (= tag (md-tag-table-row)))))))
          (__md-annotate-inline-list (md-node-children n))
          (__md-void)))))

  ;;; md-parse -- parse a markdown string into a block-level AST.
  ;;;
  ;;; Parameters:
  ;;;   source -- markdown text
  ;;;
  ;;; Returns:
  ;;;   A document node whose children hold NB0 block nodes.
  ;;;
  ;;; Example:
  ;;;   (md-parse "# Title")
  ;;;
  ;;; Since: NB0
  (defn __md-parse-blocks [source :cstr] #{Unsafe} :int
    ```c
    typedef struct { int kind; char *text; char *info; int meta; int start_line; int end_line;
                     int64_t *children; int child_count; int child_cap; } MdNode;
    typedef struct { char *text; int line_no; } MdLine;
    #define NEW_NODE(K,T,I,M,S,E) ({ \
      MdNode *n = malloc(sizeof(*n)); \
      n->kind = (K); \
      n->text = (T) ? strdup(T) : NULL; \
      n->info = (I) ? strdup(I) : NULL; \
      n->meta = (M); \
      n->start_line = (S); \
      n->end_line = (E); \
      n->children = NULL; \
      n->child_count = 0; \
      n->child_cap = 0; \
      (int64_t)(intptr_t)n; \
    })
    #define ADD_CHILD(P,C) do { \
      MdNode *p = (MdNode*)(intptr_t)(P); \
      if (p->child_count >= p->child_cap) { \
        p->child_cap = p->child_cap ? p->child_cap * 2 : 4; \
        p->children = realloc(p->children, (size_t)p->child_cap * sizeof(int64_t)); \
      } \
      p->children[p->child_count++] = (C); \
    } while (0)
    #define BUF_INIT() size_t buf_len = 0, buf_cap = 64; char *buf = malloc(buf_cap); buf[0] = '\0'
    #define BUF_APPEND_BYTES(PTR,LEN) do { \
      size_t need = buf_len + (size_t)(LEN) + 1; \
      while (need > buf_cap) { buf_cap *= 2; buf = realloc(buf, buf_cap); } \
      memcpy(buf + buf_len, (PTR), (size_t)(LEN)); \
      buf_len += (size_t)(LEN); \
      buf[buf_len] = '\0'; \
    } while (0)
    #define BUF_APPEND_STR(S) BUF_APPEND_BYTES((S), strlen(S))
    #define BUF_APPEND_CH(CH) do { \
      if (buf_len + 2 > buf_cap) { buf_cap *= 2; buf = realloc(buf, buf_cap); } \
      buf[buf_len++] = (char)(CH); \
      buf[buf_len] = '\0'; \
    } while (0)
    const char *src = source ? (const char *)(intptr_t)source : "";
    int64_t doc = NEW_NODE(0, NULL, NULL, 0, 1, 1);

    MdLine *lines = NULL;
    int line_count = 0, line_cap = 0;
    const char *cur = src, *start = src;
    int line_no = 1;
    while (*cur) {
      if (*cur == '\n') {
        size_t len = (size_t)(cur - start);
        char *copy = malloc(len + 1);
        memcpy(copy, start, len);
        copy[len] = '\0';
        if (line_count >= line_cap) {
          line_cap = line_cap ? line_cap * 2 : 16;
          lines = realloc(lines, (size_t)line_cap * sizeof(*lines));
        }
        lines[line_count].text = copy;
        lines[line_count].line_no = line_no++;
        line_count++;
        cur++;
        start = cur;
      } else {
        cur++;
      }
    }
    if (cur != start || (*src == '\0')) {
      size_t len = (size_t)(cur - start);
      if (!(len == 0 && *src == '\0')) {
        char *copy = malloc(len + 1);
        memcpy(copy, start, len);
        copy[len] = '\0';
        if (line_count >= line_cap) {
          line_cap = line_cap ? line_cap * 2 : 16;
          lines = realloc(lines, (size_t)line_cap * sizeof(*lines));
        }
        lines[line_count].text = copy;
        lines[line_count].line_no = line_no++;
        line_count++;
      }
    }
    if (line_count == 0) {
      free(lines);
      return doc;
    }

    int i = 0;
    while (i < line_count) {
      char *line = lines[i].text;
      int len = (int)strlen(line);
      int pos = 0;
      while (pos < len && (line[pos] == ' ' || line[pos] == '\t')) pos++;
      bool is_blank = true;
      for (int k = 0; k < len; k++) {
        if (!(line[k] == ' ' || line[k] == '\t')) { is_blank = false; break; }
      }
      if (is_blank) { i++; continue; }

      /* thematic break */
      {
        int p = 0, indent = 0;
        while (p < len && indent < 3 && line[p] == ' ') { p++; indent++; }
        char mark = 0;
        int count = 0;
        bool ok = true;
        for (int k = p; k < len; k++) {
          char ch = line[k];
          if (ch == ' ' || ch == '\t') continue;
          if (mark == 0 && (ch == '-' || ch == '*' || ch == '_')) { mark = ch; count = 1; continue; }
          if (ch == mark) { count++; continue; }
          ok = false; break;
        }
        if (ok && mark != 0 && count >= 3) {
          ADD_CHILD(doc, NEW_NODE(7, NULL, NULL, 0, lines[i].line_no, lines[i].line_no));
          i++;
          continue;
        }
      }

      /* math block ($$ ... $$) */
      {
        int p = 0, indent = 0;
        while (p < len && indent < 3 && line[p] == ' ') { p++; indent++; }
        if (p + 1 < len && line[p] == '$' && line[p + 1] == '$') {
          int after = p + 2;
          /* one-line form: $$ body $$ on a single line */
          int close_pos = -1;
          for (int k = after; k + 1 < len; k++) {
            if (line[k] == '\\' && k + 1 < len) { k++; continue; }
            if (line[k] == '$' && line[k + 1] == '$') {
              int t = k + 2;
              while (t < len && (line[t] == ' ' || line[t] == '\t')) t++;
              if (t == len) { close_pos = k; break; }
            }
          }
          if (close_pos >= 0) {
            int bs = after;
            while (bs < close_pos && (line[bs] == ' ' || line[bs] == '\t')) bs++;
            int be = close_pos;
            while (be > bs && (line[be - 1] == ' ' || line[be - 1] == '\t')) be--;
            char *body = malloc((size_t)(be - bs) + 1);
            memcpy(body, line + bs, (size_t)(be - bs));
            body[be - bs] = '\0';
            ADD_CHILD(doc, NEW_NODE(22, body, NULL, 0, lines[i].line_no, lines[i].line_no));
            free(body);
            i++;
            continue;
          }
          /* multi-line: opener line is $$ optionally followed by whitespace only */
          int tail_p = after;
          while (tail_p < len && (line[tail_p] == ' ' || line[tail_p] == '\t')) tail_p++;
          if (tail_p == len) {
            BUF_INIT();
            int j = i + 1;
            int end_line = lines[i].line_no;
            bool first_body_line = true;
            bool closed = false;
            while (j < line_count) {
              char *cand = lines[j].text;
              int clen = (int)strlen(cand);
              int cp = 0, cindent = 0;
              while (cp < clen && cindent < 3 && cand[cp] == ' ') { cp++; cindent++; }
              if (cp + 1 < clen && cand[cp] == '$' && cand[cp + 1] == '$') {
                int ct = cp + 2;
                while (ct < clen && (cand[ct] == ' ' || cand[ct] == '\t')) ct++;
                if (ct == clen) { end_line = lines[j].line_no; j++; closed = true; break; }
              }
              if (!first_body_line) BUF_APPEND_CH('\n');
              BUF_APPEND_STR(cand);
              end_line = lines[j].line_no;
              first_body_line = false;
              j++;
            }
            if (closed) {
              ADD_CHILD(doc, NEW_NODE(22, buf, NULL, 0, lines[i].line_no, end_line));
              free(buf);
              i = j;
              continue;
            }
            /* unterminated: graceful degradation, fall through to paragraph */
            free(buf);
          }
        }
      }

      /* fenced code block */
      {
        int p = 0, indent = 0;
        while (p < len && indent < 3 && line[p] == ' ') { p++; indent++; }
        if (p + 2 < len && (line[p] == '`' || line[p] == '~') &&
            line[p + 1] == line[p] && line[p + 2] == line[p]) {
          char fence_ch = line[p];
          int fence_len = 3;
          while (p + fence_len < len && line[p + fence_len] == fence_ch) fence_len++;
          int info_start = p + fence_len;
          while (info_start < len && (line[info_start] == ' ' || line[info_start] == '\t')) info_start++;
          int info_end = len;
          while (info_end > info_start && (line[info_end - 1] == ' ' || line[info_end - 1] == '\t')) info_end--;
          char *info = malloc((size_t)(info_end - info_start) + 1);
          memcpy(info, line + info_start, (size_t)(info_end - info_start));
          info[info_end - info_start] = '\0';

          BUF_INIT();
          int j = i + 1;
          int end_line = lines[i].line_no;
          bool first_body_line = true;
          while (j < line_count) {
            char *cand = lines[j].text;
            int clen = (int)strlen(cand);
            int cp = 0, cindent = 0;
            while (cp < clen && cindent < 3 && cand[cp] == ' ') { cp++; cindent++; }
            int ccount = 0;
            while (cp + ccount < clen && cand[cp + ccount] == fence_ch) ccount++;
            bool closer = ccount >= fence_len;
            if (closer) {
              int tail_pos = cp + ccount;
              while (tail_pos < clen && (cand[tail_pos] == ' ' || cand[tail_pos] == '\t')) tail_pos++;
              if (tail_pos != clen) closer = false;
            }
            if (closer) { end_line = lines[j].line_no; j++; break; }
            if (!first_body_line) BUF_APPEND_CH('\n');
            BUF_APPEND_STR(cand);
            end_line = lines[j].line_no;
            first_body_line = false;
            j++;
          }
          ADD_CHILD(doc, NEW_NODE(6, buf, info, 0, lines[i].line_no, end_line));
          free(info);
          free(buf);
          i = j;
          continue;
        }
      }

      /* indented code block */
      {
        int spaces = 0;
        while (spaces < len && line[spaces] == ' ') spaces++;
        if (spaces >= 4 || (len > 0 && line[0] == '\t')) {
          BUF_INIT();
          int j = i;
          int end_line = lines[i].line_no;
          while (j < line_count) {
            char *cand = lines[j].text;
            int clen = (int)strlen(cand);
            bool blank = true;
            for (int k = 0; k < clen; k++) {
              if (!(cand[k] == ' ' || cand[k] == '\t')) { blank = false; break; }
            }
            int cut = 0;
            while (cut < clen && cut < 4 && cand[cut] == ' ') cut++;
            if (!(blank || cut >= 4 || (clen > 0 && cand[0] == '\t'))) break;
            if (blank) {
              /* preserve blank lines inside indented blocks */
            } else if (clen > 0 && cand[0] == '\t') {
              BUF_APPEND_STR(cand + 1);
            } else {
              BUF_APPEND_STR(cand + 4);
            }
            if (j + 1 < line_count) BUF_APPEND_CH('\n');
            end_line = lines[j].line_no;
            j++;
          }
          ADD_CHILD(doc, NEW_NODE(6, buf, "", 0, lines[i].line_no, end_line));
          free(buf);
          i = j;
          continue;
        }
      }

      /* blockquote */
      {
        int p = 0, indent = 0;
        while (p < len && indent < 3 && line[p] == ' ') { p++; indent++; }
        if (p < len && line[p] == '>') {
          int64_t quote = NEW_NODE(3, NULL, NULL, 0, lines[i].line_no, lines[i].line_no);
          BUF_INIT();
          int j = i;
          int end_line = lines[i].line_no;
          bool first_quote_line = true;
          while (j < line_count) {
            char *cand = lines[j].text;
            int clen = (int)strlen(cand);
            int cp = 0, cindent = 0;
            while (cp < clen && cindent < 3 && cand[cp] == ' ') { cp++; cindent++; }
            bool blank = true;
            for (int k = 0; k < clen; k++) {
              if (!(cand[k] == ' ' || cand[k] == '\t')) { blank = false; break; }
            }
            if (blank) break;
            if (!(cp < clen && cand[cp] == '>')) break;
            if (!blank) {
              cp++;
              if (cp < clen && cand[cp] == ' ') cp++;
              if (!first_quote_line) BUF_APPEND_CH('\n');
              BUF_APPEND_STR(cand + cp);
            }
            end_line = lines[j].line_no;
            first_quote_line = false;
            j++;
          }
          if (buf[0] != '\0') {
            ADD_CHILD(quote, NEW_NODE(2, buf, NULL, 0, lines[i].line_no, end_line));
          }
          ((MdNode*)(intptr_t)quote)->end_line = end_line;
          ADD_CHILD(doc, quote);
          free(buf);
          i = j;
          continue;
        }
      }

      /* list */
      {
        int p = 0, indent = 0;
        while (p < len && indent < 3 && line[p] == ' ') { p++; indent++; }
        bool bullet = false, ordered = false;
        int start_num = 0, marker_len = 0;
        char marker_ch = 0;
        if (p + 1 < len && (line[p] == '-' || line[p] == '+' || line[p] == '*') &&
            (line[p + 1] == ' ' || line[p + 1] == '\t')) {
          bullet = true;
          marker_ch = line[p];
          marker_len = 2;
        } else {
          int q = p;
          while (q < len && line[q] >= '0' && line[q] <= '9') q++;
          if (q > p && q + 1 < len && (line[q] == '.' || line[q] == ')') &&
              (line[q + 1] == ' ' || line[q + 1] == '\t')) {
            ordered = true;
            marker_ch = line[q];
            marker_len = (q - p) + 2;
            start_num = atoi(line + p);
          }
        }
        if (bullet || ordered) {
          char list_info[2] = { bullet ? marker_ch : marker_ch, '\0' };
          int64_t list = NEW_NODE(4, NULL, list_info, ordered ? start_num : 0, lines[i].line_no, lines[i].line_no);
          int j = i;
          int end_line = lines[i].line_no;
          while (j < line_count) {
            char *item_line = lines[j].text;
            int ilen = (int)strlen(item_line);
            int ip = 0, iindent = 0;
            while (ip < ilen && iindent < 3 && item_line[ip] == ' ') { ip++; iindent++; }
            bool same = false;
            int content_start = ip;
            int current_num = 0;
            if (bullet) {
              if (ip + 1 < ilen && item_line[ip] == marker_ch &&
                  (item_line[ip + 1] == ' ' || item_line[ip + 1] == '\t')) {
                same = true;
                content_start = ip + 2;
              }
            } else {
              int q = ip;
              while (q < ilen && item_line[q] >= '0' && item_line[q] <= '9') q++;
              if (q > ip && q + 1 < ilen && item_line[q] == marker_ch &&
                  (item_line[q + 1] == ' ' || item_line[q + 1] == '\t')) {
                same = true;
                content_start = q + 2;
                current_num = atoi(item_line + ip);
              }
            }
            if (!same) break;
            while (content_start < ilen && (item_line[content_start] == ' ' || item_line[content_start] == '\t')) content_start++;
            int64_t item = NEW_NODE(5, NULL, NULL, 0, lines[j].line_no, lines[j].line_no);
            BUF_INIT();
            BUF_APPEND_STR(item_line + content_start);
            int k = j + 1;
            int item_end = lines[j].line_no;
            while (k < line_count) {
              char *next = lines[k].text;
              int nlen = (int)strlen(next);
              bool next_blank = true;
              for (int m = 0; m < nlen; m++) {
                if (!(next[m] == ' ' || next[m] == '\t')) { next_blank = false; break; }
              }
              int np = 0, nindent = 0;
              while (np < nlen && nindent < 3 && next[np] == ' ') { np++; nindent++; }
              bool next_marker = false;
              if (bullet) {
                next_marker = (np + 1 < nlen && next[np] == marker_ch &&
                               (next[np + 1] == ' ' || next[np + 1] == '\t'));
              } else {
                int q = np;
                while (q < nlen && next[q] >= '0' && next[q] <= '9') q++;
                next_marker = (q > np && q + 1 < nlen && next[q] == marker_ch &&
                               (next[q + 1] == ' ' || next[q + 1] == '\t'));
              }
              if (next_marker) break;
              if (next_blank) { break; }
              BUF_APPEND_CH('\n');
              if (nlen >= marker_len) BUF_APPEND_STR(next + marker_len);
              else BUF_APPEND_STR(next);
              item_end = lines[k].line_no;
              k++;
            }
            if (buf[0] != '\0') ADD_CHILD(item, NEW_NODE(2, buf, NULL, 0, lines[j].line_no, item_end));
            ((MdNode*)(intptr_t)item)->end_line = item_end;
            ADD_CHILD(list, item);
            free(buf);
            end_line = item_end;
            j = k;
            while (j < line_count) {
              bool blank = true;
              int blen = (int)strlen(lines[j].text);
              for (int m = 0; m < blen; m++) {
                if (!(lines[j].text[m] == ' ' || lines[j].text[m] == '\t')) { blank = false; break; }
              }
              if (!blank) break;
              j++;
              end_line = lines[j - 1].line_no;
            }
          }
          ((MdNode*)(intptr_t)list)->end_line = end_line;
          if (ordered && ((MdNode*)(intptr_t)list)->meta == 0) {
            ((MdNode*)(intptr_t)list)->meta = start_num;
          }
          ADD_CHILD(doc, list);
          i = j;
          continue;
        }
      }

      /* headings */
      {
        int p = 0, indent = 0;
        while (p < len && indent < 3 && line[p] == ' ') { p++; indent++; }
        if (p < len && line[p] == '#') {
          int level = 0;
          while (p + level < len && line[p + level] == '#') level++;
          if (level >= 1 && level <= 6 && (p + level == len || line[p + level] == ' ' || line[p + level] == '\t')) {
            int text_start = p + level;
            while (text_start < len && (line[text_start] == ' ' || line[text_start] == '\t')) text_start++;
            int text_end = len;
            while (text_end > text_start && (line[text_end - 1] == ' ' || line[text_end - 1] == '\t')) text_end--;
            while (text_end > text_start && line[text_end - 1] == '#') text_end--;
            while (text_end > text_start && (line[text_end - 1] == ' ' || line[text_end - 1] == '\t')) text_end--;
            char *text = malloc((size_t)(text_end - text_start) + 1);
            memcpy(text, line + text_start, (size_t)(text_end - text_start));
            text[text_end - text_start] = '\0';
            ADD_CHILD(doc, NEW_NODE(1, text, NULL, level, lines[i].line_no, lines[i].line_no));
            free(text);
            i++;
            continue;
          }
        }
      }

      /* setext heading */
      if (i + 1 < line_count) {
        char *next = lines[i + 1].text;
        int nlen = (int)strlen(next);
        int np = 0, nindent = 0;
        while (np < nlen && nindent < 3 && next[np] == ' ') { np++; nindent++; }
        char mark = 0;
        int run = 0;
        while (np + run < nlen && (next[np + run] == '=' || next[np + run] == '-')) {
          if (mark == 0) mark = next[np + run];
          if (next[np + run] != mark) break;
          run++;
        }
        bool setext = run > 0;
        int rest = np + run;
        while (rest < nlen && (next[rest] == ' ' || next[rest] == '\t')) rest++;
        if (rest != nlen) setext = false;
        if (setext) {
          ADD_CHILD(doc, NEW_NODE(1, line + pos, NULL, (mark == '=') ? 1 : 2,
                                  lines[i].line_no, lines[i + 1].line_no));
          i += 2;
          continue;
        }
      }

      /* paragraph */
      {
        BUF_INIT();
        int j = i;
        int end_line = lines[i].line_no;
        while (j < line_count) {
          char *cand = lines[j].text;
          int clen = (int)strlen(cand);
          bool blank = true;
          for (int k = 0; k < clen; k++) {
            if (!(cand[k] == ' ' || cand[k] == '\t')) { blank = false; break; }
          }
          if (blank) break;
          if (j > i) {
            int p = 0, indent = 0;
            while (p < clen && indent < 3 && cand[p] == ' ') { p++; indent++; }
            bool special = false;
            if (p + 2 < clen && ((cand[p] == '`' && cand[p + 1] == '`' && cand[p + 2] == '`') ||
                                 (cand[p] == '~' && cand[p + 1] == '~' && cand[p + 2] == '~'))) special = true;
            if (p < clen && cand[p] == '>') special = true;
            if (p < clen && cand[p] == '#') special = true;
            if (p + 1 < clen && cand[p] == '$' && cand[p + 1] == '$') special = true;
            if (special) break;
          }
          if (buf[0] != '\0') BUF_APPEND_CH('\n');
          BUF_APPEND_STR(cand);
          end_line = lines[j].line_no;
          j++;
          if (j < line_count && j == i + 1) {
            char *maybe = lines[j].text;
            int mlen = (int)strlen(maybe);
            int mp = 0, mindent = 0;
            while (mp < mlen && mindent < 3 && maybe[mp] == ' ') { mp++; mindent++; }
            if (mp < mlen && (maybe[mp] == '=' || maybe[mp] == '-')) break;
          }
        }
        ADD_CHILD(doc, NEW_NODE(2, buf, NULL, 0, lines[i].line_no, end_line));
        free(buf);
        i = j;
      }
    }

    if (((MdNode*)(intptr_t)doc)->child_count > 0) {
      ((MdNode*)(intptr_t)doc)->end_line =
        ((MdNode*)(intptr_t)((MdNode*)(intptr_t)doc)->children[((MdNode*)(intptr_t)doc)->child_count - 1])->end_line;
    }
    for (int k = 0; k < line_count; k++) free(lines[k].text);
    free(lines);
    #undef NEW_NODE
    #undef ADD_CHILD
    #undef BUF_INIT
    #undef BUF_APPEND_BYTES
    #undef BUF_APPEND_STR
    #undef BUF_APPEND_CH
    return doc;
    ```)

  (defn md-parse [source :cstr] #{Unsafe} :int
    (let [doc (__md-parse-blocks source)]
      (do
        (__md-upgrade-gfm doc)
        (__md-annotate-inlines doc)
        doc)))

  (defn __emit-nodes-with-sep [nodes :int sep :cstr] #{Unsafe} :int
    (if (list-nil? nodes)
      (__cstr-as-int "")
      (let [cur (__emit-node-int (head nodes))]
        (if (list-nil? (tail nodes))
          cur
          (__cstr-as-int
            (__str-concat (__int-as-cstr cur)
                         (__str-concat sep (__int-as-cstr (__emit-nodes-with-sep (tail nodes) sep)))))))))

  (defn __emit-list-items [items :int ordered :bool start :int marker :cstr idx :int] #{Unsafe} :int
    (if (list-nil? items)
      (__cstr-as-int "")
      (let [item (head items)
            body (__int-as-cstr (__emit-nodes-with-sep (md-node-children item) "\n\n"))
            checkbox (if (= (md-node-meta item) 1)
                      "[ ] "
                      (if (= (md-node-meta item) 2)
                        "[x] "
                        ""))
            full-body (__str-concat checkbox body)
            prefix (if ordered
                     (__str-concat (__int->cstr (+ start idx)) (__str-concat marker " "))
                     (__str-concat marker " "))
            rendered (__format-list-item prefix full-body)]
        (if (list-nil? (tail items))
          (__cstr-as-int rendered)
          (__cstr-as-int
            (__str-concat rendered
                         (__str-concat "\n" (__int-as-cstr (__emit-list-items (tail items) ordered start marker (+ idx 1))))))))))

  (defn __table-align-mark [align :int] :cstr
    (if (= align 1)
      ":---"
      (if (= align 2)
        ":---:"
        (if (= align 3)
          "---:"
          "---"))))

  (defn __emit-table-row-cells [cells :int] #{Unsafe} :int
    (if (list-nil? cells)
      (__cstr-as-int "")
      (let [cell-text (md-node-text (head cells))]
        (if (list-nil? (tail cells))
          (__cstr-as-int cell-text)
          (__cstr-as-int
            (__str-concat cell-text
                         (__str-concat " | " (__int-as-cstr (__emit-table-row-cells (tail cells))))))))))

  (defn __emit-table-align-cells [cells :int] #{Unsafe} :int
    (if (list-nil? cells)
      (__cstr-as-int "")
      (let [cell-mark (__table-align-mark (md-node-meta (head cells)))]
        (if (list-nil? (tail cells))
          (__cstr-as-int cell-mark)
          (__cstr-as-int
            (__str-concat cell-mark
                         (__str-concat " | " (__int-as-cstr (__emit-table-align-cells (tail cells))))))))))

  (defn __emit-table-row [row :int] #{Unsafe} :int
    (__cstr-as-int
      (__str-concat "| "
                    (__str-concat (__int-as-cstr (__emit-table-row-cells (md-node-children row))) " |"))))

  (defn __emit-table-body-rows [rows :int] #{Unsafe} :int
    (if (list-nil? rows)
      (__cstr-as-int "")
      (let [rendered (__emit-table-row (head rows))]
        (if (list-nil? (tail rows))
          rendered
          (__cstr-as-int
            (__str-concat (__int-as-cstr rendered)
                         (__str-concat "\n" (__int-as-cstr (__emit-table-body-rows (tail rows))))))))))

  (defn __emit-table-node [n :int] #{Unsafe} :int
    (let [rows (md-node-children n)
          header (head rows)
          body (tail rows)
          align-row (__cstr-as-int
                     (__str-concat "| "
                                   (__str-concat (__int-as-cstr (__emit-table-align-cells (md-node-children header))) " |")))]
      (if (list-nil? body)
        (__cstr-as-int
          (__str-concat (__int-as-cstr (__emit-table-row header))
                       (__str-concat "\n" (__int-as-cstr align-row))))
        (__cstr-as-int
          (__str-concat (__int-as-cstr (__emit-table-row header))
                       (__str-concat "\n"
                                     (__str-concat (__int-as-cstr align-row)
                                                   (__str-concat "\n" (__int-as-cstr (__emit-table-body-rows body))))))))))

  (defn __emit-node-int [n :int] #{Unsafe} :int
    (let [tag (md-node-tag n)]
      (if (= tag (md-tag-document))
        (__emit-nodes-with-sep (md-node-children n) "\n\n")
        (if (= tag (md-tag-heading))
          (__cstr-as-int
            (__str-concat (__repeat-char 35 (md-node-meta n))
                         (__str-concat " " (md-node-text n))))
          (if (= tag (md-tag-paragraph))
            (__cstr-as-int (md-node-text n))
            (if (= tag (md-tag-blockquote))
              (__cstr-as-int
                (__prefix-lines "> " (__int-as-cstr (__emit-nodes-with-sep (md-node-children n) "\n\n"))))
              (if (= tag (md-tag-list))
                (__emit-list-items (md-node-children n)
                                  (> (md-node-meta n) 0)
                                  (md-node-meta n)
                                  (md-node-info n)
                                  0)
                (if (= tag (md-tag-table))
                  (__emit-table-node n)
                  (if (= tag (md-tag-list-item))
                  (__emit-nodes-with-sep (md-node-children n) "\n\n")
                    (if (= tag (md-tag-code-block))
                    (__cstr-as-int
                     (__str-concat "```"
                                   (__str-concat (md-node-info n)
                                                 (__str-concat "\n"
                                                               (__str-concat (md-node-text n)
                                                                             "\n```")))))
                      (if (= tag (md-tag-thematic-break))
                       (__cstr-as-int "---")
                       (if (= tag (md-tag-math-block))
                         (__cstr-as-int
                           (__str-concat "$$\n"
                                         (__str-concat (md-node-text n) "\n$$")))
                         (if (= tag (md-tag-math-inline))
                           (__cstr-as-int
                             (__str-concat "$" (__str-concat (md-node-text n) "$")))
                           (__cstr-as-int ""))))))))))))))

  ;;; md-emit -- serialize a parsed NB0 AST back to normalized markdown.
  ;;;
  ;;; Parameters:
  ;;;   n -- node handle
  ;;;
  ;;; Returns:
  ;;;   Markdown source string.
  ;;;
  ;;; Example:
  ;;;   (md-emit (md-parse "# Title"))
  ;;;
  ;;; Since: NB0
  (defn md-emit [n :int] #{Unsafe} :cstr
    (__int-as-cstr (__emit-node-int n)))

  (defn __html-escape-math [s :cstr] #{Unsafe} :cstr
    ```c
    const char *src = s ? (const char *)(intptr_t)s : "";
    size_t len = strlen(src), cap = len * 5 + 1;
    char *out = malloc(cap);
    size_t j = 0;
    for (size_t i = 0; i < len; i++) {
      const char *rep = NULL;
      switch (src[i]) {
        case '&': rep = "&amp;"; break;
        case '<': rep = "&lt;"; break;
        case '>': rep = "&gt;"; break;
        default: break;
      }
      if (rep) {
        size_t rl = strlen(rep);
        memcpy(out + j, rep, rl);
        j += rl;
      } else {
        out[j++] = src[i];
      }
    }
    out[j] = '\0';
    return out;
    ```)

  (defn __html-escape [s :cstr] #{Unsafe} :cstr
    ```c
    const char *src = s ? (const char *)(intptr_t)s : "";
    size_t len = strlen(src), cap = len * 6 + 1;
    char *out = malloc(cap);
    size_t j = 0;
    for (size_t i = 0; i < len; i++) {
      const char *rep = NULL;
      switch (src[i]) {
        case '&': rep = "&amp;"; break;
        case '<': rep = "&lt;"; break;
        case '>': rep = "&gt;"; break;
        case '"': rep = "&quot;"; break;
        default: break;
      }
      if (rep) {
        size_t rl = strlen(rep);
        memcpy(out + j, rep, rl);
        j += rl;
      } else {
        out[j++] = src[i];
      }
    }
    out[j] = '\0';
    return out;
    ```)

  (defn __emit-inline-plain-list [nodes :int] #{Unsafe} :int
    (if (list-nil? nodes)
      (__cstr-as-int "")
      (__cstr-as-int
        (__str-concat (__int-as-cstr (__emit-inline-plain-node-int (head nodes)))
                      (__int-as-cstr (__emit-inline-plain-list (tail nodes)))))))

  (defn __emit-inline-html-list [nodes :int] #{Unsafe} :int
    (if (list-nil? nodes)
      (__cstr-as-int "")
      (__cstr-as-int
        (__str-concat (__int-as-cstr (__emit-inline-html-node-int (head nodes)))
                      (__int-as-cstr (__emit-inline-html-list (tail nodes)))))))

  (defn __emit-block-html-list [nodes :int] #{Unsafe} :int
    (if (list-nil? nodes)
      (__cstr-as-int "")
      (let [cur (__emit-block-html-node-int (head nodes))]
        (if (list-nil? (tail nodes))
          cur
          (__cstr-as-int
            (__str-concat (__int-as-cstr cur)
                          (__str-concat "\n" (__int-as-cstr (__emit-block-html-list (tail nodes))))))))))

  (defn __emit-inline-plain-node-int [n :int] #{Unsafe} :int
    (let [tag (md-node-tag n)]
      (if (= tag (md-tag-text))
        (__cstr-as-int (md-node-text n))
        (if (= tag (md-tag-code-span))
          (__cstr-as-int (md-node-text n))
          (if (= tag (md-tag-link))
            (__emit-inline-plain-list (md-node-children n))
            (if (= tag (md-tag-image))
              (__emit-inline-plain-list (md-node-children n))
              (if (= tag (md-tag-autolink))
                (__cstr-as-int (md-node-text n))
                (if (or (= tag (md-tag-emph))
                        (or (= tag (md-tag-strong))
                            (= tag (md-tag-strikethrough))))
                  (__emit-inline-plain-list (md-node-children n))
                  (if (= tag (md-tag-hard-break))
                    (__cstr-as-int "\n")
                    (if (= tag (md-tag-soft-break))
                      (__cstr-as-int "\n")
                      (__cstr-as-int "")))))))))))

  (defn __emit-link-html-int [n :int] #{Unsafe} :int
    (let [title-attr (if (__cstr-eq? (md-node-text n) "")
                       ">"
                       (__str-concat " title=\"" (__str-concat (__html-escape (md-node-text n)) "\">")))]
      (__cstr-as-int
        (__str-concat "<a href=\"" (__str-concat (__html-escape (md-node-info n))
          (__str-concat "\"" (__str-concat title-attr
            (__str-concat (__int-as-cstr (__emit-inline-html-list (md-node-children n))) "</a>"))))))))

  (defn __emit-image-html-int [n :int] #{Unsafe} :int
    (let [title-tail (if (__cstr-eq? (md-node-text n) "")
                       " />"
                       (__str-concat " title=\"" (__str-concat (__html-escape (md-node-text n)) "\" />")))]
      (__cstr-as-int
        (__str-concat "<img src=\"" (__str-concat (__html-escape (md-node-info n))
          (__str-concat "\" alt=\"" (__str-concat (__html-escape (__int-as-cstr (__emit-inline-plain-list (md-node-children n))))
            (__str-concat "\"" title-tail))))))))

  (defn __emit-inline-html-node-int [n :int] #{Unsafe} :int
    (let [tag (md-node-tag n)]
      (if (= tag (md-tag-text))
        (__cstr-as-int (__html-escape (md-node-text n)))
        (if (= tag (md-tag-emph))
          (__cstr-as-int
            (__str-concat "<em>" (__str-concat (__int-as-cstr (__emit-inline-html-list (md-node-children n))) "</em>")))
          (if (= tag (md-tag-strong))
            (__cstr-as-int
              (__str-concat "<strong>" (__str-concat (__int-as-cstr (__emit-inline-html-list (md-node-children n))) "</strong>")))
            (if (= tag (md-tag-strikethrough))
              (__cstr-as-int
                (__str-concat "<del>" (__str-concat (__int-as-cstr (__emit-inline-html-list (md-node-children n))) "</del>")))
            (if (= tag (md-tag-code-span))
              (__cstr-as-int
                (__str-concat "<code>" (__str-concat (__html-escape (md-node-text n)) "</code>")))
              (if (= tag (md-tag-link))
                (__emit-link-html-int n)
                (if (= tag (md-tag-image))
                  (__emit-image-html-int n)
                  (if (= tag (md-tag-autolink))
                    (__cstr-as-int
                      (__str-concat "<a href=\"" (__str-concat (__html-escape (md-node-info n))
                        (__str-concat "\">" (__str-concat (__html-escape (md-node-text n)) "</a>")))))
                    (if (= tag (md-tag-hard-break))
                      (__cstr-as-int "<br />\n")
                      (if (= tag (md-tag-soft-break))
                        (__cstr-as-int "\n")
                        (if (= tag (md-tag-math-inline))
                          (__cstr-as-int
                            (__str-concat "<span class=\"math inline\">$"
                              (__str-concat (__html-escape-math (md-node-text n)) "$</span>")))
                          (__cstr-as-int ""))))))))))))))

  (defn __table-align-attr [align :int] :cstr
    (if (= align 1)
      " align=\"left\""
      (if (= align 2)
        " align=\"center\""
        (if (= align 3)
          " align=\"right\""
          ""))))

  (defn __emit-table-cells-html [cells :int header? :bool] #{Unsafe} :int
    (if (list-nil? cells)
      (__cstr-as-int "")
      (let [cell (head cells)
            tag-name (if header? "th" "td")
            body (if (list-nil? (md-node-children cell))
                   (__html-escape (md-node-text cell))
                   (__int-as-cstr (__emit-inline-html-list (md-node-children cell))))
            rendered (__str-concat "<"
                                   (__str-concat tag-name
                                                 (__str-concat (__table-align-attr (md-node-meta cell))
                                                               (__str-concat ">"
                                                                             (__str-concat body
                                                                                           (__str-concat "</"
                                                                                                         (__str-concat tag-name ">")))))))]
        (if (list-nil? (tail cells))
          (__cstr-as-int rendered)
          (__cstr-as-int
            (__str-concat rendered (__int-as-cstr (__emit-table-cells-html (tail cells) header?))))))))

  (defn __emit-table-row-html [row :int header? :bool] #{Unsafe} :int
    (__cstr-as-int
      (__str-concat "<tr>"
                    (__str-concat (__int-as-cstr (__emit-table-cells-html (md-node-children row) header?)) "</tr>"))))

  (defn __emit-table-body-html [rows :int] #{Unsafe} :int
    (if (list-nil? rows)
      (__cstr-as-int "")
      (let [rendered (__emit-table-row-html (head rows) false)]
        (if (list-nil? (tail rows))
          rendered
          (__cstr-as-int
            (__str-concat (__int-as-cstr rendered)
                          (__str-concat "\n" (__int-as-cstr (__emit-table-body-html (tail rows))))))))))

  (defn __emit-table-html-int [n :int] #{Unsafe} :int
    (let [rows (md-node-children n)
          header (head rows)
          body (tail rows)
          header-html (__emit-table-row-html header true)]
      (if (list-nil? body)
        (__cstr-as-int
          (__str-concat "<table>\n<thead>\n"
                        (__str-concat (__int-as-cstr header-html) "\n</thead>\n</table>")))
        (__cstr-as-int
          (__str-concat "<table>\n<thead>\n"
                        (__str-concat (__int-as-cstr header-html)
                                      (__str-concat "\n</thead>\n<tbody>\n"
                                                    (__str-concat (__int-as-cstr (__emit-table-body-html body))
                                                                  "\n</tbody>\n</table>"))))))))

  (defn __emit-heading-html-int [n :int] #{Unsafe} :int
    (let [lvl (__int->cstr (md-node-meta n))]
      (__cstr-as-int
        (__str-concat "<h" (__str-concat lvl (__str-concat ">"
          (__str-concat (__int-as-cstr (__emit-inline-html-list (md-node-children n)))
                        (__str-concat "</h" (__str-concat lvl ">")))))))))

  (defn __emit-block-html-node-int [n :int] #{Unsafe} :int
    (let [tag (md-node-tag n)]
      (if (= tag (md-tag-document))
        (__emit-block-html-list (md-node-children n))
        (if (= tag (md-tag-heading))
          (__emit-heading-html-int n)
          (if (= tag (md-tag-paragraph))
            (__cstr-as-int
              (__str-concat "<p>" (__str-concat (__int-as-cstr (__emit-inline-html-list (md-node-children n))) "</p>")))
            (if (= tag (md-tag-blockquote))
              (__cstr-as-int
                (__str-concat "<blockquote>\n" (__str-concat (__int-as-cstr (__emit-block-html-list (md-node-children n))) "\n</blockquote>")))
              (if (= tag (md-tag-list))
                (if (> (md-node-meta n) 0)
                  (__cstr-as-int
                    (__str-concat
                      (if (= (md-node-meta n) 1)
                        "<ol>"
                        (__str-concat "<ol start=\"" (__str-concat (__int->cstr (md-node-meta n)) "\">")))
                      (__str-concat (__int-as-cstr (__emit-block-html-list (md-node-children n))) "</ol>")))
                  (__cstr-as-int
                    (__str-concat "<ul>" (__str-concat (__int-as-cstr (__emit-block-html-list (md-node-children n))) "</ul>"))))
                (if (= tag (md-tag-list-item))
                  (__cstr-as-int
                    (__str-concat "<li>"
                                  (__str-concat
                                    (if (= (md-node-meta n) 1)
                                      "<input type=\"checkbox\" disabled=\"\" /> "
                                      (if (= (md-node-meta n) 2)
                                        "<input type=\"checkbox\" checked=\"\" disabled=\"\" /> "
                                        ""))
                                    (__str-concat (__int-as-cstr (__emit-block-html-list (md-node-children n))) "</li>"))))
                  (if (= tag (md-tag-table))
                    (__emit-table-html-int n)
                    (if (= tag (md-tag-code-block))
                    (__cstr-as-int
                      (__str-concat "<pre><code"
                                    (__str-concat
                                      (if (__cstr-eq? (md-node-info n) "")
                                        ">"
                                        (__str-concat " class=\"language-" (__str-concat (__html-escape (md-node-info n)) "\">")))
                                      (__str-concat (__html-escape (md-node-text n)) "</code></pre>"))))
                    (if (= tag (md-tag-thematic-break))
                      (__cstr-as-int "<hr />")
                      (if (= tag (md-tag-math-block))
                        (__cstr-as-int
                          (__str-concat "<span class=\"math display\">$$"
                            (__str-concat (__html-escape-math (md-node-text n)) "$$</span>")))
                        (__cstr-as-int "")))))))))))))

  (defn md-emit-html [n :int] #{Unsafe} :cstr
    (__int-as-cstr (__emit-block-html-node-int n)))

) ;; end defmodule notebook/cmark
