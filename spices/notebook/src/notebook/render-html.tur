    typedef struct {
      char *output_dir;
      int64_t use_cache;
      int64_t include_source;
      int64_t include_output;
      int64_t fail_fast;
      int64_t math_mode;  /* 0=auto 1=always 2=never */
    } RenderOpts;
    RenderOpts *o = (RenderOpts *)(intptr_t)opts;
    return o && o->output_dir ? o->output_dir : "";
    ```)

