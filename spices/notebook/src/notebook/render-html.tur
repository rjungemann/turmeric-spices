  (defn __rhtml-copy-file [src_path :cstr dst_path :cstr] #{Unsafe} :int
    ```c
    const char *src = src_path ? (const char *)(intptr_t)src_path : "";
    const char *dst = dst_path ? (const char *)(intptr_t)dst_path : "";
    FILE *in = fopen(src, "rb");
    if (!in) return 0;
    FILE *out = fopen(dst, "wb");
    if (!out) { fclose(in); return 0; }
    char buf[8192];
    size_t n;
    int ok = 1;
    while ((n = fread(buf, 1, sizeof(buf), in)) > 0) {
      if (fwrite(buf, 1, n, out) != n) { ok = 0; break; }
    }
    fclose(in);
    fclose(out);
    return ok;
    ```)

  (defn __rhtml-png-data-url [img_path :cstr] #{Unsafe} :cstr
    ```c
    const char *path = img_path ? (const char *)(intptr_t)img_path : "";
    FILE *fp = fopen(path, "rb");
    if (!fp) return strdup("");
    if (fseek(fp, 0, SEEK_END) != 0) { fclose(fp); return strdup(""); }
    long sz = ftell(fp);
    if (sz < 0) { fclose(fp); return strdup(""); }
    rewind(fp);
    unsigned char *src = malloc((size_t)sz);
    size_t got = fread(src, 1, (size_t)sz, fp);
    fclose(fp);

    static const char tbl[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
    size_t out_len = ((got + 2) / 3) * 4;
    char *b64 = malloc(out_len + 1);
    size_t i = 0, j = 0;
    while (i < got) {
      unsigned a = src[i++];
      unsigned b = i < got ? src[i++] : 0;
      unsigned c = i < got ? src[i++] : 0;
      unsigned tri = (a << 16) | (b << 8) | c;
      b64[j++] = tbl[(tri >> 18) & 63];
      b64[j++] = tbl[(tri >> 12) & 63];
      b64[j++] = (i - 1 > got) ? '=' : tbl[(tri >> 6) & 63];
      b64[j++] = (i > got) ? '=' : tbl[tri & 63];
    }
    if (got % 3 == 1) { b64[out_len - 1] = '='; b64[out_len - 2] = '='; }
    else if (got % 3 == 2) { b64[out_len - 1] = '='; }
    b64[out_len] = '\0';
    free(src);

    size_t need = strlen("data:image/png;base64,") + out_len + 1;
    char *out = malloc(need);
    snprintf(out, need, "data:image/png;base64,%s", b64);
    free(b64);
    return out;
    ```)

  (defn __rhtml-image-rel-name [img_path :cstr html_path :cstr cell_id_value :cstr idx :int] #{Unsafe} :cstr
    ```c
    const char *src = img_path ? (const char *)(intptr_t)img_path : "";
    const char *html_out = html_path ? (const char *)(intptr_t)html_path : "";
    const char *cell_id = cell_id_value ? (const char *)(intptr_t)cell_id_value : "";
    const char *html_base = strrchr(html_out, '/');
    html_base = html_base ? html_base + 1 : html_out;
    size_t stem_len = strlen(html_base);
    const char *dot = strrchr(html_base, '.');
    if (dot) stem_len = (size_t)(dot - html_base);
    const char *src_base = strrchr(src, '/');
    src_base = src_base ? src_base + 1 : src;
    const char *ext = strrchr(src_base, '.');
    if (!ext) ext = ".png";
    char *stem = malloc(stem_len + 1);
    memcpy(stem, html_base, stem_len);
    stem[stem_len] = '\0';
    char buf[512];
    snprintf(buf, sizeof(buf), "%s-%s-%lld%s",
             stem[0] ? stem : "notebook",
             cell_id[0] ? cell_id : "cell",
             (long long)idx,
             ext);
    free(stem);
    return strdup(buf);
    ```)

  (defn __rhtml-dir-join [dir_path :cstr child :cstr] #{Unsafe} :cstr
    ```c
    const char *dir = dir_path ? (const char *)(intptr_t)dir_path : "";
    const char *child_name = child ? (const char *)(intptr_t)child : "";
    size_t need = strlen(dir) + (dir[0] ? 1 : 0) + strlen(child_name) + 1;
    char *out = malloc(need);
    if (dir[0]) snprintf(out, need, "%s/%s", dir, child_name);
    else snprintf(out, need, "%s", child_name);
    return out;
    ```)

  (defn __rhtml-output-dir [html_path :cstr] #{Unsafe} :cstr
    ```c
    const char *src = html_path ? (const char *)(intptr_t)html_path : "";
    const char *slash = strrchr(src, '/');
    if (!slash) return strdup("");
    size_t n = (size_t)(slash - src);
    char *out = malloc(n + 1);
    memcpy(out, src, n);
    out[n] = '\0';
    return out;
    ```)

  (defn __rhtml-render-image-block [output :int image_mode :cstr html_path :cstr cell_id_value :cstr] #{Unsafe} :cstr
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct {
      char *cell_id;
      int64_t status;
      char *stdout_text;
      char *value_repr;
      char *error_msg;
      int64_t elapsed_ms;
      int64_t image_paths;
    } NotebookCellOutput;

    NotebookCellOutput *out = (NotebookCellOutput *)(intptr_t)output;
    if (!out || !out->image_paths) return strdup("");

    const char *mode = image_mode ? (const char *)(intptr_t)image_mode : "inline";
    const char *html_out = html_path ? (const char *)(intptr_t)html_path : "";
    const char *cell_id = cell_id_value ? (const char *)(intptr_t)cell_id_value : "";

    size_t cap = 256;
    size_t len = 0;
    char *html = malloc(cap);
    strcpy(html, "<div class=\"cell-images\">");
    len = strlen(html);

    int idx = 1;
    for (Cons *lst = (Cons *)(intptr_t)out->image_paths; lst; lst = (Cons *)(intptr_t)lst->tail, idx++) {
      const char *img_path = (const char *)(intptr_t)lst->head;
      if (!img_path || !img_path[0]) continue;

      char *src_ref = NULL;
      if (strcmp(mode, "file") == 0) {
        const char *base = strrchr(img_path, '/');
        base = base ? base + 1 : img_path;
        const char *ext = strrchr(base, '.');
        if (!ext) ext = ".png";

        const char *html_base = strrchr(html_out, '/');
        html_base = html_base ? html_base + 1 : html_out;
        size_t stem_len = strlen(html_base);
        const char *dot = strrchr(html_base, '.');
        if (dot) stem_len = (size_t)(dot - html_base);
        char stem[256];
        if (stem_len == 0) snprintf(stem, sizeof(stem), "notebook");
        else snprintf(stem, sizeof(stem), "%.*s", (int)stem_len, html_base);

        char rel_name[512];
        snprintf(rel_name, sizeof(rel_name), "%s-%s-%d%s",
                 stem,
                 cell_id[0] ? cell_id : "cell",
                 idx,
                 ext);

        if (html_out[0]) {
          const char *slash = strrchr(html_out, '/');
          char dst[1024];
          if (slash) snprintf(dst, sizeof(dst), "%.*s/%s", (int)(slash - html_out), html_out, rel_name);
          else snprintf(dst, sizeof(dst), "%s", rel_name);

          FILE *in = fopen(img_path, "rb");
          if (in) {
            FILE *outf = fopen(dst, "wb");
            if (outf) {
              char buf[8192];
              size_t n;
              while ((n = fread(buf, 1, sizeof(buf), in)) > 0) fwrite(buf, 1, n, outf);
              fclose(outf);
            }
            fclose(in);
          }
          src_ref = strdup(rel_name);
        } else {
          src_ref = strdup(img_path);
        }
      } else {
        FILE *fp = fopen(img_path, "rb");
        if (!fp) continue;
        if (fseek(fp, 0, SEEK_END) != 0) { fclose(fp); continue; }
        long sz = ftell(fp);
        if (sz < 0) { fclose(fp); continue; }
        rewind(fp);
        unsigned char *src = malloc((size_t)sz);
        size_t got = fread(src, 1, (size_t)sz, fp);
        fclose(fp);

        static const char tbl[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
        size_t b64_len = ((got + 2) / 3) * 4;
        char *b64 = malloc(b64_len + 1);
        size_t i = 0, j = 0;
        while (i < got) {
          unsigned a = src[i++];
          unsigned b = i < got ? src[i++] : 0;
          unsigned c = i < got ? src[i++] : 0;
          unsigned tri = (a << 16) | (b << 8) | c;
          b64[j++] = tbl[(tri >> 18) & 63];
          b64[j++] = tbl[(tri >> 12) & 63];
          b64[j++] = (i - 1 > got) ? '=' : tbl[(tri >> 6) & 63];
          b64[j++] = (i > got) ? '=' : tbl[tri & 63];
        }
        if (got % 3 == 1) { b64[b64_len - 1] = '='; b64[b64_len - 2] = '='; }
        else if (got % 3 == 2) { b64[b64_len - 1] = '='; }
        b64[b64_len] = '\0';
        free(src);

        size_t need = strlen("data:image/png;base64,") + b64_len + 1;
        src_ref = malloc(need);
        snprintf(src_ref, need, "data:image/png;base64,%s", b64);
        free(b64);
      }

      size_t esc_cap = strlen(src_ref) * 6 + 1;
      char *src_esc = malloc(esc_cap);
      size_t esc_len = 0;
      for (const char *p = src_ref; *p; p++) {
        const char *rep = NULL;
        switch (*p) {
          case '&': rep = "&amp;"; break;
          case '<': rep = "&lt;"; break;
          case '>': rep = "&gt;"; break;
          case '"': rep = "&quot;"; break;
          case '\'': rep = "&#39;"; break;
          default: break;
        }
        if (rep) {
          size_t n = strlen(rep);
          memcpy(src_esc + esc_len, rep, n);
          esc_len += n;
        } else {
          src_esc[esc_len++] = *p;
        }
      }
      src_esc[esc_len] = '\0';

      size_t need = len + strlen(src_esc) + 64;
      while (need > cap) { cap *= 2; html = realloc(html, cap); }
      len += (size_t)snprintf(html + len, cap - len,
                              "<img src=\"%s\" alt=\"cell image %d\" />",
                              src_esc, idx);
      free(src_ref);
      free(src_esc);
    }

    if (len == strlen("<div class=\"cell-images\">")) {
      free(html);
      return strdup("");
    }
    size_t need = len + strlen("</div>") + 1;
    while (need > cap) { cap *= 2; html = realloc(html, cap); }
    strcpy(html + len, "</div>");
    return html;
    ```)

  (defn __rhtml-cell-shows-source? [cell :int opts :int] #{Unsafe} :bool
