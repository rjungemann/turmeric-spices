;;; notebook/render-html -- render notebook documents to standalone HTML.
;; notebook/render-html -- evaluate .tur.md files and emit HTML output.

(defmodule notebook/render-html
  (import notebook/cmark :refer [md-emit-html])
  (import notebook/format :refer [parse-file node-tag node-prose node-cell])
  (import notebook/cell :refer [attr-get attr-get-bool cell-id cell-lang cell-source cell-attrs cells-assign-ids])
  (import notebook/session :refer [session-open session-close
                                   output-status-ok output-status-error output-status-skipped
                                   cell-output-status cell-output-cell-id
                                   cell-output-stdout cell-output-value-repr
                                   cell-output-error-msg cell-output-elapsed-ms
                                   cell-output-image-paths])
  (import notebook/eval :refer [eval-all])
  (import notebook/cache :refer [cache-open cache-close])
  (export render-html-string render-html-string-at render-html)

  (defn __rhtml-build-hint [] :int
    ```c
    /* __tur_include__: #include <sys/stat.h> */
    return 0;
    ```)

  (defn __rhtml-nil-value [] #{Unsafe} :int
    ```c
    return 0;
    ```)

  (defn __rhtml-list-nil? [lst :int] #{Unsafe} :bool
    ```c
    return lst == 0;
    ```)

  (defn __rhtml-cons [value :int next :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = malloc(sizeof(*cell));
    cell->head = value;
    cell->tail = next;
    return (int64_t)(intptr_t)cell;
    ```)

  (defn __rhtml-head [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    if (!cell) { fprintf(stderr, "head: empty list\n"); exit(1); }
    return cell->head;
    ```)

  (defn __rhtml-tail [lst :int] #{Unsafe} :int
    ```c
    struct { int64_t head; int64_t tail; } *cell = (void*)(intptr_t)lst;
    if (!cell) { fprintf(stderr, "tail: empty list\n"); exit(1); }
    return cell->tail;
    ```)

  (defn __rhtml-ok [value :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = true;
    r->ok_val = value;
    r->err_val = 0;
    return (int64_t)(intptr_t)r;
    ```)

  (defn __rhtml-err [value :cstr] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = false;
    r->ok_val = 0;
    r->err_val = (int64_t)(intptr_t)(value ? strdup((const char *)(intptr_t)value) : strdup(""));
    return (int64_t)(intptr_t)r;
    ```)

  (defn __rhtml-result-ok? [result :int] #{Unsafe} :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void*)(intptr_t)result;
    return r && r->is_ok;
    ```)

  (defn __rhtml-result-ok-val [result :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void*)(intptr_t)result;
    return r ? r->ok_val : 0;
    ```)

  (defn __rhtml-cstr-as-int [s :cstr] #{Unsafe} :int
    ```c
    return (int64_t)(intptr_t)s;
    ```)

  (defn __rhtml-int-as-cstr [value :int] #{Unsafe} :cstr
    ```c
    return (const char *)(intptr_t)value;
    ```)

  (defn __rhtml-cstr-empty? [s :cstr] #{Unsafe} :bool
    ```c
    const char *src = s ? (const char *)(intptr_t)s : "";
    return src[0] == '\0';
    ```)

  (defn __rhtml-cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    return strcmp(sa, sb) == 0;
    ```)

  (defn __rhtml-str-concat [a :cstr b :cstr] #{Unsafe} :cstr
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    size_t la = strlen(sa), lb = strlen(sb);
    char *out = malloc(la + lb + 1);
    memcpy(out, sa, la);
    memcpy(out + la, sb, lb);
    out[la + lb] = '\0';
    return out;
    ```)

  (defn __rhtml-join-blocks [a :cstr b :cstr] #{Unsafe} :cstr
    (if (__rhtml-cstr-empty? a)
      b
      (if (__rhtml-cstr-empty? b)
        a
        (__rhtml-str-concat a (__rhtml-str-concat "\n" b)))))

  (defn __rhtml-output-path [src_path :cstr output_dir :cstr] #{Unsafe} :cstr
    ```c
    const char *src = src_path ? (const char *)(intptr_t)src_path : "";
    const char *out_dir = output_dir ? (const char *)(intptr_t)output_dir : "";
    const char *base = strrchr(src, '/');
    base = base ? base + 1 : src;

    size_t base_len = strlen(base);
    size_t stem_len = base_len;
    if (base_len >= 7 && strcmp(base + base_len - 7, ".tur.md") == 0) {
      stem_len = base_len - 7;
    } else {
      const char *dot = strrchr(base, '.');
      if (dot) stem_len = (size_t)(dot - base);
    }

    char *stem = malloc(stem_len + 1);
    memcpy(stem, base, stem_len);
    stem[stem_len] = '\0';

    char *dir = NULL;
    if (out_dir[0] != '\0') {
      dir = strdup(out_dir);
    } else {
      const char *slash = strrchr(src, '/');
      if (!slash) {
        dir = strdup("");
      } else {
        size_t dir_len = (size_t)(slash - src);
        dir = malloc(dir_len + 1);
        memcpy(dir, src, dir_len);
        dir[dir_len] = '\0';
      }
    }

    size_t need = strlen(dir) + (dir[0] ? 1 : 0) + strlen(stem) + 5 + 1;
    char *out = malloc(need);
    if (dir[0]) snprintf(out, need, "%s/%s.html", dir, stem);
    else snprintf(out, need, "%s.html", stem);

    free(stem);
    free(dir);
    return out;
    ```)

  (defn __rhtml-style-path [html_path :cstr] #{Unsafe} :cstr
    ```c
    const char *src = html_path ? (const char *)(intptr_t)html_path : "";
    const char *slash = strrchr(src, '/');
    size_t dir_len = slash ? (size_t)(slash - src) : 0;
    size_t need = dir_len + (dir_len ? 1 : 0) + strlen("style.css") + 1;
    char *out = malloc(need);
    if (dir_len) snprintf(out, need, "%.*s/style.css", (int)dir_len, src);
    else snprintf(out, need, "style.css");
    return out;
    ```)

  (defn __rhtml-ensure-parent-dir [path :cstr] #{Unsafe} :int
    ```c
    #include <sys/stat.h>
    const char *src = path ? (const char *)(intptr_t)path : "";
    const char *slash = strrchr(src, '/');
    if (!slash) return 0;
    size_t len = (size_t)(slash - src);
    char *dir = malloc(len + 1);
    memcpy(dir, src, len);
    dir[len] = '\0';
    if (dir[0] == '\0') { free(dir); return 0; }

    int ret = 0;
    for (char *p = dir + 1; *p; p++) {
      if (*p == '/') {
        struct stat st;
        *p = '\0';
        if (stat(dir, &st) != 0) {
          if (mkdir(dir, 0755) != 0) { ret = -1; break; }
        } else if (!S_ISDIR(st.st_mode)) {
          ret = -1;
          break;
        }
        *p = '/';
      }
    }
    if (ret == 0) {
      struct stat st;
      if (stat(dir, &st) != 0) {
        if (mkdir(dir, 0755) != 0) ret = -1;
      } else if (!S_ISDIR(st.st_mode)) {
        ret = -1;
      }
    }
    free(dir);
    return ret;
    ```)

  (defn __rhtml-write-file [path :cstr s :cstr] #{Unsafe} :int
    ```c
    const char *p = path ? (const char *)(intptr_t)path : "";
    const char *text = s ? (const char *)(intptr_t)s : "";
    FILE *fp = fopen(p, "wb");
    if (!fp) return 0;
    size_t len = strlen(text);
    size_t wrote = fwrite(text, 1, len, fp);
    fclose(fp);
    return wrote == len ? 1 : 0;
    ```)

  (defn __rhtml-close-cache [cache :int] #{Unsafe} :int
    (if (not (= cache 0))
      (do
        (cache-close cache)
        0)
      0))

  (defn __rhtml-render-opts-output-dir [opts :int] #{Unsafe} :cstr
