  (defn __rhtml-render-math-body [text :cstr] #{Unsafe} :cstr
    ```c
    /* Scan text for $$...$$  and $...$, emit HTML math spans interleaved with
       escaped plain text.  Produces markup that KaTeX auto-render will pick up
       via class="math display|inline". */
    const char *src = text ? (const char *)(intptr_t)text : "";
    size_t slen = strlen(src);
    size_t cap = slen * 4 + 256;
    char *out = malloc(cap);
    size_t j = 0;

#define ENSURE(n) do { \
    if (j + (n) + 1 >= cap) { cap = (j + (n) + 1) * 2; out = realloc(out, cap); } \
} while (0)

#define APPEND(s) do { \
    size_t _len = strlen(s); ENSURE(_len); memcpy(out + j, s, _len); j += _len; \
} while (0)

#define APPEND_CHAR_ESC(c) do { \
    if ((c) == '&') { ENSURE(5); memcpy(out+j,"&amp;",5); j+=5; } \
    else if ((c) == '<') { ENSURE(4); memcpy(out+j,"&lt;",4); j+=4; } \
    else if ((c) == '>') { ENSURE(4); memcpy(out+j,"&gt;",4); j+=4; } \
    else { ENSURE(1); out[j++] = (c); } \
} while (0)

    for (size_t i = 0; i < slen; ) {
        /* Display math: $$ ... $$ */
        if (i + 1 < slen && src[i] == '$' && src[i+1] == '$') {
            size_t start = i + 2;
            size_t k = start;
            while (k + 1 < slen && !(src[k] == '$' && src[k+1] == '$')) k++;
            if (k + 1 < slen) {
                /* found closing $$ */
                APPEND("<span class=\"math display\">$$");
                for (size_t m = start; m < k; m++) {
                    if (src[m] == '&') { ENSURE(5); memcpy(out+j,"&amp;",5); j+=5; }
                    else if (src[m] == '<') { ENSURE(4); memcpy(out+j,"&lt;",4); j+=4; }
                    else if (src[m] == '>') { ENSURE(4); memcpy(out+j,"&gt;",4); j+=4; }
                    else { ENSURE(1); out[j++] = src[m]; }
                }
                APPEND("$$</span>");
                i = k + 2;
                continue;
            }
        }
        /* Inline math: $ ... $ (not followed by digit/space) */
        if (src[i] == '$') {
            char prv = (i > 0) ? src[i-1] : '\0';
            char nxt = (i + 1 < slen) ? src[i+1] : '\0';
            int opener = (nxt != '\0' && nxt != ' ' && nxt != '\t' && nxt != '\n'
                          && !(nxt >= '0' && nxt <= '9') && prv != '\\');
            if (opener) {
                size_t start = i + 1;
                size_t k = start;
                while (k < slen && src[k] != '$') k++;
                if (k < slen) {
                    APPEND("<span class=\"math inline\">$");
                    for (size_t m = start; m < k; m++) {
                        if (src[m] == '&') { ENSURE(5); memcpy(out+j,"&amp;",5); j+=5; }
                        else if (src[m] == '<') { ENSURE(4); memcpy(out+j,"&lt;",4); j+=4; }
                        else if (src[m] == '>') { ENSURE(4); memcpy(out+j,"&gt;",4); j+=4; }
                        else { ENSURE(1); out[j++] = src[m]; }
                    }
                    APPEND("$</span>");
                    i = k + 1;
                    continue;
                }
            }
        }
        APPEND_CHAR_ESC(src[i]);
        i++;
    }
    out[j] = '\0';
    return out;
    ```)

