  (defn __rhtml-lang-label [lang :int] #{Unsafe} :cstr
    (if (= lang 0) "turmeric" "sweet-exp"))

  (defn __rhtml-status-label [status :int] #{Unsafe} :cstr
    (if (= status (output-status-ok))
      "ok"
      (if (= status (output-status-skipped))
        "skipped"
        "error")))

  (defn __rhtml-cell-class [lang :int] #{Unsafe} :cstr
    (if (= lang 0) "turmeric-cell" "sweet-exp-cell"))

  (defn __rhtml-html-escape [text :cstr] #{Unsafe} :cstr
    ```c
    const char *src = text ? (const char *)(intptr_t)text : "";
    size_t cap = strlen(src) * 6 + 1;
    char *out = malloc(cap);
    size_t len = 0;
    while (*src) {
      const char *rep = NULL;
      switch (*src) {
        case '&': rep = "&amp;"; break;
        case '<': rep = "&lt;"; break;
        case '>': rep = "&gt;"; break;
        case '"': rep = "&quot;"; break;
        case '\'': rep = "&#39;"; break;
        default: break;
      }
      if (rep) {
        size_t n = strlen(rep);
        memcpy(out + len, rep, n);
        len += n;
      } else {
        out[len++] = *src;
      }
      src++;
    }
    out[len] = '\0';
    return out;
    ```)

  (defn __rhtml-page-title [path :cstr] #{Unsafe} :cstr
    ```c
    const char *src = path ? (const char *)(intptr_t)path : "";
    const char *base = strrchr(src, '/');
    base = base ? base + 1 : src;
    size_t n = strlen(base);
    if (n >= 7 && strcmp(base + n - 7, ".tur.md") == 0) n -= 7;
    else {
      const char *dot = strrchr(base, '.');
      if (dot) n = (size_t)(dot - base);
    }
    if (n == 0) return strdup("Notebook");
    char *out = malloc(n + 1);
    memcpy(out, base, n);
    out[n] = '\0';
    return out;
    ```)

