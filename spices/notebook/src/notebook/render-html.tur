         (= (attr-get-bool (cell-attrs cell) "output" 1) 1)))

  (defn __rhtml-render-cell-content [cell :int output :int opts :int html_path :cstr] #{Unsafe} :cstr
    (let [source-part (if (__rhtml-cell-shows-source? cell opts)
                        (__rhtml-render-source-pre cell)
                        "")
          math-cell? (= (attr-get-bool (cell-attrs cell) "math" 0) 1)
          output-part (if (__rhtml-cell-shows-output? cell output opts)
                        (if math-cell?
                          (__rhtml-render-math-output output)
                          (__rhtml-render-output-pre output))
                        "")
          image-part (if (__rhtml-cell-shows-output? cell output opts)
                       (__rhtml-render-image-block output
                                                   (attr-get (cell-attrs cell) "image" "inline")
                                                   html_path
                                                   (cell-id cell))
                       "")]
      (__rhtml-join-blocks source-part (__rhtml-join-blocks output-part image-part))))

