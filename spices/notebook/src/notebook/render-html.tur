      ".code-version[hidden] { display: none; }\n"
    );
    ```)

  (defn __rhtml-toggle-script [] #{Unsafe} :cstr
    ```c
    return strdup(
      "document.querySelectorAll('.code-syntax-toggle').forEach(function(toggle){\n"
      "  toggle.addEventListener('click', function(e){\n"
      "    if (!e.target.classList.contains('seg-btn')) return;\n"
      "    var syntax = e.target.getAttribute('data-syntax');\n"
      "    var card = toggle.closest('.code-card');\n"
      "    toggle.querySelectorAll('.seg-btn').forEach(function(btn){\n"
      "      var active = btn === e.target;\n"
      "      btn.classList.toggle('active', active);\n"
      "      btn.setAttribute('aria-selected', active ? 'true' : 'false');\n"
      "    });\n"
      "    card.querySelectorAll('.code-version').forEach(function(panel){\n"
      "      panel.hidden = !panel.classList.contains(syntax + '-version');\n"
      "    });\n"
      "  });\n"
      "});\n"
    );
    ```)

  (defn __rhtml-render-source-pre [cell :int] #{Unsafe} :cstr
    (let [escaped (__rhtml-html-escape (cell-source cell))]
      (__rhtml-str-concat
        "<div class=\"notebook-cell-bar\"><span class=\"cell-kind\">"
        (__rhtml-str-concat
          (__rhtml-lang-label (cell-lang cell))
          (__rhtml-str-concat
            "</span><span class=\"cell-meta\">"
            (__rhtml-str-concat
              (__rhtml-html-escape (cell-id cell))
              (__rhtml-str-concat
                "</span></div><pre class=\""
                (__rhtml-str-concat
                  (__rhtml-cell-class (cell-lang cell))
                  (__rhtml-str-concat "\"><code>" (__rhtml-str-concat escaped "</code></pre>"))))))))))

  (defn __rhtml-output-skipped? [output :int] #{Unsafe} :bool
    (or (= output 0)
        (= (cell-output-status output) (output-status-skipped))))

  (defn __rhtml-output-meta [output :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      char *cell_id;
      int64_t status;
      char *stdout_text;
      char *value_repr;
      char *error_msg;
      int64_t elapsed_ms;
      int64_t image_paths;
    } NotebookCellOutput;
    NotebookCellOutput *out = (NotebookCellOutput *)(intptr_t)output;
    if (!out || out->status == 2) return strdup("");
    const char *status = out->status == 0 ? "ok" : "error";
    const char *cell_id = out->cell_id ? out->cell_id : "";
    char buf[256];
    snprintf(buf, sizeof(buf), "cell-id=%s status=%s elapsed=%lldms",
             cell_id, status, (long long)out->elapsed_ms);
    return strdup(buf);
    ```)

  (defn __rhtml-output-body [output :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      char *cell_id;
      int64_t status;
      char *stdout_text;
      char *value_repr;
      char *error_msg;
      int64_t elapsed_ms;
      int64_t image_paths;
    } NotebookCellOutput;
    NotebookCellOutput *out = (NotebookCellOutput *)(intptr_t)output;
    if (!out || out->status == 2) return strdup("");

    const char *stdout_text = out->stdout_text ? out->stdout_text : "";
    const char *value_repr = out->value_repr ? out->value_repr : "";
    const char *error_msg = out->error_msg ? out->error_msg : "";

    size_t cap = strlen(stdout_text) + strlen(value_repr) + strlen(error_msg) + 32;
    char *buf = malloc(cap);
    buf[0] = '\0';
    if (out->status == 0) {
      if (stdout_text[0]) strncat(buf, stdout_text, cap - strlen(buf) - 1);
      if (value_repr[0]) {
        if (buf[0]) strncat(buf, "\n", cap - strlen(buf) - 1);
        strncat(buf, ";; => ", cap - strlen(buf) - 1);
        strncat(buf, value_repr, cap - strlen(buf) - 1);
      }
    } else {
      strncat(buf, error_msg, cap - strlen(buf) - 1);
    }
    return buf;
    ```)

