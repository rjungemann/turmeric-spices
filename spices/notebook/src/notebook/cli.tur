  (defn __cli-state-set-cell-id [state :int value :cstr] #{Unsafe} :int
    ```c
    typedef struct {
      char *command; char *target; char *path; char *out; char *error_msg;
      int64_t use_cache; int64_t watch; int64_t no_output; int64_t no_source;
      int64_t help; char *keybindings_file; int64_t no_color;
      char *cell_id; int64_t exec_all;
    } CliParseState;
    CliParseState *st = (CliParseState *)(intptr_t)state;
    if (!st) return state;
    free(st->cell_id);
    st->cell_id = value ? strdup((const char *)(intptr_t)value) : strdup("");
    return state;
    ```)

  (defn __cli-state-set-exec-all [state :int value :int] #{Unsafe} :int
    ```c
    typedef struct {
