  (defn __cli-prefix-value [token :cstr prefix :cstr] #{Unsafe} :cstr
    ```c
    const char *tok = token ? (const char *)(intptr_t)token : "";
    const char *pre = prefix ? (const char *)(intptr_t)prefix : "";
    size_t n = strlen(pre);
    if (strncmp(tok, pre, n) != 0) return (const char *)(intptr_t)0;
    return (const char *)(intptr_t)(tok + n);
    ```)

  (defn __cli-state-cell-id [state :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      char *command; char *target; char *path; char *out; char *error_msg;
      int64_t use_cache; int64_t watch; int64_t no_output; int64_t no_source;
      int64_t help; char *keybindings_file; int64_t no_color;
      char *cell_id; int64_t exec_all;
    } CliParseState;
    CliParseState *st = (CliParseState *)(intptr_t)state;
    return st && st->cell_id ? st->cell_id : "";
    ```)

