  (defn __cli-state-set-command [state :int value :cstr] #{Unsafe} :int
    ```c
    typedef struct {
      char *command;
      char *target;
      char *path;
      char *out;
      char *error_msg;
      int64_t use_cache;
      int64_t watch;
      int64_t no_output;
      int64_t no_source;
      int64_t help;
    } CliParseState;
    CliParseState *st = (CliParseState *)(intptr_t)state;
    if (!st) return state;
    free(st->command);
    st->command = strdup(value ? (const char *)(intptr_t)value : "");
    return state;
    ```)

