;;; notebook/cli -- command-line entrypoint for tur-notebook.
;; notebook/cli -- argv dispatch for render/export/exec/new workflows.

(defmodule notebook/cli
  (import notebook/render-md :refer [render-opts-make render-md])
  (import notebook/render-html :refer [render-html])
  (import notebook/tui :refer [tui-opts-make tui-run])
  (import notebook/format :refer [parse-file node-tag node-cell])
  (import notebook/session :refer [session-open session-close
                                   cell-output-cell-id cell-output-status
                                   cell-output-stdout cell-output-value-repr
                                   cell-output-error-msg cell-output-elapsed-ms
                                   output-status-ok output-status-error output-status-skipped])
  (import notebook/eval :refer [eval-all eval-from])
  (import notebook/cell :refer [cell-id cells-assign-ids])
  (export cli-main)

  (defn __cli-build-hint [] :int
    ```c
    /* __tur_include__: #ifdef __APPLE__ */
    /* __tur_include__: #include <sys/event.h> */
    /* __tur_include__: #endif */
    /* __tur_include__: #ifdef __linux__ */
    /* __tur_include__: #include <poll.h> */
    /* __tur_include__: #include <sys/inotify.h> */
    /* __tur_include__: #endif */
    return 0;
    ```)

  (defn __cli-nil-value [] #{Unsafe} :int
    ```c
    return 0;
    ```)

  (defn __cli-null-cstr [] #{Unsafe} :cstr
    ```c
    return (const char *)(intptr_t)0;
    ```)

  (defn __cli-list-nil? [lst :int] #{Unsafe} :bool
    ```c
    return lst == 0;
    ```)

  (defn __cli-head [lst :int] #{Unsafe} :cstr
    ```c
    int64_t *cell = (int64_t *)(intptr_t)lst;
    return cell ? (const char *)(intptr_t)cell[0] : 0;
    ```)

  (defn __cli-tail [lst :int] #{Unsafe} :int
    ```c
    int64_t *cell = (int64_t *)(intptr_t)lst;
    return cell ? cell[1] : 0;
    ```)

  (defn __cli-cstr-eq? [a :cstr b :cstr] #{Unsafe} :bool
    ```c
    const char *sa = a ? (const char *)(intptr_t)a : "";
    const char *sb = b ? (const char *)(intptr_t)b : "";
    return strcmp(sa, sb) == 0;
    ```)

  (defn __cli-cstr-null? [s :cstr] #{Unsafe} :bool
    ```c
    return ((const void *)(intptr_t)s) == NULL;
    ```)

  (defn __cli-cstr-empty? [s :cstr] #{Unsafe} :bool
    ```c
    const char *src = s ? (const char *)(intptr_t)s : "";
    return src[0] == '\0';
    ```)

  (defn __cli-puts [s :cstr] #{Unsafe} :int
    ```c
    const char *text = s ? (const char *)(intptr_t)s : "";
    printf("%s\n", text);
    return 0;
    ```)

  (defn __cli-eputs [s :cstr] #{Unsafe} :int
    ```c
    const char *text = s ? (const char *)(intptr_t)s : "";
    fprintf(stderr, "%s\n", text);
    return 0;
    ```)

  (defn __cli-result-ok? [result :int] #{Unsafe} :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void*)(intptr_t)result;
    return r && r->is_ok;
    ```)

  (defn __cli-result-ok-cstr [result :int] #{Unsafe} :cstr
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void*)(intptr_t)result;
    return (r && r->is_ok) ? (const char *)(intptr_t)r->ok_val : "";
    ```)

  (defn __cli-result-ok-int [result :int] #{Unsafe} :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void*)(intptr_t)result;
    return (r && r->is_ok) ? r->ok_val : 0;
    ```)

  (defn __cli-result-err-cstr [result :int] #{Unsafe} :cstr
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = (void*)(intptr_t)result;
    return (r && !r->is_ok) ? (const char *)(intptr_t)r->err_val : "";
    ```)

  (defn __cli-pos-count [lst :int] #{Unsafe} :int
    (if (__cli-list-nil? lst)
      0
      (+ 1 (__cli-pos-count (__cli-tail lst)))))

  (defn __cli-pos-first [lst :int] #{Unsafe} :cstr
    (if (__cli-list-nil? lst) (__cli-null-cstr) (__cli-head lst)))

  (defn __cli-pos-second [lst :int] #{Unsafe} :cstr
    (if (__cli-list-nil? lst)
      (__cli-null-cstr)
      (__cli-pos-first (__cli-tail lst))))

  (defn __cli-parse-state-make [] #{Unsafe} :int
    ```c
    typedef struct {
      char *command;
      char *target;
      char *path;
      char *out;
      char *error_msg;
      int64_t use_cache;
      int64_t watch;
      int64_t no_output;
      int64_t no_source;
      int64_t help;
      char *keybindings_file;
      int64_t no_color;
      char *cell_id;
      int64_t exec_all;
    } CliParseState;
    CliParseState *st = calloc(1, sizeof(*st));
    st->command = strdup("");
    st->target = strdup("");
    st->path = strdup("");
    st->out = strdup("");
    st->error_msg = strdup("");
    st->keybindings_file = strdup("");
    st->cell_id = strdup("");
    st->no_color = 0;
    st->exec_all = 0;
    return (int64_t)(intptr_t)st;
    ```)

  (defn __cli-state-command [state :int] #{Unsafe} :cstr
    ```c
    typedef struct {
      char *command;
      char *target;
      char *path;
      char *out;
      char *error_msg;
      int64_t use_cache;
      int64_t watch;
      int64_t no_output;
      int64_t no_source;
      int64_t help;
    } CliParseState;
    CliParseState *st = (CliParseState *)(intptr_t)state;
    return st && st->command ? st->command : "";
    ```)

