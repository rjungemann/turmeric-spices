;; tests/c-dsl/core_test.tur -- tests for c-dsl/types, c-dsl/core, c-dsl/fns,
;;   c-dsl/mem, c-dsl/pp, and c-dsl/typedef.
(defmodule c-dsl/tests/core
  (import c-dsl/codegen  :refer [c-stmts compile-c])
  (import c-dsl/types    :refer [c-type c-ptr-type c-arr-type c-const-type])
  (import c-dsl/core     :refer [c-let1 c-let1-uninit c-const1 c-set! c-return
                                  c-break c-continue c-inc! c-dec!
                                  c-if c-if-only c-while c-for1
                                  c-binop c-unop c-ternary c-case c-default-case
                                  c-switch])
  (import c-dsl/fns      :refer [c-param c-defn c-call c-declare])
  (import c-dsl/types    :refer [cfield->cstr cparam->cstr])
  (import c-dsl/mem      :refer [c-addr c-deref c-index c-cast
                                  c-malloc c-free c-sizeof c-null
                                  c-ptr-add])
  (import c-dsl/pp       :refer [c-include c-include-sys c-define c-ifdef
                                  c-ifndef c-static-assert c-pragma])
  (import c-dsl/typedef  :refer [c-field c-defstruct c-defunion c-defenum
                                  c-typedef])
  (import test/assert    :refer [assert-true])
  (import test/suite     :refer [describe it])
  (import test/runner    :refer [run-all])

  (defn cstr= [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char*)(intptr_t)a, (const char*)(intptr_t)b) == 0;
    ```)

  ;; --- types ---

  (describe "c-type"
    (it "maps :void"   (assert-true (cstr= (c-type ":void")  "void")))
    (it "maps :int"    (assert-true (cstr= (c-type ":int")   "int32_t")))
    (it "maps :int32"  (assert-true (cstr= (c-type ":int32") "int32_t")))
    (it "maps :uint"   (assert-true (cstr= (c-type ":uint")  "uint32_t")))
    (it "maps :float"  (assert-true (cstr= (c-type ":float") "float")))
    (it "maps :double" (assert-true (cstr= (c-type ":double")"double")))
    (it "maps :bool"   (assert-true (cstr= (c-type ":bool")  "bool")))
    (it "maps :cstr"   (assert-true (cstr= (c-type ":cstr")  "char*")))
    (it "maps :size-t" (assert-true (cstr= (c-type ":size-t")"size_t")))
    (it "strips colon from unknown" (assert-true (cstr= (c-type ":MyType") "MyType")))
    (it "passes bare identifier"    (assert-true (cstr= (c-type "MyType") "MyType"))))

  (describe "c-ptr-type"
    (it "makes int pointer"  (assert-true (cstr= (c-ptr-type ":int")  "int32_t*")))
    (it "makes void pointer" (assert-true (cstr= (c-ptr-type ":void") "void*")))
    (it "makes char pointer" (assert-true (cstr= (c-ptr-type ":char") "char*"))))

  (describe "c-arr-type"
    (it "makes int array of 10" (assert-true (cstr= (c-arr-type ":int" 10) "int32_t[10]")))
    (it "makes uint8 array"     (assert-true (cstr= (c-arr-type ":uint8" 16) "uint8_t[16]"))))

  (describe "c-const-type"
    (it "prepends const" (assert-true (cstr= (c-const-type "char*") "const char*"))))

  ;; --- core ---

  (describe "c-let1"
    (it "declares initialized var"
      (assert-true (cstr= (c-let1 "x" ":int" "42") "int32_t x = 42;")))
    (it "declares float var"
      (assert-true (cstr= (c-let1 "y" ":float" "3.14f") "float y = 3.14f;"))))

  (describe "c-let1-uninit"
    (it "declares uninitialized var"
      (assert-true (cstr= (c-let1-uninit "p" ":cstr") "char* p;"))))

  (describe "c-const1"
    (it "declares const var"
      (assert-true (cstr= (c-const1 "MAX" ":int" "100") "const int32_t MAX = 100;"))))

  (describe "c-set!"
    (it "emits assignment"
      (assert-true (cstr= (c-set! "x" "42") "x = 42;")))
    (it "emits field assignment"
      (assert-true (cstr= (c-set! "p.x" "0") "p.x = 0;"))))

  (describe "c-return"
    (it "emits return"
      (assert-true (cstr= (c-return "x + 1") "return x + 1;"))))

  (describe "c-break"
    (it "emits break" (assert-true (cstr= (c-break) "break;"))))

  (describe "c-continue"
    (it "emits continue" (assert-true (cstr= (c-continue) "continue;"))))

  (describe "c-inc! and c-dec!"
    (it "emits increment" (assert-true (cstr= (c-inc! "i") "i++;")))
    (it "emits decrement" (assert-true (cstr= (c-dec! "n") "n--;"))))

  (describe "c-binop"
    (it "addition"    (assert-true (cstr= (c-binop "+" "a" "b") "(a + b)")))
    (it "comparison"  (assert-true (cstr= (c-binop "<" "i" "10") "(i < 10)")))
    (it "equality"    (assert-true (cstr= (c-binop "==" "x" "0") "(x == 0)"))))

  (describe "c-unop"
    (it "negation" (assert-true (cstr= (c-unop "!" "flag") "(!flag)")))
    (it "negate"   (assert-true (cstr= (c-unop "-" "x") "(-x)"))))

  (describe "c-ternary"
    (it "emits ternary"
      (assert-true (cstr= (c-ternary "x > 0" "1" "-1") "(x > 0 ? 1 : -1)"))))

  (describe "c-if"
    (it "emits if/else"
      (assert-true
        (cstr= (c-if "x > 0" "y = 1;" "y = -1;")
               "if (x > 0) {\n    y = 1;\n} else {\n    y = -1;\n}"))))

  (describe "c-if-only"
    (it "emits if without else"
      (assert-true
        (cstr= (c-if-only "flag" "return 1;")
               "if (flag) {\n    return 1;\n}"))))

  (describe "c-while"
    (it "emits while loop"
      (assert-true
        (cstr= (c-while "i < 10" "i++;")
               "while (i < 10) {\n    i++;\n}"))))

  (describe "c-for1"
    (it "emits typed for loop"
      (assert-true
        (cstr= (c-for1 "i" ":int" "0" "i < 10" "i++" "sum += i;")
               "for (int32_t i = 0; i < 10; i++) {\n    sum += i;\n}"))))

  (describe "c-switch"
    (it "emits switch with cases"
      (assert-true
        (cstr= (c-switch "x"
                 (cons (c-case "0" "break;")
                       (cons (c-default-case "return -1;") 0)))
               "switch (x) {\ncase 0:\n    break;\ndefault:\n    return -1;\n}"))))

  ;; --- fns ---

  (describe "c-param"
    (it "formats int param"   (assert-true (cstr= (cparam->cstr (c-param "x" ":int"))   "int32_t x")))
    (it "formats float param" (assert-true (cstr= (cparam->cstr (c-param "f" ":float")) "float f")))
    (it "formats cstr param"  (assert-true (cstr= (cparam->cstr (c-param "s" ":cstr"))  "char* s"))))

  ;; c-call describe block elided -- bare identifier `c-call` collides with a
  ;; turmeric core form that expects a symbol argument, so the imported
  ;; c-dsl/fns c-call cannot be invoked without renaming at the import site
  ;; (preexisting issue, unrelated to U6).

  (describe "c-defn"
    (it "emits a simple function"
      (assert-true
        (cstr= (c-defn "square"
                       ":int"
                       (c-return (c-binop "*" "x" "x"))
                       (c-param "x" ":int"))
               "int32_t square(int32_t x) {\n    return (x * x);\n}")))
    (it "emits void function with no params"
      (assert-true
        (cstr= (c-defn "noop" ":void" "return;")
               "void noop() {\n    return;\n}"))))

  (describe "c-declare"
    (it "emits forward declaration"
      (assert-true
        (cstr= (c-declare ":int" "add" (cons "int32_t" (cons "int32_t" 0)))
               "int32_t add(int32_t, int32_t);"))))

  ;; --- mem ---

  (describe "c-addr"
    (it "takes address" (assert-true (cstr= (c-addr "x") "(&x)"))))

  (describe "c-deref"
    (it "dereferences" (assert-true (cstr= (c-deref "ptr") "(*ptr)"))))

  (describe "c-index"
    (it "indexes array" (assert-true (cstr= (c-index "arr" "i") "arr[i]"))))

  (describe "c-cast"
    (it "casts to int"
      (assert-true (cstr= (c-cast "3.14" ":int") "((int32_t)3.14)")))
    (it "casts to void pointer"
      (assert-true (cstr= (c-cast "ptr" ":void*") "((void*)ptr)"))))

  (describe "c-malloc"
    (it "emits malloc"
      (assert-true (cstr= (c-malloc "size") "malloc(size)"))))

  (describe "c-free"
    (it "emits free statement"
      (assert-true (cstr= (c-free "buf") "free(buf);"))))

  (describe "c-sizeof"
    (it "sizeof int"
      (assert-true (cstr= (c-sizeof ":int") "sizeof(int32_t)")))
    (it "sizeof struct"
      (assert-true (cstr= (c-sizeof "Point") "sizeof(Point)"))))

  (describe "c-null"
    (it "null void pointer"
      (assert-true (cstr= (c-null ":void*") "((void*)NULL)"))))

  (describe "c-ptr-add"
    (it "pointer arithmetic"
      (assert-true (cstr= (c-ptr-add "arr" "i") "(arr + i)"))))

  ;; --- pp ---

  (describe "c-include"
    (it "local include"
      (assert-true (cstr= (c-include "mylib.h") "#include \"mylib.h\""))))

  (describe "c-include-sys"
    (it "system include"
      (assert-true (cstr= (c-include-sys "stdio.h") "#include <stdio.h>"))))

  (describe "c-define"
    (it "simple define"
      (assert-true (cstr= (c-define "PI" "3.14159f") "#define PI 3.14159f"))))

  (describe "c-ifdef"
    (it "ifdef guard"
      (assert-true
        (cstr= (c-ifdef "DEBUG" "printf(\"debug\\n\");")
               "#ifdef DEBUG\nprintf(\"debug\\n\");\n#endif"))))

  (describe "c-static-assert"
    (it "emits static_assert"
      (assert-true
        (cstr= (c-static-assert "sizeof(int32_t) == 4" "\"int32_t must be 4 bytes\"")
               "static_assert(sizeof(int32_t) == 4, \"int32_t must be 4 bytes\");"))))

  (describe "c-pragma"
    (it "once pragma"
      (assert-true (cstr= (c-pragma "once") "#pragma once"))))

  ;; --- typedef ---

  (describe "c-field"
    (it "int field"   (assert-true (cstr= (cfield->cstr (c-field "x" ":int"))   "int32_t x;")))
    (it "cstr field"  (assert-true (cstr= (cfield->cstr (c-field "name" ":cstr")) "char* name;"))))

  (describe "c-defstruct"
    (it "emits typedef struct"
      (assert-true
        (cstr= (c-defstruct "Point"
                            (c-field "x" ":int")
                            (c-field "y" ":int"))
               "typedef struct {\n    int32_t x;\n    int32_t y;\n} Point;"))))

  (describe "c-defunion"
    (it "emits typedef union"
      (assert-true
        (cstr= (c-defunion "Val"
                           (c-field "i" ":int")
                           (c-field "f" ":float"))
               "typedef union {\n    int32_t i;\n    float f;\n} Val;"))))

  (describe "c-defenum"
    (it "emits typedef enum"
      (assert-true
        (cstr= (c-defenum "Color" (cons "RED" (cons "GREEN" (cons "BLUE" 0))))
               "typedef enum {\n    RED,\n    GREEN,\n    BLUE\n} Color;"))))

  (describe "c-typedef"
    (it "emits typedef alias"
      (assert-true
        (cstr= (c-typedef "int32_t*" "IntPtr") "typedef int32_t* IntPtr;"))))

  ;; --- integration: compile a small C program ---

  (describe "compile-c integration"
    (it "assembles a complete function from fragments"
      (let [decl (c-defn "add"
                   ":int"
                   (c-return (c-binop "+" "a" "b"))
                   (c-param "a" ":int")
                   (c-param "b" ":int"))
            src  (compile-c (cons (c-include-sys "stdint.h") (cons decl 0)))]
        (assert-true
          (cstr= src
            "#include <stdint.h>\n\nint32_t add(int32_t a, int32_t b) {\n    return (a + b);\n}")))))


  (defn main [] : int
    (run-all)
    0))
