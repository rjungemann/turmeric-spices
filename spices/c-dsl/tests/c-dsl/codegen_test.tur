;; tests/c-dsl/codegen_test.tur -- tests for c-dsl/codegen string utilities.
(defmodule c-dsl/tests/codegen
  (import c-dsl/codegen :refer [c-int->str c-float->str c-cat2 c-cat3 c-cat4
                                 c-join c-lines c-indent c-stmts c-block
                                 compile-c c-sprintf1 c-sprintf2])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  (defn cstr= [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char*)(intptr_t)a, (const char*)(intptr_t)b) == 0;
    ```)

  (describe "c-int->str"
    (it "converts zero"     (assert-true (cstr= (c-int->str 0)    "0")))
    (it "converts positive" (assert-true (cstr= (c-int->str 42)   "42")))
    (it "converts negative" (assert-true (cstr= (c-int->str -7)   "-7"))))

  (describe "c-cat2"
    (it "concatenates two strings"
      (assert-true (cstr= (c-cat2 "int32_t" "*") "int32_t*")))
    (it "handles empty left"
      (assert-true (cstr= (c-cat2 "" "foo") "foo")))
    (it "handles empty right"
      (assert-true (cstr= (c-cat2 "foo" "") "foo"))))

  (describe "c-cat3"
    (it "concatenates three strings"
      (assert-true (cstr= (c-cat3 "a" "b" "c") "abc"))))

  (describe "c-sprintf1"
    (it "substitutes one placeholder"
      (assert-true (cstr= (c-sprintf1 "return %s;" "x") "return x;")))
    (it "substitutes in the middle"
      (assert-true (cstr= (c-sprintf1 "(%s)" "expr") "(expr)"))))

  (describe "c-sprintf2"
    (it "substitutes two placeholders"
      (assert-true (cstr= (c-sprintf2 "%s = %s;" "x" "42") "x = 42;"))))

  (describe "c-join"
    (it "joins empty list to empty string"
      (assert-true (cstr= (c-join 0 ", ") "")))
    (it "joins single item without separator"
      (assert-true (cstr= (c-join (cons "a" 0) ", ") "a")))
    (it "joins two items with separator"
      (assert-true (cstr= (c-join (cons "a" (cons "b" 0)) ", ") "a, b")))
    (it "joins three items"
      (assert-true (cstr= (c-join (cons "x" (cons "y" (cons "z" 0))) "-") "x-y-z"))))

  (describe "c-indent"
    (it "indents a single line"
      (assert-true (cstr= (c-indent "int x = 0;") "    int x = 0;")))
    (it "indents multiple lines"
      (assert-true (cstr= (c-indent "a;\nb;") "    a;\n    b;")))
    (it "handles empty string"
      (assert-true (cstr= (c-indent "") ""))))

  (describe "c-block"
    (it "wraps a single statement"
      (assert-true (cstr= (c-block (cons "return 0;" 0)) "{\n    return 0;\n}")))
    (it "wraps multiple statements"
      (assert-true (cstr= (c-block (cons "int x = 1;" (cons "return x;" 0)))
                          "{\n    int x = 1;\n    return x;\n}"))))

  (describe "compile-c"
    (it "joins top-level fragments with double newlines"
      (assert-true
        (cstr= (compile-c (cons "#include <stdio.h>" (cons "int x = 0;" 0)))
               "#include <stdio.h>\n\nint x = 0;"))))


  (defn main [] : int
    (run-all)
    0))
