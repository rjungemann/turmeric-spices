;; tests/c-dsl/sized_test.tur -- c-dsl/sized (U4 statically-length CArr).
;;
;; Pure-Turmeric (string building only), runs anywhere. Positive coverage of
;; the phantom-length C array surface; the negative case -- a memcpy between
;; arrays of different declared lengths -- is a compile error (TUR-E0260) and
;; so lives in tests/errors/, not here.

(load "stdlib/sized.tur")

(defmodule c-dsl/tests/sized
  (import c-dsl/sized :refer [CArr c-array c-arr-name c-arr-len c-arr-decl
                              c-arr-index c-arr-at c-arr-copy-stmt])
  (import test/assert :refer [assert-eq assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn cstr= [a : cstr b : cstr] : bool
    ```c return strcmp((const char*)(intptr_t)a, (const char*)(intptr_t)b) == 0; ```)

  ;; an 8-element array named "buf"
  (defn buf [] : (CArr (Static 8)) (c-array "buf" 8))

  (defn main [] : int
    (do
      (describe "c-array / c-arr-name / c-arr-len"
        (it "carries the array name" (assert-true (cstr= "buf" (c-arr-name (buf)))))
        (it "carries the length"     (assert-eq 8 (c-arr-len (buf)))))

      (describe "c-arr-decl"
        (it "emits a sized declaration"
          (assert-true (cstr= "int32_t buf[8];" (c-arr-decl (buf) ":int")))))

      (describe "c-arr-index (dynamic)"
        (it "subscripts with a C expression"
          (assert-true (cstr= "buf[i]" (c-arr-index (buf) "i")))))

      (describe "c-arr-at (literal, bounds-checked)"
        (it "subscripts an in-range literal"
          (assert-true (cstr= "buf[0]" (c-arr-at (buf) 0))))
        (it "subscripts the last valid index"
          (assert-true (cstr= "buf[7]" (c-arr-at (buf) 7)))))

      (describe "c-arr-copy-stmt (shared n)"
        (it "emits a sizeof-based memcpy between same-length arrays"
          (assert-true (cstr= "memcpy(dst, src, sizeof(dst));"
                              (c-arr-copy-stmt (:: (c-array "dst" 8) (CArr (Static 8)))
                                               (:: (c-array "src" 8) (CArr (Static 8))))))))

      (run-all)
      0)))
