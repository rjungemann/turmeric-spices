;; plutovg/canvas.tur -- drawing context bound to a surface.
;;
;; PV0 scope: create / destroy a canvas, set a solid-color source, and fill
;; an axis-aligned rectangle.  Path recording, transforms, gradients, and
;; text arrive in later phases (PV1..PV5).
;;
;; Handles are opaque :int (cast from plutovg_canvas_t* via intptr_t).
;; Results are compatible with stdlib/result.tur:
;;   ok? / ok-val / err-val from (import result :refer [ok? ok-val err-val])

(defmodule plutovg/canvas
  (export canvas-create canvas-destroy
          canvas-set-source-color canvas-fill-rect
          ;; PV1: path recording
          canvas-move-to canvas-line-to canvas-quad-to canvas-cubic-to
          canvas-close-path
          ;; PV1: shape helpers
          canvas-rect canvas-ellipse canvas-circle
          ;; PV1: render the recorded path
          canvas-fill canvas-stroke canvas-clip
          ;; PV2: integration with standalone plutovg/path objects
          canvas-add-path canvas-fill-path canvas-stroke-path
          ;; PV4: state stack
          canvas-save canvas-restore
          ;; PV4: transforms
          canvas-translate canvas-scale canvas-rotate
          canvas-transform canvas-reset-transform
          ;; PV4: stroke properties
          canvas-set-line-width canvas-set-line-cap canvas-set-line-join
          canvas-set-miter-limit
          ;; PV4: dash
          canvas-set-dash-offset canvas-set-dash-array
          dash-array-create dash-array-add
          dash-array-destroy dash-array-count
          ;; PV4: fill rule, blend operator, global opacity
          canvas-set-fill-rule canvas-set-operator canvas-set-opacity
          ;; PV6: arc helpers + draw-image
          canvas-arc canvas-arc-to canvas-round-rect canvas-draw-image)

;; -------------------------------------------------------------------------
;; Private: result type helpers (layout matches stdlib/result.tur)
;; -------------------------------------------------------------------------

;;; __ok -- create an ok result wrapping integer value v.
(defn __ok [v : int] : ptr<void>
  ```c
  #include <stdlib.h>
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  r->is_ok = true; r->ok_val = v; r->err_val = 0; return r;
  ```)

;;; __err -- create an err result wrapping integer error value e.
(defn __err [e : int] : ptr<void>
  ```c
  #include <stdlib.h>
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  r->is_ok = false; r->ok_val = 0; r->err_val = e; return r;
  ```)

;; -------------------------------------------------------------------------
;; Public API
;; -------------------------------------------------------------------------

;;; canvas-create -- allocate a drawing context that writes into surface s.
;;;
;;; Parameters:
;;;   s -- surface handle (ok-val from surface-create)
;;;
;;; Returns:
;;;   (ok handle) on success; (err 0) on failure.
;;;   Free with canvas-destroy when done.  The surface must outlive the
;;;   canvas.
;;;
;;; Example:
;;;   (let [r (canvas-create s)]
;;;     (if (ok? r) (let [c (ok-val r)] ...) (println "create failed")))
;;;
;;; Since: PV0
(defn canvas-create [s : int] : ptr<void>
  ```c
  #include <stdlib.h>
  #include <plutovg.h>
  plutovg_canvas_t *c = plutovg_canvas_create((plutovg_surface_t *)(intptr_t)s);
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  if (!c) { r->is_ok = false; r->ok_val = 0; r->err_val = 0; return r; }
  r->is_ok = true; r->ok_val = (int64_t)(intptr_t)c; r->err_val = 0;
  return r;
  ```)

;;; canvas-destroy -- release a canvas allocated by canvas-create.
;;;
;;; Parameters:
;;;   c -- canvas handle (ok-val from canvas-create)
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-destroy c)
;;;
;;; Since: PV0
(defn canvas-destroy [c : int] : void
  ```c
  #include <plutovg.h>
  if (c) plutovg_canvas_destroy((plutovg_canvas_t *)(intptr_t)c);
  ```)

;;; canvas-set-source-color -- set the current paint to a solid RGBA color.
;;;
;;; Parameters:
;;;   c -- canvas handle
;;;   r -- red   in [0.0, 1.0]
;;;   g -- green in [0.0, 1.0]
;;;   b -- blue  in [0.0, 1.0]
;;;   a -- alpha in [0.0, 1.0]
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-set-source-color c 1.0 0.0 0.0 1.0)  ; opaque red
;;;
;;; Since: PV0
(defn canvas-set-source-color [c : int r : float g : float b : float a : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)c,
                          (float)r, (float)g, (float)b, (float)a);
  ```)

;;; canvas-fill-rect -- fill an axis-aligned rectangle with the current paint.
;;;
;;; Parameters:
;;;   c -- canvas handle
;;;   x -- top-left x in surface space
;;;   y -- top-left y in surface space
;;;   w -- width in pixels
;;;   h -- height in pixels
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-fill-rect c 10.0 10.0 100.0 50.0)
;;;
;;; Since: PV0
(defn canvas-fill-rect [c : int x : float y : float w : float h : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_fill_rect((plutovg_canvas_t *)(intptr_t)c,
                           (float)x, (float)y, (float)w, (float)h);
  ```)

;; -------------------------------------------------------------------------
;; PV1: Path recording
;; -------------------------------------------------------------------------

;;; canvas-move-to -- start a new subpath at (x, y).
;;;
;;; Parameters:
;;;   c -- canvas handle
;;;   x -- destination x in surface space
;;;   y -- destination y in surface space
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-move-to c 10.0 10.0)
;;;
;;; Since: PV1
(defn canvas-move-to [c : int x : float y : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)c,
                         (float)x, (float)y);
  ```)

;;; canvas-line-to -- append a straight line from the current point to (x, y).
;;;
;;; Parameters:
;;;   c -- canvas handle
;;;   x -- destination x
;;;   y -- destination y
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-line-to c 100.0 10.0)
;;;
;;; Since: PV1
(defn canvas-line-to [c : int x : float y : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)c,
                         (float)x, (float)y);
  ```)

;;; canvas-quad-to -- append a quadratic Bezier from the current point to (x, y) via control (x1, y1).
;;;
;;; Parameters:
;;;   c  -- canvas handle
;;;   x1 -- control point x
;;;   y1 -- control point y
;;;   x  -- destination x
;;;   y  -- destination y
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-quad-to c 50.0 0.0 100.0 50.0)
;;;
;;; Since: PV1
(defn canvas-quad-to [c : int x1 : float y1 : float x : float y : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_quad_to((plutovg_canvas_t *)(intptr_t)c,
                         (float)x1, (float)y1, (float)x, (float)y);
  ```)

;;; canvas-cubic-to -- append a cubic Bezier from the current point.
;;;
;;; Parameters:
;;;   c  -- canvas handle
;;;   x1 -- first control point x
;;;   y1 -- first control point y
;;;   x2 -- second control point x
;;;   y2 -- second control point y
;;;   x  -- destination x
;;;   y  -- destination y
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-cubic-to c 25.0 0.0 75.0 0.0 100.0 50.0)
;;;
;;; Since: PV1
(defn canvas-cubic-to [c : int x1 : float y1 : float x2 : float y2 : float
                       x : float y : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_cubic_to((plutovg_canvas_t *)(intptr_t)c,
                          (float)x1, (float)y1,
                          (float)x2, (float)y2,
                          (float)x,  (float)y);
  ```)

;;; canvas-close-path -- close the current subpath with a straight line to its origin.
;;;
;;; Parameters:
;;;   c -- canvas handle
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-close-path c)
;;;
;;; Since: PV1
(defn canvas-close-path [c : int] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_close_path((plutovg_canvas_t *)(intptr_t)c);
  ```)

