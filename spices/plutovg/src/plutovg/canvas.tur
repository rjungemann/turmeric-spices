                         (float)cx, (float)cy, (float)rx, (float)ry);
  ```)

;;; canvas-circle -- append a circle subpath (convenience for canvas-ellipse with rx == ry).
;;;
;;; Parameters:
;;;   c  -- canvas handle
;;;   cx -- center x
;;;   cy -- center y
;;;   r  -- radius
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-circle c 50.0 50.0 25.0)
;;;
;;; Since: PV1
(defn canvas-circle [c : int cx : float cy : float r : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_circle((plutovg_canvas_t *)(intptr_t)c,
                        (float)cx, (float)cy, (float)r);
  ```)

