;;;
;;; Parameters:
;;;   c -- canvas handle
;;;   x -- top-left x
;;;   y -- top-left y
;;;   w -- width in pixels
;;;   h -- height in pixels
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-rect c 0.0 0.0 100.0 50.0)
;;;
;;; Since: PV1
(defn canvas-rect [c : int x : float y : float w : float h : float] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_rect((plutovg_canvas_t *)(intptr_t)c,
                      (float)x, (float)y, (float)w, (float)h);
  ```)

;;; canvas-ellipse -- append an axis-aligned ellipse subpath.
;;;
;;; Parameters:
;;;   c  -- canvas handle
;;;   cx -- center x
;;;   cy -- center y
;;;   rx -- horizontal radius
;;;   ry -- vertical radius
;;;
;;; Returns:
;;;   void
;;;
;;; Example:
;;;   (canvas-ellipse c 50.0 50.0 30.0 20.0)
;;;
;;; Since: PV1
(defn canvas-ellipse [c : int cx : float cy : float rx : float ry : float] : void
  ```c
  #include <plutovg.h>
