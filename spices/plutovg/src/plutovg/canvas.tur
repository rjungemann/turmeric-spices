;;;
;;; Example:
;;;   (canvas-rect c 0.0 0.0 100.0 50.0)
;;;   (canvas-stroke c)
;;;
;;; Since: PV1
(defn canvas-stroke [c : int] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)c);
