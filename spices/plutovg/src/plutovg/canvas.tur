;;;
;;; Since: PV1
(defn canvas-fill [c : int] : void
  ```c
  #include <plutovg.h>
  plutovg_canvas_fill((plutovg_canvas_t *)(intptr_t)c);
  ```)

;;; canvas-stroke -- stroke the current path with the current paint, then clear the path.
;;;
;;; Parameters:
