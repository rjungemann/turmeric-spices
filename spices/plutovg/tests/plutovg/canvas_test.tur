;; tests/plutovg/canvas_test.tur -- PV0 smoke test for plutovg/canvas.
;;
;; Creates a 4x4 surface, fills the whole surface with opaque red, then
;; reads the bytes of pixel (0,0) from the surface buffer and verifies them.
;; plutovg stores pixels as 32-bit premultiplied ARGB (0xAARRGGBB); on a
;; little-endian host the in-memory byte order is B, G, R, A.

(defmodule plutovg/tests/canvas
  ;; ok? / ok-val are auto-loaded stdlib globals; no explicit import needed.
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-ok])
  (import test/runner     :refer [run-all])
  (import plutovg/surface :refer [surface-create surface-destroy])
  (import plutovg/canvas  :refer [canvas-create canvas-destroy
                                  canvas-set-source-color canvas-fill-rect])

  ;; Read byte at offset n from a plutovg surface's pixel buffer.  Inlining
  ;; the C plutovg_surface_get_data call here avoids relying on cross-module
  ;; return-type propagation through :exports.
  (defn surface-byte [s :int n :int] :int
    ```c
    #include <plutovg.h>
    unsigned char *p = plutovg_surface_get_data((plutovg_surface_t *)(intptr_t)s);
    return (int64_t)p[(int)n];
    ```)

  (describe "plutovg/canvas"
    (it "fills a rect with a solid color into the surface buffer"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s  (ok-val sr)
              cr (canvas-create s)]
          (assert-ok cr)
          (let [c (ok-val cr)]
            (canvas-set-source-color c 1.0 0.0 0.0 1.0)
            (canvas-fill-rect c 0.0 0.0 4.0 4.0)
            ;; little-endian 0xFFFF0000 -> bytes 0x00 0x00 0xFF 0xFF
            (assert-eq 0   (surface-byte s 0))   ; B
            (assert-eq 0   (surface-byte s 1))   ; G
            (assert-eq 255 (surface-byte s 2))   ; R
            (assert-eq 255 (surface-byte s 3))   ; A
            (canvas-destroy c))
          (surface-destroy s)))))

  (defn main [] :int
    (run-all)
    0))
