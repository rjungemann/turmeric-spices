;; tests/plutovg/swap_reject_test.tur -- compile-time swap-rejection probes for
;; the secondary opaque handle types (DashArray, FontCache, GradientStops, Rect).
;;
;; This file is a NEGATIVE fixture: every defn below is wrong on purpose,
;; passing a handle of one nominal type where another is expected. Running
;; `tur check tests/plutovg/swap_reject_test.tur` MUST produce TUR-E0001
;; mismatches at the marked sites. To use as a positive smoke test, comment
;; out the bodies.
;;
;; If any of these typecheck cleanly, the S2 audit's "secondary handle leaks"
;; have regressed.

(defmodule plutovg/tests/swap-reject
  (import plutovg/types  :refer [Canvas DashArray GradientStops FontCache Rect])
  (import plutovg/canvas :refer [canvas-set-dash-array dash-array-add])
  (import plutovg/paint  :refer [gradient-stops-add gradient-stops-count])
  (import plutovg/path   :refer [rect-x rect-w])
  (import plutovg/font   :refer [font-cache-destroy])

  ;; DashArray vs GradientStops: same int payload, distinct types.
  (defn bad-dashes-as-stops [d : DashArray] : int
    (gradient-stops-count d))            ; expects GradientStops, not DashArray

  ;; GradientStops vs DashArray: dash-array-add expects DashArray.
  (defn bad-stops-as-dashes [s : GradientStops] : void
    (dash-array-add s 1.0))              ; expects DashArray, not GradientStops

  ;; Rect vs DashArray: rect-x is a Rect accessor.
  (defn bad-dashes-as-rect [d : DashArray] : float
    (rect-x d))                          ; expects Rect, not DashArray

  ;; FontCache vs Rect: font-cache-destroy expects FontCache.
  (defn bad-rect-as-fc [r : Rect] : void
    (font-cache-destroy r))              ; expects FontCache, not Rect

  ;; Canvas vs DashArray on canvas-set-dash-array: swap positions.
  (defn bad-swap-canvas-and-dashes [c : Canvas d : DashArray] : void
    (canvas-set-dash-array d c))         ; both args swapped

  (defn main [] : int 0))
