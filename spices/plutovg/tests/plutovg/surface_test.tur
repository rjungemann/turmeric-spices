;; tests/plutovg/surface_test.tur -- PV0 tests for plutovg/surface.

(defmodule plutovg/tests/surface
  ;; ok? / ok-val are auto-loaded stdlib globals; no explicit import needed.
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-true assert-ok])
  (import test/runner     :refer [run-all])
  (import plutovg/surface :refer [surface-create surface-destroy
                                  surface-width surface-height surface-stride])

  (describe "plutovg/surface"
    (it "creates a surface with the requested dimensions"
      (let [r (surface-create 64 32)]
        (assert-ok r)
        (let [s (ok-val r)]
          (assert-eq 64 (surface-width  s))
          (assert-eq 32 (surface-height s))
          ;; plutovg surfaces are 32-bit ARGB; stride = width * 4
          (assert-eq 256 (surface-stride s))
          (surface-destroy s)))))

  (defn main [] :int
    (run-all)
    0))
