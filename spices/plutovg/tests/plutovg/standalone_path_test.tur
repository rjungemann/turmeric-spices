;; tests/plutovg/standalone_path_test.tur -- PV2 tests for plutovg/path.
;;
;; Builds a standalone path, queries its bounding box and length, parses
;; SVG path-data into a second path, clones-and-flattens a curve, and
;; renders both via canvas-fill-path on an 8x8 surface.

(defmodule plutovg/tests/standalone-path
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-ok assert-true])
  (import test/runner     :refer [run-all])
  (import plutovg/surface :refer [surface-create surface-destroy])
  (import plutovg/canvas  :refer [canvas-create canvas-destroy
                                  canvas-set-source-color
                                  canvas-fill-path canvas-stroke-path
                                  canvas-add-path canvas-fill])
  (import plutovg/path    :refer [path-create path-destroy
                                  path-add-rect path-add-circle
                                  path-add-round-rect
                                  path-move-to path-line-to path-close
                                  path-quad-to path-cubic-to
                                  path-clone path-clone-flatten
                                  path-extents path-length path-parse
                                  rect-destroy rect-x rect-y rect-w rect-h])

  ;; Convenience: read byte at offset n from a plutovg surface buffer.
  (defn surface-byte [s :int n :int] :int
    ```c
    #include <plutovg.h>
    unsigned char *p = plutovg_surface_get_data((plutovg_surface_t *)(intptr_t)s);
    return (int64_t)p[(int)n];
    ```)

  ;; Local float-equality helper (no stdlib epsilon in scope).
  (defn fapprox [a :float b :float] :bool
    ```c
    double d = (double)a - (double)b;
    if (d < 0) d = -d;
    return d < 0.001;
    ```)

  (describe "plutovg/path construction + extents"
    (it "computes the bounding box of an axis-aligned rect path"
      (let [r (path-create)]
        (assert-ok r)
        (let [p (ok-val r)]
          (path-add-rect p 2.0 3.0 4.0 5.0)
          (let [er (path-extents p)]
            (assert-ok er)
            (let [box (ok-val er)]
              (assert-true (fapprox (rect-x box) 2.0))
              (assert-true (fapprox (rect-y box) 3.0))
              (assert-true (fapprox (rect-w box) 4.0))
              (assert-true (fapprox (rect-h box) 5.0))
              (rect-destroy box)))
          (path-destroy p)))))

  (describe "plutovg/path length"
    (it "measures the perimeter of a triangle (3-4-5 right triangle)"
      (let [r (path-create)]
        (assert-ok r)
        (let [p (ok-val r)]
          (path-move-to p 0.0 0.0)
          (path-line-to p 3.0 0.0)
          (path-line-to p 3.0 4.0)
          (path-close p)
          ;; perimeter = 3 + 4 + 5 = 12
          (assert-true (fapprox (path-length p) 12.0))
          (path-destroy p)))))

  (describe "plutovg/path SVG parsing"
    (it "parses 'M 0 0 H 4 V 4 Z' into a closed unit square"
      (let [r (path-create)]
        (assert-ok r)
        (let [p (ok-val r)]
          (assert-ok (path-parse p "M 0 0 H 4 V 4 Z"))
          (assert-true (fapprox (path-length p) 12.0))
          (path-destroy p)))))

  (describe "plutovg/path clone-flatten"
    (it "approximates a quadratic curve with line segments and keeps a sensible length"
      (let [r (path-create)]
        (assert-ok r)
        (let [p (ok-val r)]
          (path-move-to p 0.0 0.0)
          (path-quad-to p 5.0 0.0 5.0 5.0)
          ;; length of the curve from (0,0) -> (5,0) -> (5,5) via the
          ;; control point is bounded between the chord (~7.07) and the
          ;; control-net (5 + 5 = 10).
          (let [lc (path-length p)]
            (assert-true (>f lc 7.0))
            (assert-true (<f lc 10.5)))
          (let [fr (path-clone-flatten p)]
            (assert-ok fr)
            (let [flat (ok-val fr)]
              ;; The flattened path approximates the same arc; its length
              ;; should be very close to the original within rounding.
              (let [lf (path-length flat)
                    lc (path-length p)]
                (assert-true (<f (fabs-diff lf lc) 0.5)))
              (path-destroy flat)))
          (path-destroy p)))))

  (describe "plutovg/canvas + path bridge"
    (it "fills a standalone path via canvas-fill-path"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (ok-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (ok-val cr)
                pr (path-create)]
            (assert-ok pr)
            (let [path (ok-val pr)]
              (path-add-rect path 0.0 0.0 4.0 4.0)
              (canvas-set-source-color c 1.0 0.0 0.0 1.0)
              (canvas-fill-path c path)
              ;; pixel (0,0) should be opaque red (B G R A = 0 0 255 255)
              (assert-eq 0   (surface-byte s 0))
              (assert-eq 0   (surface-byte s 1))
              (assert-eq 255 (surface-byte s 2))
              (assert-eq 255 (surface-byte s 3))
              (path-destroy path)))
          (canvas-destroy (ok-val cr))
          (surface-destroy s)))))

  ;; Local float helpers (avoid pulling in stdlib comparisons).
  (defn >f [a :float b :float] :bool
    ```c
    return (double)a > (double)b;
    ```)
  (defn <f [a :float b :float] :bool
    ```c
    return (double)a < (double)b;
    ```)
  (defn fabs-diff [a :float b :float] :float
    ```c
    double d = (double)a - (double)b;
    return d < 0 ? -d : d;
    ```)

  (defn main [] :int
    (run-all)
    0))
