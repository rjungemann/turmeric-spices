;; tests/plutovg/export_test.tur -- PV6 tests for surface export,
;; canvas-draw-image, the arc helpers, and path-clone-dashed.

(defmodule plutovg/tests/export
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-ok])
  (import test/runner     :refer [run-all])
  (import plutovg/surface :refer [surface-create surface-destroy
                                  surface-write-png surface-write-jpeg
                                  surface-width surface-height])
  (import plutovg/canvas  :refer [canvas-create canvas-destroy
                                  canvas-set-source-color
                                  canvas-rect canvas-fill
                                  canvas-arc canvas-arc-to canvas-round-rect
                                  canvas-draw-image
                                  dash-array-create dash-array-add
                                  dash-array-destroy])
  (import plutovg/path    :refer [path-create path-destroy
                                  path-move-to path-line-to path-close
                                  path-clone-dashed path-length])

  (defn surface-byte [s :int n :int] :int
    ```c
    #include <plutovg.h>
    unsigned char *p = plutovg_surface_get_data((plutovg_surface_t *)(intptr_t)s);
    return (int64_t)p[(int)n];
    ```)

  (defn file-exists? [path :cstr] :bool
    ```c
    #include <unistd.h>
    return access((const char *)(intptr_t)path, F_OK) == 0;
    ```)

  (defn file-size [path :cstr] :int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn unlink-file [path :cstr] :void
    ```c
    #include <unistd.h>
    unlink((const char *)(intptr_t)path);
    ```)

  (describe "plutovg/surface PNG export"
    (it "writes a 4x4 red square to a PNG on disk and the file is non-empty"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (ok-val sr) cr (canvas-create s)
              out "/tmp/plutovg-pv6-test.png"]
          (assert-ok cr)
          (unlink-file out) ; clean any stale file
          (let [c (ok-val cr)]
            (canvas-set-source-color c 1.0 0.0 0.0 1.0)
            (canvas-rect c 0.0 0.0 4.0 4.0)
            (canvas-fill c)
            (canvas-destroy c))
          (let [wr (surface-write-png s out)]
            (assert-ok wr)
            (assert-eq true (file-exists? out))
            ;; PNG header is 8 bytes, a 4x4 RGBA PNG is typically >50 bytes
            (assert-eq true (>i (file-size out) 50)))
          (unlink-file out)
          (surface-destroy s)))))

  (describe "plutovg/surface JPEG export"
    (it "writes a 4x4 surface to a JPEG and the file is non-empty"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (ok-val sr) out "/tmp/plutovg-pv6-test.jpg"]
          (unlink-file out)
          (let [wr (surface-write-jpeg s out 90)]
            (assert-ok wr)
            (assert-eq true (file-exists? out))
            ;; A minimal JPEG (SOI + headers + EOI) is several hundred bytes
            (assert-eq true (>i (file-size out) 200)))
          (unlink-file out)
          (surface-destroy s)))))

  (describe "plutovg/canvas arc helpers"
    (it "canvas-arc + canvas-arc-to + canvas-round-rect compile and run"
      ;; Smoke check only -- ensures the inline-C bodies link against
      ;; plutovg_canvas_arc / arc_to / round_rect and don't crash.
      (let [sr (surface-create 8 8)]
        (assert-ok sr)
        (let [s (ok-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (ok-val cr)]
            (canvas-set-source-color c 0.0 1.0 0.0 1.0)
            (canvas-arc c 4.0 4.0 3.0 0.0 6.2831)  ; ~ full circle
            (canvas-fill c)
            (canvas-round-rect c 0.0 0.0 8.0 8.0 2.0 2.0)
            (canvas-arc-to c 2.0 2.0 0.0 false true 8.0 8.0)
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas draw-image"
    (it "blits a source surface into a destination surface"
      ;; Source: 2x2 solid blue square.  Destination: 8x8 surface.
      ;; After canvas-draw-image c src 0 0 8 8 the top-left of dst should
      ;; contain blue (texture stretches to the destination rect).
      (let [src-r (surface-create 2 2) dst-r (surface-create 8 8)]
        (assert-ok src-r)
        (assert-ok dst-r)
        (let [src (ok-val src-r) dst (ok-val dst-r)]
          ;; paint src blue
          (let [src-cr (canvas-create src)]
            (assert-ok src-cr)
            (let [c (ok-val src-cr)]
              (canvas-set-source-color c 0.0 0.0 1.0 1.0)
              (canvas-rect c 0.0 0.0 2.0 2.0)
              (canvas-fill c)
              (canvas-destroy c)))
          ;; draw src into dst
          (let [dst-cr (canvas-create dst)]
            (assert-ok dst-cr)
            (let [c (ok-val dst-cr)]
              (canvas-draw-image c src 0.0 0.0 8.0 8.0)
              (canvas-destroy c)))
          ;; dst pixel (0, 0) should be blue: 0xFF0000FF -> B G R A
          (assert-eq 255 (surface-byte dst 0))  ; B
          (assert-eq 0   (surface-byte dst 1))  ; G
          (assert-eq 0   (surface-byte dst 2))  ; R
          (assert-eq 255 (surface-byte dst 3))  ; A
          (surface-destroy src)
          (surface-destroy dst)))))

  (describe "plutovg/path clone-dashed"
    (it "produces a non-empty cloned path whose length is positive"
      (let [pr (path-create)]
        (assert-ok pr)
        (let [p (ok-val pr) dr (dash-array-create)]
          (assert-ok dr)
          (let [dashes (ok-val dr)]
            ;; original path: a single horizontal line of length 10
            (path-move-to p 0.0 0.0)
            (path-line-to p 10.0 0.0)
            (dash-array-add dashes 2.0)   ; 2 on
            (dash-array-add dashes 1.0)   ; 1 off
            (let [r (path-clone-dashed p 0.0 dashes)]
              (assert-ok r)
              (let [dashed (ok-val r)]
                ;; A 10-unit line dashed 2-on/1-off produces multiple
                ;; "on" segments totalling roughly 7 units; the dashed
                ;; path's length should be positive and < the original.
                (let [lc (path-length p) ld (path-length dashed)]
                  (assert-eq true (>f ld 0.0))
                  (assert-eq true (<=f ld lc)))
                (path-destroy dashed)))
            (dash-array-destroy dashes))
          (path-destroy p)))))

  (defn >i  [a :int b :int] :bool   ```c return (int)a > (int)b; ```)
  (defn >f  [a :float b :float] :bool ```c return (double)a > (double)b; ```)
  (defn <=f [a :float b :float] :bool ```c return (double)a <= (double)b; ```)

  (defn main [] :int
    (run-all)
    0))
