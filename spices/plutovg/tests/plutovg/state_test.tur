;; tests/plutovg/state_test.tur -- PV4 tests for canvas state, transforms,
;; stroke properties, dash, fill rule, operator, and opacity.

(defmodule plutovg/tests/state
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-ok result-val])
  (import test/runner     :refer [run-all])
  (import plutovg/surface :refer [surface-create surface-destroy])
  (import plutovg/canvas  :refer [canvas-create canvas-destroy
                                  canvas-set-source-color
                                  canvas-rect canvas-fill canvas-stroke
                                  canvas-save canvas-restore
                                  canvas-translate canvas-scale canvas-rotate
                                  canvas-transform canvas-reset-transform
                                  canvas-set-line-width canvas-set-line-cap
                                  canvas-set-line-join canvas-set-miter-limit
                                  canvas-set-dash-offset canvas-set-dash-array
                                  dash-array-create dash-array-add
                                  dash-array-destroy dash-array-count
                                  canvas-set-fill-rule canvas-set-operator
                                  canvas-set-opacity])

  (defn surface-byte [s : int n : int] : int
    ```c
    #include <plutovg.h>
    unsigned char *p = plutovg_surface_get_data((plutovg_surface_t *)(intptr_t)s);
    return (int64_t)p[(int)n];
    ```)

  ;; Render a single 1x1 red pixel at the canvas's current origin.
  (defn fill-origin-red [c : int] : void
    (canvas-set-source-color c 1.0 0.0 0.0 1.0)
    (canvas-rect c 0.0 0.0 1.0 1.0)
    (canvas-fill c))

  (describe "plutovg/canvas transforms"
    (it "translates the origin so a 1x1 fill lands at (2, 1)"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (result-val cr)]
            (canvas-translate c 2.0 1.0)
            (fill-origin-red c)
            ;; Pixel (2, 1) = byte offset (1*16) + (2*4) = 24..27 (B G R A)
            (assert-eq 0   (surface-byte s 24))
            (assert-eq 0   (surface-byte s 25))
            (assert-eq 255 (surface-byte s 26))
            (assert-eq 255 (surface-byte s 27))
            ;; Pixel (0, 0) should be untouched (transparent)
            (assert-eq 0 (surface-byte s 0))
            (assert-eq 0 (surface-byte s 3))
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas state stack"
    (it "save/restore isolates a translate"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (result-val cr)]
            (canvas-save c)
            (canvas-translate c 3.0 0.0)
            (fill-origin-red c)
            (canvas-restore c)
            ;; After restore, translate is undone -- fill at (0, 0)
            (fill-origin-red c)
            ;; Pixel (3, 0) red, (0, 0) red
            (assert-eq 255 (surface-byte s 14))  ; (3,0) R byte
            (assert-eq 255 (surface-byte s 2))   ; (0,0) R byte
            ;; Pixel (1, 0) untouched
            (assert-eq 0   (surface-byte s 6))
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas reset-transform"
    (it "discards accumulated translate / scale"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (result-val cr)]
            (canvas-translate c 2.0 2.0)
            (canvas-scale c 2.0 2.0)
            (canvas-reset-transform c)
            (fill-origin-red c)
            ;; Pixel (0, 0) red
            (assert-eq 255 (surface-byte s 2))
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas opacity"
    (it "scales the alpha of subsequent fills"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (result-val cr)]
            (canvas-set-opacity c 0.5)
            (canvas-set-source-color c 1.0 0.0 0.0 1.0)
            (canvas-rect c 0.0 0.0 1.0 1.0)
            (canvas-fill c)
            ;; Output alpha at pixel (0,0) should be ~127 (premultiplied);
            ;; allow a small tolerance for rounding.
            (let [a (surface-byte s 3)]
              ;; 110..145 covers any rounding mode
              (assert-eq true (>i a 110))
              (assert-eq true (<i a 145)))
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas dash array"
    (it "accepts a dash buffer and applies it to a stroke (smoke check)"
      (let [sr (surface-create 8 1)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)
              dr (dash-array-create)]
          (assert-ok cr)
          (assert-ok dr)
          (let [c (result-val cr) dashes (result-val dr)]
            (dash-array-add dashes 2.0)  ; 2 on
            (dash-array-add dashes 2.0)  ; 2 off
            (assert-eq 2 (dash-array-count dashes))
            (canvas-set-source-color c 0.0 1.0 0.0 1.0)
            (canvas-set-line-width c 1.0)
            (canvas-set-line-cap c ":butt")
            (canvas-set-line-join c ":miter")
            (canvas-set-miter-limit c 4.0)
            (canvas-set-dash-array c dashes)
            (canvas-set-dash-offset c 0.0)
            (canvas-rect c 0.0 0.0 8.0 1.0)
            (canvas-stroke c)
            ;; Smoke: at least one pixel along the stroked rect should be
            ;; non-zero on the green channel.
            (let [any (+i (surface-byte s 1)
                          (+i (surface-byte s 5)
                              (surface-byte s 9)))]
              (assert-eq true (>i any 0)))
            (dash-array-destroy dashes)
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas fill rule"
    (it "accepts :non-zero and :even-odd keyword values"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (result-val cr)]
            (canvas-set-fill-rule c ":non-zero")
            (canvas-set-fill-rule c ":even-odd")
            (canvas-destroy c))
          (surface-destroy s)))))

  (describe "plutovg/canvas operator"
    (it "accepts the documented Porter-Duff keywords"
      (let [sr (surface-create 4 4)]
        (assert-ok sr)
        (let [s (result-val sr) cr (canvas-create s)]
          (assert-ok cr)
          (let [c (result-val cr)]
            (canvas-set-operator c ":src-over")
            (canvas-set-operator c ":src-in")
            (canvas-set-operator c ":dst-out")
            (canvas-set-operator c ":xor")
            (canvas-destroy c))
          (surface-destroy s)))))

  (defn >i [a : int b : int] : bool
    ```c
    return (int)a > (int)b;
    ```)
  (defn <i [a : int b : int] : bool
    ```c
    return (int)a < (int)b;
    ```)
  (defn +i [a : int b : int] : int
    ```c
    return (int64_t)((int)a + (int)b);
    ```)

  (defn main [] : int
    (run-all)
    0))
