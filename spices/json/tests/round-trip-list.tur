;; U2 container instances: Encode [Cons] + decode-list round-trip through arrays.
;;
;; Parses a JSON array, decodes it to a (Cons A) via decode-list, then re-encodes:
;;   [1,2,3]     -> (Cons int)   -> [1,2,3]
;;   []          -> (Cons int)   -> []
;;   ["a","b"]   -> (Cons cstr)  -> ["a","b"]
;;   [1.5,2.5]   -> (Cons float) -> [1.5,2.5]
;;
;; decode-list returns (Cons A) directly (pinned by a (Cons T) ascription);
;; encode is pinned with @Cons. `check` gates `tur test` on real behavior via
;; an inline-C fail counter.

(defmodule round_trip_list_test (export)

(import json/encode :refer [decode-list])
(import json/decode :refer [json-parse-doc json-doc-free json-doc-root])

(defn check [idx : int  name : cstr  got : cstr  want : cstr] : void
  ```c
  /* __tur_include__: static int g_rtl_fails = 0; */
  int ok = got && want && !strcmp((const char *)got, (const char *)want);
  if (!ok) g_rtl_fails++;
  printf("%s %lld - %s (got %s, want %s)\n", ok ? "ok" : "not ok",
         (long long)idx, (const char *)name,
         got ? (const char *)got : "(null)", (const char *)want);
  ```)

(defn finish [count : int] : int
  ```c
  printf("1..%lld\n", (long long)count);
  if (g_rtl_fails == 0) { fprintf(stderr, "# All %lld list round-trip tests passed.\n", (long long)count); return 0; }
  fprintf(stderr, "# %d/%lld list round-trip tests failed.\n", g_rtl_fails, (long long)count);
  return 1;
  ```)

(defn rt-int [s : cstr] : cstr
  (let [doc (unsafe (json-parse-doc s)) root (unsafe (json-doc-root doc))
        xs  (:: (decode-list doc root) (Cons int))
        out (encode @Cons (:: xs (Cons int)))]
    (unsafe (json-doc-free doc)) out))

(defn rt-float [s : cstr] : cstr
  (let [doc (unsafe (json-parse-doc s)) root (unsafe (json-doc-root doc))
        xs  (:: (decode-list doc root) (Cons float))
        out (encode @Cons (:: xs (Cons float)))]
    (unsafe (json-doc-free doc)) out))

(defn rt-cstr [s : cstr] : cstr
  (let [doc (unsafe (json-parse-doc s)) root (unsafe (json-doc-root doc))
        xs  (:: (decode-list doc root) (Cons cstr))
        out (encode @Cons (:: xs (Cons cstr)))]
    (unsafe (json-doc-free doc)) out))

(defn main [] : int
  (check 1 "int array"   (rt-int   "[1,2,3]")       "[1,2,3]")
  (check 2 "empty array" (rt-int   "[]")            "[]")
  (check 3 "cstr array"  (rt-cstr  "[\"a\",\"b\"]") "[\"a\",\"b\"]")
  (check 4 "float array" (rt-float "[1.5,2.5]")     "[1.5,2.5]")
  (finish 4)))
