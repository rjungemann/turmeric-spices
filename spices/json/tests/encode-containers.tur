;; Encode instances for containers: (Vec a) -> JSON array, (Option a) -> value
;; or null. Each element dispatches via its own Encode instance (incl. arrays
;; of derive-json structs -- arrays of objects).
;;
;; Expected:
;;   [1,2,3]
;;   ["a","b"]
;;   [true,false]
;;   [1.5,2.25]
;;   []
;;   7
;;   null
;;   [{"v":10},{"v":20}]

(defmodule encode_containers_test (export)
(import json/encode :refer [derive-json])

(defstruct P :heap [v : int])
(derive-json P (v int))

(defn main [] : int
  (do
    (let [v (:: (vec-new) (Vec int))]
      (vec-push! v 1) (vec-push! v 2) (vec-push! v 3)
      (println (encode v)))
    (let [v (:: (vec-new) (Vec cstr))]
      (vec-push! v "a") (vec-push! v "b")
      (println (encode v)))
    (let [v (:: (vec-new) (Vec bool))]
      (vec-push! v true) (vec-push! v false)
      (println (encode v)))
    (let [v (:: (vec-new) (Vec float))]
      (vec-push! v 1.5) (vec-push! v 2.25)
      (println (encode v)))
    (let [v (:: (vec-new) (Vec int))]
      (println (encode v)))
    (println (encode (:: (some 7) (Option int))))
    (println (encode (:: (none) (Option int))))
    (let [v (:: (vec-new) (Vec P))]
      (vec-push! v (make-struct P 10)) (vec-push! v (make-struct P 20))
      (println (encode v)))
    0)))
