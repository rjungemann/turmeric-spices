;; P2a Decode smoke (minimal slice): scanner + primitive decoders work
;; against a flat JSON object. The typeclass surface is deferred -- see
;; docs/reported/typeclass-method-parameterized-result-carrier-mismatch.md
;; in the turmeric repo.
;;
;; Expected:
;;   42
;;   alice
;;   1

(defmodule decode_primitives_test (export)

(import json/decode
  :refer [json-parse-doc json-doc-free json-doc-root
          json-obj-get json-decode-int json-decode-cstr])

(defn __int->cstr [n : int] #{Unsafe} : cstr
  ```c char *b = (char*)malloc(24); snprintf(b, 24, "%lld", (long long)n); return b; ```)

(defn main [] : int
  (let [doc      (unsafe (json-parse-doc "{\"id\":42,\"name\":\"alice\",\"active\":true}"))
        root     (unsafe (json-doc-root doc))
        id-off   (unsafe (json-obj-get doc root "id"))
        name-off (unsafe (json-obj-get doc root "name"))
        act-off  (unsafe (json-obj-get doc root "active"))]
    (println (unsafe (__int->cstr (unsafe (json-decode-int doc id-off)))))
    (println (unsafe (json-decode-cstr doc name-off)))
    (println (unsafe (__int->cstr (unsafe (json-decode-int doc act-off)))))
    (unsafe (json-doc-free doc))
    0))
)
