;; P2a Decode typed surface: the Decode typeclass dispatches by ascription
;; on the call's return type. The Decode class lives in json/encode
;; (alongside derive-json) so we import that to bring `decode` into scope.
;;
;; The yyjson rewrite made type checks strict: a JSON boolean no longer
;; decodes through Decode [int] (it must go through Decode [bool]); a JSON
;; number no longer decodes through Decode [bool]. This test exercises each
;; primitive instance against the field type that actually matches.
;;
;; Expected:
;;   42
;;   alice
;;   1

(defmodule decode_primitives_test (export)

(import json/decode :refer [json-parse-doc json-doc-free json-doc-root json-obj-get])
(import json/encode)

(defn __int->cstr [n : int] #fx{Unsafe} : cstr
  ```c char *b = (char*)malloc(24); snprintf(b, 24, "%lld", (long long)n); return b; ```)

(defn main [] : int
  (let [doc      (unsafe (json-parse-doc "{\"id\":42,\"name\":\"alice\",\"active\":true}"))
        root     (unsafe (json-doc-root doc))
        id-off   (unsafe (json-obj-get doc root "id"))
        name-off (unsafe (json-obj-get doc root "name"))
        act-off  (unsafe (json-obj-get doc root "active"))]
    (println (unsafe (__int->cstr (ok-val (:: (decode doc id-off)   (Result int  cstr))))))
    (println           (ok-val (:: (decode doc name-off) (Result cstr cstr))))
    (if (ok-val (:: (decode doc act-off) (Result bool cstr)))
      (println "1")
      (println "0"))
    (unsafe (json-doc-free doc))
    0)))
