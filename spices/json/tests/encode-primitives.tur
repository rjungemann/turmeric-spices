;; P2a smoke: Encode primitive instances produce well-formed JSON fragments.
;; Expected output:
;;   42
;;   true
;;   "hello\nworld"

(defmodule encode_primitives_test (export)

(import json/encode)

(defn main [] : int
  (println (encode 42))
  (println (encode true))
  (println (encode "hello\nworld"))
  0))
