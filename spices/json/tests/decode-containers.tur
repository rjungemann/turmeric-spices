;; Decode [(Vec A)]: a JSON array decodes element-by-element via each element's
;; own Decode instance, threading the first error. Pairs with Encode [(Vec A)].
;;
;; Expected:
;;   3
;;   1
;;   3
;;   decode int: not an integer
;;   b
;;   decode Vec: not a JSON array
;;   [7,8]

(defmodule decode_containers_test (export)
(import json/encode :refer [derive-json])
(import json/decode :refer [json-parse-doc json-doc-free json-doc-root])

(defn main [] : int
  ;; [1,2,3] -> (Vec int)
  (let [d (unsafe (json-parse-doc "[1,2,3]"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Vec int) cstr))]
    (if (.is-ok r)
      (let [v (ok-val r)]
        (println (vec-len v))
        (println (:: (vec-get v 0) :int))
        (println (:: (vec-get v 2) :int)))
      (println "ERR"))
    (unsafe (json-doc-free d)))

  ;; element error short-circuits: [1,"x"] as (Vec int)
  (let [d (unsafe (json-parse-doc "[1,\"x\"]"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Vec int) cstr))]
    (if (.is-ok r) (println "unexpected-ok") (println (err-val r)))
    (unsafe (json-doc-free d)))

  ;; (Vec cstr)
  (let [d (unsafe (json-parse-doc "[\"a\",\"b\"]"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Vec cstr) cstr))]
    (if (.is-ok r) (println (:: (vec-get (ok-val r) 1) :cstr)) (println "ERR"))
    (unsafe (json-doc-free d)))

  ;; non-array input is an err
  (let [d (unsafe (json-parse-doc "5"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Vec int) cstr))]
    (if (.is-ok r) (println "unexpected-ok") (println (err-val r)))
    (unsafe (json-doc-free d)))

  ;; round-trip the encode side still works
  (let [v (:: (vec-new) (Vec int))]
    (vec-push! v 7) (vec-push! v 8)
    (println (encode v)))

  0))
