;; Verify 3-field defstruct compiles + runs with derive-json after closure
;; codegen fix.
;; Expected: {"id":7,"name":"alice","active":true}
(defmodule derive_encode_struct_test (export)
(import json/encode :refer [derive-json])
(defstruct User [id : int  name : cstr  active : bool])
(derive-json User (id int) (name cstr) (active bool))
(defn main [] : int
  (println (encode (make-struct User 7 "alice" true)))
  0))
