;; U2 container instances: Encode [Option].
;;
;; A present value encodes as its element's fragment; `none` encodes as JSON
;; null. The element is dispatched through its own (Encode A) instance, so the
;; same Encode [Option] serves int / cstr / float optionals -- letting a
;; derive-json struct carry optional fields. (The matching Decode [Option] is
;; deferred on a compiler nested-carrier gap; see json/encode.tur.)
;;
;; `check` records ok/not-ok against an inline-C fail counter; `finish` returns
;; non-zero if any check failed, so `tur test` gates on real behavior.

(defmodule encode_option_test (export)

(import json/encode)

(defn check [idx : int  name : cstr  got : cstr  want : cstr] : void
  ```c
  /* __tur_include__: static int g_eo_fails = 0; */
  int ok = got && want && !strcmp((const char *)got, (const char *)want);
  if (!ok) g_eo_fails++;
  printf("%s %lld - %s (got %s, want %s)\n", ok ? "ok" : "not ok",
         (long long)idx, (const char *)name,
         got ? (const char *)got : "(null)", (const char *)want);
  ```)

(defn finish [count : int] : int
  ```c
  printf("1..%lld\n", (long long)count);
  if (g_eo_fails == 0) { fprintf(stderr, "# All %lld encode-option tests passed.\n", (long long)count); return 0; }
  fprintf(stderr, "# %d/%lld encode-option tests failed.\n", g_eo_fails, (long long)count);
  return 1;
  ```)

(defn main [] : int
  (check 1 "some int"   (encode (:: (some 42)   (Option int)))  "42")
  (check 2 "none int"   (encode (:: (none)      (Option int)))  "null")
  (check 3 "some cstr"  (encode (:: (some "hi") (Option cstr))) "\"hi\"")
  (check 4 "none cstr"  (encode (:: (none)      (Option cstr))) "null")
  (check 5 "some float" (encode (:: (some 3.5)  (Option float))) "3.5")
  (check 6 "none float" (encode (:: (none)      (Option float))) "null")
  (finish 6)))
