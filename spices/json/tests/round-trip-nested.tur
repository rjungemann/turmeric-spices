;; U2 derive-json: nested struct composition. A derive-json'd struct whose
;; fields are themselves derive-json'd structs round-trips -- each field
;; dispatches to the nested type's own Encode/Decode instance.
;;   {"from":{"x":1,"y":2},"to":{"x":3,"y":4}} -> Line -> same JSON
;;
;; `check` gates `tur test` on real behavior via an inline-C fail counter.

(defmodule round_trip_nested_test (export)

(import json/encode :refer [derive-json])
(import json/decode :refer [json-parse-doc json-doc-free json-doc-root])

(defn check [idx : int  name : cstr  got : cstr  want : cstr] : void
  ```c
  /* __tur_include__: static int g_rtn_fails = 0; */
  int ok = got && want && !strcmp((const char *)got, (const char *)want);
  if (!ok) g_rtn_fails++;
  printf("%s %lld - %s (got %s, want %s)\n", ok ? "ok" : "not ok",
         (long long)idx, (const char *)name,
         got ? (const char *)got : "(null)", (const char *)want);
  ```)

(defn finish [count : int] : int
  ```c
  printf("1..%lld\n", (long long)count);
  if (g_rtn_fails == 0) { fprintf(stderr, "# All %lld nested-struct tests passed.\n", (long long)count); return 0; }
  fprintf(stderr, "# %d/%lld nested-struct tests failed.\n", g_rtn_fails, (long long)count);
  return 1;
  ```)

(defstruct Point [x : int  y : int])
(derive-json Point (x int) (y int))

(defstruct Line [from : Point  to : Point])
(derive-json Line (from Point) (to Point))

;; decode a Line out of JSON and re-encode it.
(defn rt-line [s : cstr] : cstr
  (let [doc (unsafe (json-parse-doc s)) root (unsafe (json-doc-root doc))
        l   (ok-val (:: (decode doc root) (Result Line cstr)))
        out (encode (:: l Line))]
    (unsafe (json-doc-free doc)) out))

;; decode just a Point to confirm the leaf type round-trips on its own too.
(defn rt-point [s : cstr] : cstr
  (let [doc (unsafe (json-parse-doc s)) root (unsafe (json-doc-root doc))
        p   (ok-val (:: (decode doc root) (Result Point cstr)))
        out (encode (:: p Point))]
    (unsafe (json-doc-free doc)) out))

(defn main [] : int
  (check 1 "leaf point"   (rt-point "{\"x\":5,\"y\":6}")
                          "{\"x\":5,\"y\":6}")
  (check 2 "nested line"  (rt-line "{\"from\":{\"x\":1,\"y\":2},\"to\":{\"x\":3,\"y\":4}}")
                          "{\"from\":{\"x\":1,\"y\":2},\"to\":{\"x\":3,\"y\":4}}")
  (finish 2)))
