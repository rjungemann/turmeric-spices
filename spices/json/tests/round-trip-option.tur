;; U2 container instances: Encode/Decode [Option] round-trip.
;;
;; Decodes optional fields out of {"a":42,"b":null,"s":"hi"} (plus a missing
;; key "c") as (Option int)/(Option cstr), then re-encodes:
;;   present int   -> (some 42)   -> "42"
;;   explicit null -> (none)      -> "null"
;;   missing key   -> (none)      -> "null"
;;   present cstr  -> (some "hi") -> "\"hi\""
;;
;; `check` records ok/not-ok against an inline-C fail counter; `finish` returns
;; non-zero if any check failed, so `tur test` gates on real behavior.

(defmodule round_trip_option_test (export)

(import json/encode)
(import json/decode :refer [json-parse-doc json-doc-free json-doc-root json-obj-get])

(defn check [idx : int  name : cstr  got : cstr  want : cstr] : void
  ```c
  /* __tur_include__: static int g_rto_fails = 0; */
  int ok = got && want && !strcmp((const char *)got, (const char *)want);
  if (!ok) g_rto_fails++;
  printf("%s %lld - %s (got %s, want %s)\n", ok ? "ok" : "not ok",
         (long long)idx, (const char *)name,
         got ? (const char *)got : "(null)", (const char *)want);
  ```)

(defn finish [count : int] : int
  ```c
  printf("1..%lld\n", (long long)count);
  if (g_rto_fails == 0) { fprintf(stderr, "# All %lld option round-trip tests passed.\n", (long long)count); return 0; }
  fprintf(stderr, "# %d/%lld option round-trip tests failed.\n", g_rto_fails, (long long)count);
  return 1;
  ```)

;; decode field `key` as (Option int) and re-encode.
(defn rt-int [doc : int  root : int  key : cstr] : cstr
  (let [opt (ok-val (:: (decode doc (unsafe (json-obj-get doc root key))) (Result (Option int) cstr)))]
    (encode (:: opt (Option int)))))

;; decode field `key` as (Option cstr) and re-encode.
(defn rt-cstr [doc : int  root : int  key : cstr] : cstr
  (let [opt (ok-val (:: (decode doc (unsafe (json-obj-get doc root key))) (Result (Option cstr) cstr)))]
    (encode (:: opt (Option cstr)))))

(defn main [] : int
  (let [doc  (unsafe (json-parse-doc "{\"a\":42,\"b\":null,\"s\":\"hi\"}"))
        root (unsafe (json-doc-root doc))]
    (check 1 "present int -> some"   (rt-int  doc root "a") "42")
    (check 2 "explicit null -> none" (rt-int  doc root "b") "null")
    (check 3 "missing key -> none"   (rt-int  doc root "c") "null")
    (check 4 "present cstr -> some"  (rt-cstr doc root "s") "\"hi\"")
    (unsafe (json-doc-free doc))
    (finish 4))))
