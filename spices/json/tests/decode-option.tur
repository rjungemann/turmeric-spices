;; Decode [(Option A)]: JSON null -> none, else decode A wrapped in some.
;; Plus nested containers (Vec of Option) round-tripping end-to-end, unblocked
;; by turmeric #492 (by-value-struct Result), #493 (nested element dispatch),
;; and #495 (by-value-struct element into a generic loop's (Vec A)).
;;
;; Expected:
;;   7
;;   none
;;   decode int: not an integer
;;   [5,null]
;;   2
;;   5
;;   none

(defmodule decode_option_test (export)
(import json/encode :refer [derive-json])
(import json/decode :refer [json-parse-doc json-doc-free json-doc-root])

(defn main [] : int
  ;; "7" -> some 7
  (let [d (unsafe (json-parse-doc "7"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Option int) cstr))]
    (if (.is-ok r)
      (if (.is-some (ok-val r)) (println (:: (.value (ok-val r)) :int)) (println "none"))
      (println "ERR"))
    (unsafe (json-doc-free d)))

  ;; "null" -> none
  (let [d (unsafe (json-parse-doc "null"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Option int) cstr))]
    (if (.is-ok r)
      (if (.is-some (ok-val r)) (println "some?!") (println "none"))
      (println "ERR"))
    (unsafe (json-doc-free d)))

  ;; bad inner value -> err threads out of the some branch
  (let [d (unsafe (json-parse-doc "\"x\""))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Option int) cstr))]
    (if (.is-ok r) (println "unexpected-ok") (println (err-val r)))
    (unsafe (json-doc-free d)))

  ;; nested encode: (Vec (Option int)) -> [5,null]
  (let [v (:: (vec-new) (Vec (Option int)))]
    (vec-push! v (:: (some 5) (Option int)))
    (vec-push! v (:: (none) (Option int)))
    (println (encode v)))

  ;; nested decode: [5,null] -> (Vec (Option int))
  (let [d (unsafe (json-parse-doc "[5,null]"))
        r (:: (decode d (unsafe (json-doc-root d))) (Result (Vec (Option int)) cstr))]
    (if (.is-ok r)
      (let [v  (ok-val r)
            e0 (:: (vec-get v 0) (Option int))
            e1 (:: (vec-get v 1) (Option int))]
        (println (vec-len v))
        (if (.is-some e0) (println (:: (.value e0) :int)) (println "none"))
        (if (.is-some e1) (println "some?!") (println "none")))
      (println "ERR"))
    (unsafe (json-doc-free d)))
  0))
