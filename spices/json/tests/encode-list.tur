;; U2 container instances: Encode [Cons] -- a homogeneous list encodes as a
;; JSON array, each element via its own (Encode A) instance.
;;   (list 1 2 3)   -> [1,2,3]
;;   (list 7.1 2.5) -> [7.1,2.5]
;;   (list "a" "b") -> ["a","b"]
;;   (tnil)         -> []
;;
;; A (Cons A) is carried as :int (heap pointer), the same carrier as int, so a
;; bare `(encode xs)` is an ambiguous dispatch -- the call sites pin it with
;; `@Cons`. `check` gates `tur test` on real behavior via an inline-C counter.

(defmodule encode_list_test (export)

(import json/encode)

(defn check [idx : int  name : cstr  got : cstr  want : cstr] : void
  ```c
  /* __tur_include__: static int g_el_fails = 0; */
  int ok = got && want && !strcmp((const char *)got, (const char *)want);
  if (!ok) g_el_fails++;
  printf("%s %lld - %s (got %s, want %s)\n", ok ? "ok" : "not ok",
         (long long)idx, (const char *)name,
         got ? (const char *)got : "(null)", (const char *)want);
  ```)

(defn finish [count : int] : int
  ```c
  printf("1..%lld\n", (long long)count);
  if (g_el_fails == 0) { fprintf(stderr, "# All %lld encode-list tests passed.\n", (long long)count); return 0; }
  fprintf(stderr, "# %d/%lld encode-list tests failed.\n", g_el_fails, (long long)count);
  return 1;
  ```)

(defn main [] : int
  (check 1 "int list"   (encode @Cons (:: (list 1 2 3)    (Cons int)))  "[1,2,3]")
  (check 2 "float list" (encode @Cons (:: (list 7.1 2.5)  (Cons float))) "[7.1,2.5]")
  (check 3 "cstr list"  (encode @Cons (:: (list "a" "b")  (Cons cstr))) "[\"a\",\"b\"]")
  (check 4 "singleton"  (encode @Cons (:: (list 42)       (Cons int)))  "[42]")
  (check 5 "empty list" (encode @Cons (:: (tnil)          (Cons int)))  "[]")
  (finish 5)))
