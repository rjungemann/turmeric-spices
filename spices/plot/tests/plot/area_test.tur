;; tests/plot/area_test.tur -- area renderer smoke tests.

(defmodule plot/tests/area
  (import plot/core  :refer [plot plot-write-png
                             __ok? __ok-val __surface-destroy
                             __pixel-is-background? __count-non-background])
  (import plot/area  :refer [rectangles area-histogram discrete-histogram stacked-histogram])
  (import plot/style :refer [default-fill-style default-plot-opts])
  (import test/assert :refer [assert-ok assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn quad [a :float b :float c :float d :float] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    union { double d; int64_t i; } ua, ub, uc, ud; ua.d = a; ub.d = b; uc.d = c; ud.d = d;
    Cons *c3 = malloc(sizeof(*c3)); Cons *c2 = malloc(sizeof(*c2)); Cons *c1 = malloc(sizeof(*c1));
    c3->head = uc.i; c3->tail = ud.i;
    c2->head = ub.i; c2->tail = (int64_t)(intptr_t)c3;
    c1->head = ua.i; c1->tail = (int64_t)(intptr_t)c2;
    return (int64_t)(intptr_t)c1;
    ```)

  (defn t-cons [v :int n :int] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = v; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn s-cons [s :cstr n :int] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = (int64_t)(intptr_t)s; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cat [label :cstr height :float] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    union { double d; int64_t i; } uh; uh.d = height;
    Cons *p = malloc(sizeof(*p));
    p->head = (int64_t)(intptr_t)label; p->tail = uh.i;
    return (int64_t)(intptr_t)p;
    ```)

  (defn group [label :cstr vals :int] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *p = malloc(sizeof(*p));
    p->head = (int64_t)(intptr_t)label; p->tail = vals;
    return (int64_t)(intptr_t)p;
    ```)

  (defn file-size [path :cstr] :int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn __f [x :float] :int
    ```c
    union { double d; int64_t i; } u;
    u.d = x;
    return u.i;
    ```)

  (defn rect-data [] :int
    (t-cons (quad -1.0 -0.5 0.0 1.0)
      (t-cons (quad 0.2 0.9 0.0 0.6) 0)))

  (defn area-bars [] :int
    (t-cons (quad 0.0 0.5 0.0 1.0)
      (t-cons (quad 0.6 1.1 0.0 1.4) 0)))

  (defn cat-bars [] :int
    (t-cons (cat "A" 1.0)
      (t-cons (cat "B" 1.4)
        (t-cons (cat "C" 0.7) 0))))

  (defn stack-groups [] :int
    (t-cons (group "Q1" (t-cons (__f 1.0) (t-cons (__f 0.8) 0)))
      (t-cons (group "Q2" (t-cons (__f 1.2) (t-cons (__f 0.5) 0)))
        0)))

  (defn stack-labels [] :int
    (s-cons "one" (s-cons "two" 0)))

  (defn area-renderers [fill :int fills :int] :int
    (vec-of (rectangles (rect-data) fill "rects")
            (area-histogram (area-bars) fills "ah")
            (discrete-histogram (cat-bars) fill 0 "dh")
            (stacked-histogram (stack-groups)
                               fills
                               (stack-labels)
                               0)))

  (defn write-area-png-ok [] :bool
    (let [fill (default-fill-style)
          fills (t-cons fill (t-cons fill (t-cons fill 0)))
          rs   (area-renderers fill fills)]
      (and (assert-ok (plot-write-png rs (default-plot-opts) "/tmp/tur-plot-area.png"))
           (assert-true (>i (file-size "/tmp/tur-plot-area.png") 100)))))

  (defn pixel-sanity-area [] :bool
    (let [fill  (default-fill-style)
          fills (t-cons fill (t-cons fill (t-cons fill 0)))
          rs    (area-renderers fill fills)
          rr    (plot rs (default-plot-opts))]
      (if (__ok? rr)
        (let [s       (__ok-val rr)
              corner? (__pixel-is-background? s 4 4)
              ink     (__count-non-background s 100 100 500 350)]
          (__surface-destroy s)
          (and (assert-true corner?)
               (assert-true (>i ink 100))))
        (assert-true false))))

  (defn >i [a :int b :int] :bool ```c return (int)a > (int)b; ```)

  (defn main [] :int
    (describe "plot/area"
      (it "renders rectangles and histograms"
        (write-area-png-ok))
      (it "fills the plot interior with non-background pixels"
        (pixel-sanity-area)))
    (run-all)
    0))
