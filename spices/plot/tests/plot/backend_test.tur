;; tests/plot/backend_test.tur -- exercises the U2 `Backend` typeclass
;; collapse directly: each output sink (canvas / surface / PNG) reached
;; through the single `render-to` method instead of the legacy entrypoints.

(defmodule plot/tests/backend
  (import plot/core  :refer [plot-into-canvas
                             __ok? __ok-val __surface-create __canvas-create
                             __canvas-destroy __surface-destroy
                             __surface-width __surface-height
                             __count-non-background])
  (import plot/style :refer [default-plot-opts])
  (import plot/decor :refer [axes tick-grid])
  (import test/assert :refer [assert-ok assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn file-exists? [path : cstr] : bool
    ```c
    #include <unistd.h>
    return access((const char *)(intptr_t)path, F_OK) == 0;
    ```)

  (defn file-size [path : cstr] : int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn unlink-file [path : cstr] : void
    ```c
    #include <unistd.h>
    unlink((const char *)(intptr_t)path);
    ```)

  (defn >i [a : int b : int] : bool ```c return (int)a > (int)b; ```)

  (defn demo-renderers [] : int
    (vec-of (tick-grid) (axes)))

  ;; SurfaceBackend: render-to returns an ok-wrapped surface handle.
  (defn surface-backend-ok [] : bool
    (let [rr (render-to (make-struct SurfaceBackend 0 0)
                        (demo-renderers) (default-plot-opts))]
      (if (__ok? rr)
        (let [s (__ok-val rr)
              w (__surface-width s)
              h (__surface-height s)]
          (__surface-destroy s)
          (and (assert-true (>i w 0)) (assert-true (>i h 0))))
        (assert-true false))))

  ;; SurfaceBackend honors explicit dimensions over the opts defaults.
  (defn surface-backend-sized-ok [] : bool
    (let [rr (render-to (make-struct SurfaceBackend 320 200)
                        (demo-renderers) (default-plot-opts))]
      (if (__ok? rr)
        (let [s (__ok-val rr)
              w (__surface-width s)
              h (__surface-height s)]
          (__surface-destroy s)
          (and (assert-true (>i w 319)) (assert-true (>i h 199))
               (assert-true (>i 321 w)) (assert-true (>i 201 h))))
        (assert-true false))))

  ;; CanvasBackend: render-to draws into an existing canvas + viewport and
  ;; leaves visible ink in the interior.
  (defn canvas-backend-ok [] : bool
    (let [sr (__surface-create 400 300)]
      (if (__ok? sr)
        (let [s  (__ok-val sr)
              cr (__canvas-create s)]
          (if (__ok? cr)
            (let [c  (__ok-val cr)
                  rr (render-to (make-struct CanvasBackend c 0 0 400 300)
                                (demo-renderers) (default-plot-opts))
                  ink (__count-non-background s 0 0 400 300)]
              (__canvas-destroy c)
              (__surface-destroy s)
              (and (assert-ok rr) (assert-true (>i ink 0))))
            (do (__surface-destroy s) (assert-true false))))
        (assert-true false))))

  ;; PngBackend: render-to renders + writes a PNG to disk.
  (defn png-backend-ok [] : bool
    (let [out "/tmp/tur-plot-backend.png"
          wr  (do (unlink-file out)
                  (render-to (make-struct PngBackend out)
                             (demo-renderers) (default-plot-opts)))]
      (and (assert-ok wr)
           (assert-true (file-exists? out))
           (assert-true (>i (file-size out) 100)))))

  (defn main [] : int
    (describe "plot/backend"
      (it "SurfaceBackend renders to a fresh surface"
        (surface-backend-ok))
      (it "SurfaceBackend honors explicit dimensions"
        (surface-backend-sized-ok))
      (it "CanvasBackend draws into an existing canvas"
        (canvas-backend-ok))
      (it "PngBackend writes a PNG file"
        (png-backend-ok)))
    (run-all)
    0))
