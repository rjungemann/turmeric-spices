;; tests/plot/core_test.tur -- basic plot surface smoke tests.

(defmodule plot/tests/core
  (import plot/core  :refer [plot plot-write-png
                             __is-ok? __ok-val __surface-destroy
                             __surface-width __surface-height
                             __pixel-is-background?])
  (import plot/style :refer [default-plot-opts])
  (import plot/decor :refer [axes tick-grid])
  (import test/assert :refer [assert-ok assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn file-exists? [path :cstr] :bool
    ```c
    #include <unistd.h>
    return access((const char *)(intptr_t)path, F_OK) == 0;
    ```)

  (defn file-size [path :cstr] :int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn unlink-file [path :cstr] :void
    ```c
    #include <unistd.h>
    unlink((const char *)(intptr_t)path);
    ```)

  (defn >i [a :int b :int] :bool ```c return (int)a > (int)b; ```)

  (defn core-renderers [] :int
    (vec-of (tick-grid) (axes)))

  (defn render-blank-ok [] :bool
    (let [rr (plot (core-renderers) (default-plot-opts))]
      (if (__is-ok? rr)
        (do (__surface-destroy (__ok-val rr)) (assert-true true))
        (assert-true false))))

  ;; Render a blank chart and confirm a known background corner pixel really is
  ;; background, and the surface has the expected dimensions. Catches
  ;; "all-zero pixels" / "transparent canvas" regressions that file-size alone
  ;; cannot.
  (defn pixel-sanity-blank [] :bool
    (let [rr (plot (core-renderers) (default-plot-opts))]
      (if (__is-ok? rr)
        (let [s   (__ok-val rr)
              w   (__surface-width s)
              h   (__surface-height s)
              ;; (5, 5) sits in the white border outside the plot rect.
              bg? (__pixel-is-background? s 5 5)]
          (__surface-destroy s)
          (and (assert-true (>i w 0))
               (assert-true (>i h 0))
               (assert-true bg?)))
        (assert-true false))))

  (defn write-core-png-ok [] :bool
    (let [out "/tmp/tur-plot-core.png"
          wr  (do
                (unlink-file out)
                (plot-write-png (core-renderers)
                                (default-plot-opts)
                                out))]
      (and (assert-ok wr)
           (assert-true (file-exists? out))
           (assert-true (>i (file-size out) 100)))))

  (defn main [] :int
    (describe "plot/core"
      (it "renders a blank plot surface"
        (render-blank-ok))
      (it "background-corner pixel is white"
        (pixel-sanity-blank))
      (it "writes a PNG"
        (write-core-png-ok)))
    (run-all)
    0))
