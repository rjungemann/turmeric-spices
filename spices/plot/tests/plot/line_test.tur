;; tests/plot/line_test.tur -- line renderer smoke tests.

(defmodule plot/tests/line
  (import plot/core  :refer [plot plot-write-png
                             __ok? __ok-val __surface-destroy
                             __pixel-is-background? __count-non-background])
  (import plot/line  :refer [function lines parametric polar inverse density])
  (import plot/decor :refer [axes tick-grid])
  (import plot/style :refer [default-line-style default-plot-opts])
  (import test/assert :refer [assert-ok assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  ;; Local pair constructor (shadows stdlib `pair`).
  (defn xy-pair [x :float y :float] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *p = malloc(sizeof(*p));
    union { double d; int64_t i; } ux, uy;
    ux.d = x; uy.d = y;
    p->head = ux.i; p->tail = uy.i;
    return (int64_t)(intptr_t)p;
    ```)

  (defn t-cons [v :int n :int] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = v; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn f-cons [x :float n :int] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    union { double d; int64_t i; } u; u.d = x;
    Cons *c = malloc(sizeof(*c));
    c->head = u.i; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn file-size [path :cstr] :int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn >i [a :int b :int] :bool ```c return (int)a > (int)b; ```)

  ;; Sampled-curve callbacks. The renderer stores these as raw function
  ;; pointers (`double(*)(double)` / `int64_t(*)(double)`), so they must be
  ;; named defns rather than untyped `fn` literals.
  (defn curve-square [x :float] :float ```c return (double)x * (double)x; ```)
  (defn curve-half [t :float] :int (xy-pair t (* 0.5 t)))
  (defn curve-radius [t :float] :float ```c return 0.4 + 0.1 * (double)t * (double)t; ```)
  (defn curve-y2 [y :float] :float ```c return (double)y * (double)y; ```)

  (defn line-renderers [] :int
    (vec-of (tick-grid)
            (axes)
            (function curve-square
                      -2.0 2.0 96
                      (default-line-style)
                      "f")
            (lines (t-cons (xy-pair -2.0 -1.0)
                     (t-cons (xy-pair -1.0 0.5)
                       (t-cons (xy-pair 1.0 1.5) 0)))
                   (default-line-style)
                   "l")
            (parametric curve-half
                        -1.0 1.0 96
                        (default-line-style)
                        "p")
            (polar curve-radius
                   -1.0 1.0 96
                   (default-line-style)
                   "r")
            (inverse curve-y2
                     -1.0 1.0 96
                     (default-line-style)
                     "i")
            (density (f-cons 0.0 (f-cons 1.0 (f-cons 1.1 (f-cons 1.2 (f-cons 2.0 0)))))
                     0.0 64
                     (default-line-style)
                     "d")))

  (defn write-line-png-ok [] :bool
    (let [rs (line-renderers)]
      (and (assert-ok (plot-write-png rs (default-plot-opts) "/tmp/tur-plot-line.png"))
           (assert-true (>i (file-size "/tmp/tur-plot-line.png") 100)))))

  ;; Render the full line bundle to a surface and confirm the plot rect
  ;; actually has non-background ink: the chart background is `fill_rect`
  ;; near-white, axes/curves are darker. A blank canvas would yield zero
  ;; non-background pixels in the interior. We require a generous floor.
  (defn pixel-sanity-line [] :bool
    (let [rs (line-renderers)
          rr (plot rs (default-plot-opts))]
      (if (__ok? rr)
        (let [s       (__ok-val rr)
              ;; corner outside the plot rect must stay background.
              corner? (__pixel-is-background? s 4 4)
              ;; interior rect [100..500, 100..350] is fully inside the
              ;; plot area for the default 600x450 opts. Axes alone already
              ;; contribute hundreds of dark pixels; require >= 100.
              ink     (__count-non-background s 100 100 500 350)]
          (__surface-destroy s)
          (and (assert-true corner?)
               (assert-true (>i ink 100))))
        (assert-true false))))

  (defn main [] :int
    (describe "plot/line"
      (it "renders line-like plots"
        (write-line-png-ok))
      (it "produces non-background ink in the plot interior"
        (pixel-sanity-line)))
    (run-all)
    0))
