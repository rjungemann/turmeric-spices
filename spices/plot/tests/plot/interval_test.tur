;; tests/plot/interval_test.tur -- interval renderer smoke tests.

(defmodule plot/tests/interval
  (import plot/core     :refer [plot plot-write-png
                                __ok? __ok-val __surface-destroy
                                __pixel-is-background? __count-non-background])
  (import plot/interval :refer [function-interval lines-interval parametric-interval polar-interval])
  (import plot/decor    :refer [axes])
  (import plot/style    :refer [default-fill-style default-line-style default-plot-opts])
  (import test/assert   :refer [assert-ok assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  ;; Local pair constructor (shadows stdlib `pair`).
  (defn xy-pair [x : float y : float] : int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *p = malloc(sizeof(*p));
    union { double d; int64_t i; } ux, uy; ux.d = x; uy.d = y;
    p->head = ux.i; p->tail = uy.i; return (int64_t)(intptr_t)p;
    ```)

  (defn t-cons [v : int n : int] : int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = v; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn file-size [path : cstr] : int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn >i [a : int b : int] : bool ```c return (int)a > (int)b; ```)

  ;; Curve callbacks (renderer wants typed function pointers, not `fn` literals).
  (defn iv-lo [x : float] : float ```c return (double)x * (double)x; ```)
  (defn iv-hi [x : float] : float ```c return (double)x * (double)x + 0.5; ```)
  (defn iv-plo [t : float] : int (xy-pair t (* 0.5 t)))
  (defn iv-phi [t : float] : int (xy-pair t (+ (* 0.5 t) 0.3)))
  (defn iv-rlo [t : float] : float ```c return 0.4; ```)
  (defn iv-rhi [t : float] : float ```c return 0.8; ```)

  (defn interval-renderers [fill : int line : int] : int
    (vec-of (axes)
            (function-interval iv-lo iv-hi -1.5 1.5 96 fill line "fi")
            (lines-interval (t-cons (xy-pair -1.0 -0.5) (t-cons (xy-pair 0.0 0.0) (t-cons (xy-pair 1.0 0.5) 0)))
                            (t-cons (xy-pair -1.0 0.2) (t-cons (xy-pair 0.0 0.7) (t-cons (xy-pair 1.0 1.1) 0)))
                            fill line "li")
            (parametric-interval iv-plo iv-phi -1.0 1.0 72 fill line "pi")
            (polar-interval iv-rlo iv-rhi -1.0 1.0 72 fill line "po")))

  (defn write-interval-png-ok [] : bool
    (let [fill (default-fill-style)
          line (default-line-style)
          rs   (interval-renderers fill line)]
      (and (assert-ok (plot-write-png rs (default-plot-opts) "/tmp/tur-plot-interval.png"))
           (assert-true (>i (file-size "/tmp/tur-plot-interval.png") 100)))))

  (defn pixel-sanity-interval [] : bool
    (let [fill (default-fill-style)
          line (default-line-style)
          rs   (interval-renderers fill line)
          rr   (plot rs (default-plot-opts))]
      (if (__ok? rr)
        (let [s       (__ok-val rr)
              corner? (__pixel-is-background? s 4 4)
              ink     (__count-non-background s 100 100 500 350)]
          (__surface-destroy s)
          (and (assert-true corner?)
               (assert-true (>i ink 100))))
        (assert-true false))))

  (defn main [] : int
    (describe "plot/interval"
      (it "renders interval fills"
        (write-interval-png-ok))
      (it "produces non-background ink in the interior"
        (pixel-sanity-interval)))
    (run-all)
    0))
