;; tests/plot/bbox_test.tur -- unit tests for the extracted bounds pass.
;;
;; Exercises `renderer-bbox` (the P0 de-monolith of plot-into-canvas's former
;; inline bounds switch, surfaced as the typed P1 `BBox`). A `lines` renderer
;; over known points must report the exact min/max box; a decoration renderer
;; with no data points must report an empty box.

(defmodule plot/tests/bbox
  (import plot/core  :refer [renderer-bbox bbox-empty? BBox])
  (import plot/line  :refer [lines])
  (import plot/decor :refer [axes])
  (import plot/style :refer [default-line-style])
  (import test/assert :refer [assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  ;; Local cons-pair / cons-list builders (mirror line_test): a point is a
  ;; cons of the two coordinate doubles' bit patterns; a point list is a
  ;; cons-list of those pairs terminated by 0.
  (defn xy-pair [x : float y : float] : int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *p = malloc(sizeof(*p));
    union { double d; int64_t i; } ux, uy;
    ux.d = x; uy.d = y;
    p->head = ux.i; p->tail = uy.i;
    return (int64_t)(intptr_t)p;
    ```)

  (defn t-cons [v : int n : int] : int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = v; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn close? [a : float b : float] : bool
    ```c
    double d = (double)a - (double)b;
    if (d < 0) d = -d;
    return d < 1e-9;
    ```)

  ;; Points (-2,-1), (-1,0.5), (1,1.5) -> box x:[-2,1] y:[-1,1.5].
  (defn sample-lines [] : int
    (lines (t-cons (xy-pair -2.0 -1.0)
             (t-cons (xy-pair -1.0 0.5)
               (t-cons (xy-pair 1.0 1.5) 0)))
           (default-line-style) ""))

  (defn lines-bbox-exact [] : bool
    (let [bb (renderer-bbox (sample-lines))]
      (and (assert-true (not (bbox-empty? bb)))
           (assert-true (close? -2.0 (.x-min bb)))
           (assert-true (close?  1.0 (.x-max bb)))
           (assert-true (close? -1.0 (.y-min bb)))
           (assert-true (close?  1.5 (.y-max bb))))))

  ;; A decoration renderer (axes) carries no data points -> empty box.
  (defn axes-bbox-empty [] : bool
    (assert-true (bbox-empty? (renderer-bbox (axes)))))

  (defn main [] : int
    (describe "plot/core renderer-bbox"
      (it "lines renderer reports exact data bounds"
        (lines-bbox-exact))
      (it "decoration renderer reports an empty box"
        (axes-bbox-empty)))
    (run-all)
    0))
