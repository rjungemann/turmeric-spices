;; tests/plot/point_test.tur -- point renderer smoke tests.

(defmodule plot/tests/point
  (import plot/core  :refer [plot-write-png])
  (import plot/point :refer [points error-bars vector-field arrows])
  (import plot/line  :refer [function])
  (import plot/decor :refer [axes])
  (import plot/style :refer [default-line-style default-point-style default-plot-opts])
  (import test/assert :refer [assert-ok assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn pair [x :float y :float] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *p = malloc(sizeof(*p));
    union { double d; int64_t i; } ux, uy; ux.d = x; uy.d = y;
    p->head = ux.i; p->tail = uy.i; return (int64_t)(intptr_t)p;
    ```)

  (defn t-cons [v :int n :int] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = v; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn triple [a :float b :float c :float] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    union { double d; int64_t i; } ua, ub, uc; ua.d = a; ub.d = b; uc.d = c;
    Cons *c2 = malloc(sizeof(*c2)); Cons *c1 = malloc(sizeof(*c1));
    c2->head = ub.i; c2->tail = uc.i;
    c1->head = ua.i; c1->tail = (int64_t)(intptr_t)c2;
    return (int64_t)(intptr_t)c1;
    ```)

  (defn quad [a :float b :float c :float d :float] :int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    union { double d; int64_t i; } ua, ub, uc, ud; ua.d = a; ub.d = b; uc.d = c; ud.d = d;
    Cons *c3 = malloc(sizeof(*c3)); Cons *c2 = malloc(sizeof(*c2)); Cons *c1 = malloc(sizeof(*c1));
    c3->head = uc.i; c3->tail = ud.i;
    c2->head = ub.i; c2->tail = (int64_t)(intptr_t)c3;
    c1->head = ua.i; c1->tail = (int64_t)(intptr_t)c2;
    return (int64_t)(intptr_t)c1;
    ```)

  (defn file-size [path :cstr] :int
    ```c
    #include <sys/stat.h>
    struct stat st;
    if (stat((const char *)(intptr_t)path, &st) != 0) return -1;
    return (int64_t)st.st_size;
    ```)

  (defn point-renderers [] :int
    (t-cons (axes)
      (t-cons (function (fn [x :float] :float x) -1.0 2.0 64 (default-line-style) "diag")
        (t-cons (points (t-cons (pair 0.0 0.0) (t-cons (pair 1.0 1.0) (t-cons (pair 1.5 0.5) 0)))
                      (default-point-style)
                      "pts")
          (t-cons (error-bars (t-cons (triple 0.5 0.5 0.25) (t-cons (triple 1.2 1.0 0.2) 0))
                            (default-line-style)
                            0
                            "err")
            (t-cons (vector-field (fn [x :float y :float] :int (pair (* -1.0 y) x))
                                -1.0 1.0 -1.0 1.0
                                8 1
                                (default-line-style)
                                "vf")
              (t-cons (arrows (t-cons (quad -0.5 -0.5 0.5 0.5) (t-cons (quad 0.0 1.0 1.0 0.2) 0))
                            (default-line-style)
                            "arr")
                   0)))))))

  (defn write-point-png-ok [] :bool
    (let [rs (point-renderers)]
      (and (assert-ok (plot-write-png rs (default-plot-opts) "/tmp/tur-plot-point.png"))
           (assert-true (>i (file-size "/tmp/tur-plot-point.png") 100)))))

  (describe "plot/point"
    (it "renders point and arrow-based plots"
      (write-point-png-ok)))

  (defn >i [a :int b :int] :bool ```c return (int)a > (int)b; ```)

  (defn main [] :int
    (run-all)
    0))
