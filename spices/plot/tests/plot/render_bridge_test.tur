;; tests/plot/render_bridge_test.tur -- P4 (render bridge) of the plot Renderer
;; typeclass plan.
;;
;; `plot-anyrenderers` renders a heterogeneous (Vec AnyRenderer) by dispatching
;; each renderer's `to-legacy` lowering through its packed Renderer dictionary
;; and handing the result to the existing draw pipeline. This asserts the typed
;; path is *pixel-identical* to building the same renderers with the legacy
;; constructors and calling `plot` -- the migration's correctness invariant.

(defmodule plot/tests/render_bridge
  (import plot/core  :refer [plot plot-anyrenderers __surfaces-equal?
                             any-renderer lines-r points-r label-r
                             __ok? __ok-val __surface-destroy])
  (import plot/line  :refer [lines])
  (import plot/point :refer [points])
  (import plot/decor :refer [point-label-styled])
  (import plot/style :refer [default-line-style default-point-style default-plot-opts])
  (import test/assert :refer [assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn xy-pair [x : float y : float] : int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *p = malloc(sizeof(*p));
    union { double d; int64_t i; } ux, uy;
    ux.d = x; uy.d = y;
    p->head = ux.i; p->tail = uy.i;
    return (int64_t)(intptr_t)p;
    ```)

  (defn t-cons [v : int n : int] : int
    ```c
    typedef struct { int64_t head; int64_t tail; } Cons;
    Cons *c = malloc(sizeof(*c));
    c->head = v; c->tail = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn sample-points [] : int
    (t-cons (xy-pair -2.0 -1.0)
      (t-cons (xy-pair -1.0 0.5)
        (t-cons (xy-pair 1.0 1.5) 0))))

  ;; The typed AnyRenderer vec and the legacy int-handle vec are built from the
  ;; *same* point lists and style handles, so any pixel difference is a defect
  ;; in the to-legacy lowering / dispatch, not in the inputs.
  (defn typed-vec [pts : int  lpts : int  lstyle : int  pstyle : int]
      : (Vec (exists [a] [(Renderer a)] a))
    (let [rs (:: (vec-new) (Vec (exists [a] [(Renderer a)] a)))]
      (vec-push! rs (any-renderer (lines-r  pts  lstyle "")))
      (vec-push! rs (any-renderer (points-r lpts pstyle "")))
      (vec-push! rs (any-renderer (label-r  0.5 0.5 "x" lstyle)))
      rs))

  (defn legacy-vec [pts : int  lpts : int  lstyle : int  pstyle : int] : (Vec int)
    (let [rs (:: (vec-new) (Vec int))]
      (vec-push! rs (lines pts lstyle ""))
      (vec-push! rs (points lpts pstyle ""))
      (vec-push! rs (point-label-styled 0.5 0.5 "x" 0 lstyle))
      rs))

  ;; Render both vecs and assert byte-identical surfaces.
  (defn pixel-identical [] : bool
    (let [pts    (sample-points)
          lpts   (sample-points)
          lstyle (default-line-style)
          pstyle (default-point-style)
          opts   (default-plot-opts)
          r1 (plot-anyrenderers (typed-vec pts lpts lstyle pstyle) opts)
          r2 (plot (:: (legacy-vec pts lpts lstyle pstyle) :int) opts)]
      (if (and (__ok? r1) (__ok? r2))
        (let [s1 (__ok-val r1)
              s2 (__ok-val r2)
              eq (__surfaces-equal? s1 s2)]
          (__surface-destroy s1)
          (__surface-destroy s2)
          (assert-true eq))
        (assert-true false))))

  (defn main [] : int
    (describe "plot/core AnyRenderer render bridge -- pixel identity vs legacy"
      (it "plot-anyrenderers matches the legacy plot pixel-for-pixel"
          (pixel-identical)))
    (run-all)
    0))
