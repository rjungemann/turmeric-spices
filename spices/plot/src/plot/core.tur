      int *__resolved_line = (RESOLVED_LINE); \
      int __color = __fs ? (int)__fs->color : -1; \
      if (__color < 0) __color = NEXT_AUTO(); \
      __color %= 8; if (__color < 0) __color += 8; \
      int __lcolor = (__fs && __fs->line_color >= 0) ? (int)__fs->line_color : __color; \
      double __alpha = (__fs && __fs->alpha > 0.0) ? __fs->alpha : 0.5; \
      if (__resolved_fill) *__resolved_fill = __color; \
      if (__resolved_line) *__resolved_line = __lcolor; \
      plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, \
                              (float)palette[__color][0], (float)palette[__color][1], \
                              (float)palette[__color][2], (float)__alpha); \
    } while (0)
    #define SET_POINT_STYLE(HANDLE, RESOLVED_STROKE, RESOLVED_FILL) do { \
      PointStyle *__ps = (PointStyle *)(intptr_t)(HANDLE); \
