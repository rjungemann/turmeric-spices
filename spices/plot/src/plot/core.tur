        case RK_RECTANGLES:
        case RK_AREA_HIST:
        case RK_DISCRETE_HIST:
        case RK_STACKED_HIST: {
          if (r->kind == RK_DISCRETE_HIST || r->kind == RK_STACKED_HIST) {
            int idx = 0, fill_idx = 0;
            for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail, idx++) {
              double x0 = idx, x1 = idx + 0.8;
              if (r->kind == RK_DISCRETE_HIST) {
                Cons *bar = (Cons *)(intptr_t)p->head;
                double h = BITS_DBL(bar->tail);
                SET_FILL_STYLE(r->style1, ((int *)0), ((int *)0));
                double vx0, vy0, vx1, vy1;
                if (r->i1) { MAP_POINT(0.0, x0, &vx0, &vy0); MAP_POINT(h, x1, &vx1, &vy1); }
                else { MAP_POINT(x0, 0.0, &vx0, &vy0); MAP_POINT(x1, h, &vx1, &vy1); }
                plutovg_canvas_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)vx0, (float)fmin(vy0, vy1), (float)(vx1 - vx0), (float)fabs(vy1 - vy0));
                plutovg_canvas_fill((plutovg_canvas_t *)(intptr_t)canvas);
              } else {
                Cons *grp = (Cons *)(intptr_t)p->head;
                double acc = 0.0;
                Cons *vals = (Cons *)(intptr_t)grp->tail;
                Cons *fills = (Cons *)(intptr_t)r->data3;
                while (vals) {
                  int64_t fill = fills ? fills->head : r->style1;
                  SET_FILL_STYLE(fill, ((int *)0), ((int *)0));
                  double h = BITS_DBL(vals->head);
                  double vx0, vy0, vx1, vy1;
                  if (r->i1) { MAP_POINT(acc, x0, &vx0, &vy0); MAP_POINT(acc + h, x1, &vx1, &vy1); }
                  else { MAP_POINT(x0, acc, &vx0, &vy0); MAP_POINT(x1, acc + h, &vx1, &vy1); }
                  plutovg_canvas_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)vx0, (float)fmin(vy0, vy1), (float)(vx1 - vx0), (float)fabs(vy1 - vy0));
                  plutovg_canvas_fill((plutovg_canvas_t *)(intptr_t)canvas);
                  acc += h;
                  vals = (Cons *)(intptr_t)vals->tail;
                  fills = fills ? (Cons *)(intptr_t)fills->tail : NULL;
                }
              }
            }
          } else {
            Cons *fills = (Cons *)(intptr_t)r->data2;
            for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail) {
              int64_t fill = (r->kind == RK_AREA_HIST) ? (fills ? fills->head : r->style1) : r->style1;
              SET_FILL_STYLE(fill, ((int *)0), ((int *)0));
              Cons *a = (Cons *)(intptr_t)p->head;
              double x0 = BITS_DBL(a->head);
              Cons *b = (Cons *)(intptr_t)a->tail;
              double x1 = BITS_DBL(b->head);
              Cons *c = (Cons *)(intptr_t)b->tail;
              double y0 = BITS_DBL(c->head);
              double y1 = BITS_DBL(c->tail);
              double vx0, vy0, vx1, vy1; MAP_POINT(x0, y0, &vx0, &vy0); MAP_POINT(x1, y1, &vx1, &vy1);
              plutovg_canvas_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)fmin(vx0, vx1), (float)fmin(vy0, vy1), (float)fabs(vx1 - vx0), (float)fabs(vy1 - vy0));
              plutovg_canvas_fill((plutovg_canvas_t *)(intptr_t)canvas);
              fills = fills ? (Cons *)(intptr_t)fills->tail : NULL;
            }
          }
        } break;
        case RK_COLOR_FIELD:
        case RK_CONTOUR_INTERVALS: {
          int samples = (int)r->i1; if (samples < 8) samples = 8;
          Cons *fills = (Cons *)(intptr_t)r->style1;
          for (int iy = 0; iy < samples - 1; iy++) for (int ix = 0; ix < samples - 1; ix++) {
            double x0 = r->f1 + (r->f2 - r->f1) * ((double)ix / (double)(samples - 1));
            double x1 = r->f1 + (r->f2 - r->f1) * ((double)(ix + 1) / (double)(samples - 1));
            double y0 = r->f3 + (r->f4 - r->f3) * ((double)iy / (double)(samples - 1));
            double y1 = r->f3 + (r->f4 - r->f3) * ((double)(iy + 1) / (double)(samples - 1));
            double v = ((double(*)(double,double))(intptr_t)r->data1)((x0 + x1) * 0.5, (y0 + y1) * 0.5);
            int color = 0;
            double alpha = (r->kind == RK_COLOR_FIELD) ? r->f5 : 0.55;
            if (r->kind == RK_COLOR_FIELD) {
              color = ((int(*)(double,double))(intptr_t)r->data1)((x0 + x1) * 0.5, (y0 + y1) * 0.5);
              color %= 8; if (color < 0) color += 8;
            } else {
              int bands = (int)r->i2 + 1;
              double t = (v - r->f5) / (r->f6 - r->f5);
              if (!(t == t)) t = 0.0;
              if (t < 0.0) t = 0.0; if (t > 0.999) t = 0.999;
              int band = (int)floor(t * bands);
              Cons *fs = (Cons *)(intptr_t)r->style1;
              for (int bi = 0; bi < band && fs; bi++) fs = (Cons *)(intptr_t)fs->tail;
              FillStyle *fill = (FillStyle *)(intptr_t)(fs ? fs->head : 0);
              color = fill ? (int)fill->color : band % 8;
              if (color < 0) color = band % 8;
            }
            double vx0, vy0, vx1, vy1; MAP_POINT(x0, y0, &vx0, &vy0); MAP_POINT(x1, y1, &vx1, &vy1);
            plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, (float)palette[color][0], (float)palette[color][1], (float)palette[color][2], (float)alpha);
            plutovg_canvas_fill_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)fmin(vx0, vx1), (float)fmin(vy0, vy1), (float)fabs(vx1 - vx0), (float)fabs(vy1 - vy0));
          }
        } break;
        case RK_ISOLINE:
        case RK_CONTOURS: {
          SET_LINE_STYLE(r->style1, ((int *)0));
          int samples = (int)r->i1; if (samples < 8) samples = 8;
          int nlevels = (r->kind == RK_CONTOURS) ? (int)r->i2 : 1;
          for (int li = 0; li < nlevels; li++) {
            double level = (r->kind == RK_ISOLINE) ? r->f5 : (r->f5 + (r->f6 - r->f5) * ((double)(li + 1) / (double)(nlevels + 1)));
            for (int iy = 0; iy < samples - 1; iy++) for (int ix = 0; ix < samples - 1; ix++) {
              double x0 = r->f1 + (r->f2 - r->f1) * ((double)ix / (double)(samples - 1));
              double x1 = r->f1 + (r->f2 - r->f1) * ((double)(ix + 1) / (double)(samples - 1));
              double y0 = r->f3 + (r->f4 - r->f3) * ((double)iy / (double)(samples - 1));
              double y1 = r->f3 + (r->f4 - r->f3) * ((double)(iy + 1) / (double)(samples - 1));
              double v00 = ((double(*)(double,double))(intptr_t)r->data1)(x0, y0) - level;
              double v10 = ((double(*)(double,double))(intptr_t)r->data1)(x1, y0) - level;
              double v01 = ((double(*)(double,double))(intptr_t)r->data1)(x0, y1) - level;
              double v11 = ((double(*)(double,double))(intptr_t)r->data1)(x1, y1) - level;
              double ptsx[4], ptsy[4]; int pc = 0;
              if ((v00 <= 0 && v10 > 0) || (v00 > 0 && v10 <= 0)) { double t = v00 / (v00 - v10); ptsx[pc] = x0 + (x1 - x0) * t; ptsy[pc++] = y0; }
              if ((v10 <= 0 && v11 > 0) || (v10 > 0 && v11 <= 0)) { double t = v10 / (v10 - v11); ptsx[pc] = x1; ptsy[pc++] = y0 + (y1 - y0) * t; }
              if ((v11 <= 0 && v01 > 0) || (v11 > 0 && v01 <= 0)) { double t = v11 / (v11 - v01); ptsx[pc] = x1 + (x0 - x1) * t; ptsy[pc++] = y1; }
              if ((v01 <= 0 && v00 > 0) || (v01 > 0 && v00 <= 0)) { double t = v01 / (v01 - v00); ptsx[pc] = x0; ptsy[pc++] = y1 + (y0 - y1) * t; }
              if (pc >= 2) {
                double vx0, vy0, vx1, vy1; MAP_POINT(ptsx[0], ptsy[0], &vx0, &vy0); MAP_POINT(ptsx[1], ptsy[1], &vx1, &vy1);
                plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx0, (float)vy0);
                plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx1, (float)vy1);
              }
            }
          }
          plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
        } break;
        default: break;
      }
      }
    }

    plutovg_canvas_restore((plutovg_canvas_t *)(intptr_t)canvas);

    if (font_ok && legend_pos != 0) {
      double lx = (legend_pos == 2 || legend_pos == 4) ? left + 12.0 : right - 120.0;
      double ly = (legend_pos == 3 || legend_pos == 4) ? bottom - 16.0 : top + 16.0;
      plutovg_canvas_set_font_face((plutovg_canvas_t *)(intptr_t)canvas, font);
      plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 12.0f);
      int row = 0;
      RendVec *__rvec3 = (RendVec *)(intptr_t)renderers;
      size_t __rlen3 = __rvec3 ? __rvec3->len : 0;
      for (size_t __ri3 = 0; __ri3 < __rlen3; __ri3++) {
        PlotRenderer *r = (PlotRenderer *)(intptr_t)__rvec3->data[__ri3];
        if (!r || !r->label || !r->label[0]) continue;
        double y = ly + row * 16.0;
        int color = row % 8;
        plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas,
                                (float)palette[color][0], (float)palette[color][1],
                                (float)palette[color][2], 1.0f);
        plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)lx, (float)y);
        plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)(lx + 12.0), (float)y);
        plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
        plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.15f, 0.15f, 0.15f, 1.0f);
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas, r->label, (int)strlen(r->label),
                                 PLUTOVG_TEXT_ENCODING_UTF8, (float)(lx + 18.0), (float)(y + 4.0));
        row++;
      }
    }
    if (font) plutovg_font_face_destroy(font);
    RETURN_OK(0);
    ```)

  ;;; plot -- render a Vec[Renderer] to a new surface and return it.
  ;;;
  ;;; renderers is a Vec[Renderer] (build with vec-of, or vec-new + vec-push!).
  ;;; This used to be a cons list (:int with terminating 0) prior to 0.2.0.
  (defn plot [renderers :int opts :int] :ptr<void>
    (let [w (if (> (plot-opts-width opts) 0) (plot-opts-width opts) 600)
          h (if (> (plot-opts-height opts) 0) (plot-opts-height opts) 450)
          sr (__surface-create w h)]
      (if (__ok? sr)
        (let [surface (__ok-val sr)
              cr (__canvas-create surface)]
          (if (__ok? cr)
            (let [canvas (__ok-val cr)
                  rr (plot-into-canvas canvas renderers opts 0 0 w h)]
              (__canvas-destroy canvas)
              (if (__ok? rr)
                (__ok surface)
                (do
                  (__surface-destroy surface)
                  (__err (__err-val rr)))))
            (__err (__err-val cr))))
        (__err (__err-val sr)))))

  ;;; plot-write-png -- render a Vec[Renderer] and write it to a PNG file.
  ;;;
  ;;; renderers is a Vec[Renderer] (build with vec-of, or vec-new + vec-push!).
  ;;; This used to be a cons list (:int with terminating 0) prior to 0.2.0.
  (defn plot-write-png [renderers :int opts :int path :cstr] :ptr<void>
    (let [r (plot renderers opts)]
      (if (__ok? r)
        (let [s (__ok-val r)
              wr (__surface-write-png s path)]
          (__surface-destroy s)
          wr)
        (__err (__err-val r)))))

) ;; end defmodule plot/core
