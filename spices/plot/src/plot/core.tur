            double vx, vy; MAP_POINT(x, y, &vx, &vy);
            if (!have) plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)vy);
            else plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)vy);
            px0 = vx; py0 = vy; have = true;
          }
          if (have) plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
        } break;
        case RK_FUNCTION:
        case RK_INVERSE:
        case RK_DENSITY:
        case RK_PARAMETRIC:
        case RK_POLAR: {
          SET_LINE_STYLE(r->style1, ((int *)0));
          int n = (int)r->i1; if (n < 32) n = 32;
          if (r->kind == RK_DENSITY) {
            bool started = false;
            double xs[2048]; int m = 0;
            double mean = 0.0, sd = 0.0;
            for (Cons *p = (Cons *)(intptr_t)r->data1; p && m < 2048; p = (Cons *)(intptr_t)p->tail) {
              xs[m++] = BITS_DBL(p->head);
              mean += xs[m - 1];
            }
            if (m == 0) break;
            mean /= (double)m;
            for (int i = 0; i < m; i++) { double d = xs[i] - mean; sd += d * d; }
            sd = sqrt(sd / (double)(m > 1 ? m - 1 : 1));
            double bw = r->f1 > 0.0 ? r->f1 : (1.06 * sd * pow((double)m, -0.2));
            if (!(bw > 0.0)) bw = 1.0;
            for (int i = 0; i < n; i++) {
              double x = bx_min + (bx_max - bx_min) * ((double)i / (double)(n - 1));
              double sum = 0.0;
              for (int j = 0; j < m; j++) {
