    #define BITS_DBL(v) (((union { double d; int64_t i; }){.i=(v)}).d)
    #define ISNAN(v) ((v) != (v))
    typedef struct { int64_t *data; size_t len; size_t cap; } RendVec;
    int auto_color = 0;
    #define NEXT_AUTO() ((auto_color++) % 8)
    #define SET_LINE_STYLE(HANDLE, RESOLVED_COLOR) do { \
      LineStyle *__ls = (LineStyle *)(intptr_t)(HANDLE); \
      int *__resolved_color = (RESOLVED_COLOR); \
      int __color = __ls ? (int)__ls->color : -1; \
      if (__color < 0) __color = NEXT_AUTO(); \
      __color %= 8; if (__color < 0) __color += 8; \
      double __alpha = (__ls && __ls->alpha > 0.0) ? __ls->alpha : 1.0; \
      double __width = (__ls && __ls->width > 0.0) ? __ls->width : 1.5; \
      plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, \
                              (float)palette[__color][0], (float)palette[__color][1], \
                              (float)palette[__color][2], (float)__alpha); \
      plutovg_canvas_set_line_width((plutovg_canvas_t *)(intptr_t)canvas, (float)__width); \
      if (__resolved_color) *__resolved_color = __color; \
