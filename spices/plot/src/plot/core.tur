;; plot/core.tur -- renderer representation and plot entrypoints.

(defmodule plot/core
  (export plot plot-write-png plot-into-canvas render
          __make-renderer __renderer-floats __renderer-ints __renderer-bounds
          __surface-create __surface-destroy __surface-write-png
          __canvas-create __canvas-destroy
          __plot-sample-adaptive
          BBox renderer-bbox bbox-empty? bbox-from-raw
          LinesR PointsR LabelR lines-r points-r label-r
          any-renderer renderers-bbox bbox-union bbox-empty-box
          anyrenderers->legacy plot-anyrenderers __surfaces-equal?
          __ok? __ok-val __err-val
          __surface-width __surface-height __surface-pixel-byte
          __pixel-is-background? __count-non-background)

  (import plot/style :refer [plot-opts-width plot-opts-height])

  ;;; __ok -- create an ok result wrapping integer value v.
  (defn __ok [v : int] : ptr<void>
    ```c
    #include <stdlib.h>
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = true; r->ok_val = v; r->err_val = 0; return r;
    ```)

  ;;; __err -- create an err result wrapping integer error value e.
  (defn __err [e : int] : ptr<void>
    ```c
    #include <stdlib.h>
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = false; r->ok_val = 0; r->err_val = e; return r;
    ```)

  ;;; __ok? -- predicate for the local :ptr<void> result envelope.
  (defn __ok? [r : ptr<void>] : bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res && res->is_ok;
    ```)

  ;;; __ok-val -- extract the ok payload from the local :ptr<void> result envelope.
  (defn __ok-val [r : ptr<void>] : int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res ? res->ok_val : 0;
    ```)

  ;;; __err-val -- extract the err payload from the local :ptr<void> result envelope.
  (defn __err-val [r : ptr<void>] : int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res ? res->err_val : 0;
    ```)

  ;;; __make-renderer -- allocate the generic opaque renderer handle used by all plot modules.
  (defn __make-renderer [kind : int
                         style1 : int style2 : int
                         data1 : int data2 : int data3 : int data4 : int data5 : int
                         label : cstr text : cstr] : int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    #include <string.h>
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)malloc(sizeof(*r));
    const char *src_label = (const char *)(intptr_t)label;
    const char *src_text = (const char *)(intptr_t)text;
    if (!r) return 0;
    r->kind = kind;
    r->style1 = style1; r->style2 = style2;
    r->data1 = data1; r->data2 = data2; r->data3 = data3; r->data4 = data4; r->data5 = data5;
    r->f1 = 0.0; r->f2 = 0.0; r->f3 = 0.0; r->f4 = 0.0; r->f5 = 0.0; r->f6 = 0.0;
    r->i1 = 0; r->i2 = 0; r->i3 = 0; r->i4 = 0;
    if (src_label) {
      size_t len = strlen(src_label);
      r->label = (char *)malloc(len + 1);
      if (r->label) memcpy(r->label, src_label, len + 1);
    } else {
      r->label = NULL;
    }
    if (src_text) {
      size_t len = strlen(src_text);
      r->text = (char *)malloc(len + 1);
      if (r->text) memcpy(r->text, src_text, len + 1);
    } else {
      r->text = NULL;
    }
    r->x_min = 0.0 / 0.0; r->x_max = 0.0 / 0.0; r->y_min = 0.0 / 0.0; r->y_max = 0.0 / 0.0;
    return (int64_t)(intptr_t)r;
    ```)

  ;;; __renderer-floats -- attach the six generic float payload slots to a renderer.
  (defn __renderer-floats [renderer : int
                           f1 : float f2 : float f3 : float f4 : float f5 : float f6 : float] : int
    ```c
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) return 0;
    r->f1 = f1; r->f2 = f2; r->f3 = f3; r->f4 = f4; r->f5 = f5; r->f6 = f6;
    return renderer;
    ```)

  ;;; __renderer-ints -- attach the four generic integer payload slots to a renderer.
  (defn __renderer-ints [renderer : int i1 : int i2 : int i3 : int i4 : int] : int
    ```c
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) return 0;
    r->i1 = i1; r->i2 = i2; r->i3 = i3; r->i4 = i4;
    return renderer;
    ```)

  ;;; __renderer-bounds -- attach explicit bounds hints to a renderer.
  (defn __renderer-bounds [renderer : int x-min : float x-max : float y-min : float y-max : float] : int
    ```c
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) return 0;
    r->x_min = x_min; r->x_max = x_max; r->y_min = y_min; r->y_max = y_max;
    return renderer;
    ```)

  ;;; __surface-create -- allocate a new plutovg surface.
  (defn __surface-create [width : int height : int] : ptr<void>
    ```c
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    extern void* plutovg_surface_create(int width, int height);
    void *s = plutovg_surface_create((int)width, (int)height);
    PlotResult *r = (PlotResult *)malloc(sizeof(*r));
    r->is_ok = s != NULL;
    r->ok_val = s ? (int64_t)(intptr_t)s : 0;
    r->err_val = s ? 0 : 1;
    return r;
    ```)

  ;;; __surface-destroy -- destroy a plutovg surface.
  (defn __surface-destroy [surface : int] : void
    ```c
    extern void plutovg_surface_destroy(void* surface);
    if (surface) plutovg_surface_destroy((void *)(intptr_t)surface);
    ```)

  ;;; __surface-write-png -- write a plutovg surface to a PNG file.
  (defn __surface-write-png [surface : int path : cstr] : ptr<void>
    ```c
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    extern bool plutovg_surface_write_to_png(const void* surface, const char* filename);
    bool ok = plutovg_surface_write_to_png((void *)(intptr_t)surface,
                                           (const char *)(intptr_t)path);
    PlotResult *r = (PlotResult *)malloc(sizeof(*r));
    r->is_ok = ok;
    r->ok_val = 0;
    r->err_val = ok ? 0 : 1;
    return r;
    ```)

  ;;; __canvas-create -- allocate a canvas for an existing surface.
  (defn __canvas-create [surface : int] : ptr<void>
    ```c
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    extern void* plutovg_canvas_create(void* surface);
    void *c = plutovg_canvas_create((void *)(intptr_t)surface);
    PlotResult *r = (PlotResult *)malloc(sizeof(*r));
    r->is_ok = c != NULL;
    r->ok_val = c ? (int64_t)(intptr_t)c : 0;
    r->err_val = c ? 0 : 1;
    return r;
    ```)

  ;;; __canvas-destroy -- destroy a plutovg canvas.
  (defn __canvas-destroy [canvas : int] : void
    ```c
    extern void plutovg_canvas_destroy(void* canvas);
    if (canvas) plutovg_canvas_destroy((void *)(intptr_t)canvas);
    ```)

  ;;; __surface-width -- width of a plutovg surface in pixels.
  (defn __surface-width [surface : int] : int
    ```c
    extern int plutovg_surface_get_width(const void* surface);
    if (!surface) return 0;
    return (int64_t)plutovg_surface_get_width((const void *)(intptr_t)surface);
    ```)

  ;;; __surface-height -- height of a plutovg surface in pixels.
  (defn __surface-height [surface : int] : int
    ```c
    extern int plutovg_surface_get_height(const void* surface);
    if (!surface) return 0;
    return (int64_t)plutovg_surface_get_height((const void *)(intptr_t)surface);
    ```)

  ;;; __surface-pixel-byte -- read a single byte from the surface's raw pixel buffer.
  ;;;
  ;;; plutovg stores pixels in 32-bpp BGRA order (premultiplied alpha) on
  ;;; little-endian platforms. `channel` selects the byte within the pixel:
  ;;;   0 -- B, 1 -- G, 2 -- R, 3 -- A.
  ;;; Returns -1 if (x, y) is out of bounds.
  (defn __surface-pixel-byte [surface : int x : int y : int channel : int] : int
    ```c
    extern unsigned char* plutovg_surface_get_data(const void* surface);
    extern int plutovg_surface_get_width(const void* surface);
    extern int plutovg_surface_get_height(const void* surface);
    extern int plutovg_surface_get_stride(const void* surface);
    if (!surface) return -1;
    int w = plutovg_surface_get_width((const void *)(intptr_t)surface);
    int h = plutovg_surface_get_height((const void *)(intptr_t)surface);
    if ((int)x < 0 || (int)x >= w || (int)y < 0 || (int)y >= h) return -1;
    if ((int)channel < 0 || (int)channel > 3) return -1;
    int stride = plutovg_surface_get_stride((const void *)(intptr_t)surface);
    unsigned char *data = plutovg_surface_get_data((const void *)(intptr_t)surface);
    if (!data) return -1;
    return (int64_t)data[(int)y * stride + (int)x * 4 + (int)channel];
    ```)

  ;;; __count-non-background -- count pixels in [x0, x1) x [y0, y1) that are not background.
  ;;;
  ;;; Useful for "this renderer produced *some* ink in this region" assertions
  ;;; without pinning a specific pixel.
  (defn __count-non-background [surface : int
                                x0 : int y0 : int
                                x1 : int y1 : int] : int
    ```c
    extern unsigned char* plutovg_surface_get_data(const void* surface);
    extern int plutovg_surface_get_width(const void* surface);
    extern int plutovg_surface_get_height(const void* surface);
    extern int plutovg_surface_get_stride(const void* surface);
    if (!surface) return 0;
    int w = plutovg_surface_get_width((const void *)(intptr_t)surface);
    int h = plutovg_surface_get_height((const void *)(intptr_t)surface);
    int stride = plutovg_surface_get_stride((const void *)(intptr_t)surface);
    unsigned char *data = plutovg_surface_get_data((const void *)(intptr_t)surface);
    if (!data) return 0;
    int xa = (int)x0 < 0 ? 0 : (int)x0;
    int ya = (int)y0 < 0 ? 0 : (int)y0;
    int xb = (int)x1 > w ? w : (int)x1;
    int yb = (int)y1 > h ? h : (int)y1;
    int64_t cnt = 0;
    for (int yy = ya; yy < yb; yy++) {
      for (int xx = xa; xx < xb; xx++) {
        unsigned char b = data[yy * stride + xx * 4 + 0];
        unsigned char g = data[yy * stride + xx * 4 + 1];
        unsigned char r = data[yy * stride + xx * 4 + 2];
        unsigned char a = data[yy * stride + xx * 4 + 3];
        if (!(r >= 250 && g >= 250 && b >= 250 && a >= 250)) cnt++;
      }
    }
    return cnt;
    ```)

  ;;; __pixel-is-background? -- true when a pixel is near pure white (>=250 in all RGB channels and full alpha).
  ;;;
  ;;; Useful for "this region was not drawn over" assertions. The plot
  ;;; background is `fill_rect` with rgba(1,1,1,1).
  (defn __pixel-is-background? [surface : int x : int y : int] : bool
    ```c
    extern unsigned char* plutovg_surface_get_data(const void* surface);
    extern int plutovg_surface_get_width(const void* surface);
    extern int plutovg_surface_get_height(const void* surface);
    extern int plutovg_surface_get_stride(const void* surface);
    if (!surface) return false;
    int w = plutovg_surface_get_width((const void *)(intptr_t)surface);
    int h = plutovg_surface_get_height((const void *)(intptr_t)surface);
    if ((int)x < 0 || (int)x >= w || (int)y < 0 || (int)y >= h) return false;
    int stride = plutovg_surface_get_stride((const void *)(intptr_t)surface);
    unsigned char *data = plutovg_surface_get_data((const void *)(intptr_t)surface);
    if (!data) return false;
    unsigned char b = data[(int)y * stride + (int)x * 4 + 0];
    unsigned char g = data[(int)y * stride + (int)x * 4 + 1];
    unsigned char r = data[(int)y * stride + (int)x * 4 + 2];
    unsigned char a = data[(int)y * stride + (int)x * 4 + 3];
    return r >= 250 && g >= 250 && b >= 250 && a >= 250;
    ```)

  ;;; __plot-sample-adaptive -- adaptive subdivision sampler for sampled-line renderers.
  ;;;
  ;;; Walks the parameter interval `[r->f1, r->f2]` in `initial-samples`
  ;;; uniform pieces and bisects each piece when the angle between adjacent
  ;;; screen-space segments exceeds the subdivision threshold, up to a fixed
  ;;; recursion cap. NaN evaluations break the active sub-path so curves with
  ;;; vertical asymptotes (e.g. tan, 1/x) render as separate strokes.
  ;;;
  ;;; Strokes the resulting polyline onto canvas. The caller is responsible for
  ;;; installing the line style (color / width / dash / alpha) before invoking.
  ;;; Supports renderer kinds RK_FUNCTION (21), RK_PARAMETRIC (22),
  ;;; RK_POLAR (23), and RK_INVERSE (24); other kinds are a no-op.
  ;;;
  ;;; Parameters:
  ;;;   renderer        -- PlotRenderer* (treat as opaque int64_t handle)
  ;;;   canvas          -- plutovg canvas handle
  ;;;   bx-min/bx-max   -- data-space x bounds
  ;;;   by-min/by-max   -- data-space y bounds
  ;;;   left/top        -- viewport top-left in canvas pixels
  ;;;   plot-w/plot-h   -- viewport size in pixels
  ;;;   initial-samples -- baseline uniform sample count (clamped to >= 2)
  ;;;
  ;;; Since: plot-v0.1.0
  ;;;
  ;;; Pinned to the stable C symbol `plot_sample_adaptive` via `export-as` so
  ;;; the inline-C call site in `plot-into-canvas` below can name it directly.
  ;;; Without the pin, turmeric's injective identifier mangler encodes this
  ;;; `__`-prefixed, kebab-cased name as `..._un_unplot_hysample_hyadaptive`,
  ;;; which the hand-written C call could not track across mangling changes.
  (defn (export-as "plot_sample_adaptive")
        __plot-sample-adaptive [renderer : int canvas : int
                                bx-min : float bx-max : float
                                by-min : float by-max : float
                                left : int top : int
                                plot-w : int plot-h : int
                                initial-samples : int] : void
    ```c
    extern double cos(double);
    extern double sin(double);
    extern double sqrt(double);
    extern void plutovg_canvas_move_to(void* canvas, float x, float y);
    extern void plutovg_canvas_line_to(void* canvas, float x, float y);
    extern void plutovg_canvas_stroke(void* canvas);

    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;

    #define ADAPTIVE_BITS_DBL(v) (((union { double d; int64_t i; }){.i=(v)}).d)
    #define ADAPTIVE_ISNAN(v) ((v) != (v))

    enum { RK_FUNCTION_K = 21, RK_PARAMETRIC_K = 22, RK_POLAR_K = 23, RK_INVERSE_K = 24 };

    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    void *cv = (void *)(intptr_t)canvas;
    if (!r || !cv) return;
    if (r->kind != RK_FUNCTION_K && r->kind != RK_INVERSE_K
        && r->kind != RK_PARAMETRIC_K && r->kind != RK_POLAR_K) return;

    int n = (int)initial_samples; if (n < 2) n = 2;
    double t_min = r->f1, t_max = r->f2;
    if (!(t_max > t_min)) return;
    double inv_w = (bx_max > bx_min) ? 1.0 / (bx_max - bx_min) : 1.0;
    double inv_h = (by_max > by_min) ? 1.0 / (by_max - by_min) : 1.0;
    double pw_d = (double)plot_w, ph_d = (double)plot_h;
    double left_d = (double)left, top_d = (double)top;

    enum { MAX_DEPTH = 6 };
    const double cos_thresh = 0.9961947;  /* cos(5 deg) */
    const double min_seg_px2 = 0.25;      /* (0.5 px)^2 floor */

    typedef struct { double t; double vx, vy; int valid; } Sample;

    #define EVAL_AT(T, OUT) do { \
      double __t = (T); \
      double __x = 0.0, __y = 0.0; \
      if (r->kind == RK_FUNCTION_K) { __x = __t; __y = ((double(*)(double))(intptr_t)r->data1)(__t); } \
      else if (r->kind == RK_INVERSE_K) { __y = __t; __x = ((double(*)(double))(intptr_t)r->data1)(__t); } \
      else if (r->kind == RK_PARAMETRIC_K) { \
        Cons *__pair = (Cons *)(intptr_t)((int64_t(*)(double))(intptr_t)r->data1)(__t); \
        if (__pair) { __x = ADAPTIVE_BITS_DBL(__pair->head); __y = ADAPTIVE_BITS_DBL(__pair->tail); } \
        else { __x = __y = 0.0/0.0; } \
      } else { \
        double __radius = ((double(*)(double))(intptr_t)r->data1)(__t); \
        __x = __radius * cos(__t); __y = __radius * sin(__t); \
      } \
      (OUT).t = __t; \
      if (ADAPTIVE_ISNAN(__x) || ADAPTIVE_ISNAN(__y)) { (OUT).valid = 0; (OUT).vx = 0.0; (OUT).vy = 0.0; } \
      else { \
        double __tx = (__x - bx_min) * inv_w; \
        double __ty = (__y - by_min) * inv_h; \
        (OUT).vx = left_d + __tx * pw_d; \
        (OUT).vy = top_d + ph_d - __ty * ph_d; \
        (OUT).valid = 1; \
      } \
    } while (0)

    int started = 0;
    #define EMIT(S) do { \
      if ((S).valid) { \
        if (!started) { plutovg_canvas_move_to(cv, (float)(S).vx, (float)(S).vy); started = 1; } \
        else { plutovg_canvas_line_to(cv, (float)(S).vx, (float)(S).vy); } \
      } else { \
        started = 0; \
      } \
    } while (0)

    typedef struct { Sample A, B; int depth; } Frame;
    Frame stack[MAX_DEPTH * 2 + 4];

    Sample prev; EVAL_AT(t_min, prev);
    EMIT(prev);

    for (int i = 0; i < n - 1; i++) {
      double tB = t_min + (t_max - t_min) * ((double)(i + 1) / (double)(n - 1));
      Sample A = prev;
      Sample B; EVAL_AT(tB, B);

      int sp = 0;
      stack[sp].A = A; stack[sp].B = B; stack[sp].depth = 0; sp++;

      while (sp > 0) {
        Frame f = stack[--sp];
        int subdivide = 0;
        Sample M; M.valid = 0; M.t = 0.0; M.vx = 0.0; M.vy = 0.0;
        double dx_ab = f.B.vx - f.A.vx;
        double dy_ab = f.B.vy - f.A.vy;
        double seg_len2 = dx_ab * dx_ab + dy_ab * dy_ab;
        int both_valid = f.A.valid && f.B.valid;

        if (f.depth < MAX_DEPTH && (!both_valid || seg_len2 > min_seg_px2)) {
          double tM = 0.5 * (f.A.t + f.B.t);
          EVAL_AT(tM, M);
          if (M.valid != f.A.valid || M.valid != f.B.valid) {
            /* Validity transition inside segment -> bisect to localize the gap. */
            subdivide = 1;
          } else if (both_valid && M.valid) {
            double v1x = M.vx - f.A.vx, v1y = M.vy - f.A.vy;
            double v2x = f.B.vx - M.vx, v2y = f.B.vy - M.vy;
            double l1 = v1x * v1x + v1y * v1y;
            double l2 = v2x * v2x + v2y * v2y;
            if (l1 > min_seg_px2 && l2 > min_seg_px2) {
              double dot = v1x * v2x + v1y * v2y;
              double denom = sqrt(l1 * l2);
              double cos_a = (denom > 0.0) ? (dot / denom) : 1.0;
              if (cos_a < cos_thresh) subdivide = 1;
            }
          }
        }

        if (subdivide) {
          /* Right then left so left pops first => emission is left-to-right. */
          stack[sp].A = M;   stack[sp].B = f.B; stack[sp].depth = f.depth + 1; sp++;
          stack[sp].A = f.A; stack[sp].B = M;   stack[sp].depth = f.depth + 1; sp++;
        } else {
          EMIT(f.B);
        }
      }

      prev = B;
    }

    if (started) plutovg_canvas_stroke(cv);

    #undef EVAL_AT
    #undef EMIT
    #undef ADAPTIVE_BITS_DBL
    #undef ADAPTIVE_ISNAN
    ```)

  ;;; data->viewport -- map data coordinates to viewport coordinates.
  (defn data->viewport [x : float y : float bx-min : float bx-max : float
                        by-min : float by-max : float
                        px : int py : int pw : int ph : int] : int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    typedef struct { double x; double y; } Pt;
    Pt *p = (Pt *)malloc(sizeof(*p));
    double tx = (x - bx_min) / (bx_max - bx_min);
    double ty = (y - by_min) / (by_max - by_min);
    p->x = (double)px + tx * (double)pw;
    p->y = (double)py + (1.0 - ty) * (double)ph;
    return (int64_t)(intptr_t)p;
    ```)

  ;;; viewport->data -- map viewport coordinates back to data coordinates.
  (defn viewport->data [vx : float vy : float bx-min : float bx-max : float
                        by-min : float by-max : float
                        px : int py : int pw : int ph : int] : int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    typedef struct { double x; double y; } Pt;
    Pt *p = (Pt *)malloc(sizeof(*p));
    double tx = (vx - (double)px) / (double)pw;
    double ty = 1.0 - ((vy - (double)py) / (double)ph);
    p->x = bx_min + tx * (bx_max - bx_min);
    p->y = by_min + ty * (by_max - by_min);
    return (int64_t)(intptr_t)p;
    ```)

  ;;; __renderer-bbox -- compute a single renderer's data-space bounding box.
  ;;;
  ;;; P0 de-monolith of the plot Renderer typeclass plan: this is the former
  ;;; per-kind bounds-union `switch` lifted verbatim out of `plot-into-canvas`
  ;;; into a standalone, independently-callable function. Each renderer kind
  ;;; unions its own points into a local box; `plot-into-canvas` now folds the
  ;;; returned box corners instead of inlining ~80 lines of per-kind C.
  ;;;
  ;;; Returns a malloc'd carrier `{ double x0, x1, y0, y1; int valid; }` (an
  ;;; int64 handle). `valid == 0` means the renderer contributed no finite
  ;;; point, so callers must skip it. The caller owns the buffer and frees it.
  ;;;
  ;;; Folding box corners is identical to unioning the underlying points:
  ;;; min/max over all points == min/max over per-renderer box corners, so the
  ;;; resolved plot bounds (and therefore every pixel) are unchanged.
  ;;;
  ;;; Pinned to the stable C symbol `plot_renderer_bbox` via `export-as` so the
  ;;; inline-C fold site in `plot-into-canvas` can name it directly, mirroring
  ;;; the `plot_sample_adaptive` pin above.
  (defn (export-as "plot_renderer_bbox") __renderer-bbox [renderer : int] : ptr<void>
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    typedef struct { double x0, x1, y0, y1; int valid; } RBBox;

    enum {
      RK_HRULE = 7, RK_VRULE = 8, RK_LABEL = 9,
      RK_LINES = 20, RK_FUNCTION = 21, RK_PARAMETRIC = 22, RK_POLAR = 23, RK_INVERSE = 24, RK_DENSITY = 25,
      RK_POINTS = 30, RK_ERROR_BARS = 31, RK_VECTOR_FIELD = 32, RK_ARROWS = 33,
      RK_FUNCTION_INTERVAL = 40, RK_LINES_INTERVAL = 41, RK_PARAM_INTERVAL = 42, RK_POLAR_INTERVAL = 43,
      RK_RECTANGLES = 50, RK_AREA_HIST = 51, RK_DISCRETE_HIST = 52, RK_STACKED_HIST = 53,
      RK_ISOLINE = 60, RK_CONTOURS = 61, RK_CONTOUR_INTERVALS = 62, RK_COLOR_FIELD = 63
    };

    #define BITS_DBL(v) (((union { double d; int64_t i; }){.i=(v)}).d)
    #define ISNAN(v) ((v) != (v))

    RBBox *out = (RBBox *)malloc(sizeof(*out));
    double lx0 = 0.0, lx1 = 0.0, ly0 = 0.0, ly1 = 0.0;
    int lvalid = 0;
    #define UNION_POINT(X, Y) do { \
      double __ux = (X), __uy = (Y); \
      if (!ISNAN(__ux) && !ISNAN(__uy)) { \
        if (!lvalid) { lx0 = lx1 = __ux; ly0 = ly1 = __uy; lvalid = 1; } \
        else { \
          if (__ux < lx0) lx0 = __ux; \
          if (__ux > lx1) lx1 = __ux; \
          if (__uy < ly0) ly0 = __uy; \
          if (__uy > ly1) ly1 = __uy; \
        } \
      } \
    } while (0)
    #define UNION_LIST_POINTS(LST) do { \
      for (Cons *__p = (Cons *)(intptr_t)(LST); __p; __p = (Cons *)(intptr_t)__p->tail) { \
        Cons *__pt = (Cons *)(intptr_t)__p->head; \
        if (!__pt) continue; \
        UNION_POINT(BITS_DBL(__pt->head), BITS_DBL(__pt->tail)); \
      } \
    } while (0)

    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) { out->x0 = out->x1 = out->y0 = out->y1 = 0.0; out->valid = 0; return (int64_t)(intptr_t)out; }

    switch ((int)r->kind) {
      case RK_LINES:
      case RK_POINTS:
      case RK_ARROWS:
        UNION_LIST_POINTS(r->data1);
        break;
      case RK_ERROR_BARS: {
        for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail) {
          Cons *a = (Cons *)(intptr_t)p->head;
          if (!a) continue;
          double x = BITS_DBL(a->head);
          Cons *b = (Cons *)(intptr_t)a->tail;
          if (!b) continue;
          double y = BITS_DBL(b->head);
          double h = BITS_DBL(b->tail);
          if (r->i1) { UNION_POINT(x - h, y); UNION_POINT(x + h, y); }
          else { UNION_POINT(x, y - h); UNION_POINT(x, y + h); }
        }
      } break;
      case RK_HRULE: UNION_POINT(0.0, r->f1); break;
      case RK_VRULE: UNION_POINT(r->f1, 0.0); break;
      case RK_LABEL: UNION_POINT(r->f1, r->f2); break;
      case RK_RECTANGLES:
      case RK_AREA_HIST: {
        for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail) {
          Cons *a = (Cons *)(intptr_t)p->head;
          if (!a) continue;
          double x0 = BITS_DBL(a->head);
          Cons *b = (Cons *)(intptr_t)a->tail;
          double x1 = BITS_DBL(b->head);
          Cons *c = (Cons *)(intptr_t)b->tail;
          double y0 = BITS_DBL(c->head);
          double y1 = BITS_DBL(c->tail);
          UNION_POINT(x0, y0);
          UNION_POINT(x1, y1);
        }
      } break;
      case RK_DISCRETE_HIST: {
        int idx = 0;
        for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail, idx++) {
          Cons *bar = (Cons *)(intptr_t)p->head;
          if (!bar) continue;
          double h = BITS_DBL(bar->tail);
          if (r->i1) { UNION_POINT(0.0, idx); UNION_POINT(h, idx + 0.8); }
          else { UNION_POINT(idx, 0.0); UNION_POINT(idx + 0.8, h); }
        }
      } break;
      case RK_STACKED_HIST: {
        int idx = 0;
        for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail, idx++) {
          Cons *grp = (Cons *)(intptr_t)p->head;
          double sum = 0.0;
          for (Cons *vals = (Cons *)(intptr_t)grp->tail; vals; vals = (Cons *)(intptr_t)vals->tail)
            sum += BITS_DBL(vals->head);
          if (r->i1) { UNION_POINT(0.0, idx); UNION_POINT(sum, idx + 0.8); }
          else { UNION_POINT(idx, 0.0); UNION_POINT(idx + 0.8, sum); }
        }
      } break;
      case RK_FUNCTION:
      case RK_INVERSE:
      case RK_DENSITY:
      case RK_PARAMETRIC:
      case RK_POLAR:
      case RK_FUNCTION_INTERVAL:
      case RK_PARAM_INTERVAL:
      case RK_POLAR_INTERVAL:
      case RK_ISOLINE:
      case RK_CONTOURS:
      case RK_CONTOUR_INTERVALS:
      case RK_COLOR_FIELD:
      case RK_VECTOR_FIELD:
        if (!ISNAN(r->x_min) && !ISNAN(r->x_max) && !ISNAN(r->y_min) && !ISNAN(r->y_max)) {
          UNION_POINT(r->x_min, r->y_min);
          UNION_POINT(r->x_max, r->y_max);
        }
        break;
      case RK_LINES_INTERVAL: UNION_LIST_POINTS(r->data1); UNION_LIST_POINTS(r->data2); break;
      default: break;
    }

    out->x0 = lx0; out->x1 = lx1; out->y0 = ly0; out->y1 = ly1; out->valid = lvalid;
    return (int64_t)(intptr_t)out;
    #undef UNION_POINT
    #undef UNION_LIST_POINTS
    #undef BITS_DBL
    #undef ISNAN
    ```)

  ;;; BBox -- an axis-aligned data-space bounding box: the typed result of the
  ;;; bounds pass (P1 of the plot Renderer typeclass plan, the shape the future
  ;;; `Renderer` `bounds` method returns). An empty box -- a renderer that
  ;;; contributed no finite point -- is represented with `x-min` = NaN; use
  ;;; `bbox-empty?` to test for it.
  (defstruct BBox :copy [x-min : float  x-max : float  y-min : float  y-max : float])

  ;; Raw-carrier accessors over __renderer-bbox's { x0,x1,y0,y1; valid } buffer.
  (defn __rbb-valid? [b : ptr<void>] : bool
    ```c return ((struct { double x0,x1,y0,y1; int valid; } *)b)->valid != 0; ```)
  (defn __rbb-get [b : ptr<void> which : int] : float
    ```c
    struct RBB { double x0,x1,y0,y1; int valid; } *p = (struct RBB *)b;
    switch ((int)which) { case 0: return p->x0; case 1: return p->x1;
                          case 2: return p->y0; default: return p->y1; }
    ```)
  (defn __rbb-free [b : ptr<void>] : void ```c free(b); ```)
  (defn __rbb-nan [] : float ```c return 0.0 / 0.0; ```)

  ;;; bbox-empty? -- true when a BBox carries no finite extent (x-min is NaN).
  (defn bbox-empty? [bb : BBox] : bool
    (let [lo (.x-min bb)] (not (= lo lo))))

  ;;; renderer-bbox -- a renderer's data-space bounding box as a typed BBox.
  ;;;
  ;;; The Turmeric-level wrapper over the P0 `__renderer-bbox` extraction: it
  ;;; reads the raw carrier and packs a `BBox` (building it with `make-struct`,
  ;;; so no struct-by-value crosses the inline-C boundary). A renderer with no
  ;;; finite points yields an empty box (`bbox-empty?` true). This is the value
  ;;; the forthcoming `Renderer` typeclass's `bounds` method will hand back.
  (defn renderer-bbox [renderer : int] : BBox
    (bbox-from-raw (__renderer-bbox renderer)))

  ;;; bbox-from-raw -- pack the raw { x0,x1,y0,y1; valid } carrier (as produced
  ;;; by __renderer-bbox / __point-list-bbox) into a typed BBox with make-struct
  ;;; (so no struct-by-value crosses the inline-C boundary), freeing the
  ;;; carrier. An invalid carrier becomes an empty box (x-min = NaN).
  (defn bbox-from-raw [b : ptr<void>] : BBox
    (if (__rbb-valid? b)
      (let [box (make-struct BBox (__rbb-get b 0) (__rbb-get b 1)
                                  (__rbb-get b 2) (__rbb-get b 3))]
        (do (__rbb-free b) box))
      (let [n   (__rbb-nan)
            box (make-struct BBox n n n n)]
        (do (__rbb-free b) box))))

  ;; ===========================================================================
  ;; Renderer typeclass -- U2 renderer-kind collapse, P2.
  ;;
  ;; The dispatch axis plot's plan targets is the renderer *kind*: the central
  ;; ~30-arm switch that interprets the generic data1..5 / f1..6 / i1..4 slot
  ;; bag differently per kind. P2 replaces "one int `kind` tag drives a switch"
  ;; with "each kind is a struct carrying its real typed payload + a `Renderer`
  ;; instance". This slice establishes the class and the `bounds` method over
  ;; the first per-kind structs, computing the data extent from named fields and
  ;; verified against the legacy slot-bag bounds. The `render` method (delegating
  ;; to the extracted draw pass) and the existential box that lets a heterogeneous
  ;; renderer Vec dispatch through the class land with P3/P4.
  ;; ===========================================================================

  ;;; __point-list-bbox -- bounding box of a cons-list of (cons x y) points: the
  ;;; bounds rule shared by the lines / points / arrows kinds. Same raw-carrier
  ;;; shape as __renderer-bbox; NaN coordinates are skipped, an empty list is an
  ;;; invalid (empty) box.
  (defn (export-as "plot_point_list_bbox") __point-list-bbox [points : int] : ptr<void>
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct { double x0, x1, y0, y1; int valid; } RBBox;
    #define BITS_DBL(v) (((union { double d; int64_t i; }){.i=(v)}).d)
    #define ISNAN(v) ((v) != (v))
    RBBox *out = (RBBox *)malloc(sizeof(*out));
    double lx0 = 0.0, lx1 = 0.0, ly0 = 0.0, ly1 = 0.0;
    int lvalid = 0;
    for (Cons *p = (Cons *)(intptr_t)points; p; p = (Cons *)(intptr_t)p->tail) {
      Cons *pt = (Cons *)(intptr_t)p->head;
      if (!pt) continue;
      double x = BITS_DBL(pt->head), y = BITS_DBL(pt->tail);
      if (ISNAN(x) || ISNAN(y)) continue;
      if (!lvalid) { lx0 = lx1 = x; ly0 = ly1 = y; lvalid = 1; }
      else { if (x < lx0) lx0 = x; if (x > lx1) lx1 = x;
             if (y < ly0) ly0 = y; if (y > ly1) ly1 = y; }
    }
    out->x0 = lx0; out->x1 = lx1; out->y0 = ly0; out->y1 = ly1; out->valid = lvalid;
    return (int64_t)(intptr_t)out;
    #undef BITS_DBL
    #undef ISNAN
    ```)

  ;;; Renderer -- typeclass collapsing the per-kind renderer dispatch. Each kind
  ;;; is a struct carrying its real typed fields; `bounds` computes the data
  ;;; extent from those fields and `to-legacy` lowers the struct to the slot-bag
  ;;; `int` handle the C draw pass still consumes. Lives beside its instances so
  ;;; the orphan-instance check is satisfied (same as ansi Color / json Encode).
  (defclass Renderer [a]
    (bounds [r] : BBox)
    (to-legacy [r] : int))

  ;;; LinesR / PointsR -- a polyline / scatter over an explicit (cons x y) list.
  ;;; PointsR is nominally distinct from LinesR though their payloads match, so
  ;;; the two can never be silently swapped (the slot-bag `kind` tag could be).
  (defstruct LinesR  :copy [points : int  style : int  label : cstr])
  (defstruct PointsR :copy [points : int  style : int  label : cstr])
  ;;; LabelR -- a text label anchored at one (x, y) data point.
  (defstruct LabelR  :copy [x : float  y : float  text : cstr  style : int])

  (defn lines-r  [points : int  style : int  label : cstr] : LinesR
    (make-struct LinesR points style label))
  (defn points-r [points : int  style : int  label : cstr] : PointsR
    (make-struct PointsR points style label))
  (defn label-r  [x : float  y : float  text : cstr  style : int] : LabelR
    (make-struct LabelR x y text style))

  ;; to-legacy rebuilds the exact slot-bag handle the legacy constructor emits
  ;; (`lines` -> RK_LINES 20, `points` -> RK_POINTS 30, `point-label-styled`
  ;; -> RK_LABEL 9), so routing a typed renderer through the existing draw pass
  ;; is pixel-identical to the legacy path.
  (definstance Renderer [LinesR]
    (bounds [r] (bbox-from-raw (__point-list-bbox (.points r))))
    (to-legacy [r] (__make-renderer 20 (.style r) 0 (.points r) 0 0 0 0 (.label r) "")))
  (definstance Renderer [PointsR]
    (bounds [r] (bbox-from-raw (__point-list-bbox (.points r))))
    (to-legacy [r] (__make-renderer 30 (.style r) 0 (.points r) 0 0 0 0 (.label r) "")))
  (definstance Renderer [LabelR]
    (bounds [r] (make-struct BBox (.x r) (.x r) (.y r) (.y r)))
    (to-legacy [r]
      (__renderer-bounds
        (__renderer-floats
          (__make-renderer 9 (.style r) 0 0 0 0 0 0 "" (.text r))
          (.x r) (.y r) 0.0 0.0 0.0 0.0)
        (.x r) (.x r) (.y r) (.y r))))

  ;; ===========================================================================
  ;; AnyRenderer -- existential box for heterogeneous renderer vecs (P3).
  ;;
  ;; A `(Vec (exists [a] [(Renderer a)] a))` holds renderers of different kinds
  ;; (LinesR, PointsR, LabelR, ...) behind one element type; `bounds`/`render`
  ;; dispatch through each element's *packed* Renderer dictionary instead of a
  ;; runtime `kind` switch. This needs witness-indirected `open` dispatch, which
  ;; landed in turmeric main (PRs #452 open-dispatch, #456 vec-get type
  ;; preservation, #458 by-value struct payload pack).
  ;;
  ;; The `bounds`/`to-legacy` folds below are local `letrec` closures that
  ;; capture the existential `rs` and dereference it via `open` inside the lifted
  ;; closure body. turmeric main fixed the self-recursive carrier typing (both
  ;; `defn` and `letrec`) and fresh `vec-new` argument unification, and #464
  ;; closed the last gap (W3): a captured binding referenced inside
  ;; `open`/`pack`/`dispatch` is now collected into the closure's capture set and
  ;; resolves to its env slot instead of mis-emitting an undeclared C name. So
  ;; the folds no longer need to be hoisted to top-level `defn`s that thread `rs`
  ;; as an explicit parameter.
  ;; (Callers building a heterogeneous `(Vec (exists ...))` literal still ascribe
  ;; the element type at construction -- see the `mixed-vec` helper in the
  ;; any_renderer test -- because the existential element is not back-inferred
  ;; from the pushes; that is a separate, narrower case from the `(Vec int)` one.)
  ;; ===========================================================================

  ;;; any-renderer -- box a value whose type has a `Renderer` instance as an
  ;;; `AnyRenderer` existential. The `(exists ...)` form must appear literally
  ;;; at the pack site, so this is a macro (same reason as stdlib `showable`).
  ;;;
  ;;;   (any-renderer (lines-r pts style ""))  ;; => packed AnyRenderer
  (defmacro any-renderer [x] (list pack x (list exists [a] [(list Renderer a)] a)))

  ;;; bbox-empty-box -- the identity element for `bbox-union`: an empty BBox
  ;;; (x-min = NaN), matching `bbox-empty?`.
  (defn bbox-empty-box [] : BBox
    (let [n (__rbb-nan)] (make-struct BBox n n n n)))

  ;;; bbox-union -- the smallest box covering both inputs; an empty box is the
  ;;; identity (so folding from `bbox-empty-box` recovers the first non-empty).
  ;;
  ;; An empty input returns the other box directly. (A multi-field `:copy`
  ;; struct is passed by pointer; returning such a parameter by value used to
  ;; mis-emit in C as 'incompatible types ... BBox from const BBox *' -- that
  ;; codegen bug is fixed in turmeric main, so the param can be returned as-is
  ;; instead of being rebuilt field-by-field.)
  (defn bbox-union [a : BBox  b : BBox] : BBox
    (if (bbox-empty? a) b
      (if (bbox-empty? b) a
        (make-struct BBox
          (if (< (.x-min a) (.x-min b)) (.x-min a) (.x-min b))
          (if (> (.x-max a) (.x-max b)) (.x-max a) (.x-max b))
          (if (< (.y-min a) (.y-min b)) (.y-min a) (.y-min b))
          (if (> (.y-max a) (.y-max b)) (.y-max a) (.y-max b))))))

  ;;; renderers-bbox -- data-space bounding box of a heterogeneous renderer Vec,
  ;;; unioning each element's `bounds` through the `AnyRenderer` existential.
  ;;; The P3 payoff: the union is driven by coherent typeclass dispatch, not the
  ;;; legacy ~30-arm `kind` switch in `__renderer-bbox`.
  ;;;
  ;;; The fold is a local `letrec` closure that captures the existential `rs` and
  ;;; `open`s each element under a fresh abstract type, dispatching `bounds`
  ;;; through the packed witness; the per-element box is unioned into a `BBox`
  ;;; accumulator seeded from `bbox-empty-box` (the union identity). The captured
  ;;; `rs`/`open` form is correct since turmeric #464 (W3).
  (defn renderers-bbox [rs : (Vec (exists [a] [(Renderer a)] a))] : BBox
    (let [n (vec-len rs)]
      (letrec [go (fn [i : int  acc : BBox] : BBox
                    (if (>= i n) acc
                      (go (+ i 1)
                          (bbox-union acc (open (vec-get rs i) [a v] (bounds v))))))]
        (go 0 (bbox-empty-box)))))

  ;;; anyrenderers->legacy -- materialise a (Vec AnyRenderer) as the legacy
  ;;; (Vec int) of slot-bag handles the C draw pass consumes. Each element's
  ;;; lowering dispatches through its packed Renderer dictionary (`to-legacy`).
  ;;;
  ;;; A local `letrec` closure folds the Vec: it captures the existential `rs`
  ;;; and the legacy `out` accumulator, `open`s each element, and pushes the
  ;;; lowered handle in place. The seed `out` is a bare `(vec-new)` (turmeric
  ;;; unifies its element tyvar against the `(Vec int)` result, W2), and the
  ;;; captured-`rs` `open` body emits correctly since #464 (W3).
  (defn anyrenderers->legacy [rs : (Vec (exists [a] [(Renderer a)] a))] : (Vec int)
    (let [n   (vec-len rs)
          out (vec-new)]
      (letrec [go (fn [i : int] : (Vec int)
                    (if (>= i n) out
                      (let [h (open (vec-get rs i) [a v] (to-legacy v))]
                        (do (vec-push! out h)
                            (go (+ i 1))))))]
        (go 0))))

  ;;; plot-anyrenderers -- render a heterogeneous (Vec AnyRenderer) to a new
  ;;; surface (returns the same :ptr<void> result envelope as `plot`). Each
  ;;; renderer is lowered through the `Renderer` typeclass (`to-legacy`) and the
  ;;; result handed to the existing draw pipeline -- so pixel output is identical
  ;;; to building the same renderers with the legacy constructors and calling
  ;;; `plot`, but the input is the typed, type-safe `AnyRenderer` vec.
  (defn plot-anyrenderers [rs : (Vec (exists [a] [(Renderer a)] a)) opts : int] : ptr<void>
    (plot (:: (anyrenderers->legacy rs) :int) opts))

  ;;; __surfaces-equal? -- true when two plutovg surfaces have identical
  ;;; dimensions and pixel bytes. Used to assert that the typed `AnyRenderer`
  ;;; draw path is pixel-identical to the legacy constructor path.
  (defn __surfaces-equal? [s1 : int s2 : int] : bool
    ```c
    #include <string.h>
    extern unsigned char* plutovg_surface_get_data(const void*);
    extern int plutovg_surface_get_width(const void*);
    extern int plutovg_surface_get_height(const void*);
    extern int plutovg_surface_get_stride(const void*);
    if (!s1 || !s2) return false;
    const void *a = (const void *)(intptr_t)s1, *b = (const void *)(intptr_t)s2;
    int w = plutovg_surface_get_width(a), h = plutovg_surface_get_height(a);
    if (w != plutovg_surface_get_width(b) || h != plutovg_surface_get_height(b)) return false;
    int sa = plutovg_surface_get_stride(a), sb = plutovg_surface_get_stride(b);
    unsigned char *da = plutovg_surface_get_data((void *)a);
    unsigned char *db = plutovg_surface_get_data((void *)b);
    if (!da || !db) return false;
    for (int y = 0; y < h; y++) {
      if (memcmp(da + (size_t)y * sa, db + (size_t)y * sb, (size_t)w * 4) != 0) return false;
    }
    return true;
    ```)

  ;;; plot-into-canvas -- render into an existing canvas and viewport.
  ;;;
  ;;; renderers is a Vec[Renderer] (built with vec-of or vec-new/vec-push!),
  ;;; not a cons list. Internal renderer payload data (e.g. lists of point
  ;;; pairs inside each renderer) is still cons-shaped -- only the top-level
  ;;; sequence of renderers is a Vec.
  ;;; __draw-renderers -- draw the renderer Vec into `canvas` at the already-
  ;;; resolved data bounds and viewport rect. P0 de-monolith of the plot
  ;;; Renderer plan: the former per-kind draw `switch`, its clip bracket, and the
  ;;; style / auto-color / MAP_POINT machinery are lifted verbatim out of the
  ;;; ~900-line plot-into-canvas body into this standalone, independently-callable
  ;;; function. plot-into-canvas now computes bounds/axes/labels and delegates the
  ;;; data rendering here. Pure code movement -- pixel output is byte-identical.
  ;;;
  ;;; Pinned to the stable C symbol `plot_draw_renderers` via `export-as` so
  ;;; plot-into-canvas's inline-C can name it across mangling (same idiom as
  ;;; `plot_sample_adaptive` / `plot_renderer_bbox`).
  (defn (export-as "plot_draw_renderers")
        __draw-renderers [canvas : int  renderers : int
                          bx-min : float  bx-max : float  by-min : float  by-max : float
                          left : int  right : int  top : int  bottom : int
                          plot-w : int  plot-h : int  font-ok : int] : void
