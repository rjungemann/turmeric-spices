            } else {
              double vxa, vya, vxb, vyb; MAP_POINT(x, y - h, &vxa, &vya); MAP_POINT(x, y + h, &vxb, &vyb);
              plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vxa, (float)vya);
              plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vxb, (float)vyb);
            }
          }
          plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
        } break;
        case RK_ARROWS:
        case RK_VECTOR_FIELD: {
          SET_LINE_STYLE(r->style1, ((int *)0));
          if (r->kind == RK_ARROWS) {
            for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail) {
              Cons *a = (Cons *)(intptr_t)p->head;
              double x1 = BITS_DBL(a->head);
              Cons *b = (Cons *)(intptr_t)a->tail;
              double y1 = BITS_DBL(b->head);
              Cons *c = (Cons *)(intptr_t)b->tail;
              double x2 = BITS_DBL(c->head);
              double y2 = BITS_DBL(c->tail);
