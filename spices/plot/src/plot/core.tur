      if (access(font_candidates[fi], R_OK) == 0) {
        font = plutovg_font_face_load_from_file(font_candidates[fi], 0);
        if (font) { font_ok = 1; break; }
      }
    }

    #define UNION_POINT(X, Y) do { \
      double __ux = (X), __uy = (Y); \
      if (!ISNAN(__ux) && !ISNAN(__uy)) { \
        if (!have_bounds) { \
          bx_min = bx_max = __ux; \
          by_min = by_max = __uy; \
          have_bounds = true; \
        } else { \
          if (__ux < bx_min) bx_min = __ux; \
          if (__ux > bx_max) bx_max = __ux; \
          if (__uy < by_min) by_min = __uy; \
          if (__uy > by_max) by_max = __uy; \
        } \
      } \
    } while (0)
    #define UNION_LIST_POINTS(LST) do { \
      for (Cons *__p = (Cons *)(intptr_t)(LST); __p; __p = (Cons *)(intptr_t)__p->tail) { \
        Cons *__pt = (Cons *)(intptr_t)__p->head; \
        if (!__pt) continue; \
        UNION_POINT(BITS_DBL(__pt->head), BITS_DBL(__pt->tail)); \
      } \
    } while (0)

    typedef struct { int64_t *data; size_t len; size_t cap; } RendVec;
    RendVec *__rvec = (RendVec *)(intptr_t)renderers;
    size_t __rlen = __rvec ? __rvec->len : 0;
    for (size_t __ri = 0; __ri < __rlen; __ri++) {
      PlotRenderer *r = (PlotRenderer *)(intptr_t)__rvec->data[__ri];
      if (!r) continue;
      if (r->kind == RK_X_AXIS || r->kind == RK_AXES) want_x_axis = true;
      if (r->kind == RK_Y_AXIS || r->kind == RK_AXES) want_y_axis = true;
      if (r->kind == RK_X_TICKS || r->kind == RK_GRID) want_grid_x = true;
      if (r->kind == RK_Y_TICKS || r->kind == RK_GRID) want_grid_y = true;
      if ((r->kind == RK_DISCRETE_HIST || r->kind == RK_STACKED_HIST) && !categorical) {
        categorical = 1;
        categories = r->data2;
      }
      /* P0: the per-kind bounds-union switch now lives in __renderer-bbox
         (pinned C symbol plot_renderer_bbox). Fold its box corners here --
         identical to unioning the underlying points. */
      {
        extern void *plot_renderer_bbox(int64_t renderer);
        typedef struct { double x0, x1, y0, y1; int valid; } RBBox;
        RBBox *bb = (RBBox *)plot_renderer_bbox((int64_t)(intptr_t)r);
        if (bb) {
          if (bb->valid) {
            UNION_POINT(bb->x0, bb->y0);
            UNION_POINT(bb->x1, bb->y1);
          }
          free(bb);
        }
      }
    }

    if (!have_bounds) { bx_min = 0.0; bx_max = 1.0; by_min = 0.0; by_max = 1.0; }
    if (po) {
      if (!ISNAN(po->x_min)) bx_min = po->x_min;
      if (!ISNAN(po->x_max)) bx_max = po->x_max;
      if (!ISNAN(po->y_min)) by_min = po->y_min;
      if (!ISNAN(po->y_max)) by_max = po->y_max;
    }
    if (!(bx_max > bx_min)) { bx_min -= 1.0; bx_max += 1.0; }
    if (!(by_max > by_min)) { by_min -= 1.0; by_max += 1.0; }
    double padx = (bx_max - bx_min) * 0.05;
    double pady = (by_max - by_min) * 0.05;
    if (padx == 0.0) padx = 1.0;
    if (pady == 0.0) pady = 1.0;
    bx_min -= padx; bx_max += padx;
    by_min -= pady; by_max += pady;

    int left = px + 64;
    int right = px + pw - 24;
    int top = py + ((po && po->title) ? 44 : 24);
    int bottom = py + ph - ((po && (po->x_label || categorical)) ? 58 : 44);
    int plot_w = right - left;
    int plot_h = bottom - top;
    if (plot_w < 32 || plot_h < 32) RETURN_ERR(1);

    plutovg_canvas_save((plutovg_canvas_t *)(intptr_t)canvas);
    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 1.0f, 1.0f, 1.0f, 1.0f);
    plutovg_canvas_fill_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)px, (float)py, (float)pw, (float)ph);
    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.98f, 0.98f, 0.98f, 1.0f);
    plutovg_canvas_fill_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)top, (float)plot_w, (float)plot_h);
    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.7f, 0.7f, 0.7f, 1.0f);
    plutovg_canvas_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)top, (float)plot_w, (float)plot_h);
    plutovg_canvas_set_line_width((plutovg_canvas_t *)(intptr_t)canvas, 1.0f);
    plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);

    if (font_ok) {
      plutovg_canvas_set_font_face((plutovg_canvas_t *)(intptr_t)canvas, font);
      plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 12.0f);
    }

    int tick_n = 6;
    double x_ticks[32], y_ticks[32];
    const char *x_labels[32], *y_labels[32];
    int x_count = 0, y_count = 0;

    if (categorical) {
      int idx = 0;
      for (Cons *p = (Cons *)(intptr_t)categories; p && idx < 32; p = (Cons *)(intptr_t)p->tail, idx++) {
        x_ticks[idx] = (double)idx + 0.4;
        x_labels[idx] = (const char *)(intptr_t)p->head;
      }
      x_count = idx;
    } else {
      double span = bx_max - bx_min;
      double raw = span / (double)(tick_n - 1);
      double mag = pow(10.0, floor(log10(raw)));
      double norm = raw / mag;
      double step = (norm < 1.5 ? 1.0 : (norm < 3.0 ? 2.0 : (norm < 7.0 ? 5.0 : 10.0))) * mag;
      double start = ceil(bx_min / step) * step;
      int prec = step >= 1.0 ? 2 : (int)ceil(-log10(step)) + 1;
      if (prec < 0) prec = 0; if (prec > 8) prec = 8;
      char xbuf[32][64];
      for (double v = start; v <= bx_max + step * 0.25 && x_count < 32; v += step) {
        x_ticks[x_count] = v;
        snprintf(xbuf[x_count], sizeof(xbuf[x_count]), "%.*f", prec, v);
        x_labels[x_count] = xbuf[x_count];
        x_count++;
      }
    }
    {
      double span = by_max - by_min;
      double raw = span / (double)(tick_n - 1);
      double mag = pow(10.0, floor(log10(raw)));
      double norm = raw / mag;
      double step = (norm < 1.5 ? 1.0 : (norm < 3.0 ? 2.0 : (norm < 7.0 ? 5.0 : 10.0))) * mag;
      double start = ceil(by_min / step) * step;
      int prec = step >= 1.0 ? 2 : (int)ceil(-log10(step)) + 1;
      if (prec < 0) prec = 0; if (prec > 8) prec = 8;
      char ybuf[32][64];
      for (double v = start; v <= by_max + step * 0.25 && y_count < 32; v += step) {
        y_ticks[y_count] = v;
        snprintf(ybuf[y_count], sizeof(ybuf[y_count]), "%.*f", prec, v);
        y_labels[y_count] = ybuf[y_count];
        y_count++;
      }
    }

    if (!want_x_axis && by_min <= 0.0 && by_max >= 0.0) want_x_axis = true;
    if (!want_y_axis && bx_min <= 0.0 && bx_max >= 0.0) want_y_axis = true;

    if (want_grid_x || want_grid_y) {
      plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.90f, 0.90f, 0.90f, 1.0f);
      plutovg_canvas_set_line_width((plutovg_canvas_t *)(intptr_t)canvas, 1.0f);
      if (want_grid_x) for (int i = 0; i < x_count; i++) {
        double tx = (x_ticks[i] - bx_min) / (bx_max - bx_min);
        double vx = left + tx * plot_w;
        plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)top);
        plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)bottom);
      }
      if (want_grid_y) for (int i = 0; i < y_count; i++) {
        double ty = (y_ticks[i] - by_min) / (by_max - by_min);
        double vy = bottom - ty * plot_h;
        plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)vy);
        plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)right, (float)vy);
      }
      plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
    }

    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.2f, 0.2f, 0.2f, 1.0f);
    if (want_x_axis) {
      double vy = bottom - ((0.0 - by_min) / (by_max - by_min)) * plot_h;
      plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)vy);
      plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)right, (float)vy);
      plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
    }
    if (want_y_axis) {
      double vx = left + ((0.0 - bx_min) / (bx_max - bx_min)) * plot_w;
      plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)top);
      plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)bottom);
      plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
    }

    if (font_ok) {
      plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.15f, 0.15f, 0.15f, 1.0f);
      for (int i = 0; i < x_count; i++) {
        double tx = (x_ticks[i] - bx_min) / (bx_max - bx_min);
        double vx = left + tx * plot_w;
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 x_labels[i], (int)strlen(x_labels[i]),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(vx - 10.0), (float)(bottom + 18.0));
      }
      for (int i = 0; i < y_count; i++) {
        double ty = (y_ticks[i] - by_min) / (by_max - by_min);
        double vy = bottom - ty * plot_h;
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 y_labels[i], (int)strlen(y_labels[i]),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(left - 48.0), (float)(vy + 4.0));
      }
      if (po && po->title) {
        plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 16.0f);
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 po->title, (int)strlen(po->title),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)left, (float)(py + 24));
        plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 12.0f);
      }
      if (po && po->x_label) {
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 po->x_label, (int)strlen(po->x_label),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(left + plot_w / 2 - 20), (float)(py + ph - 16));
      }
      if (po && po->y_label) {
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 po->y_label, (int)strlen(po->y_label),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(px + 8), (float)(top - 8));
      }
    }

    /* P0: the per-kind draw switch + clip bracket now live in __draw-renderers
       (pinned C symbol plot_draw_renderers). Delegate the data rendering. */
    {
      extern void plot_draw_renderers(int64_t, int64_t, double, double, double, double,
                                      int64_t, int64_t, int64_t, int64_t, int64_t, int64_t, int64_t);
      plot_draw_renderers(canvas, renderers, bx_min, bx_max, by_min, by_max,
                          left, right, top, bottom, plot_w, plot_h, font_ok);
    }

    if (font_ok && legend_pos != 0) {
      double lx = (legend_pos == 2 || legend_pos == 4) ? left + 12.0 : right - 120.0;
      double ly = (legend_pos == 3 || legend_pos == 4) ? bottom - 16.0 : top + 16.0;
      plutovg_canvas_set_font_face((plutovg_canvas_t *)(intptr_t)canvas, font);
      plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 12.0f);
      int row = 0;
      RendVec *__rvec3 = (RendVec *)(intptr_t)renderers;
      size_t __rlen3 = __rvec3 ? __rvec3->len : 0;
      for (size_t __ri3 = 0; __ri3 < __rlen3; __ri3++) {
        PlotRenderer *r = (PlotRenderer *)(intptr_t)__rvec3->data[__ri3];
        if (!r || !r->label || !r->label[0]) continue;
        double y = ly + row * 16.0;
        int color = row % 8;
        plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas,
                                (float)palette[color][0], (float)palette[color][1],
                                (float)palette[color][2], 1.0f);
        plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)lx, (float)y);
        plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)(lx + 12.0), (float)y);
        plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
        plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.15f, 0.15f, 0.15f, 1.0f);
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas, r->label, (int)strlen(r->label),
                                 PLUTOVG_TEXT_ENCODING_UTF8, (float)(lx + 18.0), (float)(y + 4.0));
        row++;
      }
    }
    if (font) plutovg_font_face_destroy(font);
    RETURN_OK(0);
    ```)

  ;; ---------------------------------------------------------------------------
  ;; Backend -- the output target a plot renders to (U2 typeclass collapse).
  ;;
  ;; The three legacy entrypoints (`plot-into-canvas`, `plot`, `plot-write-png`)
  ;; differed only in *where* the same renderer Vec lands: an existing canvas, a
  ;; fresh surface, or a PNG file. They are now one method, `render-to`, with
  ;; one instance per target, so plot-building code can be written generic over
  ;; the destination and a new sink (e.g. a notebook-inline backend) becomes a
  ;; new instance rather than a new top-level function.
  ;;
  ;; Named `Backend`, not the uplift plan's "Renderer": this spice already calls
  ;; every drawable element a "renderer" (the `renderers` Vec), so a `Renderer`
  ;; typeclass sitting next to a `renderers` parameter would be needlessly
  ;; confusing. The concept the plan means is the output backend.
  ;;
  ;; `render-to` returns the same :ptr<void> result envelope the legacy
  ;; entrypoints did: ok-val carries the new surface handle for SurfaceBackend,
  ;; 0 for the canvas/PNG sinks; err-val carries the failure code.
  ;; ---------------------------------------------------------------------------
  (defclass Backend [b]
    (render-to [self : b  renderers : int  opts : int] : ptr<void>))

  ;; CanvasBackend -- draw into an existing canvas at the given viewport.
  (defstruct CanvasBackend [canvas : int  px : int  py : int  pw : int  ph : int])

  ;; SurfaceBackend -- allocate a fresh surface and return it (caller owns).
  ;; A width/height of 0 falls back to the opts dimensions (or 600x450).
  (defstruct SurfaceBackend [width : int  height : int])

  ;; PngBackend -- render to a fresh surface and write it to `path` as PNG.
  (defstruct PngBackend [path : cstr])

  ;; CanvasBackend delegates straight to the inline-C drawing worker.
  (definstance Backend [CanvasBackend]
    (render-to [self renderers opts]
      (plot-into-canvas (.canvas self) renderers opts
                        (.px self) (.py self) (.pw self) (.ph self))))

  ;; SurfaceBackend allocates the surface + canvas, then dispatches the draw
  ;; through CanvasBackend and hands the surface back on success.
  (definstance Backend [SurfaceBackend]
    (render-to [self renderers opts]
      (let [w  (if (> (.width self) 0) (.width self)
                 (if (> (plot-opts-width opts) 0) (plot-opts-width opts) 600))
            h  (if (> (.height self) 0) (.height self)
                 (if (> (plot-opts-height opts) 0) (plot-opts-height opts) 450))
            sr (__surface-create w h)]
        (if (__ok? sr)
          (let [surface (__ok-val sr)
                cr      (__canvas-create surface)]
            (if (__ok? cr)
              (let [canvas (__ok-val cr)
                    rr (render-to (make-struct CanvasBackend canvas 0 0 w h)
                                  renderers opts)]
                (__canvas-destroy canvas)
                (if (__ok? rr)
                  (__ok surface)
                  (do
                    (__surface-destroy surface)
                    (__err (__err-val rr)))))
              (__err (__err-val cr))))
          (__err (__err-val sr))))))

  ;; PngBackend renders through SurfaceBackend, then writes + frees the surface.
  (definstance Backend [PngBackend]
    (render-to [self renderers opts]
      (let [r (render-to (make-struct SurfaceBackend 0 0) renderers opts)]
        (if (__ok? r)
          (let [s  (__ok-val r)
                wr (__surface-write-png s (.path self))]
            (__surface-destroy s)
            wr)
          (__err (__err-val r))))))

  ;;; render -- draw `renderers` to any Backend, generic over the sink.
  ;;;
  ;;; This is the plan's "the plot DSL becomes generic in Backend": one entry
  ;;; point polymorphic over the output target, so a caller can hold a backend
  ;;; value and dispatch to the right instance regardless of concrete type.
  ;;; `plot`, `plot-write-png`, and `plot-into-canvas` are the convenience
  ;;; monomorphic wrappers; `render` is the generic form.
  ;;;
  ;;; Example:
  ;;;   (render (make-struct PngBackend "out.png") rs opts)
  ;;;   (render (make-struct SurfaceBackend 0 0)   rs opts)
  (defn render [^Backend B b : B  renderers : int  opts : int] : ptr<void>
    (render-to b renderers opts))

  ;;; plot -- render a Vec[Renderer] to a new surface and return it.
  ;;;
  ;;; renderers is a Vec[Renderer] (build with vec-of, or vec-new + vec-push!).
  ;;; This used to be a cons list (:int with terminating 0) prior to 0.2.0.
  ;;;
  ;;; Thin wrapper over the `Backend` dispatch (the `SurfaceBackend` instance);
  ;;; equivalent to `(render-to (make-struct SurfaceBackend 0 0) renderers opts)`.
  (defn plot [renderers : int opts : int] : ptr<void>
    (render-to (make-struct SurfaceBackend 0 0) renderers opts))

  ;;; plot-write-png -- render a Vec[Renderer] and write it to a PNG file.
  ;;;
  ;;; renderers is a Vec[Renderer] (build with vec-of, or vec-new + vec-push!).
  ;;; This used to be a cons list (:int with terminating 0) prior to 0.2.0.
  ;;;
  ;;; Thin wrapper over the `Backend` dispatch (the `PngBackend` instance);
  ;;; equivalent to `(render-to (make-struct PngBackend path) renderers opts)`.
  (defn plot-write-png [renderers : int opts : int path : cstr] : ptr<void>
    (render-to (make-struct PngBackend path) renderers opts))

) ;; end defmodule plot/core
