;; plot/core.tur -- renderer representation and plot entrypoints.

(defmodule plot/core
  (export plot plot-write-png plot-into-canvas
          __make-renderer __renderer-floats __renderer-ints __renderer-bounds
          __surface-create __surface-destroy __surface-write-png
          __canvas-create __canvas-destroy
          __plot-sample-adaptive
          __ok? __ok-val __err-val
          __surface-width __surface-height __surface-pixel-byte
          __pixel-is-background? __count-non-background)

  (import plot/style :refer [plot-opts-width plot-opts-height])

  ;;; __ok -- create an ok result wrapping integer value v.
  (defn __ok [v :int] :ptr<void>
    ```c
    #include <stdlib.h>
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = true; r->ok_val = v; r->err_val = 0; return r;
    ```)

  ;;; __err -- create an err result wrapping integer error value e.
  (defn __err [e :int] :ptr<void>
    ```c
    #include <stdlib.h>
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
    r->is_ok = false; r->ok_val = 0; r->err_val = e; return r;
    ```)

  ;;; __ok? -- predicate for the local :ptr<void> result envelope.
  (defn __ok? [r :ptr<void>] :bool
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res && res->is_ok;
    ```)

  ;;; __ok-val -- extract the ok payload from the local :ptr<void> result envelope.
  (defn __ok-val [r :ptr<void>] :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res ? res->ok_val : 0;
    ```)

  ;;; __err-val -- extract the err payload from the local :ptr<void> result envelope.
  (defn __err-val [r :ptr<void>] :int
    ```c
    struct { bool is_ok; int64_t ok_val; int64_t err_val; } *res = (void *)(intptr_t)r;
    return res ? res->err_val : 0;
    ```)

  ;;; __make-renderer -- allocate the generic opaque renderer handle used by all plot modules.
  (defn __make-renderer [kind :int
                         style1 :int style2 :int
                         data1 :int data2 :int data3 :int data4 :int data5 :int
                         label :cstr text :cstr] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    #include <string.h>
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)malloc(sizeof(*r));
    const char *src_label = (const char *)(intptr_t)label;
    const char *src_text = (const char *)(intptr_t)text;
    if (!r) return 0;
    r->kind = kind;
    r->style1 = style1; r->style2 = style2;
    r->data1 = data1; r->data2 = data2; r->data3 = data3; r->data4 = data4; r->data5 = data5;
    r->f1 = 0.0; r->f2 = 0.0; r->f3 = 0.0; r->f4 = 0.0; r->f5 = 0.0; r->f6 = 0.0;
    r->i1 = 0; r->i2 = 0; r->i3 = 0; r->i4 = 0;
    if (src_label) {
      size_t len = strlen(src_label);
      r->label = (char *)malloc(len + 1);
      if (r->label) memcpy(r->label, src_label, len + 1);
    } else {
      r->label = NULL;
    }
    if (src_text) {
      size_t len = strlen(src_text);
      r->text = (char *)malloc(len + 1);
      if (r->text) memcpy(r->text, src_text, len + 1);
    } else {
      r->text = NULL;
    }
    r->x_min = 0.0 / 0.0; r->x_max = 0.0 / 0.0; r->y_min = 0.0 / 0.0; r->y_max = 0.0 / 0.0;
    return (int64_t)(intptr_t)r;
    ```)

  ;;; __renderer-floats -- attach the six generic float payload slots to a renderer.
  (defn __renderer-floats [renderer :int
                           f1 :float f2 :float f3 :float f4 :float f5 :float f6 :float] :int
    ```c
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) return 0;
    r->f1 = f1; r->f2 = f2; r->f3 = f3; r->f4 = f4; r->f5 = f5; r->f6 = f6;
    return renderer;
    ```)

  ;;; __renderer-ints -- attach the four generic integer payload slots to a renderer.
  (defn __renderer-ints [renderer :int i1 :int i2 :int i3 :int i4 :int] :int
    ```c
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) return 0;
    r->i1 = i1; r->i2 = i2; r->i3 = i3; r->i4 = i4;
    return renderer;
    ```)

  ;;; __renderer-bounds -- attach explicit bounds hints to a renderer.
  (defn __renderer-bounds [renderer :int x-min :float x-max :float y-min :float y-max :float] :int
    ```c
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    if (!r) return 0;
    r->x_min = x_min; r->x_max = x_max; r->y_min = y_min; r->y_max = y_max;
    return renderer;
    ```)

  ;;; __surface-create -- allocate a new plutovg surface.
  (defn __surface-create [width :int height :int] :ptr<void>
    ```c
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    extern void* plutovg_surface_create(int width, int height);
    void *s = plutovg_surface_create((int)width, (int)height);
    PlotResult *r = (PlotResult *)malloc(sizeof(*r));
    r->is_ok = s != NULL;
    r->ok_val = s ? (int64_t)(intptr_t)s : 0;
    r->err_val = s ? 0 : 1;
    return r;
    ```)

  ;;; __surface-destroy -- destroy a plutovg surface.
  (defn __surface-destroy [surface :int] :void
    ```c
    extern void plutovg_surface_destroy(void* surface);
    if (surface) plutovg_surface_destroy((void *)(intptr_t)surface);
    ```)

  ;;; __surface-write-png -- write a plutovg surface to a PNG file.
  (defn __surface-write-png [surface :int path :cstr] :ptr<void>
    ```c
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    extern bool plutovg_surface_write_to_png(const void* surface, const char* filename);
    bool ok = plutovg_surface_write_to_png((void *)(intptr_t)surface,
                                           (const char *)(intptr_t)path);
    PlotResult *r = (PlotResult *)malloc(sizeof(*r));
    r->is_ok = ok;
    r->ok_val = 0;
    r->err_val = ok ? 0 : 1;
    return r;
    ```)

  ;;; __canvas-create -- allocate a canvas for an existing surface.
  (defn __canvas-create [surface :int] :ptr<void>
    ```c
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    extern void* plutovg_canvas_create(void* surface);
    void *c = plutovg_canvas_create((void *)(intptr_t)surface);
    PlotResult *r = (PlotResult *)malloc(sizeof(*r));
    r->is_ok = c != NULL;
    r->ok_val = c ? (int64_t)(intptr_t)c : 0;
    r->err_val = c ? 0 : 1;
    return r;
    ```)

  ;;; __canvas-destroy -- destroy a plutovg canvas.
  (defn __canvas-destroy [canvas :int] :void
    ```c
    extern void plutovg_canvas_destroy(void* canvas);
    if (canvas) plutovg_canvas_destroy((void *)(intptr_t)canvas);
    ```)

  ;;; __surface-width -- width of a plutovg surface in pixels.
  (defn __surface-width [surface :int] :int
    ```c
    extern int plutovg_surface_get_width(const void* surface);
    if (!surface) return 0;
    return (int64_t)plutovg_surface_get_width((const void *)(intptr_t)surface);
    ```)

  ;;; __surface-height -- height of a plutovg surface in pixels.
  (defn __surface-height [surface :int] :int
    ```c
    extern int plutovg_surface_get_height(const void* surface);
    if (!surface) return 0;
    return (int64_t)plutovg_surface_get_height((const void *)(intptr_t)surface);
    ```)

  ;;; __surface-pixel-byte -- read a single byte from the surface's raw pixel buffer.
  ;;;
  ;;; plutovg stores pixels in 32-bpp BGRA order (premultiplied alpha) on
  ;;; little-endian platforms. `channel` selects the byte within the pixel:
  ;;;   0 -- B, 1 -- G, 2 -- R, 3 -- A.
  ;;; Returns -1 if (x, y) is out of bounds.
  (defn __surface-pixel-byte [surface :int x :int y :int channel :int] :int
    ```c
    extern unsigned char* plutovg_surface_get_data(const void* surface);
    extern int plutovg_surface_get_width(const void* surface);
    extern int plutovg_surface_get_height(const void* surface);
    extern int plutovg_surface_get_stride(const void* surface);
    if (!surface) return -1;
    int w = plutovg_surface_get_width((const void *)(intptr_t)surface);
    int h = plutovg_surface_get_height((const void *)(intptr_t)surface);
    if ((int)x < 0 || (int)x >= w || (int)y < 0 || (int)y >= h) return -1;
    if ((int)channel < 0 || (int)channel > 3) return -1;
    int stride = plutovg_surface_get_stride((const void *)(intptr_t)surface);
    unsigned char *data = plutovg_surface_get_data((const void *)(intptr_t)surface);
    if (!data) return -1;
    return (int64_t)data[(int)y * stride + (int)x * 4 + (int)channel];
    ```)

  ;;; __count-non-background -- count pixels in [x0, x1) x [y0, y1) that are not background.
  ;;;
  ;;; Useful for "this renderer produced *some* ink in this region" assertions
  ;;; without pinning a specific pixel.
  (defn __count-non-background [surface :int
                                x0 :int y0 :int
                                x1 :int y1 :int] :int
    ```c
    extern unsigned char* plutovg_surface_get_data(const void* surface);
    extern int plutovg_surface_get_width(const void* surface);
    extern int plutovg_surface_get_height(const void* surface);
    extern int plutovg_surface_get_stride(const void* surface);
    if (!surface) return 0;
    int w = plutovg_surface_get_width((const void *)(intptr_t)surface);
    int h = plutovg_surface_get_height((const void *)(intptr_t)surface);
    int stride = plutovg_surface_get_stride((const void *)(intptr_t)surface);
    unsigned char *data = plutovg_surface_get_data((const void *)(intptr_t)surface);
    if (!data) return 0;
    int xa = (int)x0 < 0 ? 0 : (int)x0;
    int ya = (int)y0 < 0 ? 0 : (int)y0;
    int xb = (int)x1 > w ? w : (int)x1;
    int yb = (int)y1 > h ? h : (int)y1;
    int64_t cnt = 0;
    for (int yy = ya; yy < yb; yy++) {
      for (int xx = xa; xx < xb; xx++) {
        unsigned char b = data[yy * stride + xx * 4 + 0];
        unsigned char g = data[yy * stride + xx * 4 + 1];
        unsigned char r = data[yy * stride + xx * 4 + 2];
        unsigned char a = data[yy * stride + xx * 4 + 3];
        if (!(r >= 250 && g >= 250 && b >= 250 && a >= 250)) cnt++;
      }
    }
    return cnt;
    ```)

  ;;; __pixel-is-background? -- true when a pixel is near pure white (>=250 in all RGB channels and full alpha).
  ;;;
  ;;; Useful for "this region was not drawn over" assertions. The plot
  ;;; background is `fill_rect` with rgba(1,1,1,1).
  (defn __pixel-is-background? [surface :int x :int y :int] :bool
    ```c
    extern unsigned char* plutovg_surface_get_data(const void* surface);
    extern int plutovg_surface_get_width(const void* surface);
    extern int plutovg_surface_get_height(const void* surface);
    extern int plutovg_surface_get_stride(const void* surface);
    if (!surface) return false;
    int w = plutovg_surface_get_width((const void *)(intptr_t)surface);
    int h = plutovg_surface_get_height((const void *)(intptr_t)surface);
    if ((int)x < 0 || (int)x >= w || (int)y < 0 || (int)y >= h) return false;
    int stride = plutovg_surface_get_stride((const void *)(intptr_t)surface);
    unsigned char *data = plutovg_surface_get_data((const void *)(intptr_t)surface);
    if (!data) return false;
    unsigned char b = data[(int)y * stride + (int)x * 4 + 0];
    unsigned char g = data[(int)y * stride + (int)x * 4 + 1];
    unsigned char r = data[(int)y * stride + (int)x * 4 + 2];
    unsigned char a = data[(int)y * stride + (int)x * 4 + 3];
    return r >= 250 && g >= 250 && b >= 250 && a >= 250;
    ```)

  ;;; __plot-sample-adaptive -- adaptive subdivision sampler for sampled-line renderers.
  ;;;
  ;;; Walks the parameter interval `[r->f1, r->f2]` in `initial-samples`
  ;;; uniform pieces and bisects each piece when the angle between adjacent
  ;;; screen-space segments exceeds the subdivision threshold, up to a fixed
  ;;; recursion cap. NaN evaluations break the active sub-path so curves with
  ;;; vertical asymptotes (e.g. tan, 1/x) render as separate strokes.
  ;;;
  ;;; Strokes the resulting polyline onto canvas. The caller is responsible for
  ;;; installing the line style (color / width / dash / alpha) before invoking.
  ;;; Supports renderer kinds RK_FUNCTION (21), RK_PARAMETRIC (22),
  ;;; RK_POLAR (23), and RK_INVERSE (24); other kinds are a no-op.
  ;;;
  ;;; Parameters:
  ;;;   renderer        -- PlotRenderer* (treat as opaque int64_t handle)
  ;;;   canvas          -- plutovg canvas handle
  ;;;   bx-min/bx-max   -- data-space x bounds
  ;;;   by-min/by-max   -- data-space y bounds
  ;;;   left/top        -- viewport top-left in canvas pixels
  ;;;   plot-w/plot-h   -- viewport size in pixels
  ;;;   initial-samples -- baseline uniform sample count (clamped to >= 2)
  ;;;
  ;;; Since: plot-v0.1.0
  (defn __plot-sample-adaptive [renderer :int canvas :int
                                bx-min :float bx-max :float
                                by-min :float by-max :float
                                left :int top :int
                                plot-w :int plot-h :int
                                initial-samples :int] :void
    ```c
    extern double cos(double);
    extern double sin(double);
    extern double sqrt(double);
    extern void plutovg_canvas_move_to(void* canvas, float x, float y);
    extern void plutovg_canvas_line_to(void* canvas, float x, float y);
    extern void plutovg_canvas_stroke(void* canvas);

    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;

    #define ADAPTIVE_BITS_DBL(v) (((union { double d; int64_t i; }){.i=(v)}).d)
    #define ADAPTIVE_ISNAN(v) ((v) != (v))

    enum { RK_FUNCTION_K = 21, RK_PARAMETRIC_K = 22, RK_POLAR_K = 23, RK_INVERSE_K = 24 };

    PlotRenderer *r = (PlotRenderer *)(intptr_t)renderer;
    void *cv = (void *)(intptr_t)canvas;
    if (!r || !cv) return;
    if (r->kind != RK_FUNCTION_K && r->kind != RK_INVERSE_K
        && r->kind != RK_PARAMETRIC_K && r->kind != RK_POLAR_K) return;

    int n = (int)initial_samples; if (n < 2) n = 2;
    double t_min = r->f1, t_max = r->f2;
    if (!(t_max > t_min)) return;
    double inv_w = (bx_max > bx_min) ? 1.0 / (bx_max - bx_min) : 1.0;
    double inv_h = (by_max > by_min) ? 1.0 / (by_max - by_min) : 1.0;
    double pw_d = (double)plot_w, ph_d = (double)plot_h;
    double left_d = (double)left, top_d = (double)top;

    enum { MAX_DEPTH = 6 };
    const double cos_thresh = 0.9961947;  /* cos(5 deg) */
    const double min_seg_px2 = 0.25;      /* (0.5 px)^2 floor */

    typedef struct { double t; double vx, vy; int valid; } Sample;

    #define EVAL_AT(T, OUT) do { \
      double __t = (T); \
      double __x = 0.0, __y = 0.0; \
      if (r->kind == RK_FUNCTION_K) { __x = __t; __y = ((double(*)(double))(intptr_t)r->data1)(__t); } \
      else if (r->kind == RK_INVERSE_K) { __y = __t; __x = ((double(*)(double))(intptr_t)r->data1)(__t); } \
      else if (r->kind == RK_PARAMETRIC_K) { \
        Cons *__pair = (Cons *)(intptr_t)((int64_t(*)(double))(intptr_t)r->data1)(__t); \
        if (__pair) { __x = ADAPTIVE_BITS_DBL(__pair->head); __y = ADAPTIVE_BITS_DBL(__pair->tail); } \
        else { __x = __y = 0.0/0.0; } \
      } else { \
        double __radius = ((double(*)(double))(intptr_t)r->data1)(__t); \
        __x = __radius * cos(__t); __y = __radius * sin(__t); \
      } \
      (OUT).t = __t; \
      if (ADAPTIVE_ISNAN(__x) || ADAPTIVE_ISNAN(__y)) { (OUT).valid = 0; (OUT).vx = 0.0; (OUT).vy = 0.0; } \
      else { \
        double __tx = (__x - bx_min) * inv_w; \
        double __ty = (__y - by_min) * inv_h; \
        (OUT).vx = left_d + __tx * pw_d; \
        (OUT).vy = top_d + ph_d - __ty * ph_d; \
        (OUT).valid = 1; \
      } \
    } while (0)

    int started = 0;
    #define EMIT(S) do { \
      if ((S).valid) { \
        if (!started) { plutovg_canvas_move_to(cv, (float)(S).vx, (float)(S).vy); started = 1; } \
        else { plutovg_canvas_line_to(cv, (float)(S).vx, (float)(S).vy); } \
      } else { \
        started = 0; \
      } \
    } while (0)

    typedef struct { Sample A, B; int depth; } Frame;
    Frame stack[MAX_DEPTH * 2 + 4];

    Sample prev; EVAL_AT(t_min, prev);
    EMIT(prev);

    for (int i = 0; i < n - 1; i++) {
      double tB = t_min + (t_max - t_min) * ((double)(i + 1) / (double)(n - 1));
      Sample A = prev;
      Sample B; EVAL_AT(tB, B);

      int sp = 0;
      stack[sp].A = A; stack[sp].B = B; stack[sp].depth = 0; sp++;

      while (sp > 0) {
        Frame f = stack[--sp];
        int subdivide = 0;
        Sample M; M.valid = 0; M.t = 0.0; M.vx = 0.0; M.vy = 0.0;
        double dx_ab = f.B.vx - f.A.vx;
        double dy_ab = f.B.vy - f.A.vy;
        double seg_len2 = dx_ab * dx_ab + dy_ab * dy_ab;
        int both_valid = f.A.valid && f.B.valid;

        if (f.depth < MAX_DEPTH && (!both_valid || seg_len2 > min_seg_px2)) {
          double tM = 0.5 * (f.A.t + f.B.t);
          EVAL_AT(tM, M);
          if (M.valid != f.A.valid || M.valid != f.B.valid) {
            /* Validity transition inside segment -> bisect to localize the gap. */
            subdivide = 1;
          } else if (both_valid && M.valid) {
            double v1x = M.vx - f.A.vx, v1y = M.vy - f.A.vy;
            double v2x = f.B.vx - M.vx, v2y = f.B.vy - M.vy;
            double l1 = v1x * v1x + v1y * v1y;
            double l2 = v2x * v2x + v2y * v2y;
            if (l1 > min_seg_px2 && l2 > min_seg_px2) {
              double dot = v1x * v2x + v1y * v2y;
              double denom = sqrt(l1 * l2);
              double cos_a = (denom > 0.0) ? (dot / denom) : 1.0;
              if (cos_a < cos_thresh) subdivide = 1;
            }
          }
        }

        if (subdivide) {
          /* Right then left so left pops first => emission is left-to-right. */
          stack[sp].A = M;   stack[sp].B = f.B; stack[sp].depth = f.depth + 1; sp++;
          stack[sp].A = f.A; stack[sp].B = M;   stack[sp].depth = f.depth + 1; sp++;
        } else {
          EMIT(f.B);
        }
      }

      prev = B;
    }

    if (started) plutovg_canvas_stroke(cv);

    #undef EVAL_AT
    #undef EMIT
    #undef ADAPTIVE_BITS_DBL
    #undef ADAPTIVE_ISNAN
    ```)

  ;;; data->viewport -- map data coordinates to viewport coordinates.
  (defn data->viewport [x :float y :float bx-min :float bx-max :float
                        by-min :float by-max :float
                        px :int py :int pw :int ph :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    typedef struct { double x; double y; } Pt;
    Pt *p = (Pt *)malloc(sizeof(*p));
    double tx = (x - bx_min) / (bx_max - bx_min);
    double ty = (y - by_min) / (by_max - by_min);
    p->x = (double)px + tx * (double)pw;
    p->y = (double)py + (1.0 - ty) * (double)ph;
    return (int64_t)(intptr_t)p;
    ```)

  ;;; viewport->data -- map viewport coordinates back to data coordinates.
  (defn viewport->data [vx :float vy :float bx-min :float bx-max :float
                        by-min :float by-max :float
                        px :int py :int pw :int ph :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    typedef struct { double x; double y; } Pt;
    Pt *p = (Pt *)malloc(sizeof(*p));
    double tx = (vx - (double)px) / (double)pw;
    double ty = 1.0 - ((vy - (double)py) / (double)ph);
    p->x = bx_min + tx * (bx_max - bx_min);
    p->y = by_min + ty * (by_max - by_min);
    return (int64_t)(intptr_t)p;
    ```)

  ;;; plot-into-canvas -- render into an existing canvas and viewport.
  ;;;
  ;;; renderers is a Vec[Renderer] (built with vec-of or vec-new/vec-push!),
  ;;; not a cons list. Internal renderer payload data (e.g. lists of point
  ;;; pairs inside each renderer) is still cons-shaped -- only the top-level
  ;;; sequence of renderers is a Vec.
  (defn plot-into-canvas [canvas :int renderers :int opts :int
                          px :int py :int pw :int ph :int] :ptr<void>
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    #include <stdbool.h>
    #include <string.h>
    #include <stdio.h>
    #include <float.h>
    #include <unistd.h>
    extern double floor(double);
    extern double ceil(double);
    extern double log10(double);
    extern double pow(double, double);
    extern double sqrt(double);
    extern double cos(double);
    extern double sin(double);
    extern double atan2(double, double);
    extern double exp(double);
    extern double fabs(double);
    extern double fmin(double, double);
    typedef void plutovg_surface_t;
    typedef void plutovg_canvas_t;
    typedef void plutovg_font_face_t;
    typedef int plutovg_text_encoding_t;
    #define PLUTOVG_TEXT_ENCODING_UTF8 1
    extern void plutovg_surface_destroy(void* surface);
    extern void* plutovg_font_face_load_from_file(const char* filename, int ttcindex);
    extern void plutovg_font_face_destroy(void* face);
    extern void plutovg_canvas_save(void* canvas);
    extern void plutovg_canvas_restore(void* canvas);
    extern void plutovg_canvas_set_rgba(void* canvas, float r, float g, float b, float a);
    extern void plutovg_canvas_set_font_face(void* canvas, void* face);
    extern void plutovg_canvas_set_font_size(void* canvas, float size);
    extern void plutovg_canvas_set_line_width(void* canvas, float line_width);
    extern void plutovg_canvas_set_dash_array(void* canvas, const float* dashes, int ndashes);
    extern void plutovg_canvas_move_to(void* canvas, float x, float y);
    extern void plutovg_canvas_line_to(void* canvas, float x, float y);
    extern void plutovg_canvas_rect(void* canvas, float x, float y, float w, float h);
    extern void plutovg_canvas_circle(void* canvas, float cx, float cy, float r);
    extern void plutovg_canvas_close_path(void* canvas);
    extern void plutovg_canvas_fill(void* canvas);
    extern void plutovg_canvas_stroke(void* canvas);
    extern void plutovg_canvas_clip(void* canvas);
    extern void plutovg_canvas_fill_rect(void* canvas, float x, float y, float w, float h);
    extern float plutovg_canvas_fill_text(void* canvas, const void* text, int length,
                                          int encoding, float x, float y);

    typedef struct { int64_t head; int64_t tail; } Cons;
    typedef struct { bool is_ok; int64_t ok_val; int64_t err_val; } PlotResult;
    #define RETURN_ERR(CODE) do { \
      PlotResult *__r = (PlotResult *)malloc(sizeof(*__r)); \
      __r->is_ok = false; __r->ok_val = 0; __r->err_val = (CODE); \
      return __r; \
    } while (0)
    #define RETURN_OK(VALUE) do { \
      PlotResult *__r = (PlotResult *)malloc(sizeof(*__r)); \
      __r->is_ok = true; __r->ok_val = (VALUE); __r->err_val = 0; \
      return __r; \
    } while (0)
    typedef struct __plot_renderer {
      int64_t kind;
      int64_t style1, style2;
      int64_t data1, data2, data3, data4, data5;
      double f1, f2, f3, f4, f5, f6;
      int64_t i1, i2, i3, i4;
      char *label;
      char *text;
      double x_min, x_max, y_min, y_max;
    } PlotRenderer;
    typedef struct { int64_t color; double width; int64_t dash; double alpha; } LineStyle;
    typedef struct { int64_t color; int64_t fill_color; int64_t sym; double size; double alpha; } PointStyle;
    typedef struct { int64_t color; double alpha; int64_t line_color; double line_width; } FillStyle;
    typedef struct {
      int64_t width; int64_t height;
      char *title; char *x_label; char *y_label;
      double x_min, x_max, y_min, y_max;
      int64_t legend_pos;
    } PlotOpts;

    enum {
      RK_X_AXIS = 1, RK_Y_AXIS = 2, RK_AXES = 3,
      RK_X_TICKS = 4, RK_Y_TICKS = 5, RK_GRID = 6,
      RK_HRULE = 7, RK_VRULE = 8, RK_LABEL = 9,
      RK_LINES = 20, RK_FUNCTION = 21, RK_PARAMETRIC = 22, RK_POLAR = 23, RK_INVERSE = 24, RK_DENSITY = 25,
      RK_POINTS = 30, RK_ERROR_BARS = 31, RK_VECTOR_FIELD = 32, RK_ARROWS = 33,
      RK_FUNCTION_INTERVAL = 40, RK_LINES_INTERVAL = 41, RK_PARAM_INTERVAL = 42, RK_POLAR_INTERVAL = 43,
      RK_RECTANGLES = 50, RK_AREA_HIST = 51, RK_DISCRETE_HIST = 52, RK_STACKED_HIST = 53,
      RK_ISOLINE = 60, RK_CONTOURS = 61, RK_CONTOUR_INTERVALS = 62, RK_COLOR_FIELD = 63
    };

    static const double palette[8][3] = {
      {31.0/255.0, 119.0/255.0, 180.0/255.0},
      {214.0/255.0, 39.0/255.0, 40.0/255.0},
      {44.0/255.0, 160.0/255.0, 44.0/255.0},
      {255.0/255.0, 127.0/255.0, 14.0/255.0},
      {148.0/255.0, 103.0/255.0, 189.0/255.0},
      {140.0/255.0, 86.0/255.0, 75.0/255.0},
      {227.0/255.0, 119.0/255.0, 194.0/255.0},
      {127.0/255.0, 127.0/255.0, 127.0/255.0}
    };

    #define DBL_BITS(v) (((union { double d; int64_t i; }){.d=(v)}).i)
    #define BITS_DBL(v) (((union { double d; int64_t i; }){.i=(v)}).d)
    #define ISNAN(v) ((v) != (v))

    double bx_min = 0.0, bx_max = 1.0, by_min = 0.0, by_max = 1.0;
    bool have_bounds = false;
    bool want_x_axis = false, want_y_axis = false, want_grid_x = false, want_grid_y = false;
    int64_t categorical = 0;
    int64_t categories = 0;
    PlotOpts *po = (PlotOpts *)(intptr_t)opts;
    int legend_pos = po && po->legend_pos ? (int)po->legend_pos : 1;
    int font_ok = 0;
    plutovg_font_face_t *font = NULL;
    const char *font_candidates[] = {
      "/System/Library/Fonts/Supplemental/Arial.ttf",
      "/System/Library/Fonts/Supplemental/Helvetica.ttf",
      "/System/Library/Fonts/Helvetica.ttc",
      "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
      "/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf",
      "/usr/share/fonts/dejavu/DejaVuSans.ttf",
      NULL
    };
    for (int fi = 0; font_candidates[fi]; fi++) {
      if (access(font_candidates[fi], R_OK) == 0) {
        font = plutovg_font_face_load_from_file(font_candidates[fi], 0);
        if (font) { font_ok = 1; break; }
      }
    }

    #define UNION_POINT(X, Y) do { \
      double __ux = (X), __uy = (Y); \
      if (!ISNAN(__ux) && !ISNAN(__uy)) { \
        if (!have_bounds) { \
          bx_min = bx_max = __ux; \
          by_min = by_max = __uy; \
          have_bounds = true; \
        } else { \
          if (__ux < bx_min) bx_min = __ux; \
          if (__ux > bx_max) bx_max = __ux; \
          if (__uy < by_min) by_min = __uy; \
          if (__uy > by_max) by_max = __uy; \
        } \
      } \
    } while (0)
    #define UNION_LIST_POINTS(LST) do { \
      for (Cons *__p = (Cons *)(intptr_t)(LST); __p; __p = (Cons *)(intptr_t)__p->tail) { \
        Cons *__pt = (Cons *)(intptr_t)__p->head; \
        if (!__pt) continue; \
        UNION_POINT(BITS_DBL(__pt->head), BITS_DBL(__pt->tail)); \
      } \
    } while (0)

    typedef struct { int64_t *data; size_t len; size_t cap; } RendVec;
    RendVec *__rvec = (RendVec *)(intptr_t)renderers;
    size_t __rlen = __rvec ? __rvec->len : 0;
    for (size_t __ri = 0; __ri < __rlen; __ri++) {
      PlotRenderer *r = (PlotRenderer *)(intptr_t)__rvec->data[__ri];
      if (!r) continue;
      if (r->kind == RK_X_AXIS || r->kind == RK_AXES) want_x_axis = true;
      if (r->kind == RK_Y_AXIS || r->kind == RK_AXES) want_y_axis = true;
      if (r->kind == RK_X_TICKS || r->kind == RK_GRID) want_grid_x = true;
      if (r->kind == RK_Y_TICKS || r->kind == RK_GRID) want_grid_y = true;
      if ((r->kind == RK_DISCRETE_HIST || r->kind == RK_STACKED_HIST) && !categorical) {
        categorical = 1;
        categories = r->data2;
      }
      switch ((int)r->kind) {
        case RK_LINES:
        case RK_POINTS:
        case RK_ARROWS:
          UNION_LIST_POINTS(r->data1);
          break;
        case RK_ERROR_BARS: {
          for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail) {
            Cons *a = (Cons *)(intptr_t)p->head;
            if (!a) continue;
            double x = BITS_DBL(a->head);
            Cons *b = (Cons *)(intptr_t)a->tail;
            if (!b) continue;
            double y = BITS_DBL(b->head);
            double h = BITS_DBL(b->tail);
            if (r->i1) { UNION_POINT(x - h, y); UNION_POINT(x + h, y); }
            else { UNION_POINT(x, y - h); UNION_POINT(x, y + h); }
          }
        } break;
        case RK_HRULE: UNION_POINT(0.0, r->f1); break;
        case RK_VRULE: UNION_POINT(r->f1, 0.0); break;
        case RK_LABEL: UNION_POINT(r->f1, r->f2); break;
        case RK_RECTANGLES:
        case RK_AREA_HIST: {
          for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail) {
            Cons *a = (Cons *)(intptr_t)p->head;
            if (!a) continue;
            double x0 = BITS_DBL(a->head);
            Cons *b = (Cons *)(intptr_t)a->tail;
            double x1 = BITS_DBL(b->head);
            Cons *c = (Cons *)(intptr_t)b->tail;
            double y0 = BITS_DBL(c->head);
            double y1 = BITS_DBL(c->tail);
            UNION_POINT(x0, y0);
            UNION_POINT(x1, y1);
          }
        } break;
        case RK_DISCRETE_HIST: {
          int idx = 0;
          for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail, idx++) {
            Cons *bar = (Cons *)(intptr_t)p->head;
            if (!bar) continue;
            double h = BITS_DBL(bar->tail);
            if (r->i1) { UNION_POINT(0.0, idx); UNION_POINT(h, idx + 0.8); }
            else { UNION_POINT(idx, 0.0); UNION_POINT(idx + 0.8, h); }
          }
        } break;
        case RK_STACKED_HIST: {
          int idx = 0;
          for (Cons *p = (Cons *)(intptr_t)r->data1; p; p = (Cons *)(intptr_t)p->tail, idx++) {
            Cons *grp = (Cons *)(intptr_t)p->head;
            double sum = 0.0;
            for (Cons *vals = (Cons *)(intptr_t)grp->tail; vals; vals = (Cons *)(intptr_t)vals->tail)
              sum += BITS_DBL(vals->head);
            if (r->i1) { UNION_POINT(0.0, idx); UNION_POINT(sum, idx + 0.8); }
            else { UNION_POINT(idx, 0.0); UNION_POINT(idx + 0.8, sum); }
          }
        } break;
        case RK_FUNCTION:
        case RK_INVERSE:
        case RK_DENSITY:
        case RK_PARAMETRIC:
        case RK_POLAR:
        case RK_FUNCTION_INTERVAL:
        case RK_PARAM_INTERVAL:
        case RK_POLAR_INTERVAL:
        case RK_ISOLINE:
        case RK_CONTOURS:
        case RK_CONTOUR_INTERVALS:
        case RK_COLOR_FIELD:
        case RK_VECTOR_FIELD:
          if (!ISNAN(r->x_min) && !ISNAN(r->x_max) && !ISNAN(r->y_min) && !ISNAN(r->y_max)) {
            UNION_POINT(r->x_min, r->y_min);
            UNION_POINT(r->x_max, r->y_max);
          }
          break;
        case RK_LINES_INTERVAL: UNION_LIST_POINTS(r->data1); UNION_LIST_POINTS(r->data2); break;
        default: break;
      }
    }

    if (!have_bounds) { bx_min = 0.0; bx_max = 1.0; by_min = 0.0; by_max = 1.0; }
    if (po) {
      if (!ISNAN(po->x_min)) bx_min = po->x_min;
      if (!ISNAN(po->x_max)) bx_max = po->x_max;
      if (!ISNAN(po->y_min)) by_min = po->y_min;
      if (!ISNAN(po->y_max)) by_max = po->y_max;
    }
    if (!(bx_max > bx_min)) { bx_min -= 1.0; bx_max += 1.0; }
    if (!(by_max > by_min)) { by_min -= 1.0; by_max += 1.0; }
    double padx = (bx_max - bx_min) * 0.05;
    double pady = (by_max - by_min) * 0.05;
    if (padx == 0.0) padx = 1.0;
    if (pady == 0.0) pady = 1.0;
    bx_min -= padx; bx_max += padx;
    by_min -= pady; by_max += pady;

    int left = px + 64;
    int right = px + pw - 24;
    int top = py + ((po && po->title) ? 44 : 24);
    int bottom = py + ph - ((po && (po->x_label || categorical)) ? 58 : 44);
    int plot_w = right - left;
    int plot_h = bottom - top;
    if (plot_w < 32 || plot_h < 32) RETURN_ERR(1);

    plutovg_canvas_save((plutovg_canvas_t *)(intptr_t)canvas);
    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 1.0f, 1.0f, 1.0f, 1.0f);
    plutovg_canvas_fill_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)px, (float)py, (float)pw, (float)ph);
    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.98f, 0.98f, 0.98f, 1.0f);
    plutovg_canvas_fill_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)top, (float)plot_w, (float)plot_h);
    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.7f, 0.7f, 0.7f, 1.0f);
    plutovg_canvas_rect((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)top, (float)plot_w, (float)plot_h);
    plutovg_canvas_set_line_width((plutovg_canvas_t *)(intptr_t)canvas, 1.0f);
    plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);

    if (font_ok) {
      plutovg_canvas_set_font_face((plutovg_canvas_t *)(intptr_t)canvas, font);
      plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 12.0f);
    }

    int tick_n = 6;
    double x_ticks[32], y_ticks[32];
    const char *x_labels[32], *y_labels[32];
    int x_count = 0, y_count = 0;

    if (categorical) {
      int idx = 0;
      for (Cons *p = (Cons *)(intptr_t)categories; p && idx < 32; p = (Cons *)(intptr_t)p->tail, idx++) {
        x_ticks[idx] = (double)idx + 0.4;
        x_labels[idx] = (const char *)(intptr_t)p->head;
      }
      x_count = idx;
    } else {
      double span = bx_max - bx_min;
      double raw = span / (double)(tick_n - 1);
      double mag = pow(10.0, floor(log10(raw)));
      double norm = raw / mag;
      double step = (norm < 1.5 ? 1.0 : (norm < 3.0 ? 2.0 : (norm < 7.0 ? 5.0 : 10.0))) * mag;
      double start = ceil(bx_min / step) * step;
      int prec = step >= 1.0 ? 2 : (int)ceil(-log10(step)) + 1;
      if (prec < 0) prec = 0; if (prec > 8) prec = 8;
      char xbuf[32][64];
      for (double v = start; v <= bx_max + step * 0.25 && x_count < 32; v += step) {
        x_ticks[x_count] = v;
        snprintf(xbuf[x_count], sizeof(xbuf[x_count]), "%.*f", prec, v);
        x_labels[x_count] = xbuf[x_count];
        x_count++;
      }
    }
    {
      double span = by_max - by_min;
      double raw = span / (double)(tick_n - 1);
      double mag = pow(10.0, floor(log10(raw)));
      double norm = raw / mag;
      double step = (norm < 1.5 ? 1.0 : (norm < 3.0 ? 2.0 : (norm < 7.0 ? 5.0 : 10.0))) * mag;
      double start = ceil(by_min / step) * step;
      int prec = step >= 1.0 ? 2 : (int)ceil(-log10(step)) + 1;
      if (prec < 0) prec = 0; if (prec > 8) prec = 8;
      char ybuf[32][64];
      for (double v = start; v <= by_max + step * 0.25 && y_count < 32; v += step) {
        y_ticks[y_count] = v;
        snprintf(ybuf[y_count], sizeof(ybuf[y_count]), "%.*f", prec, v);
        y_labels[y_count] = ybuf[y_count];
        y_count++;
      }
    }

    if (!want_x_axis && by_min <= 0.0 && by_max >= 0.0) want_x_axis = true;
    if (!want_y_axis && bx_min <= 0.0 && bx_max >= 0.0) want_y_axis = true;

    if (want_grid_x || want_grid_y) {
      plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.90f, 0.90f, 0.90f, 1.0f);
      plutovg_canvas_set_line_width((plutovg_canvas_t *)(intptr_t)canvas, 1.0f);
      if (want_grid_x) for (int i = 0; i < x_count; i++) {
        double tx = (x_ticks[i] - bx_min) / (bx_max - bx_min);
        double vx = left + tx * plot_w;
        plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)top);
        plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)bottom);
      }
      if (want_grid_y) for (int i = 0; i < y_count; i++) {
        double ty = (y_ticks[i] - by_min) / (by_max - by_min);
        double vy = bottom - ty * plot_h;
        plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)vy);
        plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)right, (float)vy);
      }
      plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
    }

    plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.2f, 0.2f, 0.2f, 1.0f);
    if (want_x_axis) {
      double vy = bottom - ((0.0 - by_min) / (by_max - by_min)) * plot_h;
      plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)left, (float)vy);
      plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)right, (float)vy);
      plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
    }
    if (want_y_axis) {
      double vx = left + ((0.0 - bx_min) / (bx_max - bx_min)) * plot_w;
      plutovg_canvas_move_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)top);
      plutovg_canvas_line_to((plutovg_canvas_t *)(intptr_t)canvas, (float)vx, (float)bottom);
      plutovg_canvas_stroke((plutovg_canvas_t *)(intptr_t)canvas);
    }

    if (font_ok) {
      plutovg_canvas_set_rgba((plutovg_canvas_t *)(intptr_t)canvas, 0.15f, 0.15f, 0.15f, 1.0f);
      for (int i = 0; i < x_count; i++) {
        double tx = (x_ticks[i] - bx_min) / (bx_max - bx_min);
        double vx = left + tx * plot_w;
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 x_labels[i], (int)strlen(x_labels[i]),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(vx - 10.0), (float)(bottom + 18.0));
      }
      for (int i = 0; i < y_count; i++) {
        double ty = (y_ticks[i] - by_min) / (by_max - by_min);
        double vy = bottom - ty * plot_h;
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 y_labels[i], (int)strlen(y_labels[i]),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(left - 48.0), (float)(vy + 4.0));
      }
      if (po && po->title) {
        plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 16.0f);
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 po->title, (int)strlen(po->title),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)left, (float)(py + 24));
        plutovg_canvas_set_font_size((plutovg_canvas_t *)(intptr_t)canvas, 12.0f);
      }
      if (po && po->x_label) {
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 po->x_label, (int)strlen(po->x_label),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(left + plot_w / 2 - 20), (float)(py + ph - 16));
      }
      if (po && po->y_label) {
        plutovg_canvas_fill_text((plutovg_canvas_t *)(intptr_t)canvas,
                                 po->y_label, (int)strlen(po->y_label),
                                 PLUTOVG_TEXT_ENCODING_UTF8,
                                 (float)(px + 8), (float)(top - 8));
      }
    }

    int auto_color = 0;
    #define NEXT_AUTO() ((auto_color++) % 8)
    #define SET_LINE_STYLE(HANDLE, RESOLVED_COLOR) do { \
      LineStyle *__ls = (LineStyle *)(intptr_t)(HANDLE); \
      int *__resolved_color = (RESOLVED_COLOR); \
      int __color = __ls ? (int)__ls->color : -1; \
      if (__color < 0) __color = NEXT_AUTO(); \
      __color %= 8; if (__color < 0) __color += 8; \
