                Cons *pb = (Cons *)(intptr_t)((int64_t(*)(double))(intptr_t)r->data2)(t);
                xs[i] = BITS_DBL(pa->head); ya[i] = BITS_DBL(pa->tail); yb[i] = BITS_DBL(pb->tail);
