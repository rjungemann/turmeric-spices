;; tests/rtmidi/msg_test.tur -- tests for rtmidi/msg.
(import test/suite  :refer [describe it])
(import test/assert :refer [assert-eq])
(import test/runner :refer [run-all])
(import rtmidi/msg :refer [msg-note-on msg-status msg-channel msg-data1 msg-data2])

(describe "rtmidi/msg"
  (it "msg-note-on has correct status byte"
    (let [m (msg-note-on 0 60 127)]
      (assert-eq (msg-status m) 0x90)))
  (it "msg-note-on has correct channel"
    (let [m (msg-note-on 3 60 127)]
      (assert-eq (msg-channel m) 3)))
  (it "msg-note-on has correct note"
    (let [m (msg-note-on 0 60 127)]
      (assert-eq (msg-data1 m) 60)))
  (it "msg-note-on has correct velocity"
    (let [m (msg-note-on 0 60 127)]
      (assert-eq (msg-data2 m) 127))))

(run-all)
