;; Smoke test: exercise component packers/unpackers WITHOUT opening a
;; raylib window. Confirms the int-carrier encoding round-trips correctly
;; for Pos2, Vel2, Rot, Radius and that pos2-add! integrates as expected.

(defmodule component-smoke (export)

(import ecs-raylib/components :refer [Pos2 Vel2 Rot Radius
                                       pos2-make pos2-x pos2-y pos2-add!
                                       vel2-make vel2-x vel2-y
                                       radius-make radius-value
                                       rot-make rot-value])

(defn approx-eq [a : float b : float] : bool
  ```c
  double d = a - b; if (d < 0) d = -d;
  return d < 0.01;
  ```)

(defn check-pos2 [] : int
  (let [p (pos2-make 3.5 7.25)
        x (pos2-x p)
        y (pos2-y p)]
    (if (approx-eq x 3.5)
      (if (approx-eq y 7.25) 1 0)
      0)))

(defn check-vel2 [] : int
  (let [v (vel2-make -2.5 1.125)]
    (if (approx-eq (vel2-x v) -2.5)
      (if (approx-eq (vel2-y v) 1.125) 1 0)
      0)))

(defn check-integrate [] : int
  ;; p = (10, 20), v = (1, -2), dt = 0.5 -> (10.5, 19.0)
  (let [p  (pos2-make 10.0 20.0)
        v  (vel2-make 1.0 -2.0)
        p2 (pos2-add! p v 0.5)]
    (if (approx-eq (pos2-x p2) 10.5)
      (if (approx-eq (pos2-y p2) 19.0) 1 0)
      0)))

(defn check-radius [] : int
  (let [r (radius-make 12.5)]
    (if (approx-eq (radius-value r) 12.5) 1 0)))

(defn check-rot [] : int
  (let [r (rot-make 3.14159)]
    (if (approx-eq (rot-value r) 3.14159) 1 0)))

(defn main [] : int
  (let [a (check-pos2)
        b (check-vel2)
        c (check-integrate)
        d (check-radius)
        e (check-rot)
        total (+ a (+ b (+ c (+ d e))))]
    (println total)
    (if (= total 5) 0 1)))

) ;; end defmodule
