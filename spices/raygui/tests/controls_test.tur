;; raygui/controls smoke tests.
;;
;; Verifies that Phase 1 exports resolve and that Rect construction,
;; text buffer allocation, and style constants are correct.
;; GUI controls require an active raylib window to render interactively.

(defmodule controls_test
  (export)

(import raygui/rect     :refer [Rect rect])
(import raygui/controls :refer [make-text-buf free-text-buf text-buf->cstr])
(import raygui/style    :refer [RAYGUI_DEFAULT RAYGUI_TEXT_COLOR_NORMAL])

;;; T1: rect constructor produces correct field values.
(defn test-rect-fields [] :int
  (let [r (rect 10.0 20.0 100.0 50.0)]
    (if (and (= (.x r) 10.0)
             (and (= (.y r) 20.0)
                  (and (= (.width r) 100.0)
                       (= (.height r) 50.0))))
      (do (println "T1 PASS: rect fields correct") 0)
      (do (println "T1 FAIL: rect fields wrong") 1))))

;;; T2: make-text-buf / free-text-buf round-trip.
(defn test-text-buf [] :int
  (unsafe
    (let [buf (make-text-buf 64)]
      (if (not (= buf 0))
        (do (free-text-buf buf)
            (println "T2 PASS: text buf allocated and freed")
            0)
        (do (println "T2 FAIL: text buf is null")
            1)))))

;;; T3: style constants have expected values.
(defn test-style-constants [] :int
  (if (and (= RAYGUI_DEFAULT 0)
           (= RAYGUI_TEXT_COLOR_NORMAL 2))
    (do (println "T3 PASS: style constants correct") 0)
    (do (println "T3 FAIL: style constants wrong") 1)))

(defn main [] :int
  (let [r1 (test-rect-fields)
        r2 (test-text-buf)
        r3 (test-style-constants)]
    (+ r1 (+ r2 r3))))

) ;; end defmodule controls_test
