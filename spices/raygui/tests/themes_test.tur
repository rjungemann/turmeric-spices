;; raygui/themes smoke tests.
;;
;; Verifies that theme functions resolve and that applying the dark theme
;; actually changes a style property from its default value. Requires a
;; raygui init (GuiLoadStyleDefault is called internally), but no window.

(defmodule themes_test
  (export)

(import raygui/themes :refer [gui-apply-light-theme gui-apply-dark-theme])
(import raygui/core   :refer [gui-get-style])
(import raygui/style  :refer [RAYGUI_DEFAULT RAYGUI_BASE_COLOR_NORMAL])

;;; T1: dark theme changes base-color-normal away from the light default.
;;;
;;; Light default for BASE_COLOR_NORMAL is 0xC9C9C9FF (raygui built-in).
;;; Dark theme sets it to 0x1E1E1EFF.
(defn test-dark-theme-applies [] : int
  (gui-apply-dark-theme)
  (let [v (gui-get-style RAYGUI_DEFAULT RAYGUI_BASE_COLOR_NORMAL)]
    (if (= v 0x1E1E1EFF)
      (do (println "T1 PASS: dark theme applied correctly") 0)
      (do (println "T1 FAIL: dark theme did not apply") 1))))

;;; T2: light theme restores the default value.
(defn test-light-theme-restores [] : int
  (gui-apply-dark-theme)
  (gui-apply-light-theme)
  (let [v (gui-get-style RAYGUI_DEFAULT RAYGUI_BASE_COLOR_NORMAL)]
    ;; After reset, value must differ from the dark theme value.
    (if (not (= v 0x1E1E1EFF))
      (do (println "T2 PASS: light theme restored default") 0)
      (do (println "T2 FAIL: light theme did not restore default") 1))))

(defn main [] : int
  (let [r1 (test-dark-theme-applies)
        r2 (test-light-theme-restores)]
    (+ r1 r2)))

) ;; end defmodule themes_test
