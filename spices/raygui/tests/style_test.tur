;; raygui/style smoke tests.
;;
;; Verifies that all style and icon constants have the correct integer values.

(defmodule style_test
  (export)

(import raygui/style :refer [RAYGUI_DEFAULT RAYGUI_LABEL RAYGUI_BUTTON
                              RAYGUI_TOGGLE RAYGUI_SLIDER RAYGUI_PROGRESSBAR
                              RAYGUI_CHECKBOX RAYGUI_COMBOBOX RAYGUI_DROPDOWNBOX
                              RAYGUI_TEXTBOX RAYGUI_VALUEBOX RAYGUI_SPINNER
                              RAYGUI_LISTVIEW RAYGUI_COLORPICKER
                              RAYGUI_SCROLLBAR RAYGUI_STATUSBAR
                              RAYGUI_BORDER_COLOR_NORMAL RAYGUI_TEXT_COLOR_NORMAL
                              RAYGUI_BORDER_WIDTH RAYGUI_TEXT_ALIGNMENT])
(import raygui/icons :refer [RAYGUI_ICON_NONE RAYGUI_ICON_FOLDER_FILE_OPEN
                              RAYGUI_ICON_FILE_SAVE_CLASSIC RAYGUI_ICON_GEAR
                              RAYGUI_ICON_FILE])

;;; T1: control selector constants.
(defn test-control-constants [] : int
  (if (and (= RAYGUI_DEFAULT     0)
           (and (= RAYGUI_LABEL  1)
                (and (= RAYGUI_BUTTON 2)
                     (and (= RAYGUI_STATUSBAR 15)
                          (= RAYGUI_COLORPICKER 13)))))
    (do (println "T1 PASS: control selectors correct") 0)
    (do (println "T1 FAIL: control selectors wrong") 1)))

;;; T2: property constants.
(defn test-property-constants [] : int
  (if (and (= RAYGUI_BORDER_COLOR_NORMAL 0)
           (and (= RAYGUI_TEXT_COLOR_NORMAL 2)
                (and (= RAYGUI_BORDER_WIDTH 12)
                     (= RAYGUI_TEXT_ALIGNMENT 14))))
    (do (println "T2 PASS: property constants correct") 0)
    (do (println "T2 FAIL: property constants wrong") 1)))

;;; T3: icon constants.
(defn test-icon-constants [] : int
  (if (and (= RAYGUI_ICON_NONE 0)
           (and (= RAYGUI_ICON_FOLDER_FILE_OPEN 1)
                (and (= RAYGUI_ICON_FILE_SAVE_CLASSIC 2)
                     (and (= RAYGUI_ICON_GEAR 141)
                          (= RAYGUI_ICON_FILE 218)))))
    (do (println "T3 PASS: icon constants correct") 0)
    (do (println "T3 FAIL: icon constants wrong") 1)))

(defn main [] : int
  (let [r1 (test-control-constants)
        r2 (test-property-constants)
        r3 (test-icon-constants)]
    (+ r1 (+ r2 r3))))

) ;; end defmodule style_test
