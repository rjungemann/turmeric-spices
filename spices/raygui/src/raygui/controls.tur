;;; gui-message-box -- draw a modal message dialog.
;;;
;;; Parameters:
;;;   r       -- bounding Rect
;;;   title   -- dialog title
;;;   message -- message body text
;;;   buttons -- semicolon-separated button labels ("OK;Cancel")
;;;
;;; Returns:
;;;   Index of the clicked button (0-based), or -1 if none clicked.
;;;
;;; Example:
;;;   (let [btn (gui-message-box (rect 200.0 150.0 300.0 150.0) "Confirm" "Exit?" "Yes;No")]
;;;     (when (= btn 0) (close-window)))
;;;
;;; Since: Phase 3
(defn gui-message-box [r : Rect title : cstr message : cstr buttons : cstr] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  return (int64_t)GuiMessageBox(bounds, (const char *)title,
                                (const char *)message, (const char *)buttons);
  ```)

;;; gui-text-input-box -- draw a modal text input dialog.
;;;
;;; Parameters:
;;;   r       -- bounding Rect
;;;   title   -- dialog title
;;;   message -- prompt message
;;;   buttons -- semicolon-separated button labels
;;;   buf     -- mutable text buffer handle (from make-text-buf)
;;;   size    -- buffer capacity in bytes
;;;   secret  -- 1 to hide typed characters (password mode)
;;;
;;; Returns:
;;;   Index of the clicked button, or -1 if none clicked.
;;;
;;; Since: Phase 3
(defn gui-text-input-box [r : Rect title : cstr message : cstr buttons : cstr
                           buf : int size : int secret : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  bool sec = (bool)secret;
  return (int64_t)GuiTextInputBox(bounds, (const char *)title,
                                  (const char *)message, (const char *)buttons,
                                  (char *)(intptr_t)buf, (int)size, &sec);
  ```)

;;; gui-grid -- draw a grid and return the hovered cell as a packed int.
;;;
;;; The return value packs the cell column in the low 32 bits and the row in
;;; the high 32 bits. Use (bit-and ret 0xFFFFFFFF) for col and
;;; (bit-shift-right ret 32) for row.
;;;
;;; Parameters:
;;;   r       -- bounding Rect
;;;   text    -- grid label
;;;   spacing -- cell size in pixels
;;;   divs    -- number of subdivisions per cell
;;;
;;; Returns:
;;;   Packed (row << 32 | col) of the hovered cell, or -1 if none.
;;;
;;; Since: Phase 3
(defn gui-grid [r : Rect text : cstr spacing : float divs : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  Vector2 cell = GuiGrid(bounds, (const char *)text, (float)spacing, (int)divs, NULL);
  if (cell.x < 0.0f) return (int64_t)-1;
  return (int64_t)(((int64_t)(int)cell.y << 32) | (int64_t)(int)cell.x);
  ```)

) ;; end defmodule raygui/controls
