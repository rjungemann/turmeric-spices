;;; gui-combo-box -- draw a combo box (click to cycle through items).
;;;
;;; Parameters:
;;;   r      -- bounding Rect
;;;   text   -- semicolon-separated item list ("Item1;Item2;Item3")
;;;   active -- index of the currently selected item
;;;
;;; Returns:
;;;   Index of the selected item after this frame.
;;;
;;; Example:
;;;   (set! mode (gui-combo-box (rect 10.0 10.0 150.0 30.0) "Linear;Ease;Bounce" mode))
;;;
;;; Since: Phase 3
(defn gui-combo-box [r : Rect text : cstr active : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  int a = (int)active;
  GuiComboBox(bounds, (const char *)text, &a);
  return (int64_t)a;
  ```)

;;; gui-dropdown-box -- draw a dropdown box; expands when clicked.
;;;
;;; Parameters:
;;;   r      -- bounding Rect
;;;   text   -- semicolon-separated item list
;;;   active -- index of the currently selected item
;;;   edit   -- current open/close state (0 = closed, 1 = open)
;;;
;;; Returns:
;;;   New edit (open) state after this frame.
;;;
;;; Example:
;;;   (set! dd-open (gui-dropdown-box (rect 10.0 10.0 150.0 30.0) "A;B;C" dd-sel dd-open))
;;;
;;; Since: Phase 3
(defn gui-dropdown-box [r : Rect text : cstr active : int edit : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  int a = (int)active;
  bool edit_b = (bool)edit;
  int result = GuiDropdownBox(bounds, (const char *)text, &a, edit_b);
  if (result) edit_b = !edit_b;
  return (int64_t)edit_b;
  ```)

;;; gui-list-view -- draw a scrollable list box.
;;;
;;; Parameters:
;;;   r      -- bounding Rect
;;;   text   -- semicolon-separated item list
;;;   scroll -- current scroll offset (pixels)
;;;   active -- index of the selected item (-1 = none)
;;;
;;; Returns:
;;;   Index of the newly selected item, or -1 if none.
;;;
;;; Example:
;;;   (set! sel (gui-list-view (rect 10.0 10.0 200.0 120.0) "Apple;Banana;Cherry" 0 sel))
;;;
;;; Since: Phase 3
(defn gui-list-view [r : Rect text : cstr scroll : int active : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  int s = (int)scroll;
  int a = (int)active;
  GuiListView(bounds, (const char *)text, &s, &a);
  return (int64_t)a;
  ```)

;;; gui-list-view-ex -- draw a list box with per-item control.
;;;
;;; Parameters:
;;;   r      -- bounding Rect
;;;   text   -- semicolon-separated item list
;;;   count  -- number of items in the list
;;;   scroll -- current scroll offset
;;;   active -- index of the selected item
;;;   focus  -- index of the focused item
;;;
;;; Returns:
;;;   Index of the selected item after this frame.
;;;
;;; Since: Phase 3
(defn gui-list-view-ex [r : Rect text : cstr count : int scroll : int active : int focus : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  int s = (int)scroll;
  int a = (int)active;
  int f = (int)focus;
  GuiListViewEx(bounds, (const char **)text, (int)count, &s, &a, &f);
  return (int64_t)a;
  ```)

;; ---------------------------------------------------------------------------
;; Misc controls (Phase 3)
;; ---------------------------------------------------------------------------

;;; gui-color-picker -- draw a full color picker (hue ring + HSV square).
;;;
;;; Parameters:
;;;   r     -- bounding Rect
;;;   text  -- label
;;;   color -- current color as packed RGBA int (0xRRGGBBAA)
;;;
;;; Returns:
;;;   New packed RGBA color.
;;;
;;; Example:
;;;   (set! col (gui-color-picker (rect 10.0 10.0 200.0 200.0) "Color" col))
;;;
;;; Since: Phase 3
(defn gui-color-picker [r : Rect text : cstr color : int] : int
  ```c
  #include <raylib.h>
  #include <raygui.h>
  Rectangle bounds = { (float)r.x, (float)r.y, (float)r.width, (float)r.height };
  Color c;
  c.r = (unsigned char)((color >> 24) & 0xFF);
  c.g = (unsigned char)((color >> 16) & 0xFF);
  c.b = (unsigned char)((color >>  8) & 0xFF);
  c.a = (unsigned char)( color        & 0xFF);
  GuiColorPicker(bounds, (const char *)text, &c);
  return (int64_t)(((int64_t)c.r << 24) | ((int64_t)c.g << 16) |
                   ((int64_t)c.b <<  8) |  (int64_t)c.a);
  ```)

;;; gui-color-bar-alpha -- draw an alpha channel bar.
;;;
;;; Parameters:
;;;   r     -- bounding Rect
;;;   text  -- label
;;;   alpha -- current alpha (0.0 to 1.0)
