;; tests/frame/group_test.tur -- FR5 group-by + agg tests.

(defmodule frame/tests/group
  (import frame/type   :refer [type-int64 type-float64 type-utf8])
  (import frame/column :refer [column-length column-type
                                column-int64-at column-float64-at column-utf8-at])
  (import frame/schema :refer [field schema])
  (import frame/frame  :refer [frame frame-free frame-nrows frame-ncols
                                frame-column])
  (import frame/csv    :refer [read-csv-string])
  (import frame/group  :refer [group-by grouped-count grouped-free
                                agg summarize
                                agg-count agg-sum agg-mean agg-min agg-max])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/suite   :refer [describe it])
  (import test/runner  :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)

  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cstr->int [s :cstr] :int
    ```c
    #include <stdint.h>
    return (int64_t)(intptr_t)s;
    ```)

  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn __all-tests [] :void

    (describe "group-by"
      (it "counts distinct groups"
        (let [src "g,v\nA,1\nB,2\nA,3\nC,4\nB,5\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "g") (t-nil))
              g   (group-by f ks)
              n   (grouped-count g)]
          (grouped-free g) (frame-free f)
          (assert-eq 3 n)))
      (it "produces n_groups == n_rows for all-unique keys"
        (let [src "g\n1\n2\n3\n4\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "g") (t-nil))
              g   (group-by f ks)
              n   (grouped-count g)]
          (grouped-free g) (frame-free f)
          (assert-eq 4 n)))
      (it "produces one group when every row has the same key"
        (let [src "g\nx\nx\nx\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "g") (t-nil))
              g   (group-by f ks)
              n   (grouped-count g)]
          (grouped-free g) (frame-free f)
          (assert-eq 1 n))))

    (describe "agg: sum / count / mean / min / max"
      (it "sum per group"
        (let [src "g,v\nA,1\nB,10\nA,2\nB,20\nA,3\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "g") (t-nil))
              g   (group-by f ks)
              outs (t-cons (cstr->int "sum_v") (t-nil))
              ins  (t-cons (cstr->int "v")     (t-nil))
              tags (t-cons (agg-sum)           (t-nil))
              r    (agg g outs ins tags)
              nr   (frame-nrows r)
              nc   (frame-ncols r)
              cg   (frame-column r "g")
              cs   (frame-column r "sum_v")
              ;; Groups come out in sort order: A, B
              a0   (column-utf8-at cg 0)  a1 (column-utf8-at cg 1)
              s0   (column-int64-at cs 0) s1 (column-int64-at cs 1)
              ok   (and (= nr 2) (= nc 2)
                        (t-cstr= a0 "A") (t-cstr= a1 "B")
                        (= s0 6) (= s1 30))]
          (frame-free r) (grouped-free g) (frame-free f)
          (assert-true ok)))
      (it "count and mean side-by-side"
        (let [src "g,v\nA,10\nB,1\nA,30\nB,3\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "g") (t-nil))
              g   (group-by f ks)
              outs (t-cons (cstr->int "n")
                  (t-cons (cstr->int "avg") (t-nil)))
              ins  (t-cons (cstr->int "v")
                  (t-cons (cstr->int "v") (t-nil)))
              tags (t-cons (agg-count)
                  (t-cons (agg-mean) (t-nil)))
              r    (agg g outs ins tags)
              cn   (frame-column r "n")
              ca   (frame-column r "avg")
              n0   (column-int64-at cn 0)
              n1   (column-int64-at cn 1)
              a0   (column-float64-at ca 0)
              a1   (column-float64-at ca 1)
              ok   (and (= n0 2) (= n1 2)
                        ;; mean(10,30) = 20.0; mean(1,3) = 2.0
                        ;; comparing float equality on whole-number averages is safe.
                        (= a0 20.0) (= a1 2.0))]
          (frame-free r) (grouped-free g) (frame-free f)
          (assert-true ok)))
      (it "min and max"
        (let [src "g,v\nA,5\nA,2\nA,9\nB,7\nB,7\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "g") (t-nil))
              g   (group-by f ks)
              outs (t-cons (cstr->int "lo")
                  (t-cons (cstr->int "hi") (t-nil)))
              ins  (t-cons (cstr->int "v")
                  (t-cons (cstr->int "v") (t-nil)))
              tags (t-cons (agg-min)
                  (t-cons (agg-max) (t-nil)))
              r    (agg g outs ins tags)
              cl   (frame-column r "lo")
              ch   (frame-column r "hi")
              lo0  (column-int64-at cl 0)  lo1 (column-int64-at cl 1)
              hi0  (column-int64-at ch 0)  hi1 (column-int64-at ch 1)
              ok   (and (= lo0 2) (= lo1 7) (= hi0 9) (= hi1 7))]
          (frame-free r) (grouped-free g) (frame-free f)
          (assert-true ok))))

    (describe "summarize"
      (it "whole-frame sum"
        (let [src "v\n10\n20\n30\n"
              f   (read-csv-string src 0 0 1 0 "")
              outs (t-cons (cstr->int "total") (t-nil))
              ins  (t-cons (cstr->int "v")     (t-nil))
              tags (t-cons (agg-sum)           (t-nil))
              r    (summarize f outs ins tags)
              nr   (frame-nrows r)
              ct   (frame-column r "total")
              tot  (column-int64-at ct 0)
              ok   (and (= nr 1) (= tot 60))]
          (frame-free r) (frame-free f)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
