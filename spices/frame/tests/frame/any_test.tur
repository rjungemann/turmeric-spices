;; tests/frame/any_test.tur -- FR7.5b tests for the heterogeneous "any"
;; column kind and the transpose transform built on top of it.

(defmodule frame/tests/any
  (import frame/type   :refer [type-int32 type-int64 type-float64 type-bool
                                type-utf8 type-any type-name])
  (import frame/column :refer [column-length column-type column-free
                                column-any-builder
                                builder-any-append-int32 builder-any-append-int64
                                builder-any-append-float64 builder-any-append-bool
                                builder-any-append-utf8 builder-any-append-null
                                builder-any-finish
                                column-any-tag-at column-any-int64-at
                                column-any-float64-at column-any-utf8-at
                                column-valid?])
  (import frame/schema :refer [field schema])
  (import frame/frame  :refer [frame frame-free frame-nrows frame-ncols
                                frame-column frame-column-at frame=?])
  (import frame/csv    :refer [read-csv-string])
  (import frame/reshape :refer [transpose])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/suite   :refer [describe it])
  (import test/runner  :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)

  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn close? [x :float y :float] :bool
    ```c
    double dx = x - y;
    if (dx < 0) dx = -dx;
    return dx < 1e-9;
    ```)

  (defn __all-tests [] :void

    (describe "frame/type"
      (it "type-any is tag 10 with name \"any\""
        (let [t (type-any)
              n (type-name t)
              ok (and (= t 10) (t-cstr= n "any"))]
          (assert-true ok))))

    (describe "column-any builder"
      (it "round-trips mixed-type cells via tag-aware accessors"
        (let [b (column-any-builder 0)]
          (builder-any-append-int64 b 42)
          (builder-any-append-utf8  b "hello")
          (builder-any-append-float64 b 3.14)
          (builder-any-append-bool  b 1)
          (builder-any-append-null  b)
          (let [c   (builder-any-finish b)
                n   (column-length c)
                tt  (column-type c)
                t0  (column-any-tag-at c 0)
                t1  (column-any-tag-at c 1)
                t2  (column-any-tag-at c 2)
                t3  (column-any-tag-at c 3)
                t4  (column-any-tag-at c 4)
                v0  (column-any-int64-at c 0)
                s1  (column-any-utf8-at  c 1)
                v2  (column-any-float64-at c 2)
                v3  (column-any-int64-at c 3)
                valid0 (column-valid? c 0)
                valid4 (column-valid? c 4)
                ok  (and (= n 5) (= tt (type-any))
                         (= t0 (type-int64)) (= t1 (type-utf8))
                         (= t2 (type-float64)) (= t3 (type-bool))
                         (= t4 0)
                         (= v0 42) (t-cstr= s1 "hello")
                         (close? v2 3.14) (= v3 1)
                         valid0 (not valid4))]
            (column-free c)
            (assert-true ok))))
      (it "frame=? distinguishes (int64, 1) from (utf8, \"1\") in any columns"
        (let [b1 (column-any-builder 0)
              b2 (column-any-builder 0)]
          (builder-any-append-int64 b1 1)
          (builder-any-append-utf8 b2 "1")
          (let [c1 (builder-any-finish b1)
                c2 (builder-any-finish b2)
                fld1 (field "x" (type-any) 0)
                s1   (schema (t-cons fld1 (t-nil)))
                fld2 (field "x" (type-any) 0)
                s2   (schema (t-cons fld2 (t-nil)))
                f1   (frame s1 (t-cons c1 (t-nil)))
                f2   (frame s2 (t-cons c2 (t-nil)))
                eq   (frame=? f1 f2)]
            (frame-free f1) (frame-free f2)
            (assert-true (not eq))))))

    (describe "transpose"
      (it "round-trips a homogeneous int64 frame"
        (let [src "a,b,c\n1,2,3\n4,5,6\n"
              f   (read-csv-string src 0 0 1 0 "")
              t   (transpose f "var")
              nr  (frame-nrows t)
              nc  (frame-ncols t)
              cvar (frame-column t "var")
              ;; column "row_0" holds the values from original row 0: (1, 2, 3)
              ;; column "row_1" holds original row 1: (4, 5, 6)
              c0   (frame-column t "row_0")
              c1   (frame-column t "row_1")
              ;; each value preserves int64 tag
              t00 (column-any-tag-at c0 0) v00 (column-any-int64-at c0 0)
              t01 (column-any-tag-at c0 1) v01 (column-any-int64-at c0 1)
              t02 (column-any-tag-at c0 2) v02 (column-any-int64-at c0 2)
              t10 (column-any-tag-at c1 0) v10 (column-any-int64-at c1 0)
              ok  (and (= nr 3) (= nc 3)        ; 3 rows (= original ncols), 3 cols (var + 2 row_* )
                       (= t00 (type-int64)) (= v00 1)
                       (= t01 (type-int64)) (= v01 2)
                       (= t02 (type-int64)) (= v02 3)
                       (= t10 (type-int64)) (= v10 4))]
          (frame-free t) (frame-free f)
          (assert-true ok)))
      (it "preserves per-cell types when transposing a heterogeneous frame"
        ;; Original: 2 cols (id int64, name utf8), 2 rows.
        ;;   id,name
        ;;   1,Alice
        ;;   2,Bob
        ;; Transposed: 2 rows (one per original col), 3 cols (var + row_0 + row_1).
        ;;   var,row_0,row_1
        ;;   id,1,2          <- row_0[0]: tag=int64 val=1; row_1[0]: tag=int64 val=2
        ;;   name,Alice,Bob  <- row_0[1]: tag=utf8 val="Alice"; row_1[1]: tag=utf8 val="Bob"
        (let [src "id,name\n1,Alice\n2,Bob\n"
              f   (read-csv-string src 0 0 1 0 "")
              t   (transpose f "var")
              cvar (frame-column t "var")
              c0   (frame-column t "row_0")
              c1   (frame-column t "row_1")
              ;; var column holds "id", "name"
              ;; (utf8 cstrs are heap copies; we just check the row count + transpose key column type)
              t00 (column-any-tag-at c0 0)
              t01 (column-any-tag-at c0 1)
              v00 (column-any-int64-at c0 0)
              s01 (column-any-utf8-at  c0 1)
              t10 (column-any-tag-at c1 0)
              t11 (column-any-tag-at c1 1)
              v10 (column-any-int64-at c1 0)
              s11 (column-any-utf8-at  c1 1)
              ok  (and (= t00 (type-int64)) (= v00 1)
                       (= t01 (type-utf8))  (t-cstr= s01 "Alice")
                       (= t10 (type-int64)) (= v10 2)
                       (= t11 (type-utf8))  (t-cstr= s11 "Bob"))]
          (frame-free t) (frame-free f)
          (assert-true ok)))
      (it "ncols(transpose(f)) == nrows(f) + 1; nrows(transpose(f)) == ncols(f)"
        (let [src "a,b,c\n1,2,3\n4,5,6\n7,8,9\n"
              f   (read-csv-string src 0 0 1 0 "")
              n0r (frame-nrows f)  n0c (frame-ncols f)
              t   (transpose f "var")
              tnr (frame-nrows t)  tnc (frame-ncols t)
              ok  (and (= tnr n0c) (= tnc (+ n0r 1)))]
          (frame-free t) (frame-free f)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
