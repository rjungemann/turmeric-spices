;; tests/frame/typed_test.tur -- U3 row-typed Frame surface (frame/typed).
;;
;; These tests stay row-*polymorphic*: they build a real frame, wrap it as a
;; `Frame` newtype, and read it back through the typed delegating accessors
;; without ever naming a concrete `#row{...}` schema.  That keeps the suite
;; runnable under the default `tur test` (no `-Xdata-literals` needed).
;;
;; The compile-time schema-mismatch guarantee -- a `Frame` of one column-set
;; row being rejected where another is expected (TUR-E0001) -- is the U3
;; "negative fixture" deliverable.  Because a concrete `#row{...}` literal
;; needs `-Xdata-literals` (which this repo's CI does not pass to `tur test`)
;; and the repo has no negative-fixture harness yet (uplift-plan P5), those
;; concrete-row demonstrations live in
;; docs/u3-row-typed-schemas-unblocked-2026-06-21.md rather than here.

(defmodule frame/tests/typed
  (import frame/type    :refer [type-int32 type-utf8])
  (import frame/column  :refer [column-int32 column-utf8])
  (import frame/schema  :refer [field schema])
  (import frame/frame   :refer [frame])
  (import frame/typed   :refer [Frame frame-typed frame-handle
                                tframe-nrows tframe-ncols
                                tcol-int32-at tcol-utf8-at
                                tframe-free])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  ;; Test-local cons / cstr helpers (named t-* to dodge the private __cons
  ;; helpers frame/frame.tur emits into importers).
  (defn t-nil [] : int ```c return 0; ```)

  (defn t-cons [v : int n : int] : int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cstr->int [s : cstr] : int
    ```c return (int64_t)(intptr_t)s; ```)

  (defn t-cstr= [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  ;; Build a 2-row, 2-column frame (id : int32, name : utf8) and wrap it as a
  ;; row-typed Frame.  Row stays a free phantom var -- the win demonstrated at
  ;; runtime is that the newtype is zero-cost and threads cleanly; the
  ;; concrete-schema type-safety is a compile-time property (see the doc).
  (defn build-users [^&cols] [] : (Frame cols)
    (let [s   (schema (t-cons (field "id"   (type-int32) 0)
                      (t-cons (field "name" (type-utf8)  0)
                      (t-nil))))
          cid (column-int32 (t-cons 1 (t-cons 2 (t-nil))) 0 0)
          cnm (column-utf8  (t-cons (cstr->int "alice")
                            (t-cons (cstr->int "bob")
                            (t-nil))) 0 0)
          raw (frame s (t-cons cid (t-cons cnm (t-nil))))]
      (frame-typed raw)))

  (defn __all-tests [] : void
    (describe "frame/typed -- row-typed Frame newtype"

      (it "frame-handle round-trips the underlying :int handle"
        (let [raw (frame (schema (t-cons (field "id" (type-int32) 0) (t-nil)))
                         (t-cons (column-int32 (t-cons 7 (t-nil)) 0 0) (t-nil)))
              tf  (frame-typed raw)
              ok  (= (frame-handle tf) raw)]
          (tframe-free tf)
          (assert-true ok)))

      (it "tframe-nrows / tframe-ncols delegate through the newtype"
        (let [tf (build-users)
              nr (tframe-nrows tf)
              nc (tframe-ncols tf)]
          (tframe-free tf)
          (assert-true (and (= nr 2) (= nc 2)))))

      (it "tcol-int32-at reads typed int cells"
        (let [tf (build-users)
              a  (tcol-int32-at tf "id" 0)
              b  (tcol-int32-at tf "id" 1)]
          (tframe-free tf)
          (assert-true (and (= a 1) (= b 2)))))

      (it "tcol-utf8-at reads typed utf8 cells"
        (let [tf (build-users)
              a  (tcol-utf8-at tf "name" 0)
              b  (tcol-utf8-at tf "name" 1)
              ok (and (t-cstr= a "alice") (t-cstr= b "bob"))]
          (tframe-free tf)
          (assert-true ok)))))

  (defn main [] : int
    (__all-tests)
    (run-all)
    0))
