;; tests/frame/utf8_test.tur -- FR1 utf8 column + builder API tests.

(defmodule frame/tests/utf8
  (import frame/type    :refer [type-int32 type-int64 type-float64
                                 type-bool type-utf8])
  (import frame/column  :refer [column-utf8 column-utf8-at
                                 column-type column-length column-null-count
                                 column-valid? column-slice column-free
                                 column-builder
                                 builder-append-int32 builder-append-int64
                                 builder-append-float64 builder-append-bool
                                 builder-append-utf8 builder-append-null
                                 builder-finish
                                 column-int32-at column-int64-at
                                 column-float64-at column-bool-at])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  ;; Test-local cons / cstr helpers.
  (defn t-nil [] :int ```c return 0; ```)

  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  ;; cstr->int casts a :cstr to an int slot so t-cons can carry it.
  (defn cstr->int [s :cstr] :int
    ```c
    #include <stdint.h>
    return (int64_t)(intptr_t)s;
    ```)

  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn __all-tests [] :void

    ;; ---------- frame/column utf8 ----------

    (describe "frame/column utf8"
      (it "column-utf8 length matches the input list"
        (let [vs (t-cons (cstr->int "alpha")
                 (t-cons (cstr->int "beta")
                 (t-cons (cstr->int "gamma")
                         (t-nil))))
              c  (column-utf8 vs 0 0)
              n  (column-length c)
              tt (column-type c)
              ok (and (= n 3) (= tt (type-utf8)))]
          (column-free c)
          (assert-true ok)))
      (it "column-utf8-at round-trips the strings in order"
        (let [vs (t-cons (cstr->int "hello")
                 (t-cons (cstr->int "world")
                         (t-nil)))
              c  (column-utf8 vs 0 0)
              s0 (column-utf8-at c 0)
              s1 (column-utf8-at c 1)
              ok (and (t-cstr= s0 "hello") (t-cstr= s1 "world"))]
          (column-free c)
          (assert-true ok)))
      (it "column-utf8 handles empty strings"
        (let [vs (t-cons (cstr->int "")
                 (t-cons (cstr->int "x")
                 (t-cons (cstr->int "")
                         (t-nil))))
              c  (column-utf8 vs 0 0)
              s0 (column-utf8-at c 0)
              s1 (column-utf8-at c 1)
              s2 (column-utf8-at c 2)
              ok (and (t-cstr= s0 "") (t-cstr= s1 "x") (t-cstr= s2 ""))]
          (column-free c)
          (assert-true ok)))
      (it "column-utf8 with validity marks nulls"
        (let [vs   (t-cons (cstr->int "a")
                   (t-cons (cstr->int "b")
                   (t-cons (cstr->int "c")
                           (t-nil))))
              vals (t-cons 1 (t-cons 0 (t-cons 1 (t-nil))))
              c    (column-utf8 vs 1 vals)
              nc   (column-null-count c)
              v0   (column-valid? c 0)
              v1   (column-valid? c 1)
              v2   (column-valid? c 2)
              ok   (and (= nc 1) v0 (not v1) v2)]
          (column-free c)
          (assert-true ok)))
      (it "column-slice on utf8 preserves the right strings"
        (let [vs (t-cons (cstr->int "one")
                 (t-cons (cstr->int "two")
                 (t-cons (cstr->int "three")
                 (t-cons (cstr->int "four")
                         (t-nil)))))
              c  (column-utf8 vs 0 0)
              s  (column-slice c 1 2)
              n  (column-length s)
              a  (column-utf8-at s 0)
              b  (column-utf8-at s 1)
              ok (and (= n 2) (t-cstr= a "two") (t-cstr= b "three"))]
          (column-free s)
          (column-free c)
          (assert-true ok))))

    ;; ---------- builder API ----------

    (describe "frame/column builder"
      (it "int32 builder accumulates and finishes"
        (let [b (column-builder (type-int32) 0)]
          (builder-append-int32 b 11)
          (builder-append-int32 b 22)
          (builder-append-int32 b 33)
          (let [c  (builder-finish b)
                n  (column-length c)
                a  (column-int32-at c 0)
                d  (column-int32-at c 1)
                e  (column-int32-at c 2)
                ok (and (= n 3) (= a 11) (= d 22) (= e 33))]
            (column-free c)
            (assert-true ok))))
      (it "int32 builder grows past its initial capacity"
        (let [b (column-builder (type-int32) 2)]
          (builder-append-int32 b 1)
          (builder-append-int32 b 2)
          (builder-append-int32 b 3)
          (builder-append-int32 b 4)
          (builder-append-int32 b 5)
          (let [c  (builder-finish b)
                n  (column-length c)
                v4 (column-int32-at c 4)
                ok (and (= n 5) (= v4 5))]
            (column-free c)
            (assert-true ok))))
      (it "int64 builder round-trip"
        (let [b (column-builder (type-int64) 0)]
          (builder-append-int64 b 1000)
          (builder-append-int64 b 2000)
          (let [c  (builder-finish b)
                a  (column-int64-at c 0)
                d  (column-int64-at c 1)
                ok (and (= a 1000) (= d 2000))]
            (column-free c)
            (assert-true ok))))
      (it "float64 builder round-trip"
        (let [b (column-builder (type-float64) 0)]
          (builder-append-float64 b 1.5)
          (builder-append-float64 b 2.5)
          (let [c  (builder-finish b)
                n  (column-length c)
                ok (= n 2)]
            (column-free c)
            (assert-true ok))))
      (it "bool builder packs bits"
        (let [b (column-builder (type-bool) 0)]
          (builder-append-bool b 1)
          (builder-append-bool b 0)
          (builder-append-bool b 1)
          (builder-append-bool b 1)
          (let [c  (builder-finish b)
                n  (column-length c)
                a  (column-bool-at c 0)
                d  (column-bool-at c 1)
                e  (column-bool-at c 2)
                f  (column-bool-at c 3)
                ok (and (= n 4) (= a 1) (= d 0) (= e 1) (= f 1))]
            (column-free c)
            (assert-true ok))))
      (it "utf8 builder appends strings"
        (let [b (column-builder (type-utf8) 0)]
          (builder-append-utf8 b "foo")
          (builder-append-utf8 b "barbaz")
          (builder-append-utf8 b "qux")
          (let [c  (builder-finish b)
                n  (column-length c)
                a  (column-utf8-at c 0)
                d  (column-utf8-at c 1)
                e  (column-utf8-at c 2)
                ok (and (= n 3) (t-cstr= a "foo") (t-cstr= d "barbaz")
                        (t-cstr= e "qux"))]
            (column-free c)
            (assert-true ok))))
      (it "utf8 builder records nulls via builder-append-null"
        (let [b (column-builder (type-utf8) 0)]
          (builder-append-utf8 b "x")
          (builder-append-null b)
          (builder-append-utf8 b "y")
          (let [c  (builder-finish b)
                n  (column-length c)
                nc (column-null-count c)
                v0 (column-valid? c 0)
                v1 (column-valid? c 1)
                v2 (column-valid? c 2)
                ok (and (= n 3) (= nc 1) v0 (not v1) v2)]
            (column-free c)
            (assert-true ok))))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
