;; tests/frame/csv_test.tur -- FR3 CSV reader/writer tests.

(defmodule frame/tests/csv
  (import frame/type   :refer [type-int64 type-float64 type-bool type-utf8])
  (import frame/column :refer [column-length column-type
                                column-int64-at column-float64-at
                                column-bool-at column-utf8-at])
  (import frame/schema :refer [field schema schema-arity schema-field-at])
  (import frame/frame  :refer [frame frame-free frame-nrows frame-ncols
                                frame-column frame-column-at frame-schema
                                frame=?])
  (import frame/csv    :refer [read-csv-string read-csv-typed
                                write-csv-string])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/suite   :refer [describe it])
  (import test/runner  :refer [run-all])

  (defn t-cstr= [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn t-cstr-contains? [hay : cstr needle : cstr] : bool
    ```c
    #include <string.h>
    return strstr((const char *)(intptr_t)hay, (const char *)(intptr_t)needle) != NULL;
    ```)

  (defn t-strlen [s : cstr] : int
    ```c
    #include <string.h>
    return (int64_t)strlen((const char *)(intptr_t)s);
    ```)

  (defn __all-tests [] : void

    (describe "read-csv-string"
      (it "parses a simple header + two-row int CSV"
        (let [src "x,y\n1,10\n2,20\n"
              f   (read-csv-string src 0 0 1 0 "")
              nr  (frame-nrows f)
              nc  (frame-ncols f)
              cx  (frame-column f "x")
              cy  (frame-column f "y")
              x0  (column-int64-at cx 0)
              x1  (column-int64-at cx 1)
              y0  (column-int64-at cy 0)
              y1  (column-int64-at cy 1)
              tx  (column-type cx)
              ty  (column-type cy)
              ok  (and (= nr 2) (= nc 2)
                       (= tx (type-int64)) (= ty (type-int64))
                       (= x0 1) (= x1 2) (= y0 10) (= y1 20))]
          (frame-free f)
          (assert-true ok)))

      (it "infers float64 when a column has a decimal"
        (let [src "a,b\n1,1.5\n2,2.5\n"
              f   (read-csv-string src 0 0 1 0 "")
              ca  (frame-column f "a")
              cb  (frame-column f "b")
              ta  (column-type ca)
              tb  (column-type cb)
              ok  (and (= ta (type-int64)) (= tb (type-float64)))]
          (frame-free f)
          (assert-true ok)))

      (it "infers utf8 when a column has any non-numeric value"
        (let [src "name,age\nalice,30\nbob,25\n"
              f   (read-csv-string src 0 0 1 0 "")
              cn  (frame-column f "name")
              ca  (frame-column f "age")
              s0  (column-utf8-at cn 0)
              s1  (column-utf8-at cn 1)
              ok  (and (= (column-type cn) (type-utf8))
                       (= (column-type ca) (type-int64))
                       (t-cstr= s0 "alice") (t-cstr= s1 "bob"))]
          (frame-free f)
          (assert-true ok)))

      (it "infers bool when every cell is true/false"
        (let [src "ok\ntrue\nfalse\ntrue\n"
              f   (read-csv-string src 0 0 1 0 "")
              c   (frame-column f "ok")
              v0  (column-bool-at c 0)
              v1  (column-bool-at c 1)
              v2  (column-bool-at c 2)
              ok  (and (= (column-type c) (type-bool))
                       (= v0 1) (= v1 0) (= v2 1))]
          (frame-free f)
          (assert-true ok)))

      (it "handles quoted fields with embedded commas and quotes"
        (let [src "txt\n\"hello, world\"\n\"with \"\"quote\"\"\"\n"
              f   (read-csv-string src 0 0 1 0 "")
              c   (frame-column f "txt")
              s0  (column-utf8-at c 0)
              s1  (column-utf8-at c 1)
              ok  (and (t-cstr= s0 "hello, world")
                       (t-cstr= s1 "with \"quote\""))]
          (frame-free f)
          (assert-true ok)))

      (it "treats NA / NULL / empty as null"
        (let [src "a\n1\n\n3\nNA\n5\n"
              f   (read-csv-string src 0 0 1 0 "")
              nr  (frame-nrows f)
              ok  (= nr 5)]
          (frame-free f)
          (assert-true ok)))

      (it "synthesizes col_N names when has-header = 0"
        (let [src "1,2\n3,4\n"
              f   (read-csv-string src 0 0 0 0 "")
              c0  (frame-column f "col_0")
              c1  (frame-column f "col_1")
              ok  (and (not= c0 0) (not= c1 0))]
          (frame-free f)
          (assert-true ok))))

    (describe "write-csv-string"
      (it "renders a header + numeric rows"
        (let [src "x,y\n1,10\n2,20\n"
              f   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string f 0 0 1)
              ok  (t-cstr= s "x,y\n1,10\n2,20\n")]
          (frame-free f)
          (assert-true ok)))

      (it "quotes cells containing the delimiter"
        (let [src "txt\n\"a,b\"\nc\n"
              f   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string f 0 0 1)
              ok  (and (t-cstr-contains? s "\"a,b\"")
                       (t-cstr-contains? s "c"))]
          (frame-free f)
          (assert-true ok))))

    (describe "round-trip read -> write -> read"
      (it "produces an equal frame for mixed types"
        (let [src "name,age,active\nAlice,30,true\nBob,25,false\n"
              a   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string a 0 0 1)
              b   (read-csv-string s 0 0 1 0 "")
              ok  (frame=? a b)]
          (frame-free a) (frame-free b)
          (assert-true ok)))
      (it "preserves a column with embedded newlines and quotes"
        (let [src "txt\n\"line1\nline2\"\n\"q\"\"q\"\n"
              a   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string a 0 0 1)
              b   (read-csv-string s 0 0 1 0 "")
              ok  (frame=? a b)]
          (frame-free a) (frame-free b)
          (assert-true ok)))))

  (defn main [] : int
    (__all-tests)
    (run-all)
    0))
