;; tests/frame/sort_test.tur -- FR4 stable multi-key sort tests.

(defmodule frame/tests/sort
  (import frame/type   :refer [type-int64 type-float64 type-utf8])
  (import frame/column :refer [column-int64 column-float64 column-utf8
                                column-int64-at column-float64-at column-utf8-at
                                column-free])
  (import frame/schema :refer [field schema])
  (import frame/frame  :refer [frame frame-free frame-nrows frame-ncols
                                frame-column frame-column-at])
  (import frame/sort   :refer [arrange arrange-indices reorder])
  (import frame/csv    :refer [read-csv-string])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/suite   :refer [describe it])
  (import test/runner  :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)

  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cstr->int [s :cstr] :int
    ```c
    #include <stdint.h>
    return (int64_t)(intptr_t)s;
    ```)

  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn __all-tests [] :void

    (describe "arrange (single key)"
      (it "sorts int64 ascending"
        (let [src "x\n3\n1\n2\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "x") (t-nil))
              dirs  (t-cons 0 (t-nil))
              g     (arrange f names dirs)
              c     (frame-column g "x")
              v0    (column-int64-at c 0)
              v1    (column-int64-at c 1)
              v2    (column-int64-at c 2)
              ok    (and (= v0 1) (= v1 2) (= v2 3))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "sorts int64 descending"
        (let [src "x\n3\n1\n2\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "x") (t-nil))
              dirs  (t-cons 1 (t-nil))
              g     (arrange f names dirs)
              c     (frame-column g "x")
              v0    (column-int64-at c 0)
              v1    (column-int64-at c 1)
              v2    (column-int64-at c 2)
              ok    (and (= v0 3) (= v1 2) (= v2 1))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "sorts utf8 alphabetically"
        (let [src "name\ncharlie\nalpha\nbravo\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "name") (t-nil))
              dirs  (t-cons 0 (t-nil))
              g     (arrange f names dirs)
              c     (frame-column g "name")
              s0    (column-utf8-at c 0)
              s1    (column-utf8-at c 1)
              s2    (column-utf8-at c 2)
              ok    (and (t-cstr= s0 "alpha") (t-cstr= s1 "bravo") (t-cstr= s2 "charlie"))]
          (frame-free g) (frame-free f)
          (assert-true ok))))

    (describe "arrange (multi-key + stability)"
      (it "sorts by group asc then value desc"
        (let [src "g,v\nA,2\nB,1\nA,1\nB,2\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "g") (t-cons (cstr->int "v") (t-nil)))
              dirs  (t-cons 0 (t-cons 1 (t-nil)))
              g     (arrange f names dirs)
              cg    (frame-column g "g")
              cv    (frame-column g "v")
              g0    (column-utf8-at cg 0)  g1 (column-utf8-at cg 1)
              g2    (column-utf8-at cg 2)  g3 (column-utf8-at cg 3)
              v0    (column-int64-at cv 0) v1 (column-int64-at cv 1)
              v2    (column-int64-at cv 2) v3 (column-int64-at cv 3)
              ok    (and (t-cstr= g0 "A") (t-cstr= g1 "A")
                         (t-cstr= g2 "B") (t-cstr= g3 "B")
                         (= v0 2) (= v1 1) (= v2 2) (= v3 1))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "is stable: equal-key rows preserve original order"
        ;; Four rows with same key; values record original index.
        (let [src "k,orig\nA,0\nA,1\nA,2\nA,3\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "k") (t-nil))
              dirs  (t-cons 0 (t-nil))
              g     (arrange f names dirs)
              co    (frame-column g "orig")
              v0    (column-int64-at co 0)
              v1    (column-int64-at co 1)
              v2    (column-int64-at co 2)
              v3    (column-int64-at co 3)
              ok    (and (= v0 0) (= v1 1) (= v2 2) (= v3 3))]
          (frame-free g) (frame-free f)
          (assert-true ok))))

    (describe "arrange-indices and reorder"
      (it "arrange-indices returns the right permutation"
        (let [src "x\n30\n10\n20\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "x") (t-nil))
              dirs  (t-cons 0 (t-nil))
              ixs   (arrange-indices f names dirs)
              g     (reorder f ixs)
              c     (frame-column g "x")
              v0    (column-int64-at c 0)
              v1    (column-int64-at c 1)
              v2    (column-int64-at c 2)
              ok    (and (= v0 10) (= v1 20) (= v2 30))]
          (frame-free g) (frame-free f)
          (assert-true ok))))

    (describe "arrange error handling"
      (it "returns 0 for unknown column name"
        (let [src "x\n1\n2\n"
              f   (read-csv-string src 0 0 1 0 "")
              names (t-cons (cstr->int "missing") (t-nil))
              dirs  (t-cons 0 (t-nil))
              g     (arrange f names dirs)
              ok    (= g 0)]
          (frame-free f)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
