;; tests/frame/datetime_test.tur -- FR9 date32 + timestamp + column-cast tests.

(defmodule frame/tests/datetime
  (import frame/type    :refer [type-int32 type-int64 type-float32 type-float64
                                 type-date32 type-timestamp type-name])
  (import frame/column  :refer [column-int32 column-int64 column-float64
                                 column-date32 column-timestamp column-cast
                                 column-length column-type
                                 column-int32-at column-int64-at
                                 column-float64-at
                                 column-date32-at column-timestamp-at
                                 column-free])
  (import frame/schema  :refer [field schema])
  (import frame/frame   :refer [frame frame-free frame-nrows frame-ncols
                                 frame-column frame=?])
  (import frame/csv     :refer [read-csv-string write-csv-string])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)
  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)
  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)
  (defn t-cstr-contains? [hay :cstr needle :cstr] :bool
    ```c
    #include <string.h>
    return strstr((const char *)(intptr_t)hay, (const char *)(intptr_t)needle) != NULL;
    ```)
  (defn close? [x :float y :float] :bool
    ```c
    double dx = x - y; if (dx < 0) dx = -dx;
    return dx < 1e-9;
    ```)

  (defn __all-tests [] :void

    (describe "type-date32 / type-timestamp"
      (it "type-date32 is tag 7 named \"date32\""
        (let [t (type-date32) n (type-name t)]
          (assert-true (and (= t 7) (t-cstr= n "date32")))))
      (it "type-timestamp is tag 8 named \"timestamp\""
        (let [t (type-timestamp) n (type-name t)]
          (assert-true (and (= t 8) (t-cstr= n "timestamp"))))))

    (describe "column-date32 / column-timestamp"
      (it "column-date32 stores days-since-epoch and exposes type tag 7"
        (let [c (column-date32 (t-cons 0 (t-cons 1 (t-cons 365 (t-nil)))) 0 0)
              n (column-length c)
              t (column-type c)
              v0 (column-date32-at c 0)
              v1 (column-date32-at c 1)
              v2 (column-date32-at c 2)
              ok (and (= n 3) (= t (type-date32))
                      (= v0 0) (= v1 1) (= v2 365))]
          (column-free c)
          (assert-true ok)))
      (it "column-timestamp stores microseconds with tag 8"
        (let [c (column-timestamp (t-cons 0 (t-cons 1000000 (t-nil))) 0 0)
              t (column-type c)
              v0 (column-timestamp-at c 0)
              v1 (column-timestamp-at c 1)
              ok (and (= t (type-timestamp)) (= v0 0) (= v1 1000000))]
          (column-free c)
          (assert-true ok))))

    (describe "column-cast"
      (it "int32 -> int64 widens"
        (let [a (column-int32 (t-cons 1 (t-cons 2 (t-cons 3 (t-nil)))) 0 0)
              b (column-cast a (type-int64))
              v0 (column-int64-at b 0)
              v2 (column-int64-at b 2)
              ok (and (= (column-type b) (type-int64))
                      (= v0 1) (= v2 3))]
          (column-free a) (column-free b)
          (assert-true ok)))
      (it "int64 -> float64 converts"
        (let [a (column-int64 (t-cons 10 (t-cons 20 (t-nil))) 0 0)
              b (column-cast a (type-float64))
              v0 (column-float64-at b 0)
              v1 (column-float64-at b 1)
              ok (and (= (column-type b) (type-float64))
                      (close? v0 10.0) (close? v1 20.0))]
          (column-free a) (column-free b)
          (assert-true ok)))
      (it "date32 -> int32 keeps the underlying days value"
        (let [a (column-date32 (t-cons 19500 (t-cons 19501 (t-nil))) 0 0)
              b (column-cast a (type-int32))
              v0 (column-int32-at b 0)
              v1 (column-int32-at b 1)
              ok (and (= (column-type b) (type-int32))
                      (= v0 19500) (= v1 19501))]
          (column-free a) (column-free b)
          (assert-true ok)))
      (it "returns 0 for unsupported casts (utf8)"
        (let [a (column-int64 (t-cons 1 (t-nil)) 0 0)
              b (column-cast a 6)   ; type-utf8 = 6
              ok (= b 0)]
          (column-free a)
          (assert-true ok))))

    (describe "CSV reader infers date32 / timestamp"
      (it "infers date32 for ISO YYYY-MM-DD"
        (let [src "d\n2026-05-24\n2026-05-25\n2024-01-01\n"
              f   (read-csv-string src 0 0 1 0 "")
              c   (frame-column f "d")
              tt  (column-type c)
              d0  (column-date32-at c 0)
              d1  (column-date32-at c 1)
              ;; 2026-05-24 is days_from_civil(2026,5,24) = 20597 from civil epoch.
              ;; Computed independently: 20597.
              ok  (and (= tt (type-date32))
                       (= d0 20597) (= d1 20598))]
          (frame-free f)
          (assert-true ok)))
      (it "infers timestamp for \"YYYY-MM-DD HH:MM:SS\""
        (let [src "ts\n2026-05-24 00:00:00\n2026-05-24 12:30:45\n"
              f   (read-csv-string src 0 0 1 0 "")
              c   (frame-column f "ts")
              tt  (column-type c)
              t0  (column-timestamp-at c 0)
              t1  (column-timestamp-at c 1)
              ;; t0 = 20597 days * 86400 s * 1e6 us = 1,779,580,800,000,000 us.
              ;; t1 = t0 + (12*3600 + 30*60 + 45) * 1e6 us = t0 + 45,045,000,000 us
              expected-t0 1779580800000000
              expected-t1 1779625845000000
              ok  (and (= tt (type-timestamp))
                       (= t0 expected-t0)
                       (= t1 expected-t1))]
          (frame-free f)
          (assert-true ok))))

    (describe "CSV writer renders date32 / timestamp"
      (it "writes date32 as YYYY-MM-DD"
        (let [src "d\n2026-05-24\n2024-01-01\n"
              f   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string f 0 0 1)
              ok  (and (t-cstr-contains? s "2026-05-24")
                       (t-cstr-contains? s "2024-01-01"))]
          (frame-free f)
          (assert-true ok)))
      (it "writes timestamp as YYYY-MM-DD HH:MM:SS"
        (let [src "ts\n2026-05-24 12:30:45\n"
              f   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string f 0 0 1)
              ok  (t-cstr-contains? s "2026-05-24 12:30:45")]
          (frame-free f)
          (assert-true ok))))

    (describe "CSV round-trip with dates"
      (it "round-trips a frame with date32 and int columns"
        (let [src "id,d\n1,2026-05-24\n2,2024-01-01\n"
              a   (read-csv-string src 0 0 1 0 "")
              s   (write-csv-string a 0 0 1)
              b   (read-csv-string s 0 0 1 0 "")
              ok  (frame=? a b)]
          (frame-free a) (frame-free b)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
