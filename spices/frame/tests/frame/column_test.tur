;; tests/frame/column_test.tur -- FR0 smoke tests for type/buffer/column/schema/frame.

(defmodule frame/tests/column
  (import frame/type    :refer [type-int32 type-int64 type-float64
                                 type-bool type-name type-size
                                 type-numeric? type-variable-length?])
  (import frame/buffer  :refer [buffer-alloc buffer-free buffer-size
                                 bitmap-alloc bitmap-set bitmap-get bitmap-null-count])
  (import frame/column  :refer [column-int32 column-int64 column-bool
                                 column-type column-length column-null-count
                                 column-valid? column-int32-at column-int64-at
                                 column-bool-at column-slice column-free])
  (import frame/schema  :refer [field field-name field-type field-nullable
                                 schema schema-arity schema-index-of])
  (import frame/frame   :refer [frame frame-free frame-nrows frame-ncols
                                 frame-column frame-column-at
                                 frame-head frame-slice])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  ;; Test-local cons builder.  Named t-* to avoid collision with the private
  ;; __nil / __cons helpers that frame/frame.tur emits into every importer.
  (defn t-nil [] : int ```c return 0; ```)

  (defn t-cons [v : int n : int] : int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn t-cstr= [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn t-aligned64? [p : int] : bool
    ```c
    #include <stdint.h>
    return ((uintptr_t)p & (uintptr_t)63) == 0;
    ```)

  ;; All describe/it blocks are wrapped in __all-tests so they actually run
  ;; (top-level forms inside defmodule are emitted as static decls only, not
  ;; executed; main has to invoke them).
  (defn __all-tests [] : void

  ;; ---------- frame/type ----------

  (describe "frame/type"
    (it "type tags are stable small ints"
      (assert-eq 1 (type-int32)))
    (it "type-name returns int32 for int32 tag"
      (let [n  (type-name (type-int32))
            ok (t-cstr= n "int32")]
        (assert-true ok)))
    (it "type-size returns 4 for int32"
      (assert-eq 4 (type-size (type-int32))))
    (it "type-size returns 8 for int64"
      (assert-eq 8 (type-size (type-int64))))
    (it "type-numeric? true for float64"
      (assert-true (type-numeric? (type-float64))))
    (it "type-numeric? false for bool"
      (assert-true (not (type-numeric? (type-bool)))))
    (it "type-variable-length? false for int32"
      (assert-true (not (type-variable-length? (type-int32))))))

  ;; ---------- frame/buffer ----------

  (describe "frame/buffer"
    (it "buffer-alloc returns aligned, sized buffer"
      (let [p   (buffer-alloc 100)
            sz  (buffer-size p)
            ok? (and (not= p 0) (>= sz 100) (t-aligned64? p))]
        (buffer-free p)
        (assert-true ok?)))
    (it "bitmap-alloc starts all-valid (null-count = 0)"
      (let [b (bitmap-alloc 10)
            n (bitmap-null-count b 10)]
        (buffer-free b)
        (assert-eq 0 n)))
    (it "bitmap-set / bitmap-get round-trip"
      (let [b (bitmap-alloc 16)]
        (bitmap-set b 3 0)
        (bitmap-set b 7 0)
        (let [g3 (bitmap-get b 3)
              g4 (bitmap-get b 4)
              n  (bitmap-null-count b 16)
              ok (and (= g3 0) (= g4 1) (= n 2))]
          (buffer-free b)
          (assert-true ok)))))

  ;; ---------- frame/column ----------

  (describe "frame/column"
    (it "column-int32 length matches input list"
      (let [c (column-int32 (t-cons 10 (t-cons 20 (t-cons 30 (t-nil)))) 0 0)
            n (column-length c)]
        (column-free c)
        (assert-eq 3 n)))
    (it "column-int32-at returns stored values in order"
      (let [c  (column-int32 (t-cons 10 (t-cons 20 (t-cons 30 (t-nil)))) 0 0)
            a  (column-int32-at c 0)
            b  (column-int32-at c 1)
            d  (column-int32-at c 2)
            ok (and (= a 10) (= b 20) (= d 30))]
        (column-free c)
        (assert-true ok)))
    (it "column-int64 round-trip"
      (let [c  (column-int64 (t-cons 100 (t-cons 200 (t-nil))) 0 0)
            a  (column-int64-at c 0)
            b  (column-int64-at c 1)
            ok (and (= a 100) (= b 200))]
        (column-free c)
        (assert-true ok)))
    (it "column-bool packs and reads 1 bit per row"
      (let [vs (t-cons 1 (t-cons 0 (t-cons 1 (t-cons 1 (t-cons 0 (t-nil))))))
            c  (column-bool vs 0 0)
            a  (column-bool-at c 0)
            b  (column-bool-at c 1)
            d  (column-bool-at c 2)
            e  (column-bool-at c 3)
            f  (column-bool-at c 4)
            ok (and (= a 1) (= b 0) (= d 1) (= e 1) (= f 0))]
        (column-free c)
        (assert-true ok)))
    (it "validity list marks nulls"
      (let [vs   (t-cons 10 (t-cons 20 (t-cons 30 (t-nil))))
            vals (t-cons 1  (t-cons 0  (t-cons 1  (t-nil))))
            c    (column-int32 vs 1 vals)
            nc   (column-null-count c)
            v0   (column-valid? c 0)
            v1   (column-valid? c 1)
            v2   (column-valid? c 2)
            ok   (and (= nc 1) v0 (not v1) v2)]
        (column-free c)
        (assert-true ok)))
    (it "column-slice returns a new column with the right rows"
      (let [c  (column-int32 (t-cons 1 (t-cons 2 (t-cons 3 (t-cons 4 (t-cons 5 (t-nil))))))
                              0 0)
            s  (column-slice c 1 3)
            n  (column-length s)
            a  (column-int32-at s 0)
            b  (column-int32-at s 1)
            d  (column-int32-at s 2)
            ok (and (= n 3) (= a 2) (= b 3) (= d 4))]
        (column-free s)
        (column-free c)
        (assert-true ok))))

  ;; ---------- frame/schema ----------

  (describe "frame/schema"
    (it "field accessors return constructor arguments"
      (let [fd (field "age" (type-int32) 1)
            t  (field-type fd)
            n  (field-nullable fd)
            ok (and (= t (type-int32)) (= n 1)
                    (t-cstr= (field-name fd) "age"))]
        ;; Field will be freed when its owning schema is freed in the next test;
        ;; here we leak it deliberately because field-free is not exported in FR0.
        (assert-true ok)))
    (it "schema-arity matches the number of fields"
      (let [s  (schema (t-cons (field "x" (type-int32) 0)
                       (t-cons (field "y" (type-float64) 0)
                               (t-nil))))
            n  (schema-arity s)
            ix (schema-index-of s "y")
            ok (and (= n 2) (= ix 1))]
        ;; Frame test below will own/free a similar schema; here we let it leak.
        (assert-true ok))))

  ;; ---------- frame/frame ----------

  (describe "frame/frame"
    (it "frame builds with matching schema + columns"
      (let [s   (schema (t-cons (field "x" (type-int32) 0)
                        (t-cons (field "y" (type-int32) 0)
                                (t-nil))))
            cx  (column-int32 (t-cons 1 (t-cons 2 (t-cons 3 (t-nil)))) 0 0)
            cy  (column-int32 (t-cons 10 (t-cons 20 (t-cons 30 (t-nil)))) 0 0)
            f   (frame s (t-cons cx (t-cons cy (t-nil))))
            nr  (frame-nrows f)
            nc  (frame-ncols f)
            ok  (and (= nr 3) (= nc 2))]
        (frame-free f)
        (assert-true ok)))
    (it "frame returns 0 on arity mismatch"
      (let [s  (schema (t-cons (field "x" (type-int32) 0) (t-nil)))
            cx (column-int32 (t-cons 1 (t-nil)) 0 0)
            cy (column-int32 (t-cons 2 (t-nil)) 0 0)
            f  (frame s (t-cons cx (t-cons cy (t-nil))))]
        ;; On mismatch the schema and columns are still owned by the caller;
        ;; we free them explicitly to keep valgrind quiet.
        (column-free cx)
        (column-free cy)
        ;; schema is leaked here (schema-free not safe to call when it owns nothing
        ;; we need to drop -- documented; matches FR0 contract).
        (assert-eq 0 f)))
    (it "frame-column looks up a column by name"
      (let [s  (schema (t-cons (field "x" (type-int32) 0)
                       (t-cons (field "y" (type-int32) 0)
                               (t-nil))))
            cx (column-int32 (t-cons 1 (t-cons 2 (t-nil))) 0 0)
            cy (column-int32 (t-cons 7 (t-cons 8 (t-nil))) 0 0)
            f  (frame s (t-cons cx (t-cons cy (t-nil))))
            c  (frame-column f "y")
            a  (column-int32-at c 0)
            b  (column-int32-at c 1)
            ok (and (= a 7) (= b 8))]
        (frame-free f)
        (assert-true ok)))
    (it "frame-head returns the first n rows"
      (let [s  (schema (t-cons (field "x" (type-int32) 0) (t-nil)))
            cx (column-int32 (t-cons 1 (t-cons 2 (t-cons 3 (t-cons 4 (t-nil))))) 0 0)
            f  (frame s (t-cons cx (t-nil)))
            h  (frame-head f 2)
            nr (frame-nrows h)
            c  (frame-column h "x")
            a  (column-int32-at c 0)
            b  (column-int32-at c 1)
            ok (and (= nr 2) (= a 1) (= b 2))]
        (frame-free h)
        (frame-free f)
        (assert-true ok)))
    (it "frame-slice returns rows [offset, offset+length)"
      (let [s  (schema (t-cons (field "x" (type-int32) 0) (t-nil)))
            cx (column-int32 (t-cons 10 (t-cons 20 (t-cons 30 (t-cons 40 (t-cons 50 (t-nil)))))) 0 0)
            f  (frame s (t-cons cx (t-nil)))
            sl (frame-slice f 1 3)
            nr (frame-nrows sl)
            c  (frame-column sl "x")
            a  (column-int32-at c 0)
            b  (column-int32-at c 1)
            d  (column-int32-at c 2)
            ok (and (= nr 3) (= a 20) (= b 30) (= d 40))]
        (frame-free sl)
        (frame-free f)
        (assert-true ok)))))

  (defn main [] : int
    (__all-tests)
    (run-all)
    0))
