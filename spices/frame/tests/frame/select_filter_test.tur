;; tests/frame/select_filter_test.tur -- FR2 tests for select/drop/rename/
;; with-col/filter-mask/frame=?.

(defmodule frame/tests/select-filter
  (import frame/type    :refer [type-int32 type-int64 type-float64
                                 type-bool type-utf8])
  (import frame/column  :refer [column-int32 column-int64 column-bool column-utf8
                                 column-length column-int32-at column-utf8-at
                                 column-free])
  (import frame/schema  :refer [field schema])
  (import frame/frame   :refer [frame frame-free frame-nrows frame-ncols
                                 frame-column frame=?])
  (import frame/select  :refer [select-cols drop-cols rename with-col])
  (import frame/filter  :refer [filter-mask])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  (defn t-nil [] : int ```c return 0; ```)

  (defn t-cons [v : int n : int] : int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cstr->int [s : cstr] : int
    ```c
    #include <stdint.h>
    return (int64_t)(intptr_t)s;
    ```)

  (defn t-cstr= [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  ;; Build a 3-col, 4-row sample frame: x:int32, y:int32, name:utf8.
  (defn sample-frame [] : int
    (let [s   (schema (t-cons (field "x"    (type-int32) 0)
                      (t-cons (field "y"    (type-int32) 0)
                      (t-cons (field "name" (type-utf8)  0)
                              (t-nil)))))
          xs  (column-int32 (t-cons 1 (t-cons 2 (t-cons 3 (t-cons 4 (t-nil))))) 0 0)
          ys  (column-int32 (t-cons 10 (t-cons 20 (t-cons 30 (t-cons 40 (t-nil))))) 0 0)
          nm  (column-utf8 (t-cons (cstr->int "a")
                           (t-cons (cstr->int "b")
                           (t-cons (cstr->int "c")
                           (t-cons (cstr->int "d")
                                   (t-nil))))) 0 0)]
      (frame s (t-cons xs (t-cons ys (t-cons nm (t-nil)))))))

  (defn __all-tests [] : void

    (describe "frame=?"
      (it "equal frames compare true"
        (let [a  (sample-frame)
              b  (sample-frame)
              ok (frame=? a b)]
          (frame-free a) (frame-free b)
          (assert-true ok)))
      (it "frames with a different cell are unequal"
        (let [a  (sample-frame)
              ;; Build b with one cell changed.
              s  (schema (t-cons (field "x"    (type-int32) 0)
                         (t-cons (field "y"    (type-int32) 0)
                         (t-cons (field "name" (type-utf8)  0)
                                 (t-nil)))))
              xs (column-int32 (t-cons 1 (t-cons 99 (t-cons 3 (t-cons 4 (t-nil))))) 0 0)
              ys (column-int32 (t-cons 10 (t-cons 20 (t-cons 30 (t-cons 40 (t-nil))))) 0 0)
              nm (column-utf8 (t-cons (cstr->int "a")
                              (t-cons (cstr->int "b")
                              (t-cons (cstr->int "c")
                              (t-cons (cstr->int "d")
                                      (t-nil))))) 0 0)
              b  (frame s (t-cons xs (t-cons ys (t-cons nm (t-nil)))))
              ok (not (frame=? a b))]
          (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "frame/select"
      (it "select keeps named columns in the given order"
        (let [f      (sample-frame)
              names  (t-cons (cstr->int "name") (t-cons (cstr->int "x") (t-nil)))
              g      (select-cols f names)
              nc     (frame-ncols g)
              nr     (frame-nrows g)
              cn     (frame-column g "name")
              cx     (frame-column g "x")
              s0     (column-utf8-at cn 0)
              x0     (column-int32-at cx 0)
              ok     (and (= nc 2) (= nr 4) (t-cstr= s0 "a") (= x0 1))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "select returns 0 when a name is missing"
        (let [f      (sample-frame)
              names  (t-cons (cstr->int "nope") (t-nil))
              g      (select-cols f names)
              ok     (= g 0)]
          (frame-free f)
          (assert-true ok)))
      (it "drop-cols removes the named columns"
        (let [f      (sample-frame)
              names  (t-cons (cstr->int "y") (t-nil))
              g      (drop-cols f names)
              nc     (frame-ncols g)
              cx     (frame-column g "x")
              cy     (frame-column g "y")
              ok     (and (= nc 2) (not= cx 0) (= cy 0))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "rename changes only the chosen column's name"
        (let [f  (sample-frame)
              g  (rename f "y" "yy")
              cy  (frame-column g "y")
              cyy (frame-column g "yy")
              ok  (and (= cy 0) (not= cyy 0) (= (frame-ncols g) 3))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "with-col appends a new column when name is fresh"
        (let [f  (sample-frame)
              cw (column-int32 (t-cons 100 (t-cons 200 (t-cons 300 (t-cons 400 (t-nil))))) 0 0)
              g  (with-col f "w" (type-int32) cw)
              nc (frame-ncols g)
              cw2 (frame-column g "w")
              w0 (column-int32-at cw2 0)
              ok (and (= nc 4) (= w0 100))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "with-col replaces an existing column"
        (let [f  (sample-frame)
              cy2 (column-int32 (t-cons 7 (t-cons 7 (t-cons 7 (t-cons 7 (t-nil))))) 0 0)
              g  (with-col f "y" (type-int32) cy2)
              nc (frame-ncols g)
              cy (frame-column g "y")
              v0 (column-int32-at cy 0)
              v3 (column-int32-at cy 3)
              ok (and (= nc 3) (= v0 7) (= v3 7))]
          (frame-free g) (frame-free f)
          (assert-true ok))))

    (describe "frame/filter"
      (it "filter-mask keeps rows where mask = 1"
        (let [f    (sample-frame)
              m    (column-bool (t-cons 1 (t-cons 0 (t-cons 1 (t-cons 0 (t-nil))))) 0 0)
              g    (filter-mask f m)
              nr   (frame-nrows g)
              nc   (frame-ncols g)
              cx   (frame-column g "x")
              cn   (frame-column g "name")
              x0   (column-int32-at cx 0)
              x1   (column-int32-at cx 1)
              s0   (column-utf8-at cn 0)
              s1   (column-utf8-at cn 1)
              ok   (and (= nr 2) (= nc 3) (= x0 1) (= x1 3)
                        (t-cstr= s0 "a") (t-cstr= s1 "c"))]
          (column-free m) (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "select + filter compose"
        (let [f      (sample-frame)
              names  (t-cons (cstr->int "name") (t-cons (cstr->int "x") (t-nil)))
              g      (select-cols f names)
              m      (column-bool (t-cons 0 (t-cons 1 (t-cons 1 (t-cons 0 (t-nil))))) 0 0)
              h      (filter-mask g m)
              nr     (frame-nrows h)
              nc     (frame-ncols h)
              cx     (frame-column h "x")
              x0     (column-int32-at cx 0)
              x1     (column-int32-at cx 1)
              ok     (and (= nr 2) (= nc 2) (= x0 2) (= x1 3))]
          (column-free m)
          (frame-free h) (frame-free g) (frame-free f)
          (assert-true ok)))))

  (defn main [] : int
    (__all-tests)
    (run-all)
    0))
