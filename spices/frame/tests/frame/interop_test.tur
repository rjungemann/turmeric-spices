;; tests/frame/interop_test.tur -- FR8 Arrow C Data Interface round-trip tests.

(defmodule frame/tests/interop
  (import frame/type    :refer [type-int32 type-int64 type-float64
                                 type-bool type-utf8])
  (import frame/column  :refer [column-length column-type column-int64-at
                                 column-utf8-at column-free])
  (import frame/schema  :refer [field schema])
  (import frame/frame   :refer [frame frame-free frame-nrows frame-ncols
                                 frame-column frame=?])
  (import frame/csv     :refer [read-csv-string])
  (import frame/interop :refer [arrow-export arrow-import
                                 arrow-export-column arrow-import-column])
  (import test/assert   :refer [assert-eq assert-true])
  (import test/suite    :refer [describe it])
  (import test/runner   :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)
  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)
  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn cons-first  [xs :int] :int ```c
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    return ((struct __cons *)(intptr_t)xs)->value;
    ```)
  (defn cons-second [xs :int] :int ```c
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *p = (struct __cons *)(intptr_t)xs;
    return ((struct __cons *)(intptr_t)p->next)->value;
    ```)

  (defn __all-tests [] :void

    (describe "arrow-export-column / arrow-import-column"
      (it "round-trips an int64 column"
        (let [src "x\n10\n20\n30\n"
              f   (read-csv-string src 0 0 1 0 "")
              c0  (frame-column f "x")
              pair (arrow-export-column c0 "x")
              sch  (cons-first  pair)
              arr  (cons-second pair)
              c1   (arrow-import-column sch arr)
              n    (column-length c1)
              tt   (column-type c1)
              v0   (column-int64-at c1 0)
              v1   (column-int64-at c1 1)
              v2   (column-int64-at c1 2)
              ok   (and (= n 3) (= tt (type-int64))
                        (= v0 10) (= v1 20) (= v2 30))]
          (column-free c1) (frame-free f)
          (assert-true ok)))
      (it "round-trips a utf8 column"
        (let [src "name\nAlice\nBob\nCharlie\n"
              f   (read-csv-string src 0 0 1 0 "")
              c0  (frame-column f "name")
              pair (arrow-export-column c0 "name")
              sch  (cons-first  pair)
              arr  (cons-second pair)
              c1   (arrow-import-column sch arr)
              s0   (column-utf8-at c1 0)
              s1   (column-utf8-at c1 1)
              s2   (column-utf8-at c1 2)
              ok   (and (= (column-type c1) (type-utf8))
                        (t-cstr= s0 "Alice") (t-cstr= s1 "Bob") (t-cstr= s2 "Charlie"))]
          (column-free c1) (frame-free f)
          (assert-true ok))))

    (describe "arrow-export / arrow-import"
      (it "round-trips a numeric + utf8 frame"
        (let [src "id,name,age\n1,Alice,30\n2,Bob,25\n3,Charlie,40\n"
              f1  (read-csv-string src 0 0 1 0 "")
              pair (arrow-export f1)
              sch  (cons-first  pair)
              arr  (cons-second pair)
              f2   (arrow-import sch arr)
              ok   (frame=? f1 f2)]
          (frame-free f1) (frame-free f2)
          (assert-true ok)))
      (it "preserves frame shape across export/import"
        (let [src "a,b\n1,1.5\n2,2.5\n"
              f1  (read-csv-string src 0 0 1 0 "")
              nr  (frame-nrows f1)
              nc  (frame-ncols f1)
              pair (arrow-export f1)
              sch  (cons-first  pair)
              arr  (cons-second pair)
              f2   (arrow-import sch arr)
              ok   (and (= (frame-nrows f2) nr)
                        (= (frame-ncols f2) nc))]
          (frame-free f1) (frame-free f2)
          (assert-true ok))))

    (describe "interop preserves cell values"
      (it "int64 cells survive a round-trip exactly"
        (let [src "v\n1\n2\n3\n4\n5\n"
              f1  (read-csv-string src 0 0 1 0 "")
              pair (arrow-export f1)
              sch  (cons-first  pair)
              arr  (cons-second pair)
              f2   (arrow-import sch arr)
              c2   (frame-column f2 "v")
              v0   (column-int64-at c2 0)
              v4   (column-int64-at c2 4)
              ok   (and (= v0 1) (= v4 5))]
          (frame-free f1) (frame-free f2)
          (assert-true ok)))
      (it "utf8 cells survive a round-trip exactly"
        (let [src "name\nfoo\nbar\nbaz\n"
              f1  (read-csv-string src 0 0 1 0 "")
              pair (arrow-export f1)
              sch  (cons-first  pair)
              arr  (cons-second pair)
              f2   (arrow-import sch arr)
              c2   (frame-column f2 "name")
              s0   (column-utf8-at c2 0)
              s1   (column-utf8-at c2 1)
              s2   (column-utf8-at c2 2)
              ok   (and (t-cstr= s0 "foo") (t-cstr= s1 "bar") (t-cstr= s2 "baz"))]
          (frame-free f1) (frame-free f2)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
