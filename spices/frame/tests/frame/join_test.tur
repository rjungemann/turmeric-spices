;; tests/frame/join_test.tur -- FR6 hash join tests.

(defmodule frame/tests/join
  (import frame/type   :refer [type-int64 type-utf8])
  (import frame/column :refer [column-length column-type
                                column-int64-at column-utf8-at column-valid?])
  (import frame/schema :refer [field schema])
  (import frame/frame  :refer [frame frame-free frame-nrows frame-ncols
                                frame-column])
  (import frame/csv    :refer [read-csv-string])
  (import frame/join   :refer [inner-join left-join right-join full-join
                                semi-join anti-join cross-join join])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/suite   :refer [describe it])
  (import test/runner  :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)

  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cstr->int [s :cstr] :int
    ```c
    #include <stdint.h>
    return (int64_t)(intptr_t)s;
    ```)

  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn __all-tests [] :void

    (describe "inner-join (int keys)"
      (it "matches on equal int keys"
        (let [a (read-csv-string "id,x\n1,10\n2,20\n3,30\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n2,200\n3,300\n4,400\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (inner-join a b ks ks)
              nr (frame-nrows g)
              nc (frame-ncols g)
              cid (frame-column g "id")
              cx  (frame-column g "x")
              cy  (frame-column g "y")
              id0 (column-int64-at cid 0) id1 (column-int64-at cid 1)
              x0  (column-int64-at cx 0)  x1  (column-int64-at cx 1)
              y0  (column-int64-at cy 0)  y1  (column-int64-at cy 1)
              ok  (and (= nr 2) (= nc 3)
                       (= id0 2) (= id1 3)
                       (= x0 20) (= x1 30)
                       (= y0 200) (= y1 300))]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "inner-join (utf8 keys)"
      (it "matches on string keys with column-name collision"
        (let [a (read-csv-string "k,v\nA,1\nB,2\nC,3\n" 0 0 1 0 "")
              b (read-csv-string "k,v\nB,200\nC,300\nD,400\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "k") (t-nil))
              g  (inner-join a b ks ks)
              nr (frame-nrows g)
              nc (frame-ncols g)
              ck  (frame-column g "k")
              cv  (frame-column g "v")
              cvr (frame-column g "v_r")
              k0  (column-utf8-at ck 0)  k1 (column-utf8-at ck 1)
              v0  (column-int64-at cv 0) v1 (column-int64-at cv 1)
              vr0 (column-int64-at cvr 0) vr1 (column-int64-at cvr 1)
              ok  (and (= nr 2) (= nc 3)
                       (t-cstr= k0 "B") (t-cstr= k1 "C")
                       (= v0 2) (= v1 3)
                       (= vr0 200) (= vr1 300))]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "left-join"
      (it "keeps unmatched left rows with null right cells"
        (let [a (read-csv-string "id,x\n1,10\n2,20\n3,30\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n2,200\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (left-join a b ks ks)
              nr (frame-nrows g)
              cy (frame-column g "y")
              v0 (column-valid? cy 0)   ; left row id=1: y is null
              v1 (column-valid? cy 1)   ; left row id=2: y=200
              v2 (column-valid? cy 2)   ; left row id=3: null
              ok (and (= nr 3) (not v0) v1 (not v2))]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "right-join"
      (it "keeps unmatched right rows with null left cells"
        (let [a (read-csv-string "id,x\n2,20\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n1,100\n2,200\n3,300\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (right-join a b ks ks)
              nr (frame-nrows g)
              cx (frame-column g "x")
              ok (and (= nr 3)
                      (not (column-valid? cx 0))
                      (not (column-valid? cx 2)))]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "full-join"
      (it "produces left + right + unmatched-from-both"
        (let [a (read-csv-string "id,x\n1,10\n2,20\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n2,200\n3,300\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (full-join a b ks ks)
              nr (frame-nrows g)
              ok (= nr 3)]   ;; rows: id=1 (left only), id=2 (both), id=3 (right only)
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "semi-join / anti-join"
      (it "semi-join keeps left rows that match (no right cols)"
        (let [a (read-csv-string "id,x\n1,10\n2,20\n3,30\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n2,200\n3,300\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (semi-join a b ks ks)
              nr (frame-nrows g)
              nc (frame-ncols g)
              ok (and (= nr 2) (= nc 2))]   ;; only left columns
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok)))
      (it "anti-join keeps left rows that don't match"
        (let [a (read-csv-string "id,x\n1,10\n2,20\n3,30\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n2,200\n3,300\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (anti-join a b ks ks)
              nr (frame-nrows g)
              cid (frame-column g "id")
              id0 (column-int64-at cid 0)
              ok  (and (= nr 1) (= id0 1))]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "cross-join"
      (it "emits n_left * n_right rows"
        (let [a (read-csv-string "x\n1\n2\n3\n" 0 0 1 0 "")
              b (read-csv-string "y\n10\n20\n" 0 0 1 0 "")
              g  (cross-join a b)
              nr (frame-nrows g)
              nc (frame-ncols g)
              ok (and (= nr 6) (= nc 2))]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok))))

    (describe "convenience join"
      (it "join with how=\"inner\" matches inner-join"
        (let [a (read-csv-string "id,x\n1,10\n2,20\n" 0 0 1 0 "")
              b (read-csv-string "id,y\n2,200\n" 0 0 1 0 "")
              ks (t-cons (cstr->int "id") (t-nil))
              g  (join a b "inner" ks)
              nr (frame-nrows g)
              ok (= nr 1)]
          (frame-free g) (frame-free a) (frame-free b)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
