;; tests/frame/reshape_test.tur -- FR7 tests for distinct, sample,
;; agg-median / agg-std / agg-var.  (melt + describe live in their own tests
;; once written.)

(defmodule frame/tests/reshape
  (import frame/type   :refer [type-int64 type-float64 type-utf8])
  (import frame/column :refer [column-length column-type
                                column-int64-at column-float64-at column-utf8-at
                                column-valid?])
  (import frame/schema :refer [field schema])
  (import frame/frame  :refer [frame frame-free frame-nrows frame-ncols
                                frame-column frame=?])
  (import frame/csv    :refer [read-csv-string])
  (import frame/filter :refer [distinct sample])
  (import frame/group  :refer [group-by grouped-free agg summarize
                                agg-median agg-std agg-var agg-mean])
  (import frame/reshape :refer [melt])
  (import frame/print  :refer [frame-describe])
  (import test/assert  :refer [assert-eq assert-true])
  (import test/suite   :refer [describe it])
  (import test/runner  :refer [run-all])

  (defn t-nil [] :int ```c return 0; ```)

  (defn t-cons [v :int n :int] :int
    ```c
    #include <stdlib.h>
    #include <stdint.h>
    struct __cons { int64_t value; int64_t next; };
    struct __cons *c = (struct __cons *)malloc(sizeof(*c));
    if (!c) return 0;
    c->value = v; c->next = n;
    return (int64_t)(intptr_t)c;
    ```)

  (defn cstr->int [s :cstr] :int
    ```c
    #include <stdint.h>
    return (int64_t)(intptr_t)s;
    ```)

  (defn t-cstr= [a :cstr b :cstr] :bool
    ```c
    #include <string.h>
    return strcmp((const char *)(intptr_t)a, (const char *)(intptr_t)b) == 0;
    ```)

  (defn close? [x :float y :float] :bool
    ```c
    double dx = x - y;
    if (dx < 0) dx = -dx;
    return dx < 1e-9;
    ```)

  (defn __all-tests [] :void

    (describe "distinct"
      (it "removes duplicate rows by named key"
        (let [src "k,v\nA,1\nA,1\nB,2\nA,1\nB,3\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (t-cons (cstr->int "k") (t-cons (cstr->int "v") (t-nil)))
              g   (distinct f ks)
              nr  (frame-nrows g)
              ok  (= nr 3)]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "with nil key uses all columns"
        (let [src "x,y\n1,1\n1,1\n2,2\n"
              f   (read-csv-string src 0 0 1 0 "")
              g   (distinct f 0)
              nr  (frame-nrows g)
              ok  (= nr 2)]
          (frame-free g) (frame-free f)
          (assert-true ok))))

    (describe "sample"
      (it "n=nrows returns a permutation of all rows"
        (let [src "x\n10\n20\n30\n"
              f   (read-csv-string src 0 0 1 0 "")
              s   (sample f 3 42)
              nr  (frame-nrows s)
              ok  (= nr 3)]
          (frame-free s) (frame-free f)
          (assert-true ok)))
      (it "n<nrows returns exactly n rows"
        (let [src "x\n1\n2\n3\n4\n5\n"
              f   (read-csv-string src 0 0 1 0 "")
              s   (sample f 2 7)
              nr  (frame-nrows s)
              ok  (= nr 2)]
          (frame-free s) (frame-free f)
          (assert-true ok)))
      (it "deterministic with the same seed"
        (let [src "x\n100\n200\n300\n400\n500\n"
              f   (read-csv-string src 0 0 1 0 "")
              s1  (sample f 3 42)
              s2  (sample f 3 42)
              ok  (frame=? s1 s2)]
          (frame-free s1) (frame-free s2) (frame-free f)
          (assert-true ok))))

    (describe "agg-median / agg-std / agg-var"
      (it "median for odd-sized groups"
        (let [src "g,v\nA,1\nA,3\nA,5\nB,10\nB,20\nB,30\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (vec-of (cstr->int "g"))
              g   (group-by f ks)
              outs (t-cons (cstr->int "med") (t-nil))
              ins  (t-cons (cstr->int "v")   (t-nil))
              tags (t-cons (agg-median)      (t-nil))
              r    (agg g outs ins tags)
              cm   (frame-column r "med")
              v0   (column-float64-at cm 0)
              v1   (column-float64-at cm 1)
              ok   (and (close? v0 3.0) (close? v1 20.0))]
          (frame-free r) (grouped-free g) (frame-free f)
          (assert-true ok)))
      (it "median for even-sized groups averages the two middles"
        (let [src "g,v\nA,1\nA,3\nA,5\nA,7\n"
              f   (read-csv-string src 0 0 1 0 "")
              ks  (vec-of (cstr->int "g"))
              g   (group-by f ks)
              outs (t-cons (cstr->int "med") (t-nil))
              ins  (t-cons (cstr->int "v")   (t-nil))
              tags (t-cons (agg-median)      (t-nil))
              r    (agg g outs ins tags)
              cm   (frame-column r "med")
              v0   (column-float64-at cm 0)
              ok   (close? v0 4.0)]
          (frame-free r) (grouped-free g) (frame-free f)
          (assert-true ok)))
      (it "var of [1,2,3,4,5] is 2.5 (sample variance)"
        (let [src "v\n1\n2\n3\n4\n5\n"
              f   (read-csv-string src 0 0 1 0 "")
              outs (t-cons (cstr->int "var") (t-nil))
              ins  (t-cons (cstr->int "v")   (t-nil))
              tags (t-cons (agg-var)         (t-nil))
              r    (summarize f outs ins tags)
              cv   (frame-column r "var")
              v0   (column-float64-at cv 0)
              ok   (close? v0 2.5)]
          (frame-free r) (frame-free f)
          (assert-true ok)))
      (it "melt wide-to-long with two id cols and two value cols"
        (let [src "id,group,x,y\n1,A,10,100\n2,B,20,200\n"
              f   (read-csv-string src 0 0 1 0 "")
              ids (t-cons (cstr->int "id") (t-cons (cstr->int "group") (t-nil)))
              g   (melt f ids "var" "val")
              nr  (frame-nrows g)
              nc  (frame-ncols g)
              cv  (frame-column g "var")
              cval (frame-column g "val")
              cid  (frame-column g "id")
              v0  (column-utf8-at cv 0)  v1 (column-utf8-at cv 1)
              v2  (column-utf8-at cv 2)  v3 (column-utf8-at cv 3)
              val0 (column-int64-at cval 0) val1 (column-int64-at cval 1)
              val2 (column-int64-at cval 2) val3 (column-int64-at cval 3)
              id0  (column-int64-at cid 0)  id1 (column-int64-at cid 1)
              id2  (column-int64-at cid 2)  id3 (column-int64-at cid 3)
              ok  (and (= nr 4) (= nc 4)
                       ;; outer-loop = non-id col (x, then y); inner = row (0, 1)
                       (t-cstr= v0 "x") (t-cstr= v1 "x")
                       (t-cstr= v2 "y") (t-cstr= v3 "y")
                       (= val0 10) (= val1 20) (= val2 100) (= val3 200)
                       (= id0 1)   (= id1 2)   (= id2 1)    (= id3 2))]
          (frame-free g) (frame-free f)
          (assert-true ok)))
      (it "melt returns 0 if non-id columns have heterogeneous types"
        (let [src "id,a,b\n1,10,hello\n2,20,world\n"
              f   (read-csv-string src 0 0 1 0 "")
              ids (t-cons (cstr->int "id") (t-nil))
              g   (melt f ids "var" "val")
              ok  (= g 0)]
          (frame-free f)
          (assert-true ok)))

      (it "describe summarizes numeric columns and skips utf8 ones"
        (let [src "name,x\nA,1\nB,2\nC,3\nD,4\nE,5\n"
              f   (read-csv-string src 0 0 1 0 "")
              d   (frame-describe f)
              nr  (frame-nrows d)
              cv  (frame-column d "variable")
              cn  (frame-column d "count")
              cm  (frame-column d "mean")
              cmin (frame-column d "min")
              cmax (frame-column d "max")
              cmed (frame-column d "median")
              ;; describe only sees the numeric "x" column -> 1 row
              name0 (column-utf8-at cv 0)
              n0    (column-int64-at cn 0)
              m0    (column-float64-at cm 0)
              min0  (column-float64-at cmin 0)
              max0  (column-float64-at cmax 0)
              med0  (column-float64-at cmed 0)
              ok    (and (= nr 1) (t-cstr= name0 "x")
                         (= n0 5) (close? m0 3.0)
                         (close? min0 1.0) (close? max0 5.0)
                         (close? med0 3.0))]
          (frame-free d) (frame-free f)
          (assert-true ok)))
      (it "std equals sqrt(sample variance)"
        ;; [2,4,4,4,5,5,7,9]: sum=40, mean=5, sum_sq_dev=32, var=32/7, std=sqrt(32/7).
        (let [src "v\n2\n4\n4\n4\n5\n5\n7\n9\n"
              f   (read-csv-string src 0 0 1 0 "")
              outs (t-cons (cstr->int "sd") (t-nil))
              ins  (t-cons (cstr->int "v")  (t-nil))
              tags (t-cons (agg-std)        (t-nil))
              r    (summarize f outs ins tags)
              cv   (frame-column r "sd")
              v0   (column-float64-at cv 0)
              expected 2.138089935299395   ; sqrt(32/7)
              ok   (close? v0 expected)]
          (frame-free r) (frame-free f)
          (assert-true ok)))))

  (defn main [] :int
    (__all-tests)
    (run-all)
    0))
