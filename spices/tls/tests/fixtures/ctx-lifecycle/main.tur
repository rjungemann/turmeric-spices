;; tests/fixtures/ctx-lifecycle/main.tur -- T2 smoke test.
;;
;; Exercises the four tls/ctx lifecycle entry points end-to-end:
;;
;;   1. tls-ctx-new           -- allocate + init the ctx, returns non-zero
;;   2. tls-ctx-load-cert-pem -- parse a PEM cert into the ctx
;;   3. tls-ctx-load-key-pem  -- parse a PEM key and bind it to the cert
;;   4. tls-ctx-free          -- release the ctx and every sub-object
;;
;; The cert + key live at /tmp/tls-smoke-test/, written by the wrapping
;; run.sh script via tools/gen-cert.sh. Each step's return code is
;; checked; the program exits 0 only when every step succeeds.

(defmodule tls-ctx-lifecycle-smoke
  (import tls/ctx      :refer [tls-ctx-new tls-ctx-free tls-ctx-null?
                                tls-ctx-load-cert-pem tls-ctx-load-key-pem])
  (import tls/autolink :refer [tls-autolink-hint])

  (defn main [] : int
    ;; Reference the autolink hint so the linker pulls in -lmbedtls* flags
    ;; even when nothing else from tls/autolink is used.
    (tls-autolink-hint)

    (let [ctx (tls-ctx-new)]
      (if (tls-ctx-null? ctx)
        (do (println "FAIL: tls-ctx-new returned 0") 1)
        (let [cert-rc (tls-ctx-load-cert-pem ctx "/tmp/tls-smoke-test/test-cert.pem")]
          (if (not (= cert-rc 0))
            (do (println "FAIL: tls-ctx-load-cert-pem failed (rc != 0)")
                (tls-ctx-free ctx)
                1)
            (let [key-rc (tls-ctx-load-key-pem ctx "/tmp/tls-smoke-test/test-key.pem")]
              (if (not (= key-rc 0))
                (do (println "FAIL: tls-ctx-load-key-pem failed (rc != 0)")
                    (tls-ctx-free ctx)
                    1)
                (do
                  (tls-ctx-free ctx)
                  (println "ok: ctx-new + load-cert + load-key + ctx-free")
                  0)))))))))
