;; ws-server/server.tur -- RFC 6455 WebSocket server upgrade for tur-httpd.
;;
;; A WebSocket connection begins life as an ordinary HTTP/1.1 request with an
;; `Upgrade: websocket` header. This spice plugs into tur-httpd's two-arg
;; handler shape (`server-start-conn` / `serve-conn`): the handler receives a
;; `Conn` alongside the `Request`, and `ws-upgrade` lifts that connection from
;; HTTP to a WebSocket session for the rest of its lifetime.
;;
;; Design, mirroring ws-client (see its client.tur header):
;;
;;   * `WsConn` / `WsFrame` are opaque handles, not by-value structs. A
;;     `WsConn` owns the raw fd plus a reassembly buffer; a `WsFrame` is a view
;;     into that buffer, valid until the next `ws-server-recv`.
;;
;;   * The frame codec is duplicated locally (the smallest v0 path, exactly as
;;     the websocket-server-plan WS5 phase calls out) rather than shared with
;;     ws-client. The key difference from the client codec: server->client
;;     frames are sent UNMASKED (RFC 6455 5.1), while client->server frames
;;     arrive masked and are unmasked on read.
;;
;;   * No TLS. httpd has no TLS listener yet, so `wss://` is out of scope for
;;     v0 (plan phase WS4). The handshake + I/O go over the raw fd.
;;
;;   * `ws-upgrade` returns an :int status (1 = upgraded, 0 = not a valid
;;     WebSocket request) rather than the `:ok`/`:error` keywords the plan
;;     sketches -- this matches ws-client's int-sentinel house style and keeps
;;     the C boundary trivial. On 0 the caller should return a normal HTTP
;;     error Response; on 1 the Response the handler returns is ignored (the
;;     worker loop skips it, the connection having been upgraded).

(defmodule ws-server/server
  (import httpd/types   :refer [Conn Request])
  (import httpd/conn    :refer [conn-fd conn-mark-upgraded!])
  (import httpd/request :refer [req-header])
  (export WsConn WsFrame
          ws-upgrade
          ws-server-send ws-server-send-bytes
          ws-server-recv ws-server-close
          ws-set-server-timeout
          ws-frame-kind ws-frame-data ws-frame-len ws-frame-text
          ws-text? ws-binary? ws-ping? ws-pong?
          ws-closed? ws-timeout? ws-error?)

;; ---------------------------------------------------------------------------
;; file-scope C: shared types + static codec helpers, emitted into the same
;; translation unit as every defn body below (same property tur-http / ws-client
;; rely on), so the statics are visible without per-defn duplication.
;; ---------------------------------------------------------------------------
```c
#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <strings.h>
#include <stdio.h>
#include <unistd.h>
#include <errno.h>
#include <sys/socket.h>
#include <sys/time.h>

/* WsFrame kinds: data opcodes match the wire; negatives are synthetic
   conditions surfaced by ws-server-recv. Kept identical to ws-client. */
#define WS_KIND_TEXT     1
#define WS_KIND_BINARY   2
#define WS_KIND_CLOSE    8
#define WS_KIND_PING     9
#define WS_KIND_PONG    10
#define WS_KIND_TIMEOUT (-1)
#define WS_KIND_ERROR   (-2)

typedef struct { int kind; unsigned char *data; long len; } ws_frame_t;

typedef struct {
  int            fd;      /* client socket; owned once the connection upgrades */
  unsigned char *rbuf;    /* reassembly buffer for the current message */
  size_t         rcap;
  size_t         rlen;
  ws_frame_t     frame;   /* view returned by ws-server-recv; points into rbuf */
} ws_srv_conn_t;

/* --- base64 (encode only) ------------------------------------------------ */
static void wss__b64(const unsigned char *in, size_t len, char *out) {
  static const char t[] =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
  size_t i = 0, o = 0;
  while (len - i >= 3) {
    out[o++] = t[in[i] >> 2];
    out[o++] = t[((in[i] & 3) << 4) | (in[i+1] >> 4)];
    out[o++] = t[((in[i+1] & 15) << 2) | (in[i+2] >> 6)];
    out[o++] = t[in[i+2] & 63];
    i += 3;
  }
  if (len - i == 1) {
    out[o++] = t[in[i] >> 2];
    out[o++] = t[(in[i] & 3) << 4];
    out[o++] = '='; out[o++] = '=';
  } else if (len - i == 2) {
    out[o++] = t[in[i] >> 2];
    out[o++] = t[((in[i] & 3) << 4) | (in[i+1] >> 4)];
    out[o++] = t[(in[i+1] & 15) << 2];
    out[o++] = '=';
  }
  out[o] = '\0';
}

/* --- SHA-1 (RFC 3174) ---------------------------------------------------- */
static void wss__sha1(const unsigned char *data, size_t len, unsigned char out[20]) {
  uint32_t h0 = 0x67452301, h1 = 0xEFCDAB89, h2 = 0x98BADCFE,
           h3 = 0x10325476, h4 = 0xC3D2E1F0;
  uint64_t ml = (uint64_t)len * 8;
  size_t total = ((len + 8) / 64 + 1) * 64;
  unsigned char *msg = (unsigned char *)calloc(total, 1);
  if (!msg) return;
  memcpy(msg, data, len);
  msg[len] = 0x80;
  for (int i = 0; i < 8; i++)
    msg[total - 1 - i] = (unsigned char)((ml >> (8 * i)) & 0xff);
  for (size_t off = 0; off < total; off += 64) {
    uint32_t w[80];
    for (int i = 0; i < 16; i++)
      w[i] = ((uint32_t)msg[off + i*4]     << 24)
           | ((uint32_t)msg[off + i*4 + 1] << 16)
           | ((uint32_t)msg[off + i*4 + 2] << 8)
           | ((uint32_t)msg[off + i*4 + 3]);
    for (int i = 16; i < 80; i++) {
      uint32_t v = w[i-3] ^ w[i-8] ^ w[i-14] ^ w[i-16];
      w[i] = (v << 1) | (v >> 31);
    }
    uint32_t a = h0, b = h1, c = h2, d = h3, e = h4;
    for (int i = 0; i < 80; i++) {
      uint32_t f, k;
      if (i < 20)      { f = (b & c) | ((~b) & d);          k = 0x5A827999; }
      else if (i < 40) { f = b ^ c ^ d;                     k = 0x6ED9EBA1; }
      else if (i < 60) { f = (b & c) | (b & d) | (c & d);   k = 0x8F1BBCDC; }
      else             { f = b ^ c ^ d;                     k = 0xCA62C1D6; }
      uint32_t tmp = ((a << 5) | (a >> 27)) + f + e + k + w[i];
      e = d; d = c; c = (b << 30) | (b >> 2); b = a; a = tmp;
    }
    h0 += a; h1 += b; h2 += c; h3 += d; h4 += e;
  }
  free(msg);
  uint32_t hh[5] = { h0, h1, h2, h3, h4 };
  for (int i = 0; i < 5; i++) {
    out[i*4]     = (unsigned char)(hh[i] >> 24);
    out[i*4 + 1] = (unsigned char)(hh[i] >> 16);
    out[i*4 + 2] = (unsigned char)(hh[i] >> 8);
    out[i*4 + 3] = (unsigned char)(hh[i]);
  }
}

/* Sec-WebSocket-Accept = base64(sha1(key + GUID)). `out` needs >= 29 bytes. */
static void wss__accept(const char *key, char *out) {
  static const char GUID[] = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11";
  char buf[128];
  int n = snprintf(buf, sizeof(buf), "%s%s", key, GUID);
  unsigned char digest[20];
  wss__sha1((const unsigned char *)buf, (size_t)n, digest);
  wss__b64(digest, 20, out);
}

/* --- transport ----------------------------------------------------------- */
static long wss__send_all(int fd, const unsigned char *b, size_t n) {
  size_t off = 0;
  while (off < n) {
    long s = (long)send(fd, b + off, n - off, 0);
    if (s <= 0) return -1;
    off += (size_t)s;
  }
  return (long)n;
}

/* Fill exactly n bytes. Returns 1 ok, 0 peer-closed, -2 timeout, -1 error. */
static int wss__recv_n(int fd, unsigned char *buf, size_t n) {
  size_t off = 0;
  while (off < n) {
    long r = (long)recv(fd, buf + off, n - off, 0);
    if (r == 0) return 0;
    if (r < 0) {
      if (errno == EAGAIN || errno == EWOULDBLOCK) return -2;
      return -1;
    }
    off += (size_t)r;
  }
  return 1;
}

/* --- framing ------------------------------------------------------------- */
/* Send one UNMASKED frame (server->client). Returns bytes sent, or -1. */
static long wss__send_frame(ws_srv_conn_t *c, int opcode,
                            const unsigned char *payload, size_t len) {
  unsigned char hdr[10];
  size_t hl = 0;
  hdr[hl++] = (unsigned char)(0x80 | (opcode & 0x0f));   /* FIN + opcode */
  if (len < 126) {
    hdr[hl++] = (unsigned char)len;                      /* no mask bit */
  } else if (len <= 0xffff) {
    hdr[hl++] = 126;
    hdr[hl++] = (unsigned char)((len >> 8) & 0xff);
    hdr[hl++] = (unsigned char)(len & 0xff);
  } else {
    hdr[hl++] = 127;
    for (int i = 7; i >= 0; i--)
      hdr[hl++] = (unsigned char)((len >> (8 * i)) & 0xff);
  }
  if (wss__send_all(c->fd, hdr, hl) < 0) return -1;
  if (len > 0 && wss__send_all(c->fd, payload, len) < 0) return -1;
  return (long)(hl + len);
}

/* Read one frame; client->server frames are masked, so unmask on read. On
   success mallocs *payload (caller frees). Returns 1 ok, 0 closed, -2 timeout,
   -1 error. */
static int wss__read_one(ws_srv_conn_t *c, int *fin, int *opcode,
                         unsigned char **payload, size_t *plen) {
  unsigned char h2[2];
  int st = wss__recv_n(c->fd, h2, 2);
  if (st != 1) return st;
  *fin    = (h2[0] & 0x80) ? 1 : 0;
  *opcode = h2[0] & 0x0f;
  int masked = (h2[1] & 0x80) ? 1 : 0;
  uint64_t len = h2[1] & 0x7f;
  if (len == 126) {
    unsigned char e[2];
    if ((st = wss__recv_n(c->fd, e, 2)) != 1) return st;
    len = ((uint64_t)e[0] << 8) | e[1];
  } else if (len == 127) {
    unsigned char e[8];
    if ((st = wss__recv_n(c->fd, e, 8)) != 1) return st;
    len = 0;
    for (int i = 0; i < 8; i++) len = (len << 8) | e[i];
  }
  unsigned char mkey[4] = {0,0,0,0};
  if (masked) {
    if ((st = wss__recv_n(c->fd, mkey, 4)) != 1) return st;
  }
  unsigned char *buf = (unsigned char *)malloc((size_t)len + 1);
  if (!buf) return -1;
  if (len > 0) {
    if ((st = wss__recv_n(c->fd, buf, (size_t)len)) != 1) { free(buf); return st; }
    if (masked)
      for (uint64_t i = 0; i < len; i++) buf[i] ^= mkey[i & 3];
  }
  buf[len] = '\0';
  *payload = buf;
  *plen = (size_t)len;
  return 1;
}

/* Append bytes to the reassembly buffer (NUL-kept at tail). */
static int wss__rbuf_append(ws_srv_conn_t *c, const unsigned char *p, size_t n) {
  if (c->rlen + n + 1 > c->rcap) {
    size_t cap = c->rcap ? c->rcap : 256;
    while (cap < c->rlen + n + 1) cap *= 2;
    unsigned char *nb = (unsigned char *)realloc(c->rbuf, cap);
    if (!nb) return -1;
    c->rbuf = nb; c->rcap = cap;
  }
  memcpy(c->rbuf + c->rlen, p, n);
  c->rlen += n;
  c->rbuf[c->rlen] = '\0';
  return 0;
}
```

;;; WsConn -- opaque handle to an upgraded server-side WebSocket connection.
;;;
;;; Created by ws-upgrade and passed to the user's ws-handler; it owns the raw
;;; client fd (taken over from httpd) plus an internal reassembly buffer. Do
;;; not use it after the ws-handler returns. Stored as int64_t (a
;;; `ws_srv_conn_t*`).
;;;
;;; Since: WS1
(defopaque WsConn :int)

;;; WsFrame -- opaque handle to the frame most recently returned by
;;; ws-server-recv. A view into the connection's reassembly buffer, valid only
;;; until the next ws-server-recv. Read via ws-frame-kind / ws-frame-data /
;;; ws-frame-len / ws-frame-text and the ws-text? ... ws-error? predicates.
;;;
;;; Since: WS1
(defopaque WsFrame :int)

;; ---------------------------------------------------------------------------
;; internal: handshake + connection lifecycle.
;; ---------------------------------------------------------------------------

;; True if a header value names the websocket upgrade (case-insensitive). The
;; value may be a token list (e.g. "websocket"); a substring check is enough.
(defn wss-header-websocket? [v : cstr] : bool
  ```c
  return v != 0 && strcasestr((const char *)v, "websocket") != NULL;
  ```)

;; Compute Sec-WebSocket-Accept for `key`, write the 101 Switching Protocols
;; response directly to `fd`. Returns 1 on success, 0 on write failure.
(defn wss-write-handshake [fd : int key : cstr] : int
  ```c
  char accept[64];
  wss__accept((const char *)key, accept);
  char resp[256];
  int n = snprintf(resp, sizeof(resp),
    "HTTP/1.1 101 Switching Protocols\r\n"
    "Upgrade: websocket\r\n"
    "Connection: Upgrade\r\n"
    "Sec-WebSocket-Accept: %s\r\n"
    "\r\n",
    accept);
  return wss__send_all((int)fd, (const unsigned char *)resp, (size_t)n) < 0 ? 0 : 1;
  ```)

;; Wrap a raw fd into a server WsConn (after the handshake has been written).
(defn wss-wrap [fd : int] : WsConn
  ```c
  ws_srv_conn_t *c = (ws_srv_conn_t *)calloc(1, sizeof(*c));
  if (!c) return 0;
  c->fd = (int)fd;
  return (int64_t)(intptr_t)c;
  ```)

;; Release a WsConn: close the fd if still open, free the reassembly buffer and
;; the struct. Called by ws-upgrade after the ws-handler returns.
(defn wss-free [ws : WsConn] : void
  ```c
  if (ws == 0) return;
  ws_srv_conn_t *c = (ws_srv_conn_t *)(intptr_t)ws;
  if (c->fd >= 0) close(c->fd);
  if (c->rbuf) free(c->rbuf);
  free(c);
  ```)

;;; ws-upgrade -- upgrade an httpd connection to a WebSocket session.
;;;
;;; Must be called from an httpd handler registered via server-start-conn /
;;; serve-conn (so the handler receives a Conn alongside the Request). Validates
;;; the Upgrade + Sec-WebSocket-Key headers, writes "101 Switching Protocols"
;;; directly to the socket, marks the Conn upgraded (so the httpd worker loop
;;; does not flush a second response or close the fd), wraps the fd into a
;;; WsConn, and invokes `handler` with it. The WsConn is released after the
;;; handler returns.
;;;
;;; Parameters:
;;;   conn    -- httpd Conn handle (from the two-arg handler signature).
;;;   req     -- httpd Request (read for the Upgrade / Sec-WebSocket-Key headers).
;;;   handler -- (fn [ws : WsConn] : void), called after the upgrade succeeds.
;;;
;;; Returns:
;;;   1 if the upgrade succeeded and the handler ran; 0 if the request was not
;;;   a valid WebSocket Upgrade (the caller should then return a normal HTTP
;;;   error Response). When 1 is returned the Response the handler returns is
;;;   ignored -- the connection has been upgraded.
;;;
;;; Example:
;;;   (defn ws-echo [conn : Conn req : Request] : Response
;;;     (if (= (ws-upgrade conn req
;;;              (fn [ws : WsConn] : void
;;;                (let [f (ws-server-recv ws)]
;;;                  (ws-server-send ws (ws-frame-text f))
;;;                  (ws-server-close ws)))) 1)
;;;       (resp-ok "text/plain" "")            ;; placeholder; worker skips it
;;;       (bad-request "not a websocket request")))
;;;
;;; Since: WS1
(defn ws-upgrade [conn : Conn req : Request handler : fn] : int
  (let [up (req-header req "Upgrade")
        kr (req-header req "Sec-WebSocket-Key")]
    (if (not (and (ok? up) (ok? kr) (wss-header-websocket? (ok-val up))))
      0
      (if (= (wss-write-handshake (conn-fd conn) (ok-val kr)) 0)
        0
        (do
          (conn-mark-upgraded! conn)
          (let [ws (wss-wrap (conn-fd conn))]
            (handler ws)
            (wss-free ws)
            1))))))

;;; ws-server-send -- send a UTF-8 text frame to the client (unmasked).
;;;
;;; Parameters:
;;;   ws  -- server WsConn handle.
;;;   msg -- null-terminated UTF-8 string.
;;;
;;; Returns:
;;;   Bytes written, or negative on error.
;;;
;;; Since: WS1
(defn ws-server-send [ws : WsConn msg : cstr] : int
  ```c
  if (ws == 0) return -1;
  ws_srv_conn_t *c = (ws_srv_conn_t *)(intptr_t)ws;
  const char *m = (const char *)msg;
  return wss__send_frame(c, 0x1, (const unsigned char *)m, m ? strlen(m) : 0);
  ```)

;;; ws-server-send-bytes -- send a binary frame to the client (unmasked).
;;;
;;; Parameters:
;;;   ws  -- server WsConn handle.
;;;   ptr -- payload buffer.
;;;   len -- byte length.
;;;
;;; Returns:
;;;   Bytes written, or negative on error.
;;;
;;; Since: WS1
(defn ws-server-send-bytes [ws : WsConn ptr : ptr<void> len : int] : int
  ```c
  if (ws == 0) return -1;
  ws_srv_conn_t *c = (ws_srv_conn_t *)(intptr_t)ws;
  return wss__send_frame(c, 0x2, (const unsigned char *)ptr, (size_t)len);
  ```)

;;; ws-server-recv -- receive the next message from the client.
;;;
;;; Blocks until a complete (possibly reassembled) message arrives, or the
;;; receive timeout fires. Ping frames are answered with a Pong automatically
;;; and then surfaced; Pong and Close frames are surfaced to the caller.
;;;
;;; Parameters:
;;;   ws -- server WsConn handle.
;;;
;;; Returns:
;;;   A WsFrame handle (a view valid until the next ws-server-recv). Its kind is
;;;   :text / :binary / :ping / :pong / :close / :timeout / :error.
;;;
;;; Since: WS1
(defn ws-server-recv [ws : WsConn] : WsFrame
  ```c
  if (ws == 0) return 0;
  ws_srv_conn_t *c = (ws_srv_conn_t *)(intptr_t)ws;
  c->rlen = 0;
  if (c->rbuf) c->rbuf[0] = '\0';
  int data_opcode = 0;

  for (;;) {
    int fin, opcode;
    unsigned char *payload = NULL;
    size_t plen = 0;
    int st = wss__read_one(c, &fin, &opcode, &payload, &plen);
    if (st == -2) {
      c->frame.kind = WS_KIND_TIMEOUT; c->frame.data = NULL; c->frame.len = 0;
      return (int64_t)(intptr_t)&c->frame;
    }
    if (st <= 0) {
      c->frame.kind = (st == 0) ? WS_KIND_CLOSE : WS_KIND_ERROR;
      c->frame.data = NULL; c->frame.len = 0;
      return (int64_t)(intptr_t)&c->frame;
    }

    if (opcode == 0x8) {                 /* close -> echo close, surface */
      wss__send_frame(c, 0x8, payload, plen);
      wss__rbuf_append(c, payload, plen);
      free(payload);
      c->frame.kind = WS_KIND_CLOSE;
      c->frame.data = c->rbuf; c->frame.len = (long)c->rlen;
      return (int64_t)(intptr_t)&c->frame;
    }
    if (opcode == 0x9) {                 /* ping -> auto pong, then surface */
      wss__send_frame(c, 0xA, payload, plen);
      wss__rbuf_append(c, payload, plen);
      free(payload);
      c->frame.kind = WS_KIND_PING;
      c->frame.data = c->rbuf; c->frame.len = (long)c->rlen;
      return (int64_t)(intptr_t)&c->frame;
    }
    if (opcode == 0xA) {                 /* pong */
      wss__rbuf_append(c, payload, plen);
      free(payload);
      c->frame.kind = WS_KIND_PONG;
      c->frame.data = c->rbuf; c->frame.len = (long)c->rlen;
      return (int64_t)(intptr_t)&c->frame;
    }

    /* data frame (text/binary/continuation) -- reassemble */
    if (opcode != 0x0) data_opcode = opcode;
    wss__rbuf_append(c, payload, plen);
    free(payload);
    if (fin) {
      c->frame.kind = (data_opcode == 0x2) ? WS_KIND_BINARY : WS_KIND_TEXT;
      c->frame.data = c->rbuf; c->frame.len = (long)c->rlen;
      return (int64_t)(intptr_t)&c->frame;
    }
    /* else: not final -- keep reading continuation frames */
  }
  ```)

;;; ws-server-close -- initiate the WebSocket closing handshake.
;;;
;;; Sends a Close frame, drains until the peer's Close echo (best-effort,
;;; bounded), then closes the underlying socket. The WsConn itself is released
;;; by ws-upgrade after the handler returns.
;;;
;;; Parameters:
;;;   ws -- server WsConn handle.
;;;
;;; Since: WS1
(defn ws-server-close [ws : WsConn] : void
  ```c
  if (ws == 0) return;
  ws_srv_conn_t *c = (ws_srv_conn_t *)(intptr_t)ws;
  wss__send_frame(c, 0x8, NULL, 0);
  for (int i = 0; i < 8; i++) {
    int fin, opcode; unsigned char *p = NULL; size_t pl = 0;
    int st = wss__read_one(c, &fin, &opcode, &p, &pl);
    free(p);
    if (st != 1 || opcode == 0x8) break;
  }
  if (c->fd >= 0) { close(c->fd); c->fd = -1; }
  ```)

;;; ws-set-server-timeout -- set the receive timeout in milliseconds.
;;;
;;; A value of 0 disables the timeout (ws-server-recv blocks indefinitely).
;;; When the timeout fires, ws-server-recv returns a frame whose kind is
;;; :timeout.
;;;
;;; Parameters:
;;;   ws -- server WsConn handle.
;;;   ms -- timeout in milliseconds.
;;;
;;; Since: WS1
(defn ws-set-server-timeout [ws : WsConn ms : int] : void
  ```c
  if (ws == 0) return;
  ws_srv_conn_t *c = (ws_srv_conn_t *)(intptr_t)ws;
  struct timeval tv;
  tv.tv_sec  = (time_t)(ms / 1000);
  tv.tv_usec = (suseconds_t)((ms % 1000) * 1000);
  setsockopt(c->fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
  ```)

;; ---------------------------------------------------------------------------
;; WsFrame accessors + predicates (identical shape to ws-client).
;; ---------------------------------------------------------------------------

;;; ws-frame-kind -- integer kind of a frame (see the WS_KIND_* constants).
;;; Since: WS1
(defn ws-frame-kind [frame : WsFrame] : int
  ```c
  if (frame == 0) return WS_KIND_ERROR;
  return (int64_t)((ws_frame_t *)(intptr_t)frame)->kind;
  ```)

;;; ws-frame-data -- pointer to the frame payload (valid until next recv).
;;; Since: WS1
(defn ws-frame-data [frame : WsFrame] : ptr<void>
  ```c
  if (frame == 0) return NULL;
  return ((ws_frame_t *)(intptr_t)frame)->data;
  ```)

;;; ws-frame-len -- payload length of a frame, in bytes.
;;; Since: WS1
(defn ws-frame-len [frame : WsFrame] : int
  ```c
  if (frame == 0) return 0;
  return (int64_t)((ws_frame_t *)(intptr_t)frame)->len;
  ```)

;;; ws-frame-text -- frame payload as a NUL-terminated string.
;;; Since: WS1
(defn ws-frame-text [frame : WsFrame] : cstr
  ```c
  if (frame == 0) return (char *)"";
  ws_frame_t *f = (ws_frame_t *)(intptr_t)frame;
  return f->data ? (char *)f->data : (char *)"";
  ```)

;;; ws-text? -- true if the frame is a text message. Since: WS1
(defn ws-text? [frame : WsFrame] : bool
  ```c return frame != 0 && ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_TEXT; ```)

;;; ws-binary? -- true if the frame is a binary message. Since: WS1
(defn ws-binary? [frame : WsFrame] : bool
  ```c return frame != 0 && ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_BINARY; ```)

;;; ws-ping? -- true if the frame is a ping (already auto-ponged). Since: WS1
(defn ws-ping? [frame : WsFrame] : bool
  ```c return frame != 0 && ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_PING; ```)

;;; ws-pong? -- true if the frame is a pong. Since: WS1
(defn ws-pong? [frame : WsFrame] : bool
  ```c return frame != 0 && ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_PONG; ```)

;;; ws-closed? -- true if the frame is a close (or the peer closed). Since: WS1
(defn ws-closed? [frame : WsFrame] : bool
  ```c return frame != 0 && ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_CLOSE; ```)

;;; ws-timeout? -- true if recv returned because the timeout fired. Since: WS1
(defn ws-timeout? [frame : WsFrame] : bool
  ```c return frame != 0 && ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_TIMEOUT; ```)

;;; ws-error? -- true if recv hit a transport error. Since: WS1
(defn ws-error? [frame : WsFrame] : bool
  ```c return frame == 0 || ((ws_frame_t *)(intptr_t)frame)->kind == WS_KIND_ERROR; ```)

) ;; end defmodule ws-server/server
