;; tests/upgrade_error_test.tur -- UPG-V0 error-shape unit test (no network).
;;
;; ws-upgrade now returns (Result bool UpgradeError) instead of a bare :int.
;; ws-upgrade itself needs a live httpd Conn + Request to drive, so the
;; end-to-end success path is covered by echo_test.tur / the echo fixture; here
;; we assert the error half of the contract directly: the UpgradeError ADT
;; carries the right payloads and matches the way a handler would dispatch on a
;; rejected upgrade. We also confirm ok / err round-trip through ok? / err-val.

(defmodule ws-server/tests/upgrade-error
  (import ws-server/server :refer [UpgradeError
                                   UpgradeMissingHeader UpgradeBadVersion
                                   UpgradeUnsupportedProto UpgradeWriteFailed])
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-true])
  (import test/runner :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; A stand-in for how an httpd handler would turn an UpgradeError into a
  ;; distinct HTTP status: each variant maps to a unique code.
  (defn status-for [e : UpgradeError] : int
    (match e
      (UpgradeMissingHeader name)    400
      (UpgradeBadVersion requested)  426     ;; Upgrade Required
      (UpgradeUnsupportedProto kind) 415     ;; Unsupported Media Type-ish
      (UpgradeWriteFailed)           500))

  ;; Pull the carried payload back out, to prove the fields survive.
  (defn missing-header-name [e : UpgradeError] : cstr
    (match e
      (UpgradeMissingHeader name)    name
      (UpgradeBadVersion requested)  "?"
      (UpgradeUnsupportedProto kind) "?"
      (UpgradeWriteFailed)           "?"))

  (defn bad-version-value [e : UpgradeError] : int
    (match e
      (UpgradeMissingHeader name)    -1
      (UpgradeBadVersion requested)  requested
      (UpgradeUnsupportedProto kind) -1
      (UpgradeWriteFailed)           -1))

  ;; A result-returning stub mirroring ws-upgrade's shape, to exercise ok?/err.
  (defn upgrade-stub [good : bool] : (Result bool UpgradeError)
    (if good
      (ok true)
      (:: (err (UpgradeMissingHeader "Sec-WebSocket-Key")) (Result bool UpgradeError))))

  (defn main [] : int
    (describe "ws-server UPG-V0 -- UpgradeError ADT + result shape"

      (it "maps each variant to a distinct HTTP status"
        (assert-true (and (= (status-for (UpgradeMissingHeader "Upgrade")) 400)
                          (= (status-for (UpgradeBadVersion 8)) 426)
                          (= (status-for (UpgradeUnsupportedProto "h2c")) 415)
                          (= (status-for (UpgradeWriteFailed)) 500))))

      (it "preserves the missing-header name payload"
        (assert-true (cstr-eq? "Sec-WebSocket-Key"
                               (missing-header-name
                                 (UpgradeMissingHeader "Sec-WebSocket-Key")))))

      (it "preserves the requested-version payload"
        (assert-true (= 8 (bad-version-value (UpgradeBadVersion 8)))))

      (it "round-trips ok(true) through ok?"
        (assert-true (ok? (upgrade-stub true))))

      (it "round-trips err(UpgradeError) through ok? / err-val"
        (let [r (upgrade-stub false)]
          (assert-true (and (not (ok? r))
                            (= 400 (status-for (err-val r))))))))

    (run-all)))
