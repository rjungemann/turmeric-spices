;; tests/echo_test.tur -- WS1 live echo round-trip (self-contained).
;;
;; Exercises the whole server stack in one process: an httpd server started via
;; server-start-conn whose two-arg handler calls ws-upgrade and then echoes
;; every text frame back. The client is a minimal raw-socket WebSocket peer
;; implemented inline here, keeping this flat unit test self-contained in a
;; single process. (Since NAME-V0 ws-client and ws-server share one `WsConn` /
;; `WsFrame` from ws-core, so the two could be loaded into one program now --
;; the ws-client-driven round-trip in tests/fixtures/echo/ still runs them as
;; separate processes to exercise the real socket path end to end.)
;;
;; The inline client sends MASKED frames (client->server, per RFC 6455 5.3) and
;; expects the echo back UNMASKED (server->client, per 5.1), so a passing echo
;; confirms both framing directions plus the Sec-WebSocket-Accept handshake.
;; This is the flat tests/*.tur that routes CI through `tur test tests`.

(defmodule ws-server/tests/echo
  (import httpd/types    :refer [Conn Request])
  (import httpd/server   :refer [server-start-conn server-stop])
  (import httpd/response :refer [resp-ok bad-request])
  (import ws-server/server
    :refer [ws-upgrade
            ws-server-recv ws-server-send ws-server-close
            ws-set-server-timeout])
  (import ws-core/conn  :refer [WsConn])
  (import ws-core/frame :refer [ws-frame-text ws-text? ws-binary?
                                ws-closed? ws-error? ws-timeout?])
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-true])
  (import test/runner :refer [run-all])

;; ---------------------------------------------------------------------------
;; file-scope C: a tiny raw-socket WebSocket client used to drive the server.
;; ---------------------------------------------------------------------------
```c
#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>

/* Read exactly n bytes; 1 ok, else <= 0. */
static int wsc__recv_n(int fd, unsigned char *b, size_t n) {
  size_t off = 0;
  while (off < n) {
    long r = (long)recv(fd, b + off, n - off, 0);
    if (r <= 0) return 0;
    off += (size_t)r;
  }
  return 1;
}

/* Connect + perform the client handshake on /ws. Returns fd, or -1. The fixed
   key's accept is "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=" (RFC 6455 4.2.2 vector); we
   require the server to echo exactly that, proving its accept computation. */
static int wsc__connect(int port) {
  int fd = socket(AF_INET, SOCK_STREAM, 0);
  if (fd < 0) return -1;
  struct sockaddr_in a; memset(&a, 0, sizeof(a));
  a.sin_family = AF_INET;
  a.sin_port   = htons((uint16_t)port);
  a.sin_addr.s_addr = htonl(INADDR_LOOPBACK);
  if (connect(fd, (struct sockaddr *)&a, sizeof(a)) != 0) { close(fd); return -1; }
  const char *req =
    "GET /ws HTTP/1.1\r\n"
    "Host: 127.0.0.1\r\n"
    "Upgrade: websocket\r\n"
    "Connection: Upgrade\r\n"
    "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
    "Sec-WebSocket-Version: 13\r\n"
    "\r\n";
  if (send(fd, req, strlen(req), 0) < 0) { close(fd); return -1; }
  char buf[2048]; size_t n = 0;
  while (n < sizeof(buf) - 1) {
    unsigned char ch;
    if (wsc__recv_n(fd, &ch, 1) != 1) { close(fd); return -1; }
    buf[n++] = (char)ch;
    if (n >= 4 && buf[n-4]=='\r' && buf[n-3]=='\n' && buf[n-2]=='\r' && buf[n-1]=='\n')
      break;
  }
  buf[n] = '\0';
  if (!strstr(buf, " 101 ")) { close(fd); return -1; }
  if (!strstr(buf, "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=")) { close(fd); return -1; }
  return fd;
}

/* Send one masked text frame. Returns 0 ok, -1 error. */
static int wsc__send_text(int fd, const char *msg) {
  size_t len = strlen(msg);
  unsigned char hdr[14]; size_t hl = 0;
  hdr[hl++] = 0x81;                                  /* FIN + text */
  unsigned char mask[4] = { 0x12, 0x34, 0x56, 0x78 };
  if (len < 126) {
    hdr[hl++] = (unsigned char)(0x80 | len);
  } else if (len <= 0xffff) {
    hdr[hl++] = 0x80 | 126;
    hdr[hl++] = (unsigned char)((len >> 8) & 0xff);
    hdr[hl++] = (unsigned char)(len & 0xff);
  } else {
    hdr[hl++] = 0x80 | 127;
    for (int i = 7; i >= 0; i--) hdr[hl++] = (unsigned char)((len >> (8*i)) & 0xff);
  }
  memcpy(hdr + hl, mask, 4); hl += 4;
  if (send(fd, hdr, hl, 0) < 0) return -1;
  unsigned char *m = (unsigned char *)malloc(len ? len : 1);
  for (size_t i = 0; i < len; i++) m[i] = (unsigned char)(msg[i] ^ mask[i & 3]);
  int rc = (len > 0 && send(fd, m, len, 0) < 0) ? -1 : 0;
  free(m);
  return rc;
}

/* Read one (unmasked) frame from the server, return payload as a malloc'd
   NUL-terminated string (caller frees). Returns NULL on error. */
static char *wsc__recv_text(int fd) {
  unsigned char h2[2];
  if (wsc__recv_n(fd, h2, 2) != 1) return NULL;
  uint64_t len = h2[1] & 0x7f;
  if (len == 126) {
    unsigned char e[2];
    if (wsc__recv_n(fd, e, 2) != 1) return NULL;
    len = ((uint64_t)e[0] << 8) | e[1];
  } else if (len == 127) {
    unsigned char e[8];
    if (wsc__recv_n(fd, e, 8) != 1) return NULL;
    len = 0;
    for (int i = 0; i < 8; i++) len = (len << 8) | e[i];
  }
  if (h2[1] & 0x80) return NULL;                     /* server frames must be unmasked */
  char *buf = (char *)malloc((size_t)len + 1);
  if (!buf) return NULL;
  if (len > 0 && wsc__recv_n(fd, (unsigned char *)buf, (size_t)len) != 1) {
    free(buf); return NULL;
  }
  buf[len] = '\0';
  return buf;
}
```

  ;; ---------------------------------------------------------------------
  ;; Client driver helpers (thin wrappers over the inline C above).
  ;; ---------------------------------------------------------------------

  (defn wsc-connect [port : int] : int
    ```c return (int64_t)wsc__connect((int)port); ```)

  (defn wsc-close [fd : int] : void
    ```c if ((int)fd >= 0) close((int)fd); ```)

  ;; Send `msg`, read the echo, and report whether it came back byte-identical.
  (defn wsc-echoes? [fd : int msg : cstr] : bool
    ```c
    if ((int)fd < 0) return 0;
    if (wsc__send_text((int)fd, (const char *)msg) != 0) return 0;
    char *got = wsc__recv_text((int)fd);
    if (!got) return 0;
    int ok = strcmp(got, (const char *)msg) == 0;
    free(got);
    return ok;
    ```)

  (defn sleep-ms [ms : int] #{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  ;; ---------------------------------------------------------------------
  ;; Server side: echo every data frame until the client closes (or the
  ;; receive idle-timeout fires, as a safety valve so a stuck worker exits).
  ;; ---------------------------------------------------------------------

  (defn ws-echo-loop [ws : WsConn] : void
    (let [f (ws-server-recv ws)]
      (if (or (ws-closed? f) (ws-error? f) (ws-timeout? f))
        (ws-server-close ws)
        (do
          (when (or (ws-text? f) (ws-binary? f))
            (ws-server-send ws (ws-frame-text f)))
          (ws-echo-loop ws)))))

  ;; Two-arg httpd handler: upgrade /ws, otherwise 400.
  (defn ws-echo-handler [conn : int req : int] : int
    (let [c (:: conn Conn)
          r (:: req Request)]
      (if (ok? (ws-upgrade c r
                 (fn [ws : WsConn] : void
                   (do (ws-set-server-timeout ws 5000)
                       (ws-echo-loop ws)))))
        (:: (resp-ok "text/plain" "") :int)
        (:: (bad-request "not a websocket request") :int))))

  ;; ---------------------------------------------------------------------
  ;; Test driver
  ;; ---------------------------------------------------------------------

  (defn main [] : int
    (let [srv (server-start-conn 18750 ws-echo-handler)]
      (do
        (unsafe (sleep-ms 100))

        (describe "ws-server echo -- server-start-conn + ws-upgrade"

          (it "handshake succeeds (101 + RFC 6455 Sec-WebSocket-Accept)"
            (let [fd (wsc-connect 18750)
                  ok (>= fd 0)]
              (do (wsc-close fd) (assert-true ok))))

          (it "echoes five text messages over one connection"
            (let [fd (wsc-connect 18750)]
              (if (< fd 0)
                (assert-true false)
                (let [r (and (wsc-echoes? fd "message one")
                             (wsc-echoes? fd "message two")
                             (wsc-echoes? fd "message three")
                             (wsc-echoes? fd "message four")
                             (wsc-echoes? fd "message five"))]
                  (do (wsc-close fd) (assert-true r))))))

          (it "echoes a payload past 125 bytes (16-bit length path)"
            (let [fd (wsc-connect 18750)]
              (if (< fd 0)
                (assert-true false)
                (let [r (wsc-echoes? fd
                          "the quick brown fox jumps over the lazy dog, and then the quick brown fox jumps over the lazy dog again, for a total well past one hundred and twenty five bytes")]
                  (do (wsc-close fd) (assert-true r)))))))

        (server-stop srv)
        (run-all)))
    0))
