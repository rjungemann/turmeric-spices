#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <unistd.h>
#include <mbedtls/ssl.h>
#include <mbedtls/net_sockets.h>
#include <mbedtls/entropy.h>
#include <mbedtls/ctr_drbg.h>
/* __tur_autolink__: -lmbedtls -lmbedx509 -lmbedcrypto */

