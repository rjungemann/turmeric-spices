;; tests/tls_echo_test.tur -- WS4 live wss:// echo round-trip (self-contained).
;;
;; The TLS counterpart of echo_test.tur. It exercises the whole encrypted stack
;; in one process: an httpd TLS listener started via httpd/tls's
;; server-start-tls-conn, whose two-arg handler calls ws-upgrade (which lifts
;; the TLS connection to a WebSocket session over the same mbedTLS stream) and
;; echoes every text frame back. The client is a minimal raw mbedTLS WebSocket
;; peer implemented inline here, keeping this flat test self-contained in a
;; single process. (Since NAME-V0 ws-client and ws-server share one `WsConn` /
;; `WsFrame` from ws-core, so loading both into one program is possible now.)
;;
;; A self-signed cert + key (CN=localhost, ~100y expiry) is embedded below and
;; written to temp files at startup; the inline client connects with
;; MBEDTLS_SSL_VERIFY_NONE so the throwaway cert is accepted. The client sends
;; MASKED frames (client->server, RFC 6455 5.3) and expects UNMASKED echoes
;; (server->client, 5.1), all inside TLS -- a passing echo confirms the TLS
;; handshake, the Sec-WebSocket-Accept handshake over TLS, and both framing
;; directions over the encrypted transport. This is a flat tests/*.tur so CI's
;; `tur test tests` picks it up.

(defmodule ws-server/tests/tls-echo
  (import httpd/types    :refer [Conn Request])
  (import httpd/tls      :refer [server-start-tls-conn server-stop-tls])
  (import httpd/response :refer [resp-ok bad-request])
  (import ws-server/server
    :refer [ws-upgrade
            ws-server-recv ws-server-send ws-server-close
            ws-set-server-timeout])
  (import ws-core/conn  :refer [WsConn])
  (import ws-core/frame :refer [ws-frame-text ws-text? ws-binary?
                                ws-closed? ws-error? ws-timeout?])
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-true])
  (import test/runner :refer [run-all])

;; ---------------------------------------------------------------------------
;; file-scope C: embedded throwaway cert/key + a tiny raw mbedTLS WebSocket
;; client used to drive the server over TLS.
;; ---------------------------------------------------------------------------
```c
