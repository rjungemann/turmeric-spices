;; tests/fixtures/shared-wsconn/main.tur -- NAME-V0.3 cross-import check.
;;
;; The whole point of factoring ws-core: an application can import BOTH
;; ws-client and ws-server and refer to a single `WsConn` type, with no `:as`
;; aliasing and no name collision. Before NAME-V0 each spice exported its own
;; `WsConn` / `WsFrame` opaque, so importing both `:refer`-style was impossible.
;;
;; This fixture imports the connection/frame types from ws-core, the client
;; behaviour from ws-client, and the server behaviour from ws-server, then
;; defines helpers typed in terms of the one shared `WsConn` / `WsFrame`. That
;; it type-checks at all is the assertion (verify with `tur check main.tur`);
;; running it just confirms the client side links and reports a frame kind.

(defmodule ws-server/fixtures/shared-wsconn
  ;; One canonical WsConn / WsFrame, shared by both sides -- no aliasing.
  (import ws-core/conn  :refer [WsConn])
  (import ws-core/frame :refer [WsFrame ws-frame-kind ws-text? ws-closed? ws-error?])
  ;; Client behaviour.
  (import ws-client/client
    :refer [ws-connect ws-conn-null? ws-free ws-recv])
  ;; Server behaviour -- referenced purely to prove its WsConn is the same type.
  (import ws-server/server :refer [ws-server-send ws-server-close])

  ;; A helper typed on the shared WsConn. It is happily callable with a handle
  ;; from ws-client's ws-connect; ws-server-send below names the very same type
  ;; in its own signature -- one WsConn across both APIs.
  (defn frame-kind-of [w : WsConn] : int
    (let [f (ws-recv w)]
      (ws-frame-kind f)))

  ;; A server-side helper, also typed on the shared WsConn. The fact that
  ;; frame-kind-of (fed by ws-client) and this (calling ws-server-*) compile
  ;; against the same `WsConn` is the NAME-V0 guarantee.
  (defn server-echo [w : WsConn msg : cstr] : void
    (ws-server-send w msg)
    (ws-server-close w))

  (defn main [] : int
    (let [c (ws-connect "ws://127.0.0.1:1/never")]
      ;; We do not expect this connect to succeed (port 1); the point is purely
      ;; that one WsConn type flows through both client and server helpers.
      (if (ws-conn-null? c)
        0
        (let [k (frame-kind-of c)]
          (ws-free c)
          0)))))
