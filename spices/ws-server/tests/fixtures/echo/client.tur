;; tests/fixtures/echo/client.tur -- ws-client driver for the live echo test.
;;
;; Connects over plain ws:// to the server.tur fixture (port from WS_SRV_PORT),
;; sends five text messages plus one >125-byte payload, verifies each echoes
;; back byte-identical, then closes cleanly. Emits TAP; exit 0 iff all pass.
;; Run by run.sh as a separate process from server.tur (see that file's note on
;; why the two cannot share one program).

(defmodule ws-server/fixtures/echo-client
  (import ws-client/client
    :refer [ws-connect ws-conn-null? ws-last-error
            ws-send ws-recv ws-close ws-free ws-set-timeout])
  (import ws-core/conn  :refer [WsConn])
  (import ws-core/frame :refer [ws-frame-text ws-text?])

  (defn echo-uri [] : cstr
    ```c
    #include <stdio.h>
    #include <stdlib.h>
    static char uri[64];
    const char *p = getenv("WS_SRV_PORT");
    snprintf(uri, sizeof(uri), "ws://127.0.0.1:%s/ws", p ? p : "0");
    return uri;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap [idx : int name : cstr ok : bool] : int
    ```c
    #include <stdio.h>
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    return ok ? 0 : 1;
    ```)

  (defn echoes? [c : WsConn msg : cstr] : bool
    (let [_ (ws-send c msg)
          f (ws-recv c)]
      (and (ws-text? f) (cstr-eq? msg (ws-frame-text f)))))

  (defn main [] : int
    (let [c (ws-connect (echo-uri))]
      (if (ws-conn-null? c)
        (do (println "Bail out! ws-connect failed:") (println (ws-last-error)) 1)
        (do
          (println "1..6")
          (ws-set-timeout c 3000)
          (let [r1 (tap 1 "echoes message one"   (echoes? c "message one"))
                r2 (tap 2 "echoes message two"   (echoes? c "message two"))
                r3 (tap 3 "echoes message three" (echoes? c "message three"))
                r4 (tap 4 "echoes message four"  (echoes? c "message four"))
                r5 (tap 5 "echoes message five"  (echoes? c "message five"))
                r6 (tap 6 "echoes a >125 byte payload"
                       (echoes? c
                         "the quick brown fox jumps over the lazy dog, and then the quick brown fox jumps over the lazy dog again, well past one hundred and twenty five bytes"))]
            (do
              (ws-close c)
              (ws-free c)
              (if (= (+ (+ (+ r1 r2) (+ r3 r4)) (+ r5 r6)) 0)
                (do (println "# All 6 ws-server echo assertions passed.") 0)
                1))))))))
