;; tests/fixtures/broadcast/server.tur -- live broadcast hub driven by run.sh.
;;
;; Starts an httpd server (server-start-pool-conn) whose /ws route upgrades to
;; WebSocket and registers each connection in a shared `Mutex<vec<WsConn>>`
;; hub. Every inbound data frame is fanned out to every registered connection
;; under the hub mutex; on disconnect a worker removes itself from the hub
;; before its WsConn is freed, so a broadcast never touches a dead connection.
;; Binds the port named by WS_SRV_PORT and blocks forever; run.sh starts it in
;; the background and kills it when the client driver (client.tur, which uses
;; the ws-client spice) is done.
;;
;; This runs as a SEPARATE process from the ws-client driver to exercise the
;; real socket path end to end. (Since NAME-V0 both spices share one `WsConn` /
;; `WsFrame` from ws-core, so single-process is possible now; the split is kept
;; on purpose.) It is the broadcast counterpart of the echo fixture next door,
;; and the cross-process (real ws-client <-> ws-server) complement to the
;; self-contained tests/broadcast_test.tur.
;;
;; stdlib/mutex.tur backs the hub lock; stdlib/vec.tur is auto-loaded.
(load "stdlib/mutex.tur")

(defmodule ws-server/fixtures/broadcast-server
  (import httpd/types    :refer [Conn Request])
  (import httpd/server   :refer [server-start-pool-conn])
  (import httpd/request  :refer [req-path])
  (import httpd/response :refer [resp-ok bad-request not-found])
  (import ws-server/server
    :refer [ws-upgrade ws-server-recv ws-server-send ws-server-close
            ws-set-server-timeout])
  (import ws-core/conn  :refer [WsConn])
  (import ws-core/frame :refer [ws-frame-text ws-text? ws-binary?
                                ws-closed? ws-error? ws-timeout?])

  (defn port [] : int
    ```c
    #include <stdlib.h>
    const char *p = getenv("WS_SRV_PORT");
    return (int64_t)(p ? atoi(p) : 0);
    ```)

  (defn block-forever [] #{Unsafe} : void
    ```c
    #include <unistd.h>
    for (;;) sleep(3600);
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; ---------------------------------------------------------------------
  ;; The broadcast hub -- `Mutex<vec<WsConn>>` in plain user code. Every
  ;; mutation and every fan-out runs under the one mutex.
  ;; ---------------------------------------------------------------------

  (def hub-mutex (mutex-new))
  (def hub (:: (vec-new) (Vec WsConn)))

  (defn ws-eq? [a : WsConn b : WsConn] : bool
    (= (:: a :int) (:: b :int)))

  (defn hub-register! [ws : WsConn] : nil
    (do (mutex-lock hub-mutex)
        (vec-push! hub ws)
        (mutex-unlock hub-mutex)))

  (defn hub-index [ws : WsConn i : int n : int] : int
    (if (>= i n)
      -1
      (if (ws-eq? ws (vec-get hub i))
        i
        (hub-index ws (+ i 1) n))))

  (defn hub-unregister! [ws : WsConn] : nil
    (do (mutex-lock hub-mutex)
        (let [n   (vec-len hub)
              idx (hub-index ws 0 n)]
          (when (>= idx 0)
            (do (vec-set! hub idx (vec-get hub (- n 1)))
                (vec-pop! hub)
                nil)))
        (mutex-unlock hub-mutex)))

  (defn hub-send-each [msg : cstr i : int n : int] : nil
    (when (< i n)
      (do (ws-server-send (vec-get hub i) msg)
          (hub-send-each msg (+ i 1) n))))

  (defn hub-broadcast! [msg : cstr] : nil
    (do (mutex-lock hub-mutex)
        (hub-send-each msg 0 (vec-len hub))
        (mutex-unlock hub-mutex)))

  ;; ---------------------------------------------------------------------
  ;; Server side: register, fan every inbound data frame out to the hub.
  ;; ---------------------------------------------------------------------

  (defn broadcast-loop [ws : WsConn] : void
    (let [f (ws-server-recv ws)]
      (if (or (ws-closed? f) (ws-error? f) (ws-timeout? f))
        nil
        (do
          (when (or (ws-text? f) (ws-binary? f))
            (hub-broadcast! (ws-frame-text f)))
          (broadcast-loop ws)))))

  (defn handler [conn : int req : int] : int
    (let [c (:: conn Conn)
          r (:: req Request)]
      (if (cstr-eq? (req-path r) "/ws")
        (if (= (ws-upgrade c r
                 (fn [ws : WsConn] : void
                   (do (ws-set-server-timeout ws 10000)
                       (hub-register! ws)
                       (broadcast-loop ws)
                       (hub-unregister! ws)
                       (ws-server-close ws)))) 1)
          (:: (resp-ok "text/plain" "") :int)
          (:: (bad-request "not a websocket request") :int))
        (:: (not-found "") :int))))

  (defn main [] : int
    (let [srv (server-start-pool-conn (port) handler 8)]
      (do (unsafe (block-forever)) 0))))
