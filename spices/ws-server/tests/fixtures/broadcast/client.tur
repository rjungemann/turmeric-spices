;; tests/fixtures/broadcast/client.tur -- ws-client driver for the live
;; broadcast test.
;;
;; Opens three concurrent ws:// connections to the server.tur fixture (port
;; from WS_SRV_PORT), parks one reader thread on each, then has a single
;; connection send one text frame. Every reader must receive that frame --
;; proving the server fanned it out to all three connections. Emits TAP; exit 0
;; iff all three readers saw the broadcast. Run by run.sh as a separate process
;; from server.tur (see that file's note on why the two cannot share one
;; program).
;;
;; thread-spawn-fn / thread-join live in stdlib/thread.tur (a T19-C/D library
;; module deliberately NOT auto-loaded); pull it in explicitly.
(load "stdlib/thread.tur")

(defmodule ws-server/fixtures/broadcast-client
  (import ws-client/client
    :refer [ws-connect ws-conn-null? ws-last-error
            ws-send ws-recv ws-close ws-free ws-set-timeout])
  (import ws-core/conn  :refer [WsConn])
  (import ws-core/frame :refer [ws-frame-text ws-text?])

  (defn bcast-uri [] : cstr
    ```c
    #include <stdio.h>
    #include <stdlib.h>
    static char uri[64];
    const char *p = getenv("WS_SRV_PORT");
    snprintf(uri, sizeof(uri), "ws://127.0.0.1:%s/ws", p ? p : "0");
    return uri;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap [idx : int name : cstr ok : bool] : int
    ```c
    #include <stdio.h>
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    return ok ? 0 : 1;
    ```)

  (defn sleep-ms [ms : int] #fx{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  ;; ---------------------------------------------------------------------
  ;; Per-reader-thread argument: the ws-client WsConn handle (carried as an
  ;; int64), the message we expect to be broadcast to us, and a result slot the
  ;; main thread reads after the join.
  ;; ---------------------------------------------------------------------
  ```c
  #include <stdint.h>
  #include <stdlib.h>
  #include <string.h>
  typedef struct { int64_t conn; char msg[256]; int ok; } bcc_arg_t;
  static bcc_arg_t *bcc__arg_new(int64_t conn, const char *msg) {
    bcc_arg_t *a = (bcc_arg_t *)calloc(1, sizeof(*a));
    if (!a) return NULL;
    a->conn = conn;
    strncpy(a->msg, msg, sizeof(a->msg) - 1);
    a->ok = 0;
    return a;
  }
  ```

  (defn arg-new [conn : WsConn msg : cstr] : ptr<void>
    ```c return (void *)bcc__arg_new((int64_t)conn, (const char *)msg); ```)

  (defn arg-conn [a : ptr<void>] : WsConn
    ```c return (int64_t)((bcc_arg_t *)a)->conn; ```)

  (defn arg-msg [a : ptr<void>] : cstr
    ```c return (char *)((bcc_arg_t *)a)->msg; ```)

  (defn arg-set-ok! [a : ptr<void> ok : bool] : void
    ```c ((bcc_arg_t *)a)->ok = (int)ok; ```)

  (defn arg-ok? [a : ptr<void>] : bool
    ```c return a != 0 && ((bcc_arg_t *)a)->ok != 0; ```)

  (defn null-ptr [] : ptr<void>
    ```c return NULL; ```)

  ;; Reader thread entry (pthread shape): block on the next frame for this
  ;; connection and record whether it matched the expected broadcast message.
  (defn reader-task [arg : ptr<void>] : ptr<void>
    (let [conn (arg-conn arg)
          f    (ws-recv conn)]
      (do
        (arg-set-ok! arg (and (ws-text? f) (cstr-eq? (arg-msg arg) (ws-frame-text f))))
        (null-ptr))))

  (defn main [] : int
    (let [c1 (ws-connect (bcast-uri))
          c2 (ws-connect (bcast-uri))
          c3 (ws-connect (bcast-uri))]
      (if (or (ws-conn-null? c1) (or (ws-conn-null? c2) (ws-conn-null? c3)))
        (do (println "Bail out! ws-connect failed:") (println (ws-last-error)) 1)
        (do
          (println "1..3")
          (ws-set-timeout c1 3000)
          (ws-set-timeout c2 3000)
          (ws-set-timeout c3 3000)
          ;; Let all three upgrades register in the server hub before sending.
          (unsafe (sleep-ms 200))
          (let [msg "broadcast to everyone"
                a1  (arg-new c1 msg)
                a2  (arg-new c2 msg)
                a3  (arg-new c3 msg)]
            (do
              (unsafe
                (let [t1 (thread-spawn-fn reader-task a1)
                      t2 (thread-spawn-fn reader-task a2)
                      t3 (thread-spawn-fn reader-task a3)]
                  (do
                    (sleep-ms 50)        ;; readers parked in ws-recv
                    (ws-send c1 msg)     ;; one connection sends
                    (thread-join t1)
                    (thread-join t2)
                    (thread-join t3))))
              (let [r1 (tap 1 "client one receives the broadcast" (arg-ok? a1))
                    r2 (tap 2 "client two receives the broadcast" (arg-ok? a2))
                    r3 (tap 3 "client three receives the broadcast" (arg-ok? a3))]
                (do
                  (ws-close c1) (ws-free c1)
                  (ws-close c2) (ws-free c2)
                  (ws-close c3) (ws-free c3)
                  (if (= (+ (+ r1 r2) r3) 0)
                    (do (println "# All 3 ws-server broadcast assertions passed.") 0)
                    1))))))))))
