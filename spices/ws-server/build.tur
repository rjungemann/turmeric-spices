(defpackage tur-ws-server
  :name        "tur-ws-server"
  :version     "0.1.0"
  :description "RFC 6455 WebSocket server upgrade for tur-httpd"
  :license     "MIT"
  :spices #{
    ;; Workspace-local test framework, used only by tests/.
    "test"  #{:path "../test"}
    ;; httpd provides the Conn handle + conn-fd / conn-mark-upgraded! that
    ;; ws-upgrade plugs into, plus the Request accessors and server entry
    ;; points the echo fixture drives.
    "httpd" #{:path "../httpd"}
    ;; httpd's worker loop imports httpd/pool (-> thread-pool/pool) and the
    ;; json body codecs. Workspace-sibling imports don't propagate a sibling's
    ;; own module deps onto our -I path, so we re-declare httpd's transitive
    ;; workspace deps here (same pattern as httpd re-declaring yyjson).
    "thread-pool" #{:path "../thread-pool"}
    "json" #{:path "../json"}
    ;; tls backs the wss:// path: httpd's TLS listener (httpd/tls) terminates
    ;; TLS via tur-tls, and the tls_echo_test drives it. ws-server's own runtime
    ;; uses mbedTLS directly (below), but the tls/* modules must be on the -I
    ;; path so the httpd/tls import in the test resolves.
    "tls" #{:path "../tls" :optional true}
    ;; ws-client is a dev/test dep -- the echo fixture uses it to drive the
    ;; server. ws-server itself does not depend on it at runtime.
    "ws-client" #{:path "../ws-client" :optional true}
  }
  :cmake-deps #{
    ;; mbedTLS powers the wss:// frame I/O: when httpd hands ws-upgrade a TLS
    ;; Conn, the server sends/receives frames via mbedtls_ssl_write/read. The
    ;; ws-server module gates every mbedTLS reference on __has_include, so this
    ;; is optional -- without it ws:// still builds and works. Same pin as
    ;; tur-tls / tur-ws-client.
    "mbedtls" #{:url     "https://github.com/Mbed-TLS/mbedtls"
               :ref     "v3.6.2"
               :targets ["mbedtls" "mbedx509" "mbedcrypto"]
               :options #{:BUILD_SHARED_LIBS "OFF"
                         :ENABLE_TESTING    "OFF"
                         :ENABLE_PROGRAMS   "OFF"}}
  }
  :exports #{
    "ws-server/server" ["WsConn" "WsFrame"
                        "ws-upgrade"
                        "ws-server-send" "ws-server-send-bytes"
                        "ws-server-recv" "ws-server-close"
                        "ws-set-server-timeout"
                        "ws-frame-kind" "ws-frame-data" "ws-frame-len"
                        "ws-frame-text"
                        "ws-text?" "ws-binary?" "ws-ping?" "ws-pong?"
                        "ws-closed?" "ws-timeout?" "ws-error?"]
  })
