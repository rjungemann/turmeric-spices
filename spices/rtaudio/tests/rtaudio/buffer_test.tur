;; tests/rtaudio/buffer_test.tur -- rtaudio/buffer (U4 sized AudioBuf).
;;
;; Pure-Turmeric: rtaudio/buffer is inline-C only (no RtAudio native lib), so
;; this runs anywhere. Positive coverage of the sized interleaved buffer; the
;; negative case -- mixing an (AudioBuf (Static 256) (Static 2)) with an
;; (AudioBuf (Static 512) (Static 2)) -- is a compile error (TUR-E0260) and so
;; lives in tests/errors/, not here.

(load "stdlib/sized.tur")

(defmodule rtaudio/tests/buffer
  (import rtaudio/buffer :refer [AudioBuf audiobuf-silence audiobuf-free
                                 audiobuf-frames audiobuf-channels audiobuf-samples
                                 audiobuf-get audiobuf-set!
                                 audiobuf-mix audiobuf-gain audiobuf-peak])
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq assert-true])
  (import test/runner :refer [run-all])

  (defn fa [x : float] : float ```c return x < 0.0 ? -x : x; ```)
  (defn approx [a : float b : float] : bool (< (fa (- a b)) 1e-6))

  ;; A 2-frame stereo block:
  ;;   frame0: L=0.5  R=0.25
  ;;   frame1: L=-1.0 R=0.0
  (defn blk [] : (AudioBuf (Static 2) (Static 2))
    (let [b (audiobuf-silence 2 2)]
      (audiobuf-set! b 0 0 0.5)
      (audiobuf-set! b 0 1 0.25)
      (audiobuf-set! b 1 0 -1.0)
      (audiobuf-set! b 1 1 0.0)
      b))

  (defn main [] : int
    (do
      (describe "audiobuf shape"
        (it "reports frame count"   (assert-eq 2 (let [b (blk)] (let [n (audiobuf-frames b)]   (audiobuf-free b) n))))
        (it "reports channel count" (assert-eq 2 (let [b (blk)] (let [n (audiobuf-channels b)] (audiobuf-free b) n))))
        (it "reports sample count"  (assert-eq 4 (let [b (blk)] (let [n (audiobuf-samples b)]  (audiobuf-free b) n)))))

      (describe "audiobuf get/set"
        (it "round-trips a written sample"
          (assert-true (approx 0.25 (let [b (blk)] (let [x (audiobuf-get b 0 1)] (audiobuf-free b) x)))))
        (it "silence reads as zero"
          (assert-true (approx 0.0 (let [b (audiobuf-silence 2 2)]
                                     (let [x (audiobuf-get b 1 1)] (audiobuf-free b) x))))))

      (describe "audiobuf-mix (shared n, c)"
        (it "sums samples frame/channel-wise"
          ;; mix(blk, blk) frame0 L = 0.5 + 0.5 = 1.0
          (assert-true (approx 1.0 (let [a (blk) b (blk) m (audiobuf-mix a b)]
                                     (let [x (audiobuf-get m 0 0)]
                                       (audiobuf-free a) (audiobuf-free b) (audiobuf-free m) x))))))

      (describe "audiobuf-gain"
        (it "scales every sample"
          ;; gain(blk, 2.0) frame1 L = -1.0 * 2 = -2.0
          (assert-true (approx -2.0 (let [a (blk) g (audiobuf-gain a 2.0)]
                                      (let [x (audiobuf-get g 1 0)]
                                        (audiobuf-free a) (audiobuf-free g) x))))))

      (describe "audiobuf-peak"
        (it "finds the largest absolute sample"
          ;; peak(blk) = abs(-1.0) = 1.0
          (assert-true (approx 1.0 (let [a (blk)] (let [p (audiobuf-peak a)] (audiobuf-free a) p)))))
        (it "silence has zero peak"
          (assert-true (approx 0.0 (let [a (audiobuf-silence 4 2)]
                                     (let [p (audiobuf-peak a)] (audiobuf-free a) p))))))

      (run-all)
      0)))
