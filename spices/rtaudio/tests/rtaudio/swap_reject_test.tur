;; tests/rtaudio/swap_reject_test.tur -- compile-time swap-rejection probes for
;; rtaudio's secondary handle (DeviceInfo) and the audio callback function-type.
;;
;; NEGATIVE fixture: every defn below is wrong on purpose. Running
;; `tur check tests/rtaudio/swap_reject_test.tur` MUST produce TUR-E0001
;; (or callback-shape) mismatches at the marked sites.

(defmodule rtaudio/tests/swap-reject
  (import rtaudio/core    :refer [Audio DeviceInfo])
  (import rtaudio/devices :refer [device-info device-info-name device-info-free
                                  device-count])
  (import rtaudio/stream  :refer [stream-open])

  ;; Audio vs DeviceInfo: device-info-name expects DeviceInfo, not Audio.
  (defn bad-audio-as-di [a : Audio] : cstr
    (device-info-name a))                ; expects DeviceInfo

  ;; DeviceInfo vs Audio: device-count expects Audio.
  (defn bad-di-as-audio [di : DeviceInfo] : int
    (device-count di))                   ; expects Audio

  ;; Swap on device-info itself: (Audio, int) - passing DeviceInfo first.
  (defn bad-device-info-swap [a : Audio di : DeviceInfo] : DeviceInfo
    (device-info di 0))                  ; arg 1: expects Audio, got DeviceInfo

  ;; Wrong-shape callback for stream-open. The real shape is
  ;; (c-fn [ptr<void> ptr<void> int float int ptr<void>] int).
  ;; A nullary-int function should be rejected at the callback slot.
  (defn wrong-shape-cb [] : int 0)

  (defn bad-callback-shape [a : Audio] : (Result int int)
    (stream-open a 0 2 -1 0 ":float32" 44100 512 wrong-shape-cb))

  (defn main [] : int 0))
