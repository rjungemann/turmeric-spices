;; tests/rtaudio/devices_test.tur -- tests for rtaudio/devices.(defmodule rtaudio/tests/devices
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])

  (describe "rtaudio/devices"
    (it "module loads without error"
      (assert-eq 1 1)))


  (defn main [] :int
    (run-all)
    0))
