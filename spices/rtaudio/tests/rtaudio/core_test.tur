;; tests/rtaudio/core_test.tur -- tests for rtaudio/core.(defmodule rtaudio/tests/core
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])

  (describe "rtaudio/core"
    (it "module loads without error"
      (assert-eq 1 1)))


  (defn main [] :int
    (run-all)
    0))
