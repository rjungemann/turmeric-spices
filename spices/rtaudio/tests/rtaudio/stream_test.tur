;; tests/rtaudio/stream_test.tur -- tests for rtaudio/stream.
(defmodule rtaudio/tests/stream
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])

  (describe "rtaudio/stream"
    (it "module loads without error"
      (assert-eq 1 1)))


  (defn main [] : int
    (run-all)
    0))
