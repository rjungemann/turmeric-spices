;; pool_map -- tests for pool-map fan-out convenience (FUT-V0.3).
;;
;; Case: map work over a 5-element list through the pool and collect results.
;;   seeds   = [1 2 3 4 5]
;;   work x  = x * x
;;   results = [1 4 9 16 25], sum = 55, count = 5, and order is preserved
;;             (results[0] corresponds to seeds[0]).
;;
;; main returns the failed-assertion count.

(defmodule thread-pool/tests/pool_map
  (import thread-pool/pool     :refer [Pool pool-new pool-stop])
  (import thread-pool/parallel :refer [TList tlist-nil tlist-cons
                                       tlist-empty? tlist-head tlist-tail
                                       pool-map])

(defn fail-if [cond : bool label : cstr] : int
  (if cond (do (println label) 1) 0))

(defn noop [x : int] : void nil)
(defn square [x : int] : int (* x x))

;; tlist-sum / tlist-count over a (TList int).
(defn tlist-sum [l : (TList int)] : int
  (if (tlist-empty? l) 0 (+ (tlist-head l) (tlist-sum (tlist-tail l)))))
(defn tlist-count [A] [l : (TList A)] : int
  (if (tlist-empty? l) 0 (+ 1 (tlist-count (tlist-tail l)))))

;; first two results, to confirm order is preserved (not just the sum).
(defn tlist-2nd [l : (TList int)] : int (tlist-head (tlist-tail l)))

(defn seeds [] : (TList int)
  (tlist-cons 1 (tlist-cons 2 (tlist-cons 3 (tlist-cons 4 (tlist-cons 5 (:: (tlist-nil) (TList int))))))))

(defn main [] : int
  (let [p   (pool-new 4 noop)
        res (pool-map p (seeds) square)]
    (let [f (+ (fail-if (not= (tlist-sum res) 55)   "FAIL: pool-map sum != 55")
               (+ (fail-if (not= (tlist-count res) 5) "FAIL: pool-map count != 5")
                  (+ (fail-if (not= (tlist-head res) 1) "FAIL: pool-map[0] != 1")
                     (fail-if (not= (tlist-2nd res) 4)  "FAIL: pool-map[1] != 4"))))]
      (do
        (pool-stop p)
        (if (= f 0) (println "PASS pool_map") (println "pool_map: failures above"))
        f))))

) ;; end defmodule thread-pool/tests/pool_map
