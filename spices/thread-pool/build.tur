(defpackage tur-thread-pool
  :name        "tur-thread-pool"
  :version     "0.1.0"
  :description "Bounded POSIX worker-thread pool for Turmeric (generic ptr<void> work items)"
  :license     "MIT"
  :spices #{
    "test" #{:url    "https://github.com/rjungemann/turmeric-spices"
             :ref    "test-v0.1.0"
             :subdir "spices/test"
             :optional true}
  }
  :exports #{
    "thread-pool/pool" ["pool-new" "pool-submit" "pool-stop"]
  })
