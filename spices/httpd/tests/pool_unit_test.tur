;; pool_unit_test -- exercises httpd/pool's delegation to tur-thread-pool
;; in isolation.
;;
;; httpd/pool dispatches each dequeued work item to httpd/server's
;; srv-worker-loop trampoline via an inline-C extern, so we can test the pool
;; machinery (pool-new / pool-enqueue / pool-stop) WITHOUT pulling in
;; httpd/server + the json codec by supplying our own non-static trampoline.
;; The stub counts servings and frees the work item, standing in for the real
;; connection-servicing path.
;;
;; main returns the number of failed assertions so a logic failure surfaces as
;; a non-zero exit under `tur test`.

(defmodule httpd/tests/pool_unit_test
  (import httpd/pool :refer [pool-new pool-enqueue pool-stop])

;; Stub trampoline + a mutex-guarded serving counter.  The work item is the
;; __httpd_warg packed by httpd/pool's pool-enqueue.
```c
#include <stdlib.h>
#include <pthread.h>
struct __httpd_warg { int client_fd; void *handler; };
static pthread_mutex_t g_mu     = PTHREAD_MUTEX_INITIALIZER;
static long            g_served = 0;
static long            g_fd_sum = 0;
void *httpd__server__srv_worker_loop_trampoline(void *arg) {
  struct __httpd_warg *wa = (struct __httpd_warg *)arg;
  pthread_mutex_lock(&g_mu);
  g_served += 1;
  g_fd_sum += (long)wa->client_fd;
  pthread_mutex_unlock(&g_mu);
  free(wa);
  return NULL;
}
```

(defn served-reset [] : void
  ```c
  pthread_mutex_lock(&g_mu);
  g_served = 0;
  g_fd_sum = 0;
  pthread_mutex_unlock(&g_mu);
  ```)

(defn served-count [] : int
  ```c
  long v;
  pthread_mutex_lock(&g_mu);
  v = g_served;
  pthread_mutex_unlock(&g_mu);
  return (int)v;
  ```)

(defn served-fd-sum [] : int
  ```c
  long v;
  pthread_mutex_lock(&g_mu);
  v = g_fd_sum;
  pthread_mutex_unlock(&g_mu);
  return (int)v;
  ```)

;; A handler is required by pool-new's signature; the stub trampoline never
;; invokes it, so the body is irrelevant.
(defn dummy-handler [fd : int] : int 0)

;; enqueue-fds -- enqueue fake client fds carrying values n, n-1, ..., 1.
;; (No real sockets are involved; the stub trampoline only reads the int and
;; never calls close.)
(defn enqueue-fds [pool : ptr<void> n : int] : void
  (when (> n 0)
    (do
      (pool-enqueue pool n)
      (enqueue-fds pool (- n 1)))))

(defn fail-if [cond : bool label : cstr] : int
  (if cond
    (do (println label) 1)
    0))

;; run-case -- enqueue `n` fds into a `workers`-thread pool, stop (drain +
;; join), then assert every fd was served exactly once.  The expected fd sum
;; is n*(n+1)/2 since enqueue-fds submits values n..1.
(defn run-case [workers : int n : int label : cstr] : int
  (do
    (served-reset)
    (let [pool (pool-new workers dummy-handler)]
      (do
        (enqueue-fds pool n)
        (pool-stop pool)
        (+ (fail-if (not= (served-count) n) label)
           (fail-if (not= (served-fd-sum) (/ (* n (+ n 1)) 2)) label))))))

(defn main [] : int
  (let [;; basic submit + drain
        f1 (run-case 4 20 "FAIL: pool basic submit+drain")
        ;; back-pressure: 4 workers => cap 64; 400 fds forces not-full waits
        f2 (run-case 4 400 "FAIL: pool back-pressure")
        ;; size = 0 clamps to a single worker
        f3 (run-case 0 50 "FAIL: pool size=0 clamps to 1")
        ;; stop with queue non-empty (workers drain before join returns)
        f4 (run-case 2 150 "FAIL: pool stop with queue non-empty")
        f  (+ f1 (+ f2 (+ f3 f4)))]
    (if (= f 0)
      (println "PASS pool_unit_test")
      (println "pool_unit_test: failures above"))
    f))

) ;; end defmodule httpd/tests/pool_unit_test
