;; tests/httpd/u3_smoke.tur -- U3 row-typed Request/Response surface (httpd/typed).
;;
;; This test stays row-*polymorphic*: it wraps a raw Request / Response as
;; the `TRequest` / `TResponse` newtypes and reads their handles back
;; through the typed accessors without ever naming a concrete `#row{...}`
;; shape. That keeps the type-level shape exercised without
;; `-Xdata-literals` (mirroring sqlite/tests/u3_smoke.tur and
;; postgres/tests/postgres/u3_smoke.tur).
;;
;; The compile-time schema-mismatch guarantee -- a `TRequest` of one header
;; row being rejected where another is expected (TUR-E0001) -- is the U3
;; "negative fixture" deliverable, validated by hand on a concrete
;; `#row{...}` literal under `-Xdata-literals` (see
;; tests/errors/httpd-trequest-row-mismatch.tur); the harness for running
;; compile-fail fixtures inline is plan P5 and is not yet landed.
;;
;; The underlying httpd/request and httpd/response functions that touch a
;; real parsed request struct are NOT invoked here -- doing so would need
;; the framework to parse a live request. We only round-trip the int handle
;; through the typed wrapper to prove the phantom-row newtype erases at
;; codegen.

(defmodule httpd/tests/u3-smoke
  (import httpd/types :refer [Request Response])
  (import httpd/typed :refer [TRequest TResponse
                              treq-of treq-handle
                              tresp-of tresp-handle]))

;; Mint opaque handles from raw ints (no framework / sockets needed).
;; Request / Response are defopaque :int, so this is a free re-tag.
(defn __mk-req  [h : int] : Request  (:: h Request))
(defn __mk-resp [h : int] : Response (:: h Response))

;; Row-polymorphic round-trips: any TRequest / TResponse shape's underlying
;; int handle survives a wrap + unwrap. The smallest end-to-end check that
;; the phantom-row newtype erases at codegen.
(defn req-round-trip [^&headers] [r : (TRequest headers)] : int
  (:: (treq-handle r) :int))

(defn resp-round-trip [^&headers] [r : (TResponse headers)] : int
  (:: (tresp-handle r) :int))

(defn tap [idx : int name : cstr ok : bool] #{Unsafe} : int
  ```c
  printf("%s %lld - %s\n", ok ? "ok" : "not ok",
                            (long long)idx, (const char *)name);
  return ok ? 0 : 1;
  ```)

(defn main [] : int
  (let [req   (__mk-req 7)
        resp  (__mk-resp 11)
        treq  (treq-of req)
        tresp (tresp-of resp)
        rh    (req-round-trip treq)
        sh    (resp-round-trip tresp)]
    (unsafe
      (do
        (tap 1 "TRequest round-trip preserves the handle"  (= rh 7))
        (tap 2 "TResponse round-trip preserves the handle" (= sh 11))))))
