;; tests/httpd/handler_test.tur -- U2 Handler typeclass + serve bridge.
;;
;; Exercises the typed handler path end to end: a zero-field witness struct
;; with a `Handler` instance, started via the `serve` macro (which generates
;; the captureless trampoline and wires it to `server-start`). The round-trip
;; goes through the default pool dispatcher, same as echo_test, but the
;; handler is selected by typeclass dispatch rather than a bare `(c-fn ...)`.

(defmodule httpd/tests/handler
  (import httpd/handler  :refer [serve])
  (import httpd/request  :refer [req-method req-path])
  (import httpd/response :refer [resp-ok not-found])
  (import httpd/server   :refer [server-stop])
  (import httpd/types    :refer [Request Response])
  (import http/client    :refer [http-get])
  (import http/response  :refer [response-status response-body response-header])
  (import test/suite     :refer [describe it])
  (import test/assert    :refer [assert-eq assert-true])
  (import test/runner    :refer [run-all])

  ;; ---------------------------------------------------------------------
  ;; Helpers: unwrap http/client's result<:int> and compare cstr equality.
  ;; ---------------------------------------------------------------------

  (defn __cr-ok? [r : ptr<void>] : bool
    ```c
    if (!r) return 0;
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return ((struct __cr *)r)->is_ok;
    ```)

  (defn __cr-val [r : ptr<void>] : int
    ```c
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return (int64_t)((struct __cr *)r)->ok_val;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; Local "<method> <path>" join -- stdlib/str-concat trips the elaborator
  ;; when reached transitively through several spices, so inline a tiny
  ;; purpose-built helper (mirrors echo_test).
  (defn echo-join [method : cstr path : cstr] : cstr
    ```c
    #include <stdlib.h>
    #include <string.h>
    const char *m = (const char *)method;
    const char *p = (const char *)path;
    size_t ml = strlen(m), pl = strlen(p);
    char *out = (char *)malloc(ml + 1 + pl + 1);
    memcpy(out, m, ml);
    out[ml] = ' ';
    memcpy(out + ml + 1, p, pl);
    out[ml + 1 + pl] = '\0';
    return (int64_t)(intptr_t)out;
    ```)

  (defn sleep-ms [ms : int] #{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  ;; ---------------------------------------------------------------------
  ;; Typed handler: an opaque witness with a Handler instance.
  ;;
  ;; `respond` returns a Response directly -- the typed contract the whole
  ;; plan is about. `/health` is a fixed 200; everything else echoes
  ;; "<METHOD> <PATH>" with a 404, proving the handler reads the Request
  ;; and chooses a Response by type, not by an int tag.
  ;; ---------------------------------------------------------------------

  (defopaque Echo :int)

  (definstance Handler [Echo]
    (respond [self req]
      (let [r (:: req :Request)]
        (if (cstr-eq? "/health" (req-path r))
          (resp-ok "text/plain" "ok")
          (not-found (echo-join (req-method r) (req-path r)))))))

  ;; ---------------------------------------------------------------------
  ;; Test driver -- `serve` generates the trampoline + starts the server.
  ;; ---------------------------------------------------------------------

  (defn main [] : int
    (let [srv (serve 18083 Echo)]
      (do
        (unsafe (sleep-ms 50))

        (describe "httpd Handler typeclass -- serve bridge"

          (it "GET /health returns 200"
            (let [r (http-get "http://127.0.0.1:18083/health")]
              (if (__cr-ok? r)
                (assert-eq 200 (response-status (__cr-val r)))
                (assert-true false))))

          (it "GET /health body is 'ok'"
            (let [r (http-get "http://127.0.0.1:18083/health")]
              (if (__cr-ok? r)
                (assert-true (cstr-eq? "ok" (response-body (__cr-val r))))
                (assert-true false))))

          (it "GET /missing returns 404"
            (let [r (http-get "http://127.0.0.1:18083/missing")]
              (if (__cr-ok? r)
                (assert-eq 404 (response-status (__cr-val r)))
                (assert-true false))))

          (it "GET /missing echoes 'GET /missing'"
            (let [r (http-get "http://127.0.0.1:18083/missing")]
              (if (__cr-ok? r)
                (assert-true (cstr-eq? "GET /missing" (response-body (__cr-val r))))
                (assert-true false))))

          (it "Content-Type is text/plain"
            (let [r (http-get "http://127.0.0.1:18083/health")]
              (if (__cr-ok? r)
                (assert-true (cstr-eq? "text/plain"
                                       (response-header (__cr-val r) "Content-Type")))
                (assert-true false)))))

        (server-stop srv)
        (run-all)))
    0))
