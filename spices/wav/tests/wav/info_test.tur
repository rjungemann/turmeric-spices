;; tests/wav/info_test.tur -- tests for wav/info.
(defmodule wav/tests/info
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq assert-ok])
  (import test/runner :refer [run-all])
  (import wav/info :refer [wav-open-write wav-close wav-sample-rate wav-channels])

  (describe "wav/info"
    (it "creates a wav file with correct sample rate"
      (let [r (wav-open-write "/tmp/test_turmeric.wav" 44100 2 ":wav-pcm16")]
        (if (ok? r)
          (let [w (ok-val r)]
            (let [sr (wav-sample-rate w)]
              (wav-close w)
              (assert-eq sr 44100)))
          (assert-ok r)))))


  (defn main [] :int
    (run-all)
    0))
