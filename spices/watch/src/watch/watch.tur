    ```)

  ;;; __watcher-tree-root -- tree-mode root path (read-only borrow).
  (defn __watcher-tree-root [watcher : int] #{Unsafe} : cstr
    ```c
    TurWatcher *w = (TurWatcher *)(intptr_t)watcher;
    return (const char *)((w && w->mode == 1 && w->root) ? w->root : "");
    ```)

  ;;; watch-refresh -- re-walk a tree-mode watcher's root and register any
  ;;; new subdirectories that have appeared since open.  No-op on
  ;;; single-file watchers.  Returns the new directory count, or -1 on error.
  (defn watch-refresh [watcher : int] #{Unsafe} : int
    (if (= (__watcher-mode watcher) 1)
      (do
        (__watcher-tree-walk watcher (__watcher-tree-root watcher) 0)
        (__watcher-tree-snap-init watcher)
        (watch-tree-dir-count watcher))
      0))

  ;; --------------------------------------------------------------------
  ;; Pending event queue (WTNF4).
  ;;
  ;; watch-next returns one event per call.  When the backend drain or
  ;; snapshot diff produces multiple events, extras are stored here and
  ;; returned on subsequent calls without another OS wait.
  ;; --------------------------------------------------------------------

  ;;; __watcher-pending-push -- append an event to the tail of the pending queue.
  (defn __watcher-pending-push [watcher : int ev : int] #{Unsafe} : void
    ```c
    TurWatcher *w = (TurWatcher *)(intptr_t)watcher;
    if (!w || ev == 0) return;
    if (w->pending_n == w->pending_cap) {
      int nc = w->pending_cap ? w->pending_cap * 2 : 4;
      int64_t *g = (int64_t *)realloc(w->pending_evs, sizeof(int64_t) * (size_t)nc);
      if (!g) {
        watch__event__watch_event_free(ev);
        return;
      }
      w->pending_evs = g;
      w->pending_cap = nc;
    }
    w->pending_evs[w->pending_n++] = ev;
    ```)

  ;;; __watcher-pending-pop -- remove and return the oldest event (FIFO), or 0.
  (defn __watcher-pending-pop [watcher : int] #{Unsafe} : int
    ```c
    TurWatcher *w = (TurWatcher *)(intptr_t)watcher;
    if (!w || w->pending_n == 0) return 0;
    int64_t ev = w->pending_evs[0];
    if (w->pending_n > 1)
      memmove(w->pending_evs, w->pending_evs + 1,
              sizeof(int64_t) * (size_t)(w->pending_n - 1));
    w->pending_n--;
    return ev;
    ```)

  ;; --------------------------------------------------------------------
  ;; Per-file event production (WTNF2 Linux + WTNF3 Darwin).
  ;; --------------------------------------------------------------------

  ;;; __watcher-tree-mk-event -- build a watch-event for a tree-mode file hit.
  ;;;
  ;;; Computes full_path = dir + "/" + name (or just dir when name is ""),
  ;;; then strips the root + "/" prefix to produce the relative path stored
  ;;; in watch-event-path.
  (defn __watcher-tree-mk-event [root : cstr dir : cstr name : cstr
                                 kind : int is-dir : int cookie : int] #{Unsafe} : int
    ```c
    const char *r = root ? (const char *)(intptr_t)root : "";
    const char *d = dir  ? (const char *)(intptr_t)dir  : "";
    const char *n = name ? (const char *)(intptr_t)name : "";

    char full_path[PATH_MAX];
    if (n[0])
      snprintf(full_path, sizeof(full_path), "%s/%s", d, n);
    else
      snprintf(full_path, sizeof(full_path), "%s", d);

    /* rel_path: strip root + "/" prefix so callers get "a/b/leaf.txt"
       instead of the absolute path. */
    const char *rel_path = full_path;
    size_t rlen = strlen(r);
    if (rlen > 0 && strncmp(full_path, r, rlen) == 0) {
      const char *after = full_path + rlen;
      if (*after == '/') rel_path = after + 1;
    }

    return watch__event__watch_event_make(
      (int64_t)(intptr_t)r,
      (int64_t)(intptr_t)rel_path,
      (int64_t)(intptr_t)full_path,
      (int64_t)kind,
      (int64_t)is_dir,
      (int64_t)cookie);
    ```)

  ;;; __watcher-tree-produce-events -- drain the fired backend and push
  ;;; watch-events onto the watcher's pending queue.
  ;;;
  ;;; Linux: iterates the inotify evbuf and classifies each entry by mask.
  ;;; Darwin: takes a fresh directory snapshot and diffs against the prior one.
  ;;;
  ;;; Both paths call __watcher-tree-mk-event to build events, then push
  ;;; them onto w->pending_evs via inline realloc logic.
  (defn __watcher-tree-produce-events [watcher : int idx : int root : cstr] #{Unsafe} : void
    ```c
    /* __tur_include__: #if defined(__linux__) */
    /* __tur_include__: #include <sys/inotify.h> */
    /* __tur_include__: static int tur_inotify_kind(unsigned int mask) { if (mask & IN_Q_OVERFLOW) return 6; if (mask & (IN_DELETE|IN_DELETE_SELF|IN_MOVED_FROM)) return 3; if (mask & IN_MOVED_TO) return 4; if (mask & IN_CREATE) return 2; if (mask & (IN_MODIFY|IN_CLOSE_WRITE)) return 1; if (mask & IN_ATTRIB) return 5; return 1; } */
    /* __tur_include__: #endif */

    TurWatcher *w = (TurWatcher *)(intptr_t)watcher;
    if (!w || w->mode != 1) return;
    int i = (int)idx;
    if (i < 0 || i >= w->t_n) return;

    const char *croot = root ? (const char *)(intptr_t)root : "";
    const char *cdir  = w->t_dirs[i];
    int64_t bk        = w->t_backends[i];

    /* Helper: push one event onto the pending queue inline. */
    #define TUR_PEND_PUSH(ev_) do { \
      int64_t _ev = (ev_); \
      if (_ev) { \
        if (w->pending_n == w->pending_cap) { \
          int _nc = w->pending_cap ? w->pending_cap * 2 : 4; \
          int64_t *_g = (int64_t *)realloc(w->pending_evs, \
                          sizeof(int64_t) * (size_t)_nc); \
          if (!_g) { watch__event__watch_event_free(_ev); break; } \
          w->pending_evs = _g; w->pending_cap = _nc; \
        } \
        w->pending_evs[w->pending_n++] = _ev; \
      } \
    } while (0)

    #if defined(__linux__)
    {
      int ev_count = (int)watch__backend__backend_event_count(bk);
      for (int j = 0; j < ev_count; j++) {
        const char *ename = (const char *)(intptr_t)
            watch__backend__backend_event_name_at(bk, (int64_t)j);
        unsigned int mask   = (unsigned int)watch__backend__backend_event_mask_at(bk, (int64_t)j);
        unsigned int cookie = (unsigned int)watch__backend__backend_event_cookie_at(bk, (int64_t)j);
        int          is_dir = (int)watch__backend__backend_event_is_dir_at(bk, (int64_t)j);
        if (!ename) ename = "";

        int kind = tur_inotify_kind(mask);
        if (kind == 6) {
          /* overflow: emit one overflow event for the directory itself */
          int64_t ev = watch__watch____watcher_tree_mk_event(
              (int64_t)(intptr_t)croot, (int64_t)(intptr_t)cdir,
              (int64_t)(intptr_t)"", 6, 1, 0);
          TUR_PEND_PUSH(ev);
          break; /* one overflow is enough */
        }
        int64_t ev = watch__watch____watcher_tree_mk_event(
            (int64_t)(intptr_t)croot, (int64_t)(intptr_t)cdir,
            (int64_t)(intptr_t)ename, kind, is_dir, (int64_t)cookie);
        TUR_PEND_PUSH(ev);
      }

      /* ev_count == 0 after debounce drain: activity collapsed within the
         window, nothing to report this tick.  The overflow flag from the
         second drain is checked at the Turmeric level on the next wake. */
    }

    #elif defined(__APPLE__)
    {
      TurDirSnapshot *old_s = (w->t_snaps && i < w->t_n)
          ? (TurDirSnapshot *)w->t_snaps[i] : NULL;
      TurDirSnapshot *new_s = tur_snap_take(cdir);

      if (new_s) {
        /* Scan new entries: match + create */
        for (int ni = 0; ni < new_s->n; ni++) {
          TurSnapEntry *ne = &new_s->entries[ni];
          int found = 0;
          if (old_s) {
            for (int oi = 0; oi < old_s->n; oi++) {
              TurSnapEntry *oe = &old_s->entries[oi];
              if (strcmp(ne->name, oe->name) != 0) continue;
              found = 1;
              int kind = 0;
              if (ne->ino != oe->ino)        kind = 4; /* rename / atomic-save */
              else if (ne->size != oe->size) kind = 1; /* write */
              if (kind) {
                int64_t ev = watch__watch____watcher_tree_mk_event(
                    (int64_t)(intptr_t)croot, (int64_t)(intptr_t)cdir,
                    (int64_t)(intptr_t)ne->name, kind, ne->is_dir, 0);
                TUR_PEND_PUSH(ev);
              }
              break;
            }
          }
          if (!found) {
            /* New entry: create */
            int64_t ev = watch__watch____watcher_tree_mk_event(
                (int64_t)(intptr_t)croot, (int64_t)(intptr_t)cdir,
                (int64_t)(intptr_t)ne->name, 2, ne->is_dir, 0);
            TUR_PEND_PUSH(ev);
          }
        }

        /* Scan old entries for deletions */
        if (old_s) {
          for (int oi = 0; oi < old_s->n; oi++) {
            TurSnapEntry *oe = &old_s->entries[oi];
            int still_there = 0;
            for (int ni = 0; ni < new_s->n; ni++) {
              if (strcmp(oe->name, new_s->entries[ni].name) == 0) {
                still_there = 1; break;
              }
            }
            if (!still_there) {
              int64_t ev = watch__watch____watcher_tree_mk_event(
                  (int64_t)(intptr_t)croot, (int64_t)(intptr_t)cdir,
                  (int64_t)(intptr_t)oe->name, 3, oe->is_dir, 0);
              TUR_PEND_PUSH(ev);
            }
          }
        }

        /* Replace stored snapshot. */
        if (w->t_snaps) {
          tur_snap_free(old_s);
          w->t_snaps[i] = new_s;
        } else {
          tur_snap_free(new_s);
        }
      } else if (old_s) {
        /* Could not snapshot (dir deleted?): emit a delete for the dir. */
        int64_t ev = watch__watch____watcher_tree_mk_event(
            (int64_t)(intptr_t)croot, (int64_t)(intptr_t)cdir,
            (int64_t)(intptr_t)"", 3, 1, 0);
        TUR_PEND_PUSH(ev);
      }
    }
    #endif /* platform */

    #undef TUR_PEND_PUSH
    ```)

  ;; --------------------------------------------------------------------
  ;; Public API
  ;; --------------------------------------------------------------------

  ;;; watch-next -- block until the next event, return its handle or 0.
  ;;;
  ;;; Parameters:
  ;;;   watcher    -- handle from watch-open
  ;;;   timeout-ms -- -1 = forever, 0 = poll, N = bounded wait
  ;;;
  ;;; Returns:
  ;;;   Event handle (free via watch-event-free), or 0 on timeout.
  ;;;
  ;;; Algorithm:
  ;;;   1. backend-wait(timeout-ms)
  ;;;   2. drain backend events; record overflow if any
  ;;;   3. sleep for debounce-ms (lets atomic-save bursts settle)
  ;;;   4. drain again
  ;;;   5. re-stat the target and classify the change
  ;;;   6. emit a watch-event for the classified kind
  (defn watch-next [watcher : int timeout-ms : int] #{Unsafe} : int
    (if (= (__watcher-mode watcher) 1)
      (__watch-next-tree   watcher timeout-ms)
      (__watch-next-single watcher timeout-ms)))

  ;;; __watch-next-single -- the single-file case.
  (defn __watch-next-single [watcher : int timeout-ms : int] #{Unsafe} : int
    (let [back (__watcher-backend watcher)]
      (if (= back 0)
        0
        (let [rc (backend-wait back timeout-ms)]
          (if (<= rc 0)
            0
            (do
              (backend-drain back)
              (if (= (backend-last-overflow? back) 1)
                (watch-event-make (__watcher-dir watcher) (__watcher-full-path watcher)
                                  (__watcher-full-path watcher)
                                  (watch-kind-overflow) 0 0)
                (do
                  (__watcher-sleep-ms (__watcher-debounce-ms watcher))
                  (backend-drain back)
                  (let [kind (__watcher-reclassify watcher)]
                    (if (= kind 0)
                      0
                      (watch-event-make (__watcher-dir watcher)
                                        (__watcher-full-path watcher)
                                        (__watcher-full-path watcher)
                                        kind 0 0)))))))))))

  ;;; __watch-next-tree -- the recursive-tree case.
  ;;;
  ;;; Returns a pending event immediately if one is queued.  Otherwise
  ;;; polls all backend fds.  When a backend fires, drains its evbuf and
  ;;; calls __watcher-tree-produce-events to push per-file events onto the
  ;;; pending queue, then pops and returns the first.
  (defn __watch-next-tree [watcher : int timeout-ms : int] #{Unsafe} : int
    (let [queued (__watcher-pending-pop watcher)]
      (if (not (= queued 0))
        queued
        (let [idx (__watcher-tree-poll-fired watcher timeout-ms)]
          (if (< idx 0)
            0
            (let [back (__watcher-tree-dir-backend watcher idx)
                  root (__watcher-tree-root watcher)]
              (do
                (backend-drain-into back)
                (if (= (backend-last-overflow? back) 1)
                  (watch-event-make root (watch-tree-dir-at watcher idx)
                                    (watch-tree-dir-at watcher idx)
                                    (watch-kind-overflow) 1 0)
                  (do
                    (__watcher-sleep-ms (__watcher-debounce-ms watcher))
                    ;; Second drain after debounce window.
                    (backend-drain-into back)
                    (__watcher-tree-produce-events watcher idx root)
                    (__watcher-pending-pop watcher)))))))))

  ;;; __watch-make-cons -- internal: wrap a single event handle in a cons cell.
  (defn __watch-make-cons [head : int] #{Unsafe} : int
    ```c
    /* __tur_include__: typedef struct __tur_cons_s { int64_t head; int64_t tail; } __tur_cons_cell; */
    if (head == 0) return 0;
    __tur_cons_cell *cell = (__tur_cons_cell *)calloc(1, sizeof(*cell));
    if (!cell) return 0;
    cell->head = head;
    cell->tail = 0;
    return (int64_t)(intptr_t)cell;
    ```)

  ;;; watch-drain -- gather a debounced batch (see watch/debounce).
  ;;;
  ;;; Returns a cons-list of watch-event handles accumulated over the
  ;;; debounce window.  With multi-event batches now arriving from tree
  ;;; mode, coalesce-by-path (debounce-batch-coalesce) meaningfully
  ;;; deduplicates bursts of saves to the same file.
  ;;;
  ;;; Returns a Turmeric cons-list (use list head/tail accessors).
  (defn watch-drain [watcher : int timeout-ms : int debounce-ms : int] #{Unsafe} : int
    ;; debounce-ms is honored implicitly by watch-next's internal sleep;
    ;; multi-element batches arrive with WT6 / WTNF4.
    (let [_ debounce-ms
          ev (watch-next watcher timeout-ms)]
      (__watch-make-cons ev)))))
