;; tests/backend_smoke_test.tur -- WT2/WT3 smoke test for the backend bridge.
;;
;; This exercises end-to-end open + wait(0) + close behavior using the
;; system's /tmp directory.  It does NOT try to provoke a real filesystem
;; event -- that lives in watch_test.tur once WT4 is in place.  The goal
;; here is just "the backend compiles, opens, polls without blocking, and
;; closes cleanly."

(defmodule watch/tests/backend-smoke
  (import watch/backend :refer [backend-supported? backend-open backend-close
                                backend-wait backend-drain
                                backend-last-overflow?
                                backend-dir backend-base])

  (defn tap-record [idx : int name : cstr ok : bool] #{Unsafe} : void
    ```c
    /* __tur_include__: static int g_backend_fails = 0; */
    if (!ok) g_backend_fails++;
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)(intptr_t)name);
    ```)

  (defn tap-finish [count : int] #{Unsafe} : int
    ```c
    printf("1..%lld\n", (long long)count);
    if (g_backend_fails == 0) {
      fprintf(stderr, "# All %lld watch/backend smoke tests passed.\n",
              (long long)count);
      return 0;
    }
    fprintf(stderr, "# %d/%lld watch/backend smoke tests failed.\n",
            g_backend_fails, (long long)count);
    return 1;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] #{Unsafe} : bool
    ```c
    /* __tur_include__: #include <string.h> */
    const char *sa = (const char *)(intptr_t)a;
    const char *sb = (const char *)(intptr_t)b;
    return strcmp(sa ? sa : "", sb ? sb : "") == 0;
    ```)

  (defn main [] #{Unsafe} : int
    (do
      (tap-record 1 "backend-supported? on Linux or Darwin"
                  (= (backend-supported?) 1))

      ;; Open a watcher on /tmp with a known basename, verify accessors.
      (let [h (backend-open "/tmp" "tur-watch-smoke-target")]
        (do
          (tap-record 2 "backend-open /tmp returned non-zero handle"
                      (not (= h 0)))
          (tap-record 3 "backend-dir round-trip"
                      (cstr-eq? (backend-dir  h) "/tmp"))
          (tap-record 4 "backend-base round-trip"
                      (cstr-eq? (backend-base h) "tur-watch-smoke-target"))

          ;; Poll with zero timeout: with nothing happening in /tmp this
          ;; tick we expect either 0 (no events) or 1 (a sibling fired).
          ;; Either is fine -- we only check that the call returns
          ;; without a fatal error.
          (let [rc (backend-wait h 0)]
            (tap-record 5 "backend-wait 0 ms is not fatal"
                        (>= rc 0)))

          ;; Drain whatever happens to be queued.  Must not error.
          (let [drain-rc (backend-drain h)]
            (tap-record 6 "backend-drain is not fatal"
                        (>= drain-rc 0)))

          (tap-record 7 "no spurious overflow after a fresh open"
                      (= (backend-last-overflow? h) 0))

          (backend-close h)
          (tap-record 8 "backend-close returned" true)))

      ;; Close on 0 must be a no-op.
      (do
        (backend-close 0)
        (tap-record 9 "backend-close 0 is safe" true))

      ;; Opening a non-existent directory returns 0.
      (let [bogus (backend-open "/this/does/not/exist/0xdead" "x")]
        (do
          (tap-record 10 "backend-open on bogus dir returns 0"
                      (= bogus 0))
          (backend-close bogus)))

      (tap-finish 10)))

) ;; end defmodule
