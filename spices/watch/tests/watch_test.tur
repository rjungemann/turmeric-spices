;; tests/watch_test.tur -- WT4/WT5 integration tests for watch/watch.
;;
;; Exercises the full open + write + watch-next pipeline against a real
;; tmp file.  Each test spawns a small worker (via fork+exec is overkill
;; here; we just synchronously schedule the write) but because watch-next
;; blocks, we put the write in a tiny C thread.

(defmodule watch/tests/watch
  (import watch/event :refer [watch-kind-none watch-kind-write watch-kind-create
                              watch-kind-delete watch-kind-rename
                              watch-kind-overflow
                              watch-event-kind watch-event-full-path
                              watch-event-free])
  (import watch/opts  :refer [default-watch-opts watch-opts-make watch-opts-free])
  (import watch/watch :refer [watch-supported? watch-open watch-open-one
                              watch-close watch-next])

  (defn tap-record [idx : int name : cstr ok : bool] #{Unsafe} : void
    ```c
    /* __tur_include__: static int g_watch_fails = 0; */
    if (!ok) g_watch_fails++;
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)(intptr_t)name);
    ```)

  (defn tap-finish [count : int] #{Unsafe} : int
    ```c
    printf("1..%lld\n", (long long)count);
    if (g_watch_fails == 0) {
      fprintf(stderr, "# All %lld watch/watch tests passed.\n", (long long)count);
      return 0;
    }
    fprintf(stderr, "# %d/%lld watch/watch tests failed.\n",
            g_watch_fails, (long long)count);
    return 1;
    ```)

  ;; Create or replace a file with given byte content.  Returns 0 on success.
  (defn write-file [path : cstr content : cstr] #{Unsafe} : int
    ```c
    /* __tur_include__: #include <stdio.h> */
    const char *p = (const char *)(intptr_t)path;
    const char *c = (const char *)(intptr_t)content;
    FILE *f = fopen(p, "w");
    if (!f) return -1;
    if (c) fputs(c, f);
    fclose(f);
    return 0;
    ```)

  ;; Delete a file.  Returns 0 on success.
  (defn delete-file [path : cstr] #{Unsafe} : int
    ```c
    /* __tur_include__: #include <unistd.h> */
    const char *p = (const char *)(intptr_t)path;
    return unlink(p);
    ```)

  ;; Schedule a deferred write on a background pthread that fires after
  ;; ms milliseconds.  Caller must keep `path` and `content` alive across
  ;; the wait.  No join API -- the pthread is detached.
  (defn schedule-write [path : cstr content : cstr ms : int] #{Unsafe} : int
    ```c
    /* __tur_include__: #include <pthread.h> */
    /* __tur_include__: typedef struct { char *path; char *content; int ms; int op; } TurWatchDeferred; */
    /* __tur_include__: static void *tur_watch_deferred(void *arg) { TurWatchDeferred *d = (TurWatchDeferred *)arg; usleep((useconds_t)d->ms * 1000u); if (d->op == 0) { FILE *f = fopen(d->path, "w"); if (f) { if (d->content) fputs(d->content, f); fclose(f); } } else if (d->op == 1) { unlink(d->path); } free(d->path); if (d->content) free(d->content); free(d); return NULL; } */
    TurWatchDeferred *d = (TurWatchDeferred *)calloc(1, sizeof(*d));
    d->path    = strdup((const char *)(intptr_t)path);
    d->content = strdup((const char *)(intptr_t)content);
    d->ms      = (int)ms;
    d->op      = 0;
    pthread_t th;
    pthread_create(&th, NULL, tur_watch_deferred, d);
    pthread_detach(th);
    return 0;
    ```)

  (defn schedule-delete [path : cstr ms : int] #{Unsafe} : int
    ```c
    TurWatchDeferred *d = (TurWatchDeferred *)calloc(1, sizeof(*d));
    d->path    = strdup((const char *)(intptr_t)path);
    d->content = NULL;
    d->ms      = (int)ms;
    d->op      = 1;
    pthread_t th;
    pthread_create(&th, NULL, tur_watch_deferred, d);
    pthread_detach(th);
    return 0;
    ```)

  ;; schedule-atomic-save -- write a sibling temp file then rename it over
  ;; the target after `ms` milliseconds.  Mirrors vim / emacs save flow.
  (defn schedule-atomic-save [path : cstr content : cstr ms : int] #{Unsafe} : int
    ```c
    /* __tur_include__: typedef struct { char *path; char *tmp; char *content; int ms; } TurWatchAtomic; */
    /* __tur_include__: static void *tur_watch_atomic(void *arg) { TurWatchAtomic *a = (TurWatchAtomic *)arg; usleep((useconds_t)a->ms * 1000u); FILE *f = fopen(a->tmp, "w"); if (f) { if (a->content) fputs(a->content, f); fclose(f); rename(a->tmp, a->path); } free(a->path); free(a->tmp); if (a->content) free(a->content); free(a); return NULL; } */
    const char *p = (const char *)(intptr_t)path;
    TurWatchAtomic *a = (TurWatchAtomic *)calloc(1, sizeof(*a));
    a->path    = strdup(p);
    size_t tlen = strlen(p) + 8;
    a->tmp = (char *)malloc(tlen);
    snprintf(a->tmp, tlen, "%s.tmpXY", p);
    a->content = strdup((const char *)(intptr_t)content);
    a->ms      = (int)ms;
    pthread_t th;
    pthread_create(&th, NULL, tur_watch_atomic, a);
    pthread_detach(th);
    return 0;
    ```)

  ;; Sleep helper (lets background pthreads finish before the next test).
  (defn sleep-ms [ms : int] #{Unsafe} : void
    ```c
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  ;; Unique-ish tmp path so parallel test runs don't collide.
  (defn tmp-path [suffix : cstr] #{Unsafe} : cstr
    ```c
    /* __tur_include__: #include <unistd.h> */
    static char buf[256];
    const char *s = (const char *)(intptr_t)suffix;
    snprintf(buf, sizeof(buf), "/tmp/tur-watch-test-%d-%s.txt",
             (int)getpid(), s ? s : "x");
    return (const char *)buf;
    ```)

  (defn main [] #{Unsafe} : int
    (do
      (tap-record 1 "watch-supported? is 1"
                  (= (watch-supported?) 1))

      ;; --- Test 1: atomic-save (write temp + rename) ---
      ;;
      ;; This is the canonical editor-save flow the watcher must handle.
      ;; On both Linux (inotify IN_MOVED_TO) and Darwin (kqueue NOTE_WRITE
      ;; on the parent directory) the rename fires a directory-level event;
      ;; stat-compare then sees the inode change and classifies as RENAME.
      ;;
      ;; True in-place writes (fopen "w") fire IN_MODIFY on Linux but do
      ;; NOT fire on Darwin's directory-fd kqueue, so we exercise the
      ;; cross-platform path here.
      (let [p (tmp-path "atomic")]
        (do
          (write-file p "initial")
          (let [w (watch-open-one p (default-watch-opts))]
            (do
              (tap-record 2 "watch-open-one returns non-zero" (not (= w 0)))
              (schedule-atomic-save p "modified" 30)
              (let [ev (watch-next w 5000)]
                (do
                  (tap-record 3 "watch-next returns an event on atomic-save"
                              (not (= ev 0)))
                  (tap-record 4 "kind = rename for atomic-save"
                              (= (watch-event-kind ev) (watch-kind-rename)))
                  (watch-event-free ev)))
              (watch-close w)))
          (delete-file p)))

      ;; --- Test 2: delete event ---
      (let [p (tmp-path "delete")]
        (do
          (write-file p "doomed")
          (let [w (watch-open-one p (default-watch-opts))]
            (do
              (schedule-delete p 30)
              (let [ev (watch-next w 5000)]
                (do
                  (tap-record 5 "watch-next returns an event on delete"
                              (not (= ev 0)))
                  (tap-record 6 "kind = delete"
                              (= (watch-event-kind ev) (watch-kind-delete)))
                  (watch-event-free ev)))
              (watch-close w)))))

      ;; --- Test 3: create event (file missing at open time) ---
      (let [p (tmp-path "create")]
        (do
          ;; Make sure it does NOT exist beforehand.
          (delete-file p)
          (let [w (watch-open-one p (default-watch-opts))]
            (do
              (schedule-write p "appeared" 30)
              (let [ev (watch-next w 5000)]
                (do
                  (tap-record 7 "watch-next returns an event on create"
                              (not (= ev 0)))
                  (tap-record 8 "kind = create"
                              (= (watch-event-kind ev) (watch-kind-create)))
                  (watch-event-free ev)))
              (watch-close w)))
          (delete-file p)))

      ;; --- Test 4: timeout when nothing happens ---
      (let [p (tmp-path "timeout")]
        (do
          (write-file p "quiet")
          (let [w (watch-open-one p (default-watch-opts))]
            (do
              (let [ev (watch-next w 200)]
                (tap-record 9 "watch-next 200ms timeout returns 0"
                            (= ev 0)))
              (watch-close w)))
          (delete-file p)))

      ;; --- Test 5: watch-open == watch-open-one for single-path v0.1.0 ---
      (let [p (tmp-path "alias")]
        (do
          (write-file p "x")
          (let [w (watch-open p (default-watch-opts))]
            (do
              (tap-record 10 "watch-open returns non-zero on existing file"
                          (not (= w 0)))
              (watch-close w)))
          (delete-file p)))

      ;; Give background pthreads a moment before tearing down.
      (sleep-ms 50)
      (tap-finish 10)))

) ;; end defmodule
