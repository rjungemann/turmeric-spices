;; tests/event_test.tur -- WT1 unit tests for watch/event kinds + accessors.

(defmodule watch/tests/event
  (import watch/event :refer [watch-kind-none watch-kind-write watch-kind-create
                              watch-kind-delete watch-kind-rename
                              watch-kind-attrib watch-kind-overflow
                              watch-event-make watch-event-free
                              watch-event-root watch-event-path
                              watch-event-full-path watch-event-kind
                              watch-event-is-dir watch-event-cookie
                              watch-kind->cstr])

  (defn tap-record [idx : int name : cstr ok : bool] #{Unsafe} : void
    ```c
    /* __tur_include__: #include <stdio.h> */
    /* __tur_include__: #include <string.h> */
    /* __tur_include__: static int g_event_fails = 0; */
    if (!ok) g_event_fails++;
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)(intptr_t)name);
    ```)

  (defn tap-finish [count : int] #{Unsafe} : int
    ```c
    printf("1..%lld\n", (long long)count);
    if (g_event_fails == 0) {
      fprintf(stderr, "# All %lld watch/event tests passed.\n", (long long)count);
      return 0;
    }
    fprintf(stderr, "# %d/%lld watch/event tests failed.\n",
            g_event_fails, (long long)count);
    return 1;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] #{Unsafe} : bool
    ```c
    const char *sa = (const char *)(intptr_t)a;
    const char *sb = (const char *)(intptr_t)b;
    return strcmp(sa ? sa : "", sb ? sb : "") == 0;
    ```)

  (defn main [] #{Unsafe} : int
    (do
      ;; Kind constants are stable, contiguous, and distinct.
      (tap-record 1 "watch-kind-none = 0"     (= (watch-kind-none)     0))
      (tap-record 2 "watch-kind-write = 1"    (= (watch-kind-write)    1))
      (tap-record 3 "watch-kind-create = 2"   (= (watch-kind-create)   2))
      (tap-record 4 "watch-kind-delete = 3"   (= (watch-kind-delete)   3))
      (tap-record 5 "watch-kind-rename = 4"   (= (watch-kind-rename)   4))
      (tap-record 6 "watch-kind-attrib = 5"   (= (watch-kind-attrib)   5))
      (tap-record 7 "watch-kind-overflow = 6" (= (watch-kind-overflow) 6))

      ;; watch-kind->cstr labels round-trip.
      (tap-record  8 "kind->cstr none"     (cstr-eq? (watch-kind->cstr (watch-kind-none))     "none"))
      (tap-record  9 "kind->cstr write"    (cstr-eq? (watch-kind->cstr (watch-kind-write))    "write"))
      (tap-record 10 "kind->cstr create"   (cstr-eq? (watch-kind->cstr (watch-kind-create))   "create"))
      (tap-record 11 "kind->cstr delete"   (cstr-eq? (watch-kind->cstr (watch-kind-delete))   "delete"))
      (tap-record 12 "kind->cstr rename"   (cstr-eq? (watch-kind->cstr (watch-kind-rename))   "rename"))
      (tap-record 13 "kind->cstr attrib"   (cstr-eq? (watch-kind->cstr (watch-kind-attrib))   "attrib"))
      (tap-record 14 "kind->cstr overflow" (cstr-eq? (watch-kind->cstr (watch-kind-overflow)) "overflow"))
      (tap-record 15 "kind->cstr unknown"  (cstr-eq? (watch-kind->cstr 999) "unknown"))

      ;; Construction + accessors round-trip every field.
      (let [e (watch-event-make "src/" "notes.tur.md" "/tmp/src/notes.tur.md"
                                (watch-kind-write) 0 42)]
        (do
          (tap-record 16 "event root"      (cstr-eq? (watch-event-root      e) "src/"))
          (tap-record 17 "event path"      (cstr-eq? (watch-event-path      e) "notes.tur.md"))
          (tap-record 18 "event full-path" (cstr-eq? (watch-event-full-path e) "/tmp/src/notes.tur.md"))
          (tap-record 19 "event kind"      (= (watch-event-kind   e) (watch-kind-write)))
          (tap-record 20 "event is-dir"    (= (watch-event-is-dir e) 0))
          (tap-record 21 "event cookie"    (= (watch-event-cookie e) 42))
          (watch-event-free e)))

      ;; Zero handle is safe to query and free.
      (tap-record 22 "kind on 0 handle is 0"      (= (watch-event-kind   0) 0))
      (tap-record 23 "is-dir on 0 handle is 0"    (= (watch-event-is-dir 0) 0))
      (tap-record 24 "cookie on 0 handle is 0"    (= (watch-event-cookie 0) 0))
      (tap-record 25 "root on 0 handle is empty"  (cstr-eq? (watch-event-root 0) ""))
      (do
        (watch-event-free 0)
        (tap-record 26 "free 0 handle does not crash" true))

      (tap-finish 26)))

) ;; end defmodule
