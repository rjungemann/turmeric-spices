;; tests/opts_test.tur -- WT1 unit tests for watch/opts defaults + accessors.

(defmodule watch/tests/opts
  (import watch/opts :refer [watch-opts-make watch-opts-free default-watch-opts
                             watch-opts-recursive watch-opts-debounce-ms
                             watch-opts-coalesce watch-opts-attrib
                             watch-opts-follow-moves
                             watch-opts-set-recursive watch-opts-set-debounce-ms
                             watch-opts-set-coalesce watch-opts-set-attrib
                             watch-opts-set-follow-moves
                             watch-default-debounce-ms])

  (defn tap-record [idx : int name : cstr ok : bool] #{Unsafe} : void
    ```c
    /* __tur_include__: static int g_opts_fails = 0; */
    if (!ok) g_opts_fails++;
    printf("%s %lld - %s\n", ok ? "ok" : "not ok",
           (long long)idx, (const char *)(intptr_t)name);
    ```)

  (defn tap-finish [count : int] #{Unsafe} : int
    ```c
    printf("1..%lld\n", (long long)count);
    if (g_opts_fails == 0) {
      fprintf(stderr, "# All %lld watch/opts tests passed.\n", (long long)count);
      return 0;
    }
    fprintf(stderr, "# %d/%lld watch/opts tests failed.\n",
            g_opts_fails, (long long)count);
    return 1;
    ```)

  (defn main [] #{Unsafe} : int
    (do
      ;; default-watch-opts must match notebook-v0.1.0 contract.
      (let [d (default-watch-opts)]
        (do
          (tap-record 1 "default debounce-ms = 150"
                      (= (watch-opts-debounce-ms  d) 150))
          (tap-record 2 "default recursive = 0"
                      (= (watch-opts-recursive    d) 0))
          (tap-record 3 "default coalesce = 1"
                      (= (watch-opts-coalesce     d) 1))
          (tap-record 4 "default attrib = 0"
                      (= (watch-opts-attrib       d) 0))
          (tap-record 5 "default follow-moves = 1"
                      (= (watch-opts-follow-moves d) 1))
          (watch-opts-free d)))

      ;; watch-default-debounce-ms is the canonical constant.
      (tap-record 6 "watch-default-debounce-ms = 150"
                  (= (watch-default-debounce-ms) 150))

      ;; Explicit make round-trips every field.
      (let [o (watch-opts-make 1 250 0 1 0)]
        (do
          (tap-record  7 "make recursive"    (= (watch-opts-recursive    o) 1))
          (tap-record  8 "make debounce-ms"  (= (watch-opts-debounce-ms  o) 250))
          (tap-record  9 "make coalesce"     (= (watch-opts-coalesce     o) 0))
          (tap-record 10 "make attrib"       (= (watch-opts-attrib       o) 1))
          (tap-record 11 "make follow-moves" (= (watch-opts-follow-moves o) 0))
          (watch-opts-free o)))

      ;; Setters mutate in place and return the same handle.
      (let [o2 (watch-opts-make 0 100 0 0 0)]
        (do
          (watch-opts-set-recursive    o2 1)
          (watch-opts-set-debounce-ms  o2 500)
          (watch-opts-set-coalesce     o2 1)
          (watch-opts-set-attrib       o2 1)
          (watch-opts-set-follow-moves o2 1)
          (tap-record 12 "set recursive"    (= (watch-opts-recursive    o2) 1))
          (tap-record 13 "set debounce-ms"  (= (watch-opts-debounce-ms  o2) 500))
          (tap-record 14 "set coalesce"     (= (watch-opts-coalesce     o2) 1))
          (tap-record 15 "set attrib"       (= (watch-opts-attrib       o2) 1))
          (tap-record 16 "set follow-moves" (= (watch-opts-follow-moves o2) 1))
          (watch-opts-free o2)))

      ;; Zero handle is safe.
      (tap-record 17 "recursive on 0 = 0"   (= (watch-opts-recursive    0) 0))
      (tap-record 18 "debounce-ms on 0 = 0" (= (watch-opts-debounce-ms  0) 0))
      (do
        (watch-opts-free 0)
        (tap-record 19 "free 0 handle does not crash" true))

      (tap-finish 19)))

) ;; end defmodule
