;; tests/fixtures/rest-plus-ws/main.tur -- TOUR-V0.3 coexistence demo.
;;
;; A single tourist app serving an ordinary REST route (`/api`) and a WebSocket
;; route (`/ws`) side by side, proving ws-route! composes with get! in the same
;; item list. Served with `tourist-conn` (not `tourist`) so ws-route! can reach
;; the underlying Conn for the upgrade.
;;
;; This is a fixture, not a flat test: standing it up needs a live listener
;; (and, for the WebSocket path, mbedTLS linked via ws-server). Its job is to
;; type-check the coexistence wiring -- verify with `tur check main.tur`.

(defmodule tourist-ws/fixtures/rest-plus-ws
  (import tourist/app    :refer [tourist-conn])
  (import tourist/dsl    :refer [get!])
  (import tourist/helpers :refer [text])
  (import tourist/types  :refer [Ctx])
  (import httpd/types    :refer [Response])
  (import httpd/server   :refer [server-stop])
  (import tourist-ws/route :refer [ws-route!])
  (import ws-server/server :refer [ws-server-recv ws-server-send ws-server-close])
  (import ws-core/conn   :refer [WsConn])
  (import ws-core/frame  :refer [WsFrame ws-frame-text ws-closed? ws-error?])

  ;; A plain REST handler.
  (defn api-handler [ctx : Ctx] : Response
    (text "hello from REST"))

  ;; A WebSocket echo handler: echo text frames until the peer closes.
  (defn ws-echo [ws : WsConn] : void
    (let [f (ws-server-recv ws)]
      (if (or (ws-closed? f) (ws-error? f))
        (ws-server-close ws)
        (do (ws-server-send ws (ws-frame-text f))
            (ws-echo ws)))))

  (defn main [] : int
    ;; REST and WebSocket routes coexist in one item list, served on the
    ;; Conn-aware entry point.
    (let [srv (tourist-conn 8080
                (get! "/api" api-handler)
                (ws-route! "/ws" ws-echo))]
      ;; (a real app blocks here until shutdown)
      (server-stop srv)
      0)))
