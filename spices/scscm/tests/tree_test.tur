;; tests/tree_test.tur -- scscm/tree (U5 Fix SxF S-expression AST + cata).
;;
;; Pure-Turmeric: no lexer/parser, no scsynth, runs anywhere. Builds an
;; S-expression with the smart constructors and exercises the generic
;; catamorphism (size / depth / dotted serialize) plus the structural
;; proper-list pretty printer.

(defmodule scscm/tests/tree
  (import scscm/tree  :refer [Sx sx-nil sx-bool sx-num sx-str sx-sym sx-cons
                              sx-list1 sx-list2 sx-list3
                              sx-size sx-depth sx->sexp sx->pretty])
  (import test/assert :refer [assert-eq assert-true])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c return strcmp((const char *)a, (const char *)b) == 0; ```)

  ;; (+ 1 2)  -- the running example: a 3-element proper list.
  (defn ex [] : Sx
    (sx-list3 (sx-sym "+") (sx-num 1.0) (sx-num 2.0)))

  ;; (a . b)  -- a dotted (improper) pair.
  (defn dotted [] : Sx
    (sx-cons (sx-sym "a") (sx-sym "b")))

  (defn main [] : int
    (do
      (describe "sx-size (cata)"
        ;; (+ 1 2) = Cons(+, Cons(1, Cons(2, Nil)))
        ;; leaves: + 1 2 nil = 4 ; conses = 3 ; total = 7
        (it "counts every node" (assert-eq 7 (sx-size (ex))))
        (it "an atom is one node" (assert-eq 1 (sx-size (sx-sym "x"))))
        (it "nil is one node"     (assert-eq 1 (sx-size (sx-nil)))))

      (describe "sx-depth (cata)"
        ;; Cons(+, Cons(1, Cons(2, Nil))): nested 4 deep
        (it "measures cons nesting" (assert-eq 4 (sx-depth (ex))))
        (it "an atom has depth 1"   (assert-eq 1 (sx-depth (sx-bool true)))))

      (describe "sx->sexp (cata, dotted canonical form)"
        (it "emits fully-explicit dotted pairs"
          (assert-true (cstr-eq? "(+ . (1 . (2 . ())))" (sx->sexp (ex)))))
        (it "prints booleans" (assert-true (cstr-eq? "#t" (sx->sexp (sx-bool true)))))
        (it "prints strings"  (assert-true (cstr-eq? "\"hi\"" (sx->sexp (sx-str "hi"))))))

      (describe "sx->pretty (structural, idiomatic list form)"
        (it "prints a proper list without dots"
          (assert-true (cstr-eq? "(+ 1 2)" (sx->pretty (ex)))))
        (it "prints a dotted pair with a dot"
          (assert-true (cstr-eq? "(a . b)" (sx->pretty (dotted)))))
        (it "prints the empty list"
          (assert-true (cstr-eq? "()" (sx->pretty (sx-nil)))))
        (it "prints a singleton list"
          (assert-true (cstr-eq? "(x)" (sx->pretty (sx-list1 (sx-sym "x"))))))
        (it "prints a nested list"
          (assert-true (cstr-eq? "(let (x) y)"
                                 (sx->pretty (sx-list3 (sx-sym "let")
                                                       (sx-list1 (sx-sym "x"))
                                                       (sx-sym "y")))))))

      (run-all)
      0)))
