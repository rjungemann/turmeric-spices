;; =============================================================================
;; Synthesizer Presets
;; =============================================================================

;;; lead-synth -- bright cutting lead synth preset.
;;;
;;; Parameters:
;;;   freq     -- frequency in Hz
;;;   gate-sig -- Signal<bool>
;;;
;;; Returns:
;;;   Signal<Sample>.
(defn lead-synth [freq :float gate-sig]
  (let [params (make-struct ADSRParams 0.01 0.1 0.7 0.2)
        filter-cutoff 0.8
        filter-q 0.5]
    (voice freq params gate-sig filter-cutoff filter-q)))

;;; bass-synth -- deep warm bass synth preset.
;;;
;;; Parameters:
;;;   freq     -- frequency in Hz
;;;   gate-sig -- Signal<bool>
;;;
;;; Returns:
;;;   Signal<Sample>.
(defn bass-synth [freq :float gate-sig]
  (let [params (make-struct ADSRParams 0.02 0.3 0.5 0.4)
        filter-cutoff 0.3
        filter-q 0.3]
    (voice freq params gate-sig filter-cutoff filter-q)))

;;; pad-synth -- soft evolving pad synth preset.
;;;
;;; Parameters:
;;;   freq     -- frequency in Hz
;;;   gate-sig -- Signal<bool>
;;;
;;; Returns:
;;;   Signal<Sample>.
(defn pad-synth [freq :float gate-sig]
  (let [params (make-struct ADSRParams 0.5 0.5 0.6 1.0)
        filter-cutoff 0.4
        filter-q 0.2]
    (voice freq params gate-sig filter-cutoff filter-q)))

;;; pluck-synth -- Karplus-Strong plucked string preset.
;;;
;;; Parameters:
;;;   freq     -- frequency in Hz
;;;   gate-sig -- Signal<bool>
;;;
;;; Returns:
;;;   Signal<Sample>.
(defn pluck-synth [freq :float gate-sig]
  (let [params (make-struct ADSRParams 0.005 0.1 0.0 0.3)
        decay 0.995
        noise-duration 0.01]
    (ks-voice freq decay noise-duration params gate-sig)))

