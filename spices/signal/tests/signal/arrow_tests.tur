;; Signal Processing Tests -- Phase 0c (native :float sample ABI)
;;
;; The pre-Phase-0c test suite was built around int64-bit-pattern-of-float
;; helpers (`__f_int`, `__f_near`, `__f_add1`, etc.). All of that is gone:
;; signals are `(fn [t :float] :float)` directly. This file exercises the
;; new ABI at a smoke-test level.

(defmodule tests/arrow
  (import signal/core)
  (import signal/dsp)
  (import signal/envelope))

;; =============================================================================
;; Float comparison helper (operates on native :float)
;; =============================================================================

(defn near? [a :float b :float thresh :float] :bool
  ```c
  double diff = a - b;
  if (diff < 0.0) diff = -diff;
  return diff < thresh;
  ```)

;; =============================================================================
;; Signal-core smoke tests
;; =============================================================================

;;; test-constant-signal -- (constant 42.0) yields 42.0 at any time.
(defn test-constant-signal [] :bool
  (let [sig (constant 42.0)]
    (and (near? (sig 0.0)   42.0 0.001)
         (near? (sig 100.0) 42.0 0.001)
         (near? (sig 999.0) 42.0 0.001))))

;;; test-time-signal -- time-signal is identity on its float argument.
(defn test-time-signal [] :bool
  (and (near? (time-signal 0.0)   0.0   0.001)
       (near? (time-signal 100.0) 100.0 0.001)))

;; =============================================================================
;; DSP primitive tests (single-sample where stateless, multi-sample for filters)
;; =============================================================================

;;; test-sine-at-zero -- sin(2*pi*440*0 + 0) = 0.
(defn test-sine-at-zero [] :bool
  (let [sine-sf (sine 440.0 0.0)
        out    (sine-sf (constant 0.0))]
    (near? (out 0.0) 0.0 0.001)))

;;; test-sawtooth-range -- sawtooth(440, t=0) is in [0, 1).
(defn test-sawtooth-range [] :bool
  (let [saw-sf (sawtooth 440.0)
        out    (saw-sf (constant 0.0))
        v      (out 0.0)]
    (and (>= v 0.0)
         (<  v 1.0))))

;;; test-low-pass-impulse -- low-pass settles toward x over multiple steps.
;;; Drives a constant 1.0 input through a fresh low-pass and checks that
;;; the running EMA approaches 1.0.
(defn test-low-pass-impulse [] :bool
  (let [lp-sf (low-pass 0.5)
        out   (lp-sf (constant 1.0))
        s0    (out 0.0)
        s1    (out 0.0)
        s2    (out 0.0)
        s3    (out 0.0)]
    (and (near? s0 0.5  0.001)
         (near? s1 0.75 0.001)
         (near? s2 0.875 0.001)
         (near? s3 0.9375 0.001))))

;;; test-high-pass-impulse -- high-pass starts at x and decays toward 0
;;; on a constant input.
(defn test-high-pass-impulse [] :bool
  (let [hp-sf (high-pass 0.5)
        out   (hp-sf (constant 1.0))
        s0    (out 0.0)
        s1    (out 0.0)
        s2    (out 0.0)]
    (and (near? s0 0.5    0.001)
         (near? s1 0.25   0.001)
         (near? s2 0.125  0.001))))

;;; test-gain -- gain(2.0) applied to 0.5 yields 1.0.
(defn test-gain [] :bool
  (let [gain-sf (gain 2.0)
        out     (gain-sf (constant 0.5))]
    (near? (out 0.0) 1.0 0.001)))

;; =============================================================================
;; Envelope tests
;; =============================================================================

;;; test-adsr-at-zero -- ADSR is 0 at t=0 (with attack>0).
(defn test-adsr-at-zero [] :bool
  (let [params (make-struct ADSRParams 0.1 0.1 0.5 0.1)
        env-sf (adsr-fixed params 1.0)
        out    (env-sf (constant 0.0))]
    (near? (out 0.0) 0.0 0.001)))

;;; test-adsr-sustain -- ADSR holds sustain level mid-gate.
(defn test-adsr-sustain [] :bool
  (let [params (make-struct ADSRParams 0.1 0.1 0.5 0.1)
        env-sf (adsr-fixed params 1.0)
        out    (env-sf (constant 0.0))]
    (near? (out 0.5) 0.5 0.05)))

;;; test-adsr-after-release -- ADSR returns to 0 after gate + release.
(defn test-adsr-after-release [] :bool
  (let [params (make-struct ADSRParams 0.1 0.1 0.5 0.1)
        env-sf (adsr-fixed params 1.0)
        out    (env-sf (constant 0.0))
        v      (out 1.5)]
    (and (>= v -0.01) (<= v 0.01))))

;; =============================================================================
;; Test runner
;; =============================================================================

(defn report [name :cstr passed :bool] :int
  ```c
  printf("%s %s\n", passed ? "PASS" : "FAIL", name);
  return passed ? 0 : 1;
  ```)

(defn main [] :int
  (let [^mut failures 0]
    (set! failures (+ failures (report "constant-signal"    (test-constant-signal))))
    (set! failures (+ failures (report "time-signal"        (test-time-signal))))
    (set! failures (+ failures (report "sine-at-zero"       (test-sine-at-zero))))
    (set! failures (+ failures (report "sawtooth-range"     (test-sawtooth-range))))
    (set! failures (+ failures (report "low-pass-impulse"   (test-low-pass-impulse))))
    (set! failures (+ failures (report "high-pass-impulse"  (test-high-pass-impulse))))
    (set! failures (+ failures (report "gain"               (test-gain))))
    (set! failures (+ failures (report "adsr-at-zero"       (test-adsr-at-zero))))
    (set! failures (+ failures (report "adsr-sustain"       (test-adsr-sustain))))
    (set! failures (+ failures (report "adsr-after-release" (test-adsr-after-release))))
    failures))
