;; test_envelope -- correctness tests for signal/envelope.
;;
;; adsr-fixed computes a piecewise-linear ADSR analytically, so it can be
;; sampled at arbitrary times. Params: attack 0.1, decay 0.1, sustain 0.5,
;; release 0.2; gate held 0.5s. adsr-gen is the same with a 1.0s gate.
;;
;; main returns the failure count for `tur test`.

(defmodule signal/tests/test_envelope
  (import signal/core     :refer [constant sample])
  (import signal/envelope :refer [ADSRParams adsr-fixed adsr-gen])

(defn near? [a :float b :float] :bool
  (let [d (- a b)]
    (if (< d 0.0) (< (- 0.0 d) 0.0001) (< d 0.0001))))

(defn fail-unless [cond :bool label :cstr] :int
  (if cond 0 (do (println label) 1)))

(defn main [] : int
  (let [params (make-struct ADSRParams 0.1 0.1 0.5 0.2)
        env    ((adsr-fixed params 0.5) (constant 0.0))
        gen    ((adsr-gen (make-struct ADSRParams 0.1 0.1 0.5 0.2)) (constant 0.0))
        f (+ (fail-unless (near? (sample env 0.0) 0.0)  "FAIL: adsr attack start")
             (fail-unless (near? (sample env 0.05) 0.5) "FAIL: adsr attack mid")
             (fail-unless (near? (sample env 0.1) 1.0)  "FAIL: adsr attack peak")
             (fail-unless (near? (sample env 0.15) 0.75) "FAIL: adsr decay mid")
             (fail-unless (near? (sample env 0.2) 0.5)  "FAIL: adsr decay end")
             (fail-unless (near? (sample env 0.3) 0.5)  "FAIL: adsr sustain")
             (fail-unless (near? (sample env 0.6) 0.25) "FAIL: adsr release mid")
             (fail-unless (near? (sample env 0.7) 0.0)  "FAIL: adsr release end")
             (fail-unless (near? (sample env 1.0) 0.0)  "FAIL: adsr silence")
             ;; adsr-gen holds a 1.0s gate, so it still sustains at t = 0.9.
             (fail-unless (near? (sample gen 0.05) 0.5) "FAIL: adsr-gen attack mid")
             (fail-unless (near? (sample gen 0.9) 0.5)  "FAIL: adsr-gen sustain @ 0.9"))]
    (if (= f 0)
      (println "PASS test_envelope")
      (println "test_envelope: failures above"))
    f))

) ;; end defmodule signal/tests/test_envelope
