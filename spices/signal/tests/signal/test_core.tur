;; test_core -- smoke tests for signal/core.
;;
;; Limited surface: exercises the symbols whose end-to-end caller path
;; is currently codegen-clean. SF-application surface (oscillators,
;; filters, shapers, envelopes, effects-chain) is blocked downstream
;; by the carrier-bridge gap tracked in
;;   docs/reported/vec-typed-fat-closure-readback-fixture-regressed-codegen.md
;; in the turmeric repo. Add coverage there as that report resolves.

(defmodule signal/tests/test_core
  (import signal/core :refer [constant time-signal sample])

(defn fail-if [cond :bool label :cstr] :int
  (if cond
    (do (println label) 1)
    0))

(defn main [] : int
  (let [c   (constant 0.5)
        v0  (sample c 0.0)
        v1  (sample c 9999.0)
        t0  (time-signal 0.0)
        t1  (time-signal 0.25)
        t2  (time-signal 2.0)
        f   (+ (fail-if (not= v0 0.5) "FAIL: constant @ 0.0")
               (fail-if (not= v1 0.5) "FAIL: constant @ 9999.0")
               (fail-if (not= t0 0.0) "FAIL: time-signal @ 0.0")
               (fail-if (not= t1 0.25) "FAIL: time-signal @ 0.25")
               (fail-if (not= t2 2.0) "FAIL: time-signal @ 2.0"))]
    (if (= f 0)
      (println "PASS test_core")
      (println "test_core: failures above")))
  0)

) ;; end defmodule signal/tests/test_core
