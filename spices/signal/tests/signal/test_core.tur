;; test_core -- correctness tests for signal/core.
;;
;; Exercises constant and time-signal via `sample`. The SF-application
;; surface (oscillators, filters, shapers, envelopes, effects-chain) is now
;; covered by the sibling test_* modules. main returns the failure count so
;; `tur test` reports a non-zero exit as a failing test.

(defmodule signal/tests/test_core
  (import signal/core :refer [constant time-signal sample])

(defn fail-if [cond :bool label :cstr] :int
  (if cond
    (do (println label) 1)
    0))

(defn main [] : int
  (let [c   (constant 0.5)
        v0  (sample c 0.0)
        v1  (sample c 9999.0)
        t0  (time-signal 0.0)
        t1  (time-signal 0.25)
        t2  (time-signal 2.0)
        f   (+ (fail-if (not= v0 0.5) "FAIL: constant @ 0.0")
               (fail-if (not= v1 0.5) "FAIL: constant @ 9999.0")
               (fail-if (not= t0 0.0) "FAIL: time-signal @ 0.0")
               (fail-if (not= t1 0.25) "FAIL: time-signal @ 0.25")
               (fail-if (not= t2 2.0) "FAIL: time-signal @ 2.0"))]
    (if (= f 0)
      (println "PASS test_core")
      (println "test_core: failures above"))
    f))

) ;; end defmodule signal/tests/test_core
