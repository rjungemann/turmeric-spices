;; test_compose -- correctness tests for signal/compose.
;;
;; effects-chain applies a Vec of SF (Sample Sample) processors left-to-right
;; to an input signal. It returns a ptr<void> carrier; callers re-bind the
;; result as a ^fat signal before sampling. Covers the empty, single, two-,
;; and three-stage chains, including a captureless final stage (invert).
;;
;; main returns the failure count for `tur test`.

(defmodule signal/tests/test_compose
  (import signal/core    :refer [constant sample])
  (import signal/shaper  :refer [gain offset invert])
  (import signal/compose :refer [effects-chain])

(defn near? [a :float b :float] :bool
  (let [d (- a b)]
    (if (< d 0.0) (< (- 0.0 d) 0.0001) (< d 0.0001))))

(defn fail-unless [cond :bool label :cstr] :int
  (if cond 0 (do (println label) 1)))

(defn main [] : int
  (let [;; empty chain -> identity.
        ^fat c0 : (fn [float] float)
             (effects-chain (vec-of) (constant 0.5))
        ;; single stage.
        ^fat c1 : (fn [float] float)
             (effects-chain (vec-of (gain 3.0)) (constant 0.5))
        ;; two capturing stages: gain then offset.
        ^fat c2 : (fn [float] float)
             (effects-chain (vec-of (gain 2.0) (offset 0.1)) (constant 0.5))
        ;; three stages ending in a captureless invert.
        ^fat c3 : (fn [float] float)
             (effects-chain (vec-of (gain 2.0) (offset 0.1) (invert)) (constant 0.5))
        f (+ (fail-unless (near? (sample c0 0.0) 0.5)  "FAIL: empty chain identity")
             (fail-unless (near? (sample c1 0.0) 1.5)  "FAIL: single-stage chain")
             (fail-unless (near? (sample c2 0.0) 1.1)  "FAIL: two-stage chain")
             (fail-unless (near? (sample c3 0.0) -1.1) "FAIL: three-stage chain"))]
    (if (= f 0)
      (println "PASS test_compose")
      (println "test_compose: failures above"))
    f))

) ;; end defmodule signal/tests/test_compose
