;; test_shaper -- correctness tests for signal/shaper.
;;
;; Scalar shapers are pure: output depends only on the current input sample.
;; Capturing shapers (gain, offset, saturate-tanh, hard-clip, clip, mix) are
;; applied directly; captureless shapers (invert, abs-sf, add, multiply) are
;; bound to a name first, then applied. `scale` is a pure :float -> :float
;; remap. The Pair-consuming mixers pull from a `pair-signals` product.
;;
;; main returns the failure count for `tur test`.

(defmodule signal/tests/test_shaper
  (import signal/core   :refer [constant sample pair-signals])
  (import signal/shaper :refer [gain offset invert abs-sf scale
                                saturate-tanh hard-clip clip
                                mix add multiply])

(defn near? [a :float b :float] :bool
  (let [d (- a b)]
    (if (< d 0.0) (< (- 0.0 d) 0.0001) (< d 0.0001))))

(defn fail-unless [cond :bool label :cstr] :int
  (if cond 0 (do (println label) 1)))

(defn main [] : int
  (let [;; captureless shapers: bind first, then apply.
        iv (invert)
        ab (abs-sf)
        ad (add)
        ml (multiply)
        ;; product signal for the mixers.
        p  (pair-signals (constant 0.8) (constant 0.2))
        f (+ ;; gain / offset
             (fail-unless (near? (sample ((gain 2.0) (constant 0.5)) 0.0) 1.0)
                          "FAIL: gain")
             (fail-unless (near? (sample ((offset 0.25) (constant 0.5)) 0.0) 0.75)
                          "FAIL: offset")
             ;; invert / abs-sf
             (fail-unless (near? (sample (iv (constant 0.5)) 0.0) -0.5)
                          "FAIL: invert")
             (fail-unless (near? (sample (ab (constant -0.7)) 0.0) 0.7)
                          "FAIL: abs-sf")
             ;; saturate-tanh: tanh(drive*x)/tanh(drive) == 1 at x == 1.
             (fail-unless (near? (sample ((saturate-tanh 2.0) (constant 1.0)) 0.0) 1.0)
                          "FAIL: saturate-tanh @ 1.0")
             ;; hard-clip symmetric to [-limit, limit]
             (fail-unless (near? (sample ((hard-clip 0.4) (constant 0.9)) 0.0) 0.4)
                          "FAIL: hard-clip high")
             (fail-unless (near? (sample ((hard-clip 0.4) (constant -0.9)) 0.0) -0.4)
                          "FAIL: hard-clip low")
             (fail-unless (near? (sample ((hard-clip 0.4) (constant 0.1)) 0.0) 0.1)
                          "FAIL: hard-clip passthrough")
             ;; clip asymmetric to [lo, hi]
             (fail-unless (near? (sample ((clip -0.2 0.3) (constant 0.9)) 0.0) 0.3)
                          "FAIL: clip high")
             (fail-unless (near? (sample ((clip -0.2 0.3) (constant -0.9)) 0.0) -0.2)
                          "FAIL: clip low")
             ;; scale: pure linear remap.
             (fail-unless (near? (scale 0.0 1.0 -1.0 1.0 0.75) 0.5)
                          "FAIL: scale")
             (fail-unless (near? (scale 0.0 1.0 -1.0 1.0 0.0) -1.0)
                          "FAIL: scale lo")
             ;; mixers over a (0.8, 0.2) pair.
             (fail-unless (near? (sample ((mix 0.25) p) 0.0) 0.35)
                          "FAIL: mix")        ;; 0.25*0.8 + 0.75*0.2
             (fail-unless (near? (sample (ad p) 0.0) 1.0)
                          "FAIL: add")        ;; 0.8 + 0.2
             (fail-unless (near? (sample (ml p) 0.0) 0.16)
                          "FAIL: multiply"))] ;; 0.8 * 0.2
    (if (= f 0)
      (println "PASS test_shaper")
      (println "test_shaper: failures above"))
    f))

) ;; end defmodule signal/tests/test_shaper
