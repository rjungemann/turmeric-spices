;; tests/raylib/image_test.tur -- raylib/image (U4 sized Image).
;;
;; Pure-Turmeric: raylib/image is inline-C only (no raylib native lib / GPU /
;; display), so this runs anywhere. Positive coverage of the sized CPU pixel
;; buffer; the negative case -- overlaying differently-sized images -- is a
;; compile error (TUR-E0260) and so lives in tests/errors/, not here.

(load "stdlib/sized.tur")

(defmodule raylib/tests/image
  (import raylib/image :refer [Image rgba rgba-r rgba-g rgba-b rgba-a
                               image-blank image-filled image-free
                               image-width image-height image-get image-set!
                               image-overlay image-scale-rgb])
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq assert-true])
  (import test/runner :refer [run-all])

  ;; opaque red / transparent pixels
  (defn red   [] : int (rgba 255 0 0 255))
  (defn green [] : int (rgba 0 255 0 255))
  (defn clear [] : int (rgba 0 0 0 0))

  ;; a 2x2 image painted: (0,0)=red elsewhere transparent
  (defn img2 [] : (Image (Static 2) (Static 2))
    (let [i (image-blank 2 2)]
      (image-set! i 0 0 (red))
      i))

  (defn main [] : int
    (do
      (describe "rgba pack/unpack"
        (it "round-trips channels"
          (assert-true (let [p (rgba 12 34 56 78)]
                         (and (= 12 (rgba-r p))
                              (and (= 34 (rgba-g p))
                                   (and (= 56 (rgba-b p)) (= 78 (rgba-a p)))))))))

      (describe "image shape"
        (it "reports width"  (assert-eq 2 (let [i (img2)] (let [n (image-width i)]  (image-free i) n))))
        (it "reports height" (assert-eq 2 (let [i (img2)] (let [n (image-height i)] (image-free i) n)))))

      (describe "image get/set sampler"
        (it "round-trips a painted pixel"
          (assert-eq 255 (let [i (img2)] (let [r (rgba-r (image-get i 0 0))] (image-free i) r))))
        (it "blank pixels are transparent"
          (assert-eq 0 (let [i (img2)] (let [a (rgba-a (image-get i 1 1))] (image-free i) a)))))

      (describe "image-overlay (shared w, h)"
        (it "opaque over-pixels win, base shows through transparent ones"
          ;; base all-green, over has red at (0,0) and transparent elsewhere
          (let [base (image-filled 2 2 (green))
                over (img2)
                comp (image-overlay base over)]
            (let [top  (rgba-r (image-get comp 0 0))   ;; 255 (red won)
                  thru (rgba-g (image-get comp 1 1))]  ;; 255 (green base shows)
              (image-free base) (image-free over) (image-free comp)
              (assert-true (and (= 255 top) (= 255 thru)))))))

      (describe "image-scale-rgb"
        (it "halves the rgb channels, preserves alpha"
          (let [i (image-filled 1 1 (rgba 200 100 50 255))
                d (image-scale-rgb i 0.5)]
            (let [px (image-get d 0 0)]
              (image-free i) (image-free d)
              (assert-true (and (= 100 (rgba-r px))
                                (and (= 50 (rgba-g px))
                                     (and (= 25 (rgba-b px)) (= 255 (rgba-a px))))))))))

      (run-all)
      0)))
