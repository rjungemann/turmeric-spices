;; raylib/color.tur -- Color type, predefined constants, and color utilities.
;;
;; Colors are heap-allocated Raylib Color structs (4 bytes: r g b a) returned
;; as opaque :int handles.  Pass handles directly to drawing functions.

(defmodule raylib/color
  (export color red green blue white black gray
          yellow orange purple pink skyblue raywhite
          fade color-lerp)

;;; color -- construct a Color from RGBA components (0-255 each).
;;;
;;; Parameters:
;;;   r -- red channel (0-255)
;;;   g -- green channel (0-255)
;;;   b -- blue channel (0-255)
;;;   a -- alpha channel (0-255)
;;;
;;; Returns:
;;;   Opaque :int handle to a heap-allocated Raylib Color struct.
;;;
;;; Example:
;;;   (color 255 128 0 255)  ; => orange
;;;
;;; Since: P3
(defn color [r : int g : int b : int a : int] : int
  ```c
  #include <raylib.h>
  Color *c = malloc(sizeof(Color));
  c->r = (unsigned char)r;
  c->g = (unsigned char)g;
  c->b = (unsigned char)b;
  c->a = (unsigned char)a;
  return (int64_t)(intptr_t)c;
  ```)

;;; red -- Raylib RED color constant (230, 41, 55, 255).
;;;
;;; Since: P3
(defn red [] : int
  ```c
  #include <raylib.h>
  Color *c = malloc(sizeof(Color)); *c = RED; return (int64_t)(intptr_t)c;
  ```)

