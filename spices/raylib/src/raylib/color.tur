;;; fade -- return a copy of a color with its alpha multiplied by the given factor.
;;;
;;; Parameters:
;;;   col   -- Color handle to fade
;;;   alpha -- opacity factor in [0.0, 1.0]
;;;
;;; Returns:
;;;   A new heap-allocated Color handle with adjusted alpha.
;;;
;;; Example:
;;;   (fade (red) 0.5)  ; => semi-transparent red
;;;
;;; Since: P3
(defn fade [col : int alpha : float] : int
  ```c
  #include <raylib.h>
  Color *src = (Color *)(intptr_t)col;
  Color *out = malloc(sizeof(Color));
  *out = ColorAlpha(*src, (float)alpha);
  return (int64_t)(intptr_t)out;
  ```)

;;; color-lerp -- linearly interpolate between two colors.
;;;
;;; Parameters:
;;;   c1 -- start Color handle
;;;   c2 -- end Color handle
;;;   t  -- interpolation factor in [0.0, 1.0]
;;;
;;; Returns:
;;;   A new heap-allocated Color handle with interpolated RGBA values.
;;;
;;; Example:
;;;   (color-lerp (red) (blue) 0.5)  ; => purple-ish
;;;
;;; Since: P3
(defn color-lerp [c1 : int c2 : int t : float] : int
  ```c
  #include <raylib.h>
  Color *a = (Color *)(intptr_t)c1;
  Color *b = (Color *)(intptr_t)c2;
  Color *out = malloc(sizeof(Color));
  *out = ColorLerp(*a, *b, (float)t);
  return (int64_t)(intptr_t)out;
  ```)

) ;; end defmodule raylib/color
