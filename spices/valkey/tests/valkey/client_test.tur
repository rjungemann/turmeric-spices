;; tests/valkey/client_test.tur -- tests for valkey/client.
(defmodule valkey/tests/client
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])

  (describe "valkey/client"
    (it "module loads without error"
      (assert-eq 1 1)))


  (defn main [] :int
    (run-all)
    0))
