;; tests/valkey/reply_test.tur -- tests for valkey/reply.
(defmodule valkey/tests/reply
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])

  (describe "valkey/reply"
    (it "module loads without error"
      (assert-eq 1 1)))


  (defn main [] : int
    (run-all)
    0))
