;; tests/valkey/pubsub_test.tur -- tests for valkey/pubsub.
(defmodule valkey/tests/pubsub
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])

  (describe "valkey/pubsub"
    (it "module loads without error"
      (assert-eq 1 1)))


  (defn main [] :int
    (run-all)
    0))
