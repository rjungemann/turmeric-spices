;; tests/valkey/cmd_test.tur -- tests for valkey/cmd.
;;
;; The spice test runner has no live Valkey server, so the round-trip
;; behavior of `cmd` (send/recv) is exercised manually against a running
;; server. What we can check here without a server is that the typed
;; argument surface (U6) compiles and its constructors are callable.
;; The negative side -- that a bare cstr where a `ValkeyArg` is expected is
;; a compile error -- lives in tests/errors/valkey-cmd-untyped-arg.tur.
(defmodule valkey/tests/cmd
  (import test/suite  :refer [describe it])
  (import test/assert :refer [assert-eq])
  (import test/runner :refer [run-all])
  (import valkey/cmd  :refer [ValkeyArg vk-str vk-int vk-bytes])

  ;; Build one of each typed argument kind. This type-checks the U6 surface
  ;; and runs the constructors; returns a small int so the `it` block can
  ;; assert the helper ran end to end.
  (defn build-args [] : int
    (let [s (vk-str "hello")
          n (vk-int 60)
          b (vk-bytes "ab" 2)]
      3))

  (describe "valkey/cmd"
    (it "module loads without error"
      (assert-eq 1 1))
    (it "typed args (vk-str / vk-int / vk-bytes) construct"
      (assert-eq 3 (build-args))))


  (defn main [] : int
    (run-all)
    0))
