;;;
;;; Returns:
;;;   (ok reply-ptr) on success; (err 0) on error.
;;;
;;; Example:
;;;   (let [r (cmd-lpush c "mylist" "item")]
;;;     (if (ok? r) (reply-free (ok-val r)) (println "lpush failed")))
;;;
;;; Since: VK0
(defn cmd-lpush [c :int list :cstr val :cstr] :ptr<void>
  ```c
  #include <stdlib.h>
  #include <hiredis/hiredis.h>
  redisContext *ctx = (redisContext *)(intptr_t)c;
  redisReply *reply = (redisReply *)redisCommand(ctx, "LPUSH %s %s",
                                                 (const char *)list,
                                                 (const char *)val);
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  if (!reply || reply->type == REDIS_REPLY_ERROR) {
    if (reply) freeReplyObject(reply);
    r->is_ok = false; r->ok_val = 0; r->err_val = 0;
  } else {
    r->is_ok = true; r->ok_val = (int64_t)(intptr_t)reply; r->err_val = 0;
  }
  return r;
  ```)

;;; cmd-lrange -- send LRANGE list start stop.
;;;
;;; Parameters:
;;;   c     -- ctx-ptr (ok-val from client-connect)
;;;   list  -- list key name
;;;   start -- 0-based start index (inclusive)
;;;   stop  -- 0-based stop index (inclusive; -1 for last element)
;;;
;;; Returns:
;;;   (ok reply-ptr) on success; (err 0) on error.
;;;   Reply type is array; use reply-array-len and reply-array-get to iterate.
;;;
;;; Example:
;;;   (let [r (cmd-lrange c "mylist" 0 -1)]
;;;     (if (ok? r) (let [rep (ok-val r)] ...) (println "lrange failed")))
;;;
;;; Since: VK0
(defn cmd-lrange [c :int list :cstr start :int stop :int] :ptr<void>
  ```c
  #include <stdlib.h>
  #include <stdio.h>
  #include <hiredis/hiredis.h>
  redisContext *ctx = (redisContext *)(intptr_t)c;
  char start_buf[32], stop_buf[32];
  snprintf(start_buf, sizeof(start_buf), "%lld", (long long)start);
  snprintf(stop_buf,  sizeof(stop_buf),  "%lld", (long long)stop);
  redisReply *reply = (redisReply *)redisCommand(ctx, "LRANGE %s %s %s",
                                                 (const char *)list,
                                                 start_buf, stop_buf);
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  if (!reply || reply->type == REDIS_REPLY_ERROR) {
    if (reply) freeReplyObject(reply);
    r->is_ok = false; r->ok_val = 0; r->err_val = 0;
  } else {
    r->is_ok = true; r->ok_val = (int64_t)(intptr_t)reply; r->err_val = 0;
  }
  return r;
  ```)

) ;; end defmodule valkey/cmd
