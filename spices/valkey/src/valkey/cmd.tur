;; valkey/cmd.tur -- command dispatch for Valkey/Redis via hiredis.
;;
;; All functions return :ptr<void> results: (ok reply-ptr) or (err 0).
;; The reply-ptr is an opaque :int; use valkey/reply functions to inspect it.
;; Call reply-free when done with a reply to avoid memory leaks.

(defmodule valkey/cmd
  (export cmd cmd-get cmd-set cmd-del cmd-incr cmd-expire
          cmd-hset cmd-hget cmd-lpush cmd-lrange)

;; -------------------------------------------------------------------------
;; Private: result helpers (layout matches stdlib/result.tur)
;; -------------------------------------------------------------------------

;;; __ok -- create an ok result wrapping integer value v.
(defn __ok [v :int] :ptr<void>
  ```c
  #include <stdlib.h>
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  r->is_ok = true; r->ok_val = v; r->err_val = 0; return r;
  ```)

;;; __err -- create an err result wrapping integer error value e.
(defn __err [e :int] :ptr<void>
  ```c
  #include <stdlib.h>
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  r->is_ok = false; r->ok_val = 0; r->err_val = e; return r;
  ```)

;; -------------------------------------------------------------------------
;; Public API
;; -------------------------------------------------------------------------

;;; cmd -- send an arbitrary command with a cons list of string arguments.
;;;
;;; Parameters:
;;;   c       -- ctx-ptr (ok-val from client-connect)
;;;   command -- command name string (e.g. "SET")
;;;   args    -- cons list of :cstr argument strings; use 0 for empty list
;;;
;;; Returns:
;;;   (ok reply-ptr) on success; (err 0) on error or NULL reply.
;;;   Call reply-free on the reply-ptr when done.
;;;
;;; Example:
;;;   (let [r (cmd c "SET" (cons "mykey" (cons "myval" 0)))]
;;;     (if (ok? r) (reply-free (ok-val r)) (println "cmd failed")))
;;;
;;; Since: VK0
(defn cmd [c :int command :cstr args :int] :ptr<void>
  ```c
  #include <stdlib.h>
  #include <string.h>
  #include <hiredis/hiredis.h>
  struct __vc { int64_t value; int64_t next; };
  redisContext *ctx = (redisContext *)(intptr_t)c;
  /* count args */
  int argc = 1;
  struct __vc *cell = (struct __vc *)(intptr_t)args;
  while (cell) { argc++; cell = (struct __vc *)(intptr_t)cell->next; }
  const char **argv = malloc(sizeof(char *) * (size_t)argc);
  argv[0] = (const char *)command;
  int i = 1;
  cell = (struct __vc *)(intptr_t)args;
  while (cell) {
    argv[i++] = (const char *)(intptr_t)cell->value;
    cell = (struct __vc *)(intptr_t)cell->next;
  }
  redisReply *reply = (redisReply *)redisCommandArgv(ctx, argc, argv, NULL);
  free(argv);
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  if (!reply || reply->type == REDIS_REPLY_ERROR) {
    if (reply) freeReplyObject(reply);
    r->is_ok = false; r->ok_val = 0; r->err_val = 0;
  } else {
    r->is_ok = true; r->ok_val = (int64_t)(intptr_t)reply; r->err_val = 0;
  }
  return r;
  ```)

;;; cmd-get -- send GET key.
;;;
;;; Parameters:
;;;   c   -- ctx-ptr (ok-val from client-connect)
;;;   key -- key name string
;;;
;;; Returns:
;;;   (ok reply-ptr) on success; (err 0) on error.
;;;   Call reply-free on the reply-ptr when done.
;;;
;;; Example:
;;;   (let [r (cmd-get c "mykey")]
;;;     (if (ok? r) (println (reply-string (ok-val r))) (println "get failed")))
;;;
;;; Since: VK0
(defn cmd-get [c :int key :cstr] :ptr<void>
  ```c
  #include <stdlib.h>
  #include <hiredis/hiredis.h>
  redisContext *ctx = (redisContext *)(intptr_t)c;
  redisReply *reply = (redisReply *)redisCommand(ctx, "GET %s", (const char *)key);
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  if (!reply || reply->type == REDIS_REPLY_ERROR) {
    if (reply) freeReplyObject(reply);
    r->is_ok = false; r->ok_val = 0; r->err_val = 0;
  } else {
    r->is_ok = true; r->ok_val = (int64_t)(intptr_t)reply; r->err_val = 0;
  }
  return r;
  ```)

;;; cmd-set -- send SET key value.
