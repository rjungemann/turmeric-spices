;;; cmd-hset -- send HSET hash field value.
;;;
;;; Parameters:
;;;   c     -- ctx-ptr (ok-val from client-connect)
;;;   hash  -- hash key name
;;;   field -- field name within the hash
;;;   val   -- value string
;;;
;;; Returns:
;;;   (ok reply-ptr) on success; (err 0) on error.
;;;
;;; Example:
;;;   (let [r (cmd-hset c "user:1" "name" "Alice")]
;;;     (if (ok? r) (reply-free (ok-val r)) (println "hset failed")))
;;;
;;; Since: VK0
(defn cmd-hset [c :int hash :cstr field :cstr val :cstr] :ptr<void>
  ```c
  #include <stdlib.h>
  #include <hiredis/hiredis.h>
  redisContext *ctx = (redisContext *)(intptr_t)c;
  redisReply *reply = (redisReply *)redisCommand(ctx, "HSET %s %s %s",
                                                 (const char *)hash,
                                                 (const char *)field,
                                                 (const char *)val);
  struct { bool is_ok; int64_t ok_val; int64_t err_val; } *r = malloc(sizeof(*r));
  if (!reply || reply->type == REDIS_REPLY_ERROR) {
    if (reply) freeReplyObject(reply);
    r->is_ok = false; r->ok_val = 0; r->err_val = 0;
  } else {
    r->is_ok = true; r->ok_val = (int64_t)(intptr_t)reply; r->err_val = 0;
  }
  return r;
  ```)

