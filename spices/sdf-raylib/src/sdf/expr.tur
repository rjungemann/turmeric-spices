;;; sdf-s0 -- primary scalar (radius, blend-k, offset, etc.). Since: Phase 1
(defn sdf-s0 [e : int] : float
  ```c
  typedef struct sdf_node { int64_t tag; double v0x,v0y,v0z,v1x,v1y,v1z,s0,s1; void *left,*right; } sdf_node;
  return e ? ((sdf_node *)(intptr_t)e)->s0 : 0.0;
