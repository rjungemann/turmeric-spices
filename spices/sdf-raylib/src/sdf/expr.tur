(defn sdf-s1 [e : int] : float
  ```c
  typedef struct sdf_node { int64_t tag; double v0x,v0y,v0z,v1x,v1y,v1z,s0,s1; void *left,*right; } sdf_node;
  return e ? ((sdf_node *)(intptr_t)e)->s1 : 0.0;
  ```)

;;; sdf--make-unary-full -- allocate a unary node with all geometry fields set.
;;;
;;; Like sdf--make-unary but also stores v0 and v1 (needed for repeat nodes
;;; that carry the period vector in v0 and limit vector in v1).
;;;
;;; Parameters:
;;;   tag            -- SDF_* tag
;;;   child          -- child SdfExpr handle (stored in left)
;;;   v0x v0y v0z    -- first vec3 slot (period for repeat ops)
;;;   v1x v1y v1z    -- second vec3 slot (limits for SDF_REPEAT_FIN)
;;;   s0 s1          -- optional scalars
;;;
;;; Returns:
;;;   Opaque :int handle to heap-allocated sdf_node.
;;;
;;; Since: Phase 5
(defn sdf--make-unary-full [tag : int child : int
                             v0x : float v0y : float v0z : float
                             v1x : float v1y : float v1z : float
                             s0 : float s1 : float] : int
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  typedef struct sdf_node {
    int64_t tag;
    double v0x, v0y, v0z, v1x, v1y, v1z, s0, s1;
    struct sdf_node *left, *right;
  } sdf_node;
  sdf_node *n = (sdf_node *)calloc(1, sizeof(sdf_node));
  if (!n) return 0;
  n->tag = tag; n->v0x = v0x; n->v0y = v0y; n->v0z = v0z;
  n->v1x = v1x; n->v1y = v1y; n->v1z = v1z;
  n->s0 = s0; n->s1 = s1;
  n->left  = (sdf_node *)(intptr_t)child;
  n->right = NULL;
  return (int64_t)(intptr_t)n;
  ```)

;;; sdf-free -- recursively free an SdfExpr tree.
;;;
;;; Parameters:
;;;   e -- SdfExpr handle; safe to call with 0 (no-op).
;;;
;;; Example:
;;;   (sdf-free scene)
;;;
;;; Since: Phase 1
(defn sdf-free [e : int] : void
  ```c
  #include <stdlib.h>
  #include <stdint.h>
  typedef struct sdf_node { int64_t tag; double v0x,v0y,v0z,v1x,v1y,v1z,s0,s1; void *left,*right; } sdf_node;
  if (!e) return;
  struct { void *node; } stk[256];
  int top = 0;
  stk[top++].node = (void *)(intptr_t)e;
  while (top > 0) {
    sdf_node *n = (sdf_node *)stk[--top].node;
    if (!n) continue;
    if (top < 254) {
      if (n->left)  stk[top++].node = n->left;
      if (n->right) stk[top++].node = n->right;
    }
    free(n);
  }
  ```)

) ;; end defmodule sdf/expr
