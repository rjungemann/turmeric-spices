;;; sdf/eval -- CPU evaluator for SdfExpr trees.
;;;
;;; sdf-eval, sdf-normal-x/y/z, and (Phase 3) sdf->glsl all live here so
;;; that any drift between the three interpreters is immediately visible
;;; in code review.
;;;
;;; The evaluator dispatches on the tag returned by sdf-tag and recurses
;;; via Turmeric function calls.  This is correct but not fast -- use the
;;; C-level evaluator in raylib/integration.tur for interactive rendering.
;;;
;;; Since: Phase 1
;; -------------------------------------------------------------------------

(defmodule sdf/eval
  (export sdf-eval sdf-normal-x sdf-normal-y sdf-normal-z))

(import sdf/expr :refer [SDF_SPHERE SDF_BOX SDF_CYLINDER SDF_PLANE
                          SDF_UNION SDF_INTERSECT SDF_DIFFERENCE SDF_SMOOTH_UNION
                          SDF_OFFSET SDF_SHELL SDF_TRANSLATE
                          sdf-tag sdf-left sdf-right
                          sdf-v0x sdf-v0y sdf-v0z
                          sdf-v1x sdf-v1y sdf-v1z
                          sdf-s0])

;; ---- private primitive evaluators (inline-C for math) ----

(defn sdf--sphere-eval [cx :float cy :float cz :float r :float
                        px :float py :float pz :float] :float
  ```c
  #include <math.h>
  double dx=px-cx, dy=py-cy, dz=pz-cz;
  return sqrt(dx*dx+dy*dy+dz*dz) - r;
  ```)

(defn sdf--box-eval [lx :float ly :float lz :float
                     hx :float hy :float hz :float
                     px :float py :float pz :float] :float
  ```c
  #include <math.h>
  double cx=(lx+hx)*0.5, cy=(ly+hy)*0.5, cz=(lz+hz)*0.5;
  double ex=(hx-lx)*0.5, ey=(hy-ly)*0.5, ez=(hz-lz)*0.5;
  double qx=fabs(px-cx)-ex, qy=fabs(py-cy)-ey, qz=fabs(pz-cz)-ez;
  double mx=qx>qy?(qx>qz?qx:qz):(qy>qz?qy:qz);
  double lenq=sqrt((qx>0?qx*qx:0)+(qy>0?qy*qy:0)+(qz>0?qz*qz:0));
  return lenq + (mx<0?mx:0);
  ```)

(defn sdf--cylinder-eval [cx :float cy :float cz :float r :float
                           px :float py :float pz :float] :float
  ```c
  #include <math.h>
  double dx=px-cx, dy=py-cy;
  return sqrt(dx*dx+dy*dy) - r;
  ```)

(defn sdf--plane-eval [nx :float ny :float nz :float d :float
                       px :float py :float pz :float] :float
  ```c
  return nx*px + ny*py + nz*pz + d;
  ```)

(defn sdf--smooth-union-eval [l :float r :float k :float] :float
  ```c
  #include <math.h>
  double h = fmax(k - fabs(l-r), 0.0) / k;
  return fmin(l,r) - h*h*k*0.25;
  ```)

(defn sdf--fabs [x :float] :float
  ```c
  return x < 0.0 ? -x : x;
  ```)

;; ---- public API ----

;;; sdf-eval -- evaluate an SdfExpr at point (px, py, pz).
;;;
;;; Parameters:
;;;   e        -- SdfExpr handle
;;;   px py pz -- query point components
;;;
;;; Returns:
;;;   Signed distance: negative inside the surface, zero on it, positive outside.
;;;
;;; Example:
;;;   (sdf-eval (sdf-sphere 0.0 0.0 0.0 1.0) 0.5 0.0 0.0)  ; => -0.5
;;;
;;; Since: Phase 1
(defn sdf-eval [e :int px :float py :float pz :float] :float
  (let [tag (sdf-tag e)]
    (cond
      (= tag SDF_SPHERE)
        (sdf--sphere-eval (sdf-v0x e) (sdf-v0y e) (sdf-v0z e)
                          (sdf-s0 e) px py pz)
      (= tag SDF_BOX)
        (sdf--box-eval (sdf-v0x e) (sdf-v0y e) (sdf-v0z e)
                       (sdf-v1x e) (sdf-v1y e) (sdf-v1z e)
                       px py pz)
      (= tag SDF_CYLINDER)
        (sdf--cylinder-eval (sdf-v0x e) (sdf-v0y e) (sdf-v0z e)
                            (sdf-s0 e) px py pz)
      (= tag SDF_PLANE)
        (sdf--plane-eval (sdf-v0x e) (sdf-v0y e) (sdf-v0z e)
                         (sdf-s0 e) px py pz)
      (= tag SDF_UNION)
        (let [dl (sdf-eval (sdf-left e) px py pz)
              dr (sdf-eval (sdf-right e) px py pz)]
          (if (< dl dr) dl dr))
      (= tag SDF_INTERSECT)
        (let [dl (sdf-eval (sdf-left e) px py pz)
              dr (sdf-eval (sdf-right e) px py pz)]
          (if (> dl dr) dl dr))
      (= tag SDF_DIFFERENCE)
        (let [dl  (sdf-eval (sdf-left e) px py pz)
              dr  (sdf-eval (sdf-right e) px py pz)
              ndr (- 0.0 dr)]
          (if (> dl ndr) dl ndr))
      (= tag SDF_SMOOTH_UNION)
        (sdf--smooth-union-eval
          (sdf-eval (sdf-left e)  px py pz)
          (sdf-eval (sdf-right e) px py pz)
          (sdf-s0 e))
      (= tag SDF_OFFSET)
        (+ (sdf-eval (sdf-left e) px py pz) (sdf-s0 e))
      (= tag SDF_SHELL)
        (- (sdf--fabs (sdf-eval (sdf-left e) px py pz)) (sdf-s0 e))
      (= tag SDF_TRANSLATE)
        (sdf-eval (sdf-left e)
                  (- px (sdf-v0x e))
                  (- py (sdf-v0y e))
                  (- pz (sdf-v0z e)))
      :else 1.0e9)))

;;; sdf-normal-x -- x component of the surface normal at (px,py,pz).
;;;
;;; Computed via central-difference gradient of sdf-eval.
;;;
;;; Since: Phase 1
(defn sdf-normal-x [e :int px :float py :float pz :float] :float
  (let [eps 0.001]
    (- (sdf-eval e (+ px eps) py pz)
       (sdf-eval e (- px eps) py pz))))

;;; sdf-normal-y -- y component of the surface normal at (px,py,pz). Since: Phase 1
(defn sdf-normal-y [e :int px :float py :float pz :float] :float
  (let [eps 0.001]
    (- (sdf-eval e px (+ py eps) pz)
       (sdf-eval e px (- py eps) pz))))

;;; sdf-normal-z -- z component of the surface normal at (px,py,pz). Since: Phase 1
(defn sdf-normal-z [e :int px :float py :float pz :float] :float
  (let [eps 0.001]
    (- (sdf-eval e px py (+ pz eps))
       (sdf-eval e px py (- pz eps)))))

) ;; end defmodule sdf/eval
