;; boolean_test.tur -- unit tests for sdf/boolean CSG combinators.

(import sdf/primitives :refer [sdf-sphere])
(import sdf/boolean    :refer [sdf-union sdf-intersection sdf-difference
                                sdf-smooth-union])
(import sdf/transforms :refer [sdf-translate sdf-offset sdf-shell])
(import sdf/eval       :refer [sdf-eval])
(import sdf/expr       :refer [sdf-free])

(defn approx= [a :float b :float] :int
  ```c
  double diff = a - b; if (diff < 0) diff = -diff;
  return diff < 0.02 ? 1 : 0;
  ```)

(defn print-result [label :cstr pass :int total :int] :void
  ```c
  #include <stdio.h>
  printf("%s: %d/%d passed\n", (const char*)(intptr_t)label, (int)pass, (int)total);
  ```)

;; ---- union ----

(defn test-union-inside-both [] :int
  (let [a (sdf-sphere -0.5 0.0 0.0 1.0)
        b (sdf-sphere  0.5 0.0 0.0 1.0)
        u (sdf-union a b)
        d (sdf-eval u 0.0 0.0 0.0)]
    (sdf-free u)
    (if (< d 0.0) 1 0)))

(defn test-union-inside-one [] :int
  (let [a (sdf-sphere -2.0 0.0 0.0 0.5)
        b (sdf-sphere  2.0 0.0 0.0 0.5)
        u (sdf-union a b)
        d (sdf-eval u 2.0 0.0 0.0)]
    (sdf-free u)
    (if (< d 0.0) 1 0)))

;; ---- intersection ----

(defn test-intersection-overlap [] :int
  (let [a (sdf-sphere -0.2 0.0 0.0 1.0)
        b (sdf-sphere  0.2 0.0 0.0 1.0)
        i (sdf-intersection a b)
        d (sdf-eval i 0.0 0.0 0.0)]
    (sdf-free i)
    (if (< d 0.0) 1 0)))

(defn test-intersection-outside [] :int
  (let [a (sdf-sphere -2.0 0.0 0.0 1.0)
        b (sdf-sphere  2.0 0.0 0.0 1.0)
        i (sdf-intersection a b)
        d (sdf-eval i 0.0 0.0 0.0)]
    (sdf-free i)
    (if (> d 0.0) 1 0)))

;; ---- difference ----

(defn test-difference-carved [] :int
  (let [a (sdf-sphere 0.0 0.0 0.0 2.0)
        b (sdf-sphere 0.0 0.0 0.0 1.0)
        d (sdf-difference a b)
        v (sdf-eval d 0.0 0.0 0.0)]
    (sdf-free d)
    (if (> v 0.0) 1 0)))

(defn test-difference-outside [] :int
  (let [a (sdf-sphere 0.0 0.0 0.0 2.0)
        b (sdf-sphere 0.0 0.0 0.0 1.0)
        d (sdf-difference a b)
        v (sdf-eval d 1.5 0.0 0.0)]
    (sdf-free d)
    (if (< v 0.0) 1 0)))

;; ---- translate ----

(defn test-translate [] :int
  (let [s (sdf-sphere 0.0 0.0 0.0 1.0)
        t (sdf-translate s 5.0 0.0 0.0)
        d (sdf-eval t 5.0 0.0 0.0)]
    (sdf-free t)
    (if (approx= d -1.0) 1 0)))

;; ---- offset ----

(defn test-offset-grow [] :int
  (let [s (sdf-sphere 0.0 0.0 0.0 1.0)
        o (sdf-offset s 0.5)
        d (sdf-eval o 1.5 0.0 0.0)]
    (sdf-free o)
    (if (approx= d 0.0) 1 0)))

;; ---- smooth union ----

(defn test-smooth-union-between [] :int
  (let [a (sdf-sphere -1.0 0.0 0.0 1.2)
        b (sdf-sphere  1.0 0.0 0.0 1.2)
        u (sdf-smooth-union a b 0.5)
        d (sdf-eval u 0.0 0.0 0.0)]
    (sdf-free u)
    (if (< d 0.0) 1 0)))

;; ---- runner ----

(defn main [] :int
  (let [pass (+ (test-union-inside-both)
                (+ (test-union-inside-one)
                   (+ (test-intersection-overlap)
                      (+ (test-intersection-outside)
                         (+ (test-difference-carved)
                            (+ (test-difference-outside)
                               (+ (test-translate)
                                  (+ (test-offset-grow)
                                     (test-smooth-union-between)))))))))]
    (print-result "boolean" pass 9)
    (if (= pass 9) 0 1)))
