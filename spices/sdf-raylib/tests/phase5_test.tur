;;; phase5_test -- Phase 5 tests: torus, capsule, smooth-intersection, repeat.
;;;
;;; Since: Phase 5
;; -------------------------------------------------------------------------

(defmodule phase5_test
  (import sdf/primitives :refer [sdf-sphere sdf-torus sdf-capsule])
  (import sdf/blend      :refer [sdf-smooth-intersection])
  (import sdf/repeat     :refer [sdf-repeat-inf sdf-repeat-fin])
  (import sdf/eval       :refer [sdf-eval])
  (import sdf/expr       :refer [sdf-free])

  (defn approx= [a :float b :float] :bool
    ```c
    double diff = a - b; if (diff < 0) diff = -diff;
    return diff < 0.02;
    ```)

  (defn print-and-check [label :cstr pass :int total :int] :int
    ```c
    #include <stdio.h>
    printf("%s: %d/%d passed\n", (const char*)(intptr_t)label, (int)pass, (int)total);
    return pass == total ? 0 : 1;
    ```)

  ;; ---- torus tests ----
  ;; Torus centred at origin, major radius 1.0, minor radius 0.25.

  (defn test-torus-equator-surface [] :int
    (let [t (sdf-torus 0.0 0.0 0.0 1.0 0.25)
          d (sdf-eval t 1.25 0.0 0.0)]
      (sdf-free t)
      (if (approx= d 0.0) 1 0)))

  (defn test-torus-equator-inside [] :int
    (let [t (sdf-torus 0.0 0.0 0.0 1.0 0.25)
          d (sdf-eval t 1.0 0.0 0.0)]
      (sdf-free t)
      (if (approx= d -0.25) 1 0)))

  (defn test-torus-far-outside [] :int
    ;; At origin: qx = sqrt(0) - 1.0 = -1.0, qy = 0; d = sqrt(1) - 0.25 = 0.75
    (let [t (sdf-torus 0.0 0.0 0.0 1.0 0.25)
          d (sdf-eval t 0.0 0.0 0.0)]
      (sdf-free t)
      (if (approx= d 0.75) 1 0)))

  ;; ---- capsule tests ----
  ;; Capsule from A=(0,0,0) to B=(0,2,0) with radius 0.5.

  (defn test-capsule-mid-surface [] :int
    (let [c (sdf-capsule 0.0 0.0 0.0  0.0 2.0 0.0  0.5)
          d (sdf-eval c 0.5 1.0 0.0)]
      (sdf-free c)
      (if (approx= d 0.0) 1 0)))

  (defn test-capsule-end-surface [] :int
    (let [c (sdf-capsule 0.0 0.0 0.0  0.0 2.0 0.0  0.5)
          d (sdf-eval c 0.0 2.5 0.0)]
      (sdf-free c)
      (if (approx= d 0.0) 1 0)))

  (defn test-capsule-inside [] :int
    (let [c (sdf-capsule 0.0 0.0 0.0  0.0 2.0 0.0  0.5)
          d (sdf-eval c 0.0 1.0 0.0)]
      (sdf-free c)
      (if (approx= d -0.5) 1 0)))

  ;; ---- smooth-intersection tests ----
  ;; Two spheres radius 1 at (-0.5,0,0) and (0.5,0,0).

  (defn test-smintersect-at-origin [] :int
    ;; k=0 degenerates to sharp intersect; both spheres at origin: d = -0.5
    (let [a  (sdf-sphere -0.5 0.0 0.0 1.0)
          b  (sdf-sphere  0.5 0.0 0.0 1.0)
          si (sdf-smooth-intersection a b 0.0)
          d  (sdf-eval si 0.0 0.0 0.0)]
      (sdf-free si)
      (if (approx= d -0.5) 1 0)))

  (defn test-smintersect-blend-raises [] :int
    ;; k=0.5, l=r=-0.5 => h=1, delta=k/4=0.125 => d = -0.5 + 0.125 = -0.375
    (let [a  (sdf-sphere -0.5 0.0 0.0 1.0)
          b  (sdf-sphere  0.5 0.0 0.0 1.0)
          si (sdf-smooth-intersection a b 0.5)
          d  (sdf-eval si 0.0 0.0 0.0)]
      (sdf-free si)
      (if (approx= d -0.375) 1 0)))

  ;; ---- repeat-inf tests ----
  ;; Sphere radius 0.2 at origin, repeated every 1.0 in X.

  (defn test-repeat-inf-inside [] :int
    (let [s (sdf-sphere 0.0 0.0 0.0 0.2)
          r (sdf-repeat-inf s 1.0 0.0 0.0)
          d (sdf-eval r 0.0 0.0 0.0)]
      (sdf-free r)
      (if (approx= d -0.2) 1 0)))

  (defn test-repeat-inf-next-cell [] :int
    ;; query at x=1.0 wraps to 0 -> d = -0.2
    (let [s (sdf-sphere 0.0 0.0 0.0 0.2)
          r (sdf-repeat-inf s 1.0 0.0 0.0)
          d (sdf-eval r 1.0 0.0 0.0)]
      (sdf-free r)
      (if (approx= d -0.2) 1 0)))

  ;; ---- repeat-fin tests ----
  ;; Sphere radius 0.2 at origin, repeated every 1.0 in X, limit 2.

  (defn test-repeat-fin-inside [] :int
    (let [s (sdf-sphere 0.0 0.0 0.0 0.2)
          r (sdf-repeat-fin s 1.0 0.0 0.0  2.0 0.0 0.0)
          d (sdf-eval r 0.0 0.0 0.0)]
      (sdf-free r)
      (if (approx= d -0.2) 1 0)))

  (defn test-repeat-fin-clamped [] :int
    ;; round(5/1)=5, clamped to 2 -> warped x = 5-1*2 = 3 -> d = 3-0.2 = 2.8
    (let [s (sdf-sphere 0.0 0.0 0.0 0.2)
          r (sdf-repeat-fin s 1.0 0.0 0.0  2.0 0.0 0.0)
          d (sdf-eval r 5.0 0.0 0.0)]
      (sdf-free r)
      (if (approx= d 2.8) 1 0)))

  ;; ---- runner ----

  (defn main [] :int
    (print-and-check "phase5"
      (+ (test-torus-equator-surface)
         (+ (test-torus-equator-inside)
            (+ (test-torus-far-outside)
               (+ (test-capsule-mid-surface)
                  (+ (test-capsule-end-surface)
                     (+ (test-capsule-inside)
                        (+ (test-smintersect-at-origin)
                           (+ (test-smintersect-blend-raises)
                              (+ (test-repeat-inf-inside)
                                 (+ (test-repeat-inf-next-cell)
                                    (+ (test-repeat-fin-inside)
                                       (test-repeat-fin-clamped))))))))))))
      12))

) ;; end defmodule phase5_test
