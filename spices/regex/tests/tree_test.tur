;; tests/tree_test.tur -- regex/tree (U5 Fix ReF AST + cata + matcher).
;;
;; Pure-Turmeric: no PCRE2, no display, runs anywhere.

(defmodule regex/tests/tree
  (import regex/tree :refer [Re r-empty r-lit r-alt r-cat r-star r-plus r-opt
                             re-size re-nullable? re->str re-matches?])
  (import test/assert :refer [assert-eq assert-true assert-false])
  (import test/suite  :refer [describe it])
  (import test/runner :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c return strcmp((const char *)a, (const char *)b) == 0; ```)

  ;; (a|b)*c  -- the running example
  (defn ex [] : Re
    (r-cat (r-star (r-alt (r-lit "a") (r-lit "b"))) (r-lit "c")))

  (defn main [] : int
    (do
      (describe "re-size (cata)"
        ;; Cat(Star(Alt(a,b)), c): Cat=1 Star=1 Alt=1 a=1 b=1 c=1 = 6
        (it "counts every node" (assert-eq 6 (re-size (ex)))))

      (describe "re-nullable? (cata)"
        (it "star is nullable"        (assert-true  (re-nullable? (r-star (r-lit "a")))))
        (it "empty is nullable"       (assert-true  (re-nullable? (r-empty))))
        (it "a literal is not"        (assert-false (re-nullable? (r-lit "a"))))
        (it "(a|b)*c is not nullable" (assert-false (re-nullable? (ex))))
        (it "opt is nullable"         (assert-true  (re-nullable? (r-opt (r-lit "a"))))))

      (describe "re->str (cata)"
        (it "pretty-prints with grouping"
          (assert-true (cstr-eq? "((a|b))*c" (re->str (ex))))))

      (describe "re-matches? (backtracking)"
        (it "(a|b)*c matches c"     (assert-true  (re-matches? (ex) "c")))
        (it "(a|b)*c matches ababc" (assert-true  (re-matches? (ex) "ababc")))
        (it "(a|b)*c rejects abab"  (assert-false (re-matches? (ex) "abab")))
        (it "(a|b)*c rejects abx"   (assert-false (re-matches? (ex) "abx")))
        (it "a* matches empty"      (assert-true  (re-matches? (r-star (r-lit "a")) "")))
        (it "a+ rejects empty"      (assert-false (re-matches? (r-plus (r-lit "a")) "")))
        (it "a+ matches aaa"        (assert-true  (re-matches? (r-plus (r-lit "a")) "aaa"))))

      (run-all)
      0)))

