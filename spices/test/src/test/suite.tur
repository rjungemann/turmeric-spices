;; test/suite.tur -- describe/it test block DSL.

(defmodule test/suite
  (export describe it before-each after-each __ts __it-print __desc-print)

;;; __ts -- shared test state (opcode dispatch over static vars).
;;; op: 0=get-pass 1=inc-pass+total 2=get-fail 3=inc-fail+total 4=get-total
(defn __ts [op :int] :int
  ```c
  static int64_t pass = 0, fail = 0, n = 0;
  switch ((int)op) {
    case 0: return pass;
    case 1: pass++; n++; return n;
    case 2: return fail;
    case 3: fail++; n++; return n;
    case 4: return n;
    default: return 0;
  }
  ```)

;;; __it-print -- print a TAP test result line.
(defn __it-print [n :int desc :cstr result :bool] :void
  ```c
  #include <stdio.h>
  if (result)
    printf("ok %lld - %s\n", (long long)n, desc);
  else
    printf("not ok %lld - %s\n", (long long)n, desc);
  ```)

;;; __desc-print -- print a TAP comment for a describe block.
(defn __desc-print [name :cstr] :void
  ```c
  #include <stdio.h>
  printf("# %s\n", name);
  ```)

;;; it -- run a single test case and record the result in TAP output.
;;;
;;; Parameters:
;;;   desc   -- test description string
;;;   result -- boolean result of the test body
;;;
;;; Returns:
;;;   The result (true=pass, false=fail).
;;;
;;; Example:
;;;   (it "adds correctly" (assert-eq (+ 1 2) 3))
;;;
;;; Since: P1
(defn it [desc :cstr result :bool] :bool
  (let [n (if result (__ts 1) (__ts 3))]
    (__it-print n desc result)
    result))

;;; describe -- group related test cases under a named section.
;;;
;;; Parameters:
;;;   name -- section description
;;;   body -- one or more test expressions (typically (it ...) calls)
;;;
;;; Example:
;;;   (describe "math" (it "adds" (assert-eq (+ 1 2) 3)))
;;;
;;; Since: P1
(defmacro describe [name & body]
  `(do
    (__desc-print ~name)
    ~@body))

;;; before-each -- register a setup hook (P1 stub: runs body once).
;;;
;;; Since: P1
(defmacro before-each [& body]
  `(do ~@body))

;;; after-each -- register a teardown hook (P1 stub: runs body once).
;;;
;;; Since: P1
(defmacro after-each [& body]
  `(do ~@body))

) ;; end defmodule test/suite
