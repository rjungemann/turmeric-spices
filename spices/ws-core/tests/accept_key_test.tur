;; tests/accept_key_test.tur -- NAME-V0 handshake-crypto unit test (no network).
;;
;; ws-accept-key now lives in ws-core (it used to be ws-client's). Assert the
;; shared SHA-1 + base64 pipeline against the canonical RFC 6455 4.2.2 vector,
;; the same check the ws-client codec test used to run on its local copy.

(defmodule ws-core/tests/accept-key
  (import ws-core/handshake :refer [ws-accept-key])
  (import test/suite        :refer [describe it])
  (import test/assert       :refer [assert-true])
  (import test/runner       :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn main [] : int
    (describe "ws-core handshake crypto -- ws-accept-key (RFC 6455 4.2.2)"

      ;; key "dGhlIHNhbXBsZSBub25jZQ==" must yield
      ;; accept "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=".
      (it "computes the RFC 6455 accept value for the sample key"
        (assert-true (cstr-eq? "s3pPLMBiTxaQ9kYGzzhZRbK+xOo="
                               (ws-accept-key "dGhlIHNhbXBsZSBub25jZQ=="))))

      ;; A different key produces a different, stable digest.
      (it "is deterministic and key-sensitive"
        (assert-true (cstr-eq? "HSmrc0sMlYUkAGmm5OPpG2HaGWk="
                               (ws-accept-key "x3JJHMbDL1EzLkh9GBhXDw==")))))

    (run-all)))
