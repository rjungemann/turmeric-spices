;; tests/tourist/swap_reject_test.tur -- compile-time swap-rejection probes
;; for the Captures, Ctx, and Pattern opaque handles.
;;
;; NEGATIVE fixture: every defn below is wrong on purpose. Running
;; `tur check tests/tourist/swap_reject_test.tur` MUST produce TUR-E0001
;; mismatches at the marked sites. If any of these typecheck cleanly,
;; the S2 audit's "missing Captures defopaque" or the v0.2.2 param/capture
;; ctx:Ctx retype or the v0.2.5 router Pattern retype has regressed.

(defmodule tourist/tests/swap-reject
  (import tourist/types      :refer [Ctx Captures Item ItemList
                                     Mount MountList AppList StatusList
                                     Pattern])
  (import tourist/router     :refer [router-compile router-free router-match
                                     captures-get
                                     captures-count captures-free])
  (import tourist/param      :refer [tourist-ctx-caps param capture])
  (import tourist/middleware :refer [mw-item? mw-chain-run])
  (import tourist/routing    :refer [mount! cascade-with! passes!])

  ;; int (e.g. a raw pattern handle) is not a Captures handle.
  (defn bad-int-as-captures [pat : int] : int
    (captures-count pat))           ; expects Captures, got int

  ;; Ctx is not a Captures (even though both are :int under the hood).
  (defn bad-ctx-as-captures [ctx : Ctx] : void
    (captures-free ctx))            ; expects Captures, got Ctx

  ;; Captures is not a Pattern -- router-match arg 1 wants the Pattern handle
  ;; from router-compile (typed Pattern in v0.2.5), not the Captures it returns.
  (defn bad-captures-as-pattern [caps : Captures path : cstr] : Captures
    (router-match caps path))       ; arg 1 expects Pattern, got Captures

  ;; A bare int is not a Pattern (v0.2.5 router-compile/router-match retype):
  ;; callers must thread the typed handle, not a raw int.
  (defn bad-int-as-pattern [pat : int path : cstr] : Captures
    (router-match pat path))        ; arg 1 expects Pattern, got int

  ;; Ctx is not a Pattern even though both wrap :int.
  (defn bad-ctx-as-pattern-free [ctx : Ctx] : void
    (router-free ctx))              ; expects Pattern, got Ctx

  ;; Swapped args on captures-get: (Captures, cstr) is the right order.
  (defn bad-swap-captures-get [caps : Captures key : cstr]
      : (Result cstr cstr)
    (captures-get (:: key :Captures) caps))  ; both args swapped + bad cast

  ;; param now requires a Ctx, not a bare int (v0.2.2 residual S2 retype).
  (defn bad-int-as-ctx-for-param [ctx : int key : cstr] : (Result cstr cstr)
    (param ctx key))                ; expects Ctx, got int

  ;; capture now requires a Ctx, not a bare int (v0.2.2 residual S2 retype).
  (defn bad-int-as-ctx-for-capture [ctx : int name : cstr] : (Result cstr cstr)
    (capture ctx name))             ; expects Ctx, got int

  ;; Captures handle is not interchangeable with a Ctx for param.
  (defn bad-captures-as-ctx-for-param [caps : Captures key : cstr]
      : (Result cstr cstr)
    (param caps key))               ; expects Ctx, got Captures

  ;; mw-item? now requires an Item, not a bare int (v0.2.2 S4 cons-walker
  ;; hygiene).
  (defn bad-int-as-item [n : int] : bool
    (mw-item? n))                   ; expects Item, got int

  ;; mw-item? rejects a Captures handle (defopaque collision check).
  (defn bad-captures-as-item [caps : Captures] : bool
    (mw-item? caps))                ; expects Item, got Captures

  ;; mw-chain-run requires an ItemList head, not a raw int (cons-walker
  ;; hygiene).
  (defn bad-int-as-itemlist [n : int ctx : int] : int
    (mw-chain-run n ctx))           ; expects ItemList, got int

  ;; mw-chain-run rejects an Item (single cell) where the cons head is wanted.
  (defn bad-item-as-itemlist [item : Item ctx : int] : int
    (mw-chain-run item ctx))        ; expects ItemList, got Item

  ;; url-map!'s variadic rest is now Mount-typed; a bare int is rejected
  ;; (v0.2.3 routing cons-walker hygiene). Note that turmeric's variadic
  ;; call-site checker DOES enforce rest types, but does NOT currently
  ;; enforce non-variadic positional types when a `& rest` is also present
  ;; -- so swap-rejection for cascade-with!'s `passes : StatusList` arg is
  ;; honored only at the internal __cascade-alloc / __cascade-passes
  ;; boundaries inside routing.tur (which tur-check exercises directly),
  ;; not at the public call site.
  (defn bad-int-as-mount-rest [n : int] : int
    (url-map! n))                   ; rest expects Mount, got int

  ;; Same for AppList: it is not a Mount, even though both wrap :int.
  (defn bad-applist-as-mount-rest [as : AppList] : int
    (url-map! as))                  ; rest expects Mount, got AppList

  (defn main [] : int 0))
