;; Fixture: cascade -- cascade! tries apps in order, passes through on 404.

(defmodule tourist/tests/cascade
  (import tourist/app     :refer [tourist])
  (import tourist/dsl     :refer [get!])
  (import tourist/helpers :refer [text])
  (import tourist/routing :refer [cascade! cascade-with! passes!])
  (import httpd/server    :refer [server-stop])
  (import http/client     :refer [http-get])
  (import http/response   :refer [response-status response-body])
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-true])
  (import test/runner     :refer [run-all])

  (defn __cr-ok? [r : ptr<void>] : bool
    ```c
    if (!r) return false;
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return ((struct __cr *)r)->is_ok;
    ```)

  (defn __cr-val [r : ptr<void>] : int
    ```c
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return (int64_t)((struct __cr *)r)->ok_val;
    ```)

  (defn sleep-ms [ms : int] #{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn main [] : int
    (let [srv (tourist 18121
                (cascade! (get! "/primary" (fn [_] (text "primary")))
                          (get! "/fallback" (fn [_] (text "fallback")))
                          (get! "/" (fn [_] (text "root")))))]
      (do
        (unsafe (sleep-ms 50))
        (describe "tourist cascade!"
          (it "GET /primary returns from first app"
            (let [r (http-get "http://127.0.0.1:18121/primary")]
              (if (__cr-ok? r)
                (do
                  (assert-eq 200 (response-status (__cr-val r)))
                  (assert-true
                    (cstr-eq? "primary" (response-body (__cr-val r)))))
                (assert-true false))))
          (it "GET /fallback falls through first app, hits second"
            (let [r (http-get "http://127.0.0.1:18121/fallback")]
              (if (__cr-ok? r)
                (do
                  (assert-eq 200 (response-status (__cr-val r)))
                  (assert-true
                    (cstr-eq? "fallback" (response-body (__cr-val r)))))
                (assert-true false))))
          (it "GET / falls through to root handler"
            (let [r (http-get "http://127.0.0.1:18121/")]
              (if (__cr-ok? r)
                (assert-true
                  (cstr-eq? "root" (response-body (__cr-val r))))
                (assert-true false))))
          (it "GET /none returns 404 when no cascade entry matches"
            (let [r (http-get "http://127.0.0.1:18121/none")]
              (if (__cr-ok? r)
                (assert-eq 404 (response-status (__cr-val r)))
                (assert-true false)))))
        (server-stop srv)
        (run-all)))
    0))
