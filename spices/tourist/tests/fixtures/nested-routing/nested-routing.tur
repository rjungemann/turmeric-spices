;; Fixture: nested-routing -- url-map! within url-map!, with middleware,
;; and a cascade! of url-map! sub-apps.

(defmodule tourist/tests/nested-routing
  (import tourist/app        :refer [tourist])
  (import tourist/dsl        :refer [get!])
  (import tourist/helpers    :refer [text])
  (import tourist/middleware :refer [use!])
  (import tourist/routing    :refer [url-map! cascade! mount!])
  (import tourist/types      :refer [Ctx])
  (import httpd/types        :refer [Response])
  (import httpd/request      :refer [req-path])
  (import httpd/types        :refer [Request])
  (import httpd/server       :refer [server-stop])
  (import http/client        :refer [http-get])
  (import http/response      :refer [response-status response-body response-header])
  (import test/suite         :refer [describe it])
  (import test/assert        :refer [assert-eq assert-true])
  (import test/runner        :refer [run-all])

  (defn __cr-ok? [r : ptr<void>] : bool
    ```c
    if (!r) return false;
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return ((struct __cr *)r)->is_ok;
    ```)

  (defn __cr-val [r : ptr<void>] : int
    ```c
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return (int64_t)((struct __cr *)r)->ok_val;
    ```)

  (defn sleep-ms [ms : int] #{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; Outer middleware tags every response by short-circuiting nothing
  ;; (returns the (none) option, NULL); it just observes the request.
  (defn tag-mw [ctx : Ctx] : (Option Response)
    ```c
    (void)ctx;
    return (struct tur__option__Option *)0;
    ```)

  ;; Two leaf handlers
  (defn users-handler [ctx : Ctx] : Response (text (req-path (:: ctx :Request))))
  (defn items-handler [ctx : Ctx] : Response (text (req-path (:: ctx :Request))))
  (defn legacy-handler [ctx : Ctx] : Response (text "legacy-v1"))

  ;; v2 sub-app: url-map! with two prefixes
  (defn v2-app [] : int
    (url-map! (mount! "/users" (get! "/" users-handler))
              (mount! "/items" (get! "/" items-handler))))

  ;; v1 sub-app: returns "legacy-v1" for any /legacy path; otherwise no match.
  (defn v1-app [] : int
    (get! "/legacy" legacy-handler))

  ;; api: cascade v2-app over v1-app, so v2's 404s fall through to v1.
  (defn api-app [] : int
    (cascade! (v2-app) (v1-app)))

  (defn main [] : int
    (let [srv (tourist 18122
                (use! tag-mw)
                (url-map! (mount! "/api" (api-app))
                          (mount! "/"    (get! "/" (fn [_] (text "home"))))))]
      (do
        (unsafe (sleep-ms 50))
        (describe "tourist nested routing"
          (it "GET /api/users hits nested url-map within cascade"
            (let [r (http-get "http://127.0.0.1:18122/api/users")]
              (if (__cr-ok? r)
                (do
                  (assert-eq 200 (response-status (__cr-val r)))
                  ;; req-path inside the inner sub-app sees "/" (stripped twice).
                  (assert-true
                    (cstr-eq? "/" (response-body (__cr-val r)))))
                (assert-true false))))
          (it "GET /api/items hits the items sub-app"
            (let [r (http-get "http://127.0.0.1:18122/api/items")]
              (if (__cr-ok? r)
                (assert-eq 200 (response-status (__cr-val r)))
                (assert-true false))))
          (it "GET /api/legacy cascades to v1 after v2 misses"
            (let [r (http-get "http://127.0.0.1:18122/api/legacy")]
              (if (__cr-ok? r)
                (do
                  (assert-eq 200 (response-status (__cr-val r)))
                  (assert-true
                    (cstr-eq? "legacy-v1" (response-body (__cr-val r)))))
                (assert-true false))))
          (it "GET / hits the top-level catch-all"
            (let [r (http-get "http://127.0.0.1:18122/")]
              (if (__cr-ok? r)
                (assert-true
                  (cstr-eq? "home" (response-body (__cr-val r))))
                (assert-true false)))))
        (server-stop srv)
        (run-all)))
    0))
