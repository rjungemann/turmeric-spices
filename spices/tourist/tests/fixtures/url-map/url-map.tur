;; Fixture: url-map -- url-map! prefix dispatch + path stripping.

(defmodule tourist/tests/url-map
  (import tourist/app     :refer [tourist])
  (import tourist/dsl     :refer [get!])
  (import tourist/helpers :refer [text])
  (import tourist/routing :refer [url-map! mount!])
  (import tourist/param   :refer [req-full-path])
  (import tourist/types   :refer [Ctx])
  (import httpd/types     :refer [Response])
  (import httpd/request   :refer [req-path])
  (import httpd/types     :refer [Request])
  (import httpd/server    :refer [server-stop])
  (import http/client     :refer [http-get])
  (import http/response   :refer [response-status response-body])
  (import test/suite      :refer [describe it])
  (import test/assert     :refer [assert-eq assert-true])
  (import test/runner     :refer [run-all])

  (defn __cr-ok? [r : ptr<void>] : bool
    ```c
    if (!r) return false;
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return ((struct __cr *)r)->is_ok;
    ```)

  (defn __cr-val [r : ptr<void>] : int
    ```c
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return (int64_t)((struct __cr *)r)->ok_val;
    ```)

  (defn sleep-ms [ms : int] #fx{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; Inline join -- avoid str-concat elaborator issue through multiple spices.
  (defn __join4 [a : cstr b : cstr c : cstr d : cstr] : cstr
    ```c
    #include <stdlib.h>
    #include <string.h>
    const char *sa = (const char *)a, *sb = (const char *)b;
    const char *sc = (const char *)c, *sd = (const char *)d;
    size_t la = strlen(sa), lb = strlen(sb), lc = strlen(sc), ld = strlen(sd);
    char *out = malloc(la + lb + lc + ld + 1);
    memcpy(out,                sa, la);
    memcpy(out + la,           sb, lb);
    memcpy(out + la + lb,      sc, lc);
    memcpy(out + la + lb + lc, sd, ld + 1);
    return (const char *)out;
    ```)

  ;; A handler that echoes "stripped=<req-path> full=<req-full-path>"
  ;; so we can verify path stripping behaviour from the response body.
  (defn echo-paths [ctx : Ctx] : Response
    (text (__join4 "stripped=" (req-path (:: ctx :Request)) " full=" (req-full-path ctx))))

  (defn api-app [] : int
    (url-map! (mount! "/users" (get! "/" echo-paths))
              (mount! "/"      (get! "/" echo-paths))))

  (defn main [] : int
    (let [srv (tourist 18120
                (url-map! (mount! "/api" (api-app))
                          (mount! "/"    (get! "/" echo-paths))))]
      (do
        (unsafe (sleep-ms 50))
        (describe "tourist url-map!"
          (it "GET /api/users hits the nested /users sub-app"
            (let [r (http-get "http://127.0.0.1:18120/api/users")]
              (if (__cr-ok? r)
                (do
                  (assert-eq 200 (response-status (__cr-val r)))
                  (assert-true
                    (cstr-eq? "stripped=/ full=/api/users"
                              (response-body (__cr-val r)))))
                (assert-true false))))
          (it "GET /api falls through to /api root sub-app"
            (let [r (http-get "http://127.0.0.1:18120/api")]
              (if (__cr-ok? r)
                (assert-eq 200 (response-status (__cr-val r)))
                (assert-true false))))
          (it "GET / hits the catch-all"
            (let [r (http-get "http://127.0.0.1:18120/")]
              (if (__cr-ok? r)
                (do
                  (assert-eq 200 (response-status (__cr-val r)))
                  (assert-true
                    (cstr-eq? "stripped=/ full=/"
                              (response-body (__cr-val r)))))
                (assert-true false))))
          (it "GET /missing returns 404 (no matching prefix without catch-all in sub-app)"
            ;; "/" catch-all at the top-level matches; req-path is "/missing".
            ;; The inner Route is (get! "/" ...) which only matches "/" -- so
            ;; the inner dispatch returns 0 and the outer dispatcher 404s.
            (let [r (http-get "http://127.0.0.1:18120/missing")]
              (if (__cr-ok? r)
                (assert-eq 404 (response-status (__cr-val r)))
                (assert-true false)))))
        (server-stop srv)
        (run-all)))
    0))
