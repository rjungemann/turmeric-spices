;; Fixture: middleware -- logging middleware + short-circuit on /block

(defmodule tourist/tests/middleware
  (import tourist/app        :refer [tourist])
  (import tourist/dsl        :refer [get!])
  (import tourist/helpers    :refer [text])
  (import tourist/middleware :refer [use!])
  (import tourist/types      :refer [Ctx])
  (import httpd/types        :refer [Response])
  (import httpd/request      :refer [req-path])
  (import httpd/types        :refer [Request])
  (import httpd/response     :refer [response])
  (import httpd/server       :refer [server-stop])
  (import http/client        :refer [http-get])
  (import http/response      :refer [response-status response-body])
  (import test/suite         :refer [describe it])
  (import test/assert        :refer [assert-eq assert-true])
  (import test/runner        :refer [run-all])

  (defn __cr-ok? [r : ptr<void>] : bool
    ```c
    if (!r) return false;
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return ((struct __cr *)r)->is_ok;
    ```)

  (defn __cr-val [r : ptr<void>] : int
    ```c
    struct __cr { bool is_ok; int64_t ok_val; int64_t err_val; };
    return (int64_t)((struct __cr *)r)->ok_val;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  ;; __some-resp -- wrap a Response in a some(Response) option.
  ;; Middleware returns (Option Response): (none) to continue, (some resp) to short-circuit.
  (defn __some-resp [resp : Response] : (Option Response)
    ```c
    #include <stdlib.h>
    struct __opt { bool is_some; int64_t value; };
    struct __opt *o = (struct __opt *)malloc(sizeof(*o));
    o->is_some = true;
    o->value   = (int64_t)resp;
    return (struct tur__option__Option *)(intptr_t)o;
    ```)

  (defn __none-resp [] : (Option Response)
    ```c
    return (struct tur__option__Option *)0;
    ```)

  (defn sleep-ms [ms : int] #fx{Unsafe} : void
    ```c
    #include <unistd.h>
    if (ms > 0) usleep((useconds_t)ms * 1000u);
    ```)

  ;; blocker -- short-circuit with 403 when path is /block; pass otherwise.
  (defn blocker [ctx : Ctx] : (Option Response)
    (if (cstr-eq? "/block" (req-path (:: ctx :Request)))
      (__some-resp (:: (response 403 "text/plain" "blocked") :Response))
      (__none-resp)))

  (defn main [] : int
    (let [srv (tourist 18103
                (use! blocker)
                (get! "/" (fn [_] (text "ok")))
                (get! "/block" (fn [_] (text "should not reach"))))]
      (do
        (unsafe (sleep-ms 50))
        (describe "tourist middleware"
          (it "GET / passes through middleware; status 200"
            (let [r (http-get "http://127.0.0.1:18103/")]
              (if (__cr-ok? r)
                (assert-eq 200 (response-status (__cr-val r)))
                (assert-true false))))
          (it "GET / body is ok"
            (let [r (http-get "http://127.0.0.1:18103/")]
              (if (__cr-ok? r)
                (assert-true (cstr-eq? "ok" (response-body (__cr-val r))))
                (assert-true false))))
          (it "GET /block is short-circuited; status 403"
            (let [r (http-get "http://127.0.0.1:18103/block")]
              (if (__cr-ok? r)
                (assert-eq 403 (response-status (__cr-val r)))
                (assert-true false))))
          (it "GET /block body is blocked"
            (let [r (http-get "http://127.0.0.1:18103/block")]
              (if (__cr-ok? r)
                (assert-true (cstr-eq? "blocked" (response-body (__cr-val r))))
                (assert-true false)))))
        (server-stop srv)
        (run-all)))
    0))
