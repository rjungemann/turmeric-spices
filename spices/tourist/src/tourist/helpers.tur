;;; tourist/helpers -- response shorthand builders.
;;;
;;; text      -- 200 text/plain
;;; html      -- 200 text/html
;;; json-body -- 200 application/json
;;; redirect  -- 302 Location: <path>
;;; status    -- override the status code on any response
;;;
;;; Since: v0.1.0
;;

(defmodule tourist/helpers
  (import httpd/response :refer [response with-header with-status])
  (export text html json-body redirect status)

;;; text -- build a 200 text/plain response.
;;;
;;; Parameters:
;;;   body -- response body string
;;;
;;; Returns:
;;;   :int -- Response handle with status 200 and Content-Type text/plain
;;;
;;; Example:
;;;   (text "Hello, world!")
;;;
;;; Since: v0.1.0
(defn text [body :cstr] :int
  (response 200 "text/plain" body))

;;; html -- build a 200 text/html response.
;;;
;;; Parameters:
;;;   body -- response body string (HTML markup)
;;;
;;; Returns:
;;;   :int -- Response handle with status 200 and Content-Type text/html
;;;
;;; Example:
;;;   (html "<p>Hello</p>")
;;;
;;; Since: v0.1.0
(defn html [body :cstr] :int
  (response 200 "text/html" body))

;;; json-body -- build a 200 application/json response.
;;;
;;; Parameters:
;;;   body -- response body string (JSON-encoded value)
;;;
;;; Returns:
;;;   :int -- Response handle with status 200 and Content-Type application/json
;;;
;;; Example:
;;;   (json-body "{\"ok\":true}")
;;;
;;; Since: v0.1.0
(defn json-body [body :cstr] :int
  (response 200 "application/json" body))

;;; redirect -- build a 302 redirect response.
;;;
;;; Sets the Location header to path and returns a 302 response with an
;;; empty body. The caller may chain with-header or with-status for
;;; non-standard redirect codes (301, 303, 307, 308).
;;;
;;; Parameters:
;;;   path -- target URL or path, e.g. "/new-path"
;;;
;;; Returns:
;;;   :int -- Response handle with status 302 and Location header set
;;;
;;; Example:
;;;   (redirect "/new-path")
;;;
;;; Since: v0.1.0
(defn redirect [path :cstr] :int
  (with-header (response 302 "text/plain" "") "Location" path))

;;; status -- override the HTTP status code of an existing response.
;;;
;;; Mutates the response in place and returns the same handle.
;;;
;;; Parameters:
;;;   code -- new HTTP status code, e.g. 201, 204, 422
;;;   resp -- :int Response handle to modify
;;;
;;; Returns:
;;;   :int -- the same Response handle with the updated status code
;;;
;;; Example:
;;;   (status 201 (text "created"))
;;;
;;; Since: v0.1.0
(defn status [code :int resp :int] :int
  (with-status resp code))

) ;; end defmodule tourist/helpers
