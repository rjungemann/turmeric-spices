(defpackage tur-ws-client
  :name        "tur-ws-client"
  :version     "0.1.0"
  :description "RFC 6455 WebSocket client (ws:// and wss://) for Turmeric"
  :license     "MIT"
  :spices #{
    ;; ws-core owns the shared protocol types (WsConn, WsFrame), the frame
    ;; predicates, and ws-accept-key (NAME-V0). Declared as a :path dep so the
    ;; canonical types resolve for editor/LSP and release builds.
    "ws-core" #{:path "../ws-core"}
    ;; Workspace-local test framework, used only by tests/. Declared as a
    ;; :path dep so `tur test tests` resolves test/suite + test/assert +
    ;; test/runner from the sibling spice without a fetch or lockfile entry.
    "test" #{:path "../test"}
  }
  :cmake-deps #{
    ;; mbedTLS powers the wss:// path (TCP connect + TLS handshake + record
    ;; I/O). It is optional: the ws-client module gates every TLS reference
    ;; on __has_include(<mbedtls/ssl.h>), so when these headers are absent the
    ;; spice still builds and ws:// works -- a wss:// connect just returns a
    ;; null handle whose ws-last-error says to rebuild with mbedTLS. Same
    ;; pattern and pin as tur-http / tur-tls.
    "mbedtls" #{:url     "https://github.com/Mbed-TLS/mbedtls"
               :ref     "v3.6.2"
               :targets ["mbedtls" "mbedx509" "mbedcrypto"]
               :options #{:BUILD_SHARED_LIBS "OFF"
                         :ENABLE_TESTING    "OFF"
                         :ENABLE_PROGRAMS   "OFF"}}
  }
  ;; WsConn, WsFrame, the frame predicates, and ws-accept-key are exported by
  ;; ws-core (NAME-V0); consumers import them from there. ws-client exports only
  ;; the client-side behaviour.
  :exports #{
    "ws-client/client" ["ws-connect" "ws-connect-with-ca" "ws-connect-insecure"
                        "ws-connect-with-subprotocols" "ws-subprotocol"
                        "ws-conn-null?" "ws-last-error"
                        "ws-send" "ws-send-bytes" "ws-send-fragmented" "ws-recv"
                        "ws-close" "ws-free" "ws-set-timeout"]
  })
