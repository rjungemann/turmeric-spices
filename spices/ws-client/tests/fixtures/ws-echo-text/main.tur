;; tests/fixtures/ws-echo-text/main.tur -- WC1/WC3 live round-trip.
;;
;; Driven by run.sh, which starts echo_server.py on a free port (exported as
;; WS_ECHO_PORT) and runs this program. It connects over plain ws://, echoes
;; two text messages, confirms the receive timeout fires when the server is
;; idle, then closes cleanly. Exit 0 iff every TAP assertion passes.

(defmodule ws-client/fixtures/echo-text
  (import ws-client/client
    :refer [ws-connect ws-conn-null? ws-last-error
            ws-send ws-recv ws-close ws-free ws-set-timeout
            ws-frame-text ws-text? ws-timeout?])

  ;; "ws://127.0.0.1:<WS_ECHO_PORT>/echo"
  (defn echo-uri [] : cstr
    ```c
    #include <stdio.h>
    #include <stdlib.h>
    static char uri[64];
    const char *p = getenv("WS_ECHO_PORT");
    snprintf(uri, sizeof(uri), "ws://127.0.0.1:%s/echo", p ? p : "0");
    return uri;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap [idx : int name : cstr ok : bool] : int
    ```c
    #include <stdio.h>
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    return ok ? 0 : 1;
    ```)

  (defn main [] : int
    (let [c (ws-connect (echo-uri))]
      (if (ws-conn-null? c)
        (do (println "Bail out! ws-connect failed:") (println (ws-last-error)) 1)
        (do
          (println "1..4")
          (ws-set-timeout c 2000)
          (let [_  (ws-send c "hello websocket")
                f1 (ws-recv c)
                r1 (tap 1 "first text frame echoes back"
                        (and (ws-text? f1)
                             (cstr-eq? "hello websocket" (ws-frame-text f1))))
                _  (ws-send c "second message")
                f2 (ws-recv c)
                r2 (tap 2 "second text frame echoes back"
                        (and (ws-text? f2)
                             (cstr-eq? "second message" (ws-frame-text f2))))
                r3 (tap 3 "frame kind is text, not control"
                        (ws-text? f2))
                f3 (do (ws-set-timeout c 200) (ws-recv c))
                r4 (tap 4 "ws-recv reports :timeout when idle"
                        (ws-timeout? f3))]
            (do
              (ws-close c)
              (ws-free c)
              (if (= (+ (+ r1 r2) (+ r3 r4)) 0)
                (do (println "# All 4 ws-echo-text assertions passed.") 0)
                1))))))))
