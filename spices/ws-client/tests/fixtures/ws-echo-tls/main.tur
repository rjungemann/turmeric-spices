;; tests/fixtures/ws-echo-tls/main.tur -- WC2 live wss:// round-trip.
;;
;; Driven by run.sh, which generates a self-signed cert, starts the shared
;; echo server in TLS mode on WS_ECHO_PORT, and runs this program. It connects
;; over wss://, echoes a text message, and closes. Certificate verification is
;; disabled client-side (MBEDTLS_SSL_VERIFY_NONE), matching tur-http. Exit 0
;; iff the assertion passes. Requires the spice to be built with mbedTLS.

(defmodule ws-client/fixtures/echo-tls
  (import ws-client/client
    :refer [ws-connect ws-conn-null? ws-last-error
            ws-send ws-recv ws-close ws-free
            ws-frame-text ws-text?])

  (defn echo-uri [] : cstr
    ```c
    #include <stdio.h>
    #include <stdlib.h>
    static char uri[64];
    const char *p = getenv("WS_ECHO_PORT");
    snprintf(uri, sizeof(uri), "wss://127.0.0.1:%s/echo", p ? p : "0");
    return uri;
    ```)

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn tap [idx : int name : cstr ok : bool] : int
    ```c
    #include <stdio.h>
    printf("%s %lld - %s\n", ok ? "ok" : "not ok", (long long)idx, (const char *)name);
    return ok ? 0 : 1;
    ```)

  (defn main [] : int
    (let [c (ws-connect (echo-uri))]
      (if (ws-conn-null? c)
        (do (println "Bail out! wss connect failed:") (println (ws-last-error)) 1)
        (do
          (println "1..1")
          (let [_  (ws-send c "secure hello")
                f1 (ws-recv c)
                r1 (tap 1 "wss text frame echoes back over TLS"
                        (and (ws-text? f1)
                             (cstr-eq? "secure hello" (ws-frame-text f1))))]
            (do
              (ws-close c)
              (ws-free c)
              (if (= r1 0)
                (do (println "# ws-echo-tls assertion passed.") 0)
                1))))))))
