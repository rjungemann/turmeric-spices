;; tests/codec_test.tur -- WC1 handshake-crypto unit test (no network).
;;
;; ws-connect's handshake hinges on Sec-WebSocket-Accept =
;; base64(sha1(key + GUID)). ws-accept-key exposes exactly that transform, so
;; we can assert the spice's inline SHA-1 + base64 against the canonical
;; RFC 6455 4.2.2 vector without opening a socket. This is the flat tests/*.tur
;; that routes CI through `tur test tests`; the live echo round-trip lives in
;; tests/fixtures/ws-echo-text/ and is run manually via its run.sh.

(defmodule ws-client/tests/codec
  (import ws-client/client :refer [ws-accept-key])
  (import test/suite       :refer [describe it])
  (import test/assert      :refer [assert-true])
  (import test/runner      :refer [run-all])

  (defn cstr-eq? [a : cstr b : cstr] : bool
    ```c
    #include <string.h>
    return strcmp((const char *)a, (const char *)b) == 0;
    ```)

  (defn main [] : int
    (describe "ws-client handshake crypto -- ws-accept-key (RFC 6455 4.2.2)"

      ;; The canonical example: key "dGhlIHNhbXBsZSBub25jZQ==" must yield
      ;; accept "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=".
      (it "computes the RFC 6455 accept value for the sample key"
        (assert-true (cstr-eq? "s3pPLMBiTxaQ9kYGzzhZRbK+xOo="
                               (ws-accept-key "dGhlIHNhbXBsZSBub25jZQ=="))))

      ;; A different key produces a different, stable digest (regression
      ;; guard on the SHA-1 + base64 pipeline).
      (it "is deterministic and key-sensitive"
        (assert-true (cstr-eq? "HSmrc0sMlYUkAGmm5OPpG2HaGWk="
                               (ws-accept-key "x3JJHMbDL1EzLkh9GBhXDw==")))))

    (run-all)))
