# CMake out-of-tree build dirs (FetchContent deps land here)
**/cmake/build/
**/build/

# Object / archive artifacts
*.o
*.a
*.so
*.dylib

# macOS / editor noise
.DS_Store
*.swp

# Node
node_modules/

# Built site (regenerated by deploy-docs workflow)
web/dist/

# Generated docs HTML (source markdown stays in docs/guides/ and per-spice
# docstrings; regenerated by deploy-docs workflow via tools/genspices.py)
docs/html/

# Python bytecode cache from tools/
tools/__pycache__/

# `tur fetch` populates <spice>/spices/<dep>-<ref>/ with cloned dep
# trees (and, under the WT7 watch-cutover workaround, a symlink to the
# enclosing repo). These are package-manager output, not source.
spices/*/spices/

# Stray `tur emit-c` / `tur build` output that lands in cwd when invoked
# from the repo root. Real per-module emission goes under build/ or a target
# dir. Per-spice generated files are excluded via spices/*/.gitignore.
/event.c
/event.h
/*__*.c
/*__*.h
/*.manifest

# Stray root-level lockfile from running `tur fetch` at the repo root.
# All deps here are workspace-local, so this lock is empty; real per-spice
# locks (when needed) live under the spice dir, not the repo root.
/tur.lock
