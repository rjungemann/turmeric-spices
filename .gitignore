# CMake out-of-tree build dirs (FetchContent deps land here)
**/cmake/build/
**/build/

# Object / archive artifacts
*.o
*.a
*.so
*.dylib

# macOS / editor noise
.DS_Store
*.swp

# Node
node_modules/

# Built site (regenerated by deploy-docs workflow)
web/dist/

# Generated docs HTML (source markdown stays in docs/guides/ and per-spice
# docstrings; regenerated by deploy-docs workflow via tools/genspices.py)
docs/html/

# `tur fetch` populates <spice>/spices/<dep>-<ref>/ with cloned dep
# trees (and, under the WT7 watch-cutover workaround, a symlink to the
# enclosing repo). These are package-manager output, not source.
spices/*/spices/

# Stray `tur emit-c` output that lands in cwd when invoked from the
# repo root. Real per-module emission goes under build/ or a target dir.
/event.c
/event.h
